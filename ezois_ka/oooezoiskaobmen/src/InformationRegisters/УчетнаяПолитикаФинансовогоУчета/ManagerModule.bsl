	ПараметрыВыбора.ПутьКДанным = "Запись";
	ПараметрыВыбора.Статья      = "СтатьяПроцентныхДоходовФинансовойАренды";
	
	ПараметрыВыбора.ДоступностьПоОперации = УчетФинАренды;
