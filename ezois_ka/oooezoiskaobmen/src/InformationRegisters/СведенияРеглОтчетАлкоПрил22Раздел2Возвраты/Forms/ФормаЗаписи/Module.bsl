	СоответствиеТекущиеДанные = Новый Соответствие;
	СоответствиеТекущиеДанные.Вставить("НаименованиеПолное", Элемент.ТекущиеДанные["НаименованиеПолное"]);
	СоответствиеТекущиеДанные.Вставить("ИНН", Элемент.ТекущиеДанные["ИНН"]);
	СоответствиеТекущиеДанные.Вставить("КПП", Элемент.ТекущиеДанные["КПП"]);
	СоответствиеТекущиеДанные.Вставить("ДатаОкончания", Элемент.ТекущиеДанные["ДатаОкончания"]);
	СоответствиеТекущиеДанные.Вставить("СерияНомер", Элемент.ТекущиеДанные["СерияНомер"]);
	СоответствиеТекущиеДанные.Вставить("ВидДеятельности", Элемент.ТекущиеДанные["ВидДеятельности"]);
		
	ТаблицаПоставщиковВыборНаСервере(СоответствиеТекущиеДанные);
			
