#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
	
#Область ОбработчикиСобытий

Процедура ПриЗаписи(Отказ, Замещение)
		
	Если ЗарплатаКадры.ОтключитьБизнесЛогикуПриЗаписи(ЭтотОбъект) Тогда
		Возврат;
	КонецЕсли;
	
	СтруктурнаяЕдиница = РегистрыБЗК.ЗначенияОтбораЗаписейНабора(ЭтотОбъект, Замещение, "СтруктурнаяЕдиница", Истина);
	УстановитьПривилегированныйРежим(Истина);
	РегистрыСведений.ИсторияСамостоятельныхКлассификационныхЕдиницВторичный.ЗаполнитьВторичныеДанные(СтруктурнаяЕдиница);
		
КонецПроцедуры
	
#КонецОбласти 
	
#Иначе
	ВызватьИсключение НСтр("ru = 'Недопустимый вызов объекта на клиенте.'");
#КонецЕсли