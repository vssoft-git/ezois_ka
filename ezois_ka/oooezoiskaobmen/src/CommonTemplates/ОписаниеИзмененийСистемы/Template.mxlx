					<tl>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Поддержаны новые категории в существующих товарных группах:</v8:content>
						</v8:item>
					</tl>
				</c>
			</c>
		</row>
	</rowsItem>
