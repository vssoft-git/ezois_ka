	<rowsItem>
		<index>353</index>
		<row>
			<c>
				<c>
					<f>4</f>
					<tl>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>В библиотеке реализованы следующие возможности:</v8:content>
						</v8:item>
					</tl>
