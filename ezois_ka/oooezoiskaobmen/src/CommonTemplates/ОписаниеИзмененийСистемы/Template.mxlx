		</row>
	</rowsItem>
	<rowsItem>
		<index>355</index>
		<row>
			<c>
				<c>
					<f>4</f>
					<tl>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Интеграция с ГИС МТ "Честный знак"
Библиотека интеграции ГосИС обновлена до версии 1.1.41. Поддержаны ледующие возможности:</v8:content>
						</v8:item>
					</tl>
				</c>
