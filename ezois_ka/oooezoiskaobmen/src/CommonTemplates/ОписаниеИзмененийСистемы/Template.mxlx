					<tl>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Форма применяется начиная с отчета за 4 квартал 2023 года.</v8:content>
						</v8:item>
					</tl>
				</c>
			</c>
		</row>
	</rowsItem>
