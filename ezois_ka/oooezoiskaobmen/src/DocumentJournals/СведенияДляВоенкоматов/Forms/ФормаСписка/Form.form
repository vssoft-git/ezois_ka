    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	ЖурналДокументовСведенияДляВоенкоматов.Ссылка КАК Ссылка,
	ЖурналДокументовСведенияДляВоенкоматов.Дата КАК Дата,
	ЖурналДокументовСведенияДляВоенкоматов.ПометкаУдаления КАК ПометкаУдаления,
	ЖурналДокументовСведенияДляВоенкоматов.Номер КАК Номер,
	ЖурналДокументовСведенияДляВоенкоматов.Проведен КАК Проведен,
	ЖурналДокументовСведенияДляВоенкоматов.Организация КАК Организация,
	ЖурналДокументовСведенияДляВоенкоматов.Сотрудники КАК Сотрудники,
	ЖурналДокументовСведенияДляВоенкоматов.ОтправленоВВоенкомат КАК ОтправленоВВоенкомат,
	ЖурналДокументовСведенияДляВоенкоматов.Ответственный КАК Ответственный,
	ЖурналДокументовСведенияДляВоенкоматов.Комментарий КАК Комментарий,
	ЖурналДокументовСведенияДляВоенкоматов.Тип КАК Тип
ИЗ
	ЖурналДокументов.СведенияДляВоенкоматов КАК ЖурналДокументовСведенияДляВоенкоматов
{ГДЕ
	(ИСТИНА В
			(ВЫБРАТЬ ПЕРВЫЕ 1
				ИСТИНА
			ИЗ
				РегистрСведений.СоставДокументовЗарплатаКадры КАК СоставДокументовЗарплатаКадры
			ГДЕ
				СоставДокументовЗарплатаКадры.ФизическоеЛицо = &amp;ФизическоеЛицо
				И ЖурналДокументовСведенияДляВоенкоматов.Ссылка = СоставДокументовЗарплатаКадры.ДокументФизическогоЛица))}</queryText>
