    </notDefaultUseAlwaysAttributes>
    <main>true</main>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	ЖурналДокументовЗаявленияНаВычеты.Ссылка КАК Ссылка,
	ЖурналДокументовЗаявленияНаВычеты.Дата КАК Дата,
	НАЧАЛОПЕРИОДА(ЖурналДокументовЗаявленияНаВычеты.Дата, ДЕНЬ) КАК ДатаДокумента,
	ЖурналДокументовЗаявленияНаВычеты.ПометкаУдаления КАК ПометкаУдаления,
	ЖурналДокументовЗаявленияНаВычеты.Номер КАК Номер,
	ЖурналДокументовЗаявленияНаВычеты.Проведен КАК Проведен,
	ЖурналДокументовЗаявленияНаВычеты.Сотрудник КАК Сотрудник,
	ЖурналДокументовЗаявленияНаВычеты.Организация КАК Организация,
	ЖурналДокументовЗаявленияНаВычеты.ПрименяютсяС КАК ПрименяютсяС,
	ЖурналДокументовЗаявленияНаВычеты.Ответственный КАК Ответственный,
	ЖурналДокументовЗаявленияНаВычеты.Комментарий КАК Комментарий,
	ЖурналДокументовЗаявленияНаВычеты.Тип КАК Тип
ИЗ
	ЖурналДокументов.ЗаявленияНаВычеты КАК ЖурналДокументовЗаявленияНаВычеты
{ГДЕ
	(ИСТИНА В
			(ВЫБРАТЬ ПЕРВЫЕ 1
				ИСТИНА
			ИЗ
				РегистрСведений.СоставДокументовЗарплатаКадры КАК СоставДокументовЗарплатаКадры
			ГДЕ
				СоставДокументовЗарплатаКадры.ФизическоеЛицо = &amp;ФизическоеЛицо
				И ЖурналДокументовЗаявленияНаВычеты.Ссылка = СоставДокументовЗарплатаКадры.ДокументФизическогоЛица))}</queryText>
      <mainTable>DocumentJournal.ЗаявленияНаВычеты</mainTable>
      <dynamicDataRead>true</dynamicDataRead>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
