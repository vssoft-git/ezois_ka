  <attributes>
    <name>ДокументыВоинскогоУчета</name>
    <title>
      <key>ru</key>
      <value>Документы воинского учета</value>
    </title>
    <id>17</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>ДокументыВоинскогоУчета.Ссылка</segments>
    </notDefaultUseAlwaysAttributes>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	ЖурналДокументовДокументыВоинскогоУчета.Ссылка,
	ЖурналДокументовДокументыВоинскогоУчета.Дата,
	ЖурналДокументовДокументыВоинскогоУчета.ПометкаУдаления,
	ЖурналДокументовДокументыВоинскогоУчета.Номер,
	ЖурналДокументовДокументыВоинскогоУчета.Проведен,
	ЖурналДокументовДокументыВоинскогоУчета.Организация,
	ЖурналДокументовДокументыВоинскогоУчета.Сотрудники,
	ЖурналДокументовДокументыВоинскогоУчета.Ответственный,
	ЖурналДокументовДокументыВоинскогоУчета.Комментарий,
	ЖурналДокументовДокументыВоинскогоУчета.Тип
ИЗ
	ЖурналДокументов.ДокументыВоинскогоУчета КАК ЖурналДокументовДокументыВоинскогоУчета
ГДЕ
	ИСТИНА В
			(ВЫБРАТЬ ПЕРВЫЕ 1
				ИСТИНА
			ИЗ
				РегистрСведений.СоставДокументовЗарплатаКадры КАК СоставДокументовЗарплатаКадры
			ГДЕ
				СоставДокументовЗарплатаКадры.ФизическоеЛицо В(&amp;ФизическоеЛицо)
				И ЖурналДокументовДокументыВоинскогоУчета.Ссылка = СоставДокументовЗарплатаКадры.ДокументФизическогоЛица)</queryText>
      <mainTable>DocumentJournal.ДокументыВоинскогоУчета</mainTable>
      <dynamicDataRead>true</dynamicDataRead>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>Комментарий</dataPath>
        <field>Комментарий</field>
