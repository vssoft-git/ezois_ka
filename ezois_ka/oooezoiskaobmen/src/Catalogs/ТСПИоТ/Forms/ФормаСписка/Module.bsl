
#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// Пропускаем инициализацию, чтобы гарантировать получение формы при передаче параметра "АвтоТест".
	Если Параметры.Свойство("АвтоТест") Тогда
		Возврат;
	КонецЕсли;
	
	ЕстьПодсистемаГосИС = ОбщегоНазначенияБПО.ИспользуетсяГосИС();         
	
	Элементы.Список.ТолькоПросмотр = Не ЕстьПодсистемаГосИС;    
	
	ЭтаФорма.КоманднаяПанель.Видимость = ЕстьПодсистемаГосИС;
	
КонецПроцедуры

&НаКлиенте
Процедура ОтборРабочееМестоПриИзменении(Элемент)
	
	Если ЗначениеЗаполнено(РабочееМесто) Тогда
		
		ОбщегоНазначенияБПОКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(Список,
				"ФискальноеУстройство.РабочееМесто",
				РабочееМесто,
				ВидСравненияКомпоновкиДанных.Равно,
				"",
				Истина,
				РежимОтображенияЭлементаНастройкиКомпоновкиДанных.Недоступный); 
				
	Иначе     
				
		ОбщегоНазначенияБПОКлиентСервер.УдалитьЭлементыГруппыОтбораДинамическогоСписка(Список,
			"ФискальноеУстройство.РабочееМесто");  
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыСписок

&НаСервереБезКонтекста
Процедура СписокПриПолученииДанныхНаСервере(ИмяЭлемента, Настройки, Строки)
	
	МассивФискальныхУстройств = Новый Массив;
	РезультатыНастройкиЛМЧЗ   = Новый Соответствие;
	
	ЕстьПодсистемаГосИС = ОбщегоНазначенияБПО.ИспользуетсяГосИС();
	Если ЕстьПодсистемаГосИС Тогда
		
		Для Каждого СтрокаСписка Из Строки Цикл
			ДанныеСтроки = СтрокаСписка.Значение.Данные;
			Если МассивФискальныхУстройств.Найти(ДанныеСтроки.ФискальноеУстройство) <> Неопределено Тогда
				Продолжить;
			КонецЕсли;
			МассивФискальныхУстройств.Добавить(ДанныеСтроки.ФискальноеУстройство);
		КонецЦикла;
		
		МодульИнтеграцияТСПИоТ  = ОбщегоНазначенияБПО.ОбщийМодуль("ИнтеграцияТСПИоТ");
		РезультатыНастройкиЛМЧЗ = МодульИнтеграцияТСПИоТ.НастройкиЛокальногоМодуляЧестныйЗнакПоФискальнымУстройствам(МассивФискальныхУстройств);
		
	КонецЕсли;
	
	Для Каждого СтрокаСписка Из Строки Цикл
		
		ДанныеСтроки  = СтрокаСписка.Значение.Данные;
		НастройкаЛМЧЗ = РезультатыНастройкиЛМЧЗ.Получить(ДанныеСтроки.ФискальноеУстройство);
		
		Если НастройкаЛМЧЗ <> Неопределено Тогда
			
			Если НастройкаЛМЧЗ.Настроено Тогда
				ДанныеСтроки.ЛМЧЗАдрес = НастройкаЛМЧЗ.АдресЛокальногоМодуля;
			Иначе
				ДанныеСтроки.ЛМЧЗАдрес = "";
			КонецЕсли;
			
		КонецЕсли;
		
		ПредставлениеАдресаЛМЧЗ = "";
		
		Если ЗначениеЗаполнено(ДанныеСтроки.ЛМЧЗАдрес) Тогда
			ПредставлениеАдресаЛМЧЗ = ДанныеСтроки.ЛМЧЗАдрес;
		Иначе
			ПредставлениеАдресаЛМЧЗ = НСтр("ru = 'не настроен'");
		КонецЕсли;
		
		Если ДанныеСтроки.Тип = Перечисления.ТипыТСПИоТ.Внутренний1С Тогда
			
			ШаблонСтроки                           = НСтр("ru = 'Экземпляр: %1, ЛМ ЧЗ: %2'");
			ДанныеСтроки.ОбщееСостояниеПодключения = СтрШаблон(ШаблонСтроки, ДанныеСтроки.ПутьДанныхЭкземпляра, ПредставлениеАдресаЛМЧЗ);
			
		ИначеЕсли ДанныеСтроки.Тип = Перечисления.ТипыТСПИоТ.Внешний Тогда
			
			ШаблонСтроки                           = НСтр("ru = '%1%2:%3, ЛМ ЧЗ: %4'");
			ДанныеСтроки.ОбщееСостояниеПодключения = СтрШаблон(ШаблонСтроки,
				Формат(ДанныеСтроки.ЗащищенноеСоединение, "БЛ=http://; БИ=https://"),
				ДанныеСтроки.Сервер,
				Формат(ДанныеСтроки.Порт, "ЧГ="),
				ПредставлениеАдресаЛМЧЗ);
			
		Иначе
			Продолжить;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура СоздатьТСПИоТ(Команда)
	
	ДоступностьТолькоВнешнегоТСПИоТ = Ложь;
	
	Если Не ОбщегоНазначенияБПОклиент.ИспользуетсяТСПИоТ() И ОбщегоНазначенияБПОКлиентСервер.Доступен1СПИоТ() Тогда
		ДоступностьТолькоВнешнегоТСПИоТ = Истина;
	КонецЕсли;
	
	СтруктураЗаполнения = Новый Структура();
	
	Если ДоступностьТолькоВнешнегоТСПИоТ Тогда
		СтруктураЗаполнения.Вставить("Тип", ПредопределенноеЗначение("Перечисление.ТипыТСПИоТ.Внешний"));
	КонецЕсли;
	
	ПараметрыОткрытия = Новый Структура("ЗначенияЗаполнения", СтруктураЗаполнения);
	
	ОткрытьФорму("Справочник.ТСПИоТ.Форма.ФормаЭлемента", ПараметрыОткрытия);
	
КонецПроцедуры

#КонецОбласти
