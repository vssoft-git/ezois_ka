// Процедура создает элемент в справочнике ТС ПИоТ.
//
// Параметры:
//  ПараметрыСоздания - Структура - параметры создания подключаемог оборудования.
//
// Возвращаемое значение:
//  СправочникСсылка.ТСПИоТ - 
//        
Функция СоздатьНовыйТСПИоТ(ПараметрыСоздания) Экспорт
	
	НовыйЭлемент = СоздатьЭлемент(); 
	НовыйЭлемент.ФискальноеУстройство = ПараметрыСоздания.ФискальноеУстройство;  
	НовыйЭлемент.УровеньЛога = ПараметрыСоздания.УровеньЛога;      
	Если ПараметрыСоздания.Свойство("Тип") И Не ПустаяСтрока(ПараметрыСоздания.Тип) Тогда
		НовыйЭлемент.Тип = ПараметрыСоздания.Тип; 
	Иначе                 
		НовыйЭлемент.Тип = Перечисления.ТипыТСПИоТ.Внутренний1С;
	КонецЕсли;
	
	Наименование = ПараметрыСоздания.Наименование;
	Если ПустаяСтрока(Наименование) Тогда
		Наименование = НСтр("ru = '1С:ПИоТ для '") + Строка(ПараметрыСоздания.ФискальноеУстройство);
	КонецЕсли;
	НовыйЭлемент.Наименование = Наименование;    
	НовыйЭлемент.ИдентификаторЭкземпляра = Строка(Новый УникальныйИдентификатор());
	
	Если Не ПустаяСтрока(ПараметрыСоздания.РабочийКаталог) Тогда
		Пути = МенеджерОборудованияТСПИоТ.СформироватьПутиВнутреннегоПИоТ(НовыйЭлемент.ИдентификаторЭкземпляра, ПараметрыСоздания.РабочийКаталог);
	    НовыйЭлемент.ПутьКДрайверу = Пути.ПутьКДрайверу; 
		НовыйЭлемент.ПутьДанныхЭкземпляра = Пути.ПутьДанныхЭкземпляра;
	КонецЕсли;
	НовыйЭлемент.Записать();
	
	Возврат НовыйЭлемент.Ссылка;
	
КонецФункции

// Функция возвращает созданный ТС ПИоТ по подключаемому оборудованию
//
// Параметры:
//  ПодключаемоеОборудование - СправочникСсылка.ПодключаемоеОборудование.
//
// Возвращаемое значение:
//  - Произвольный
//
Функция ПолучитьТСПИоТ(ПодключаемоеОборудование) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Результат = Неопределено;
	
	Запрос = Новый Запрос("
	|ВЫБРАТЬ
	|	ТСПИоТ.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ТСПИоТ КАК ТСПИоТ
	|ГДЕ
	|	ФискальноеУстройство = &Идентификатор");
	
	Запрос.УстановитьПараметр("Идентификатор", ПодключаемоеОборудование);
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Результат = Выборка.Ссылка;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

