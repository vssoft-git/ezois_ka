	Если Объект.ПоРеквизитамОтЮрЛиц Тогда
		Если НастройкаОнлайнЗаказовДоступна Тогда
			ПредставлениеЗаголовка = Новый ФорматированнаяСтрока(
				НСтр("ru = 'Отключить'"),
				,
				,
				,
				"action:disable");
		Иначе
			ПредставлениеЗаголовка = НСтр("ru = 'Включен'");
		КонецЕсли;
	Иначе
		Если НастройкаОнлайнЗаказовДоступна Тогда
			ПредставлениеЗаголовка = Новый ФорматированнаяСтрока(
				НСтр("ru = 'Включить'"),
				,
				,
				,
				"action:enable");
		Иначе
