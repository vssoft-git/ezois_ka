&НаКлиенте
Функция ВозможностьВводаПогашенияИмпортаПродукции(Знач ВыделенныеСтроки)
	
	РезультатПроверки = Новый Структура("РазрешенВвод, Основание", Ложь, Неопределено);
	
	Если ВыделенныеСтроки = Неопределено Тогда
		Возврат РезультатПроверки;
	ИначеЕсли ВыделенныеСтроки.Количество() = 0 Тогда
		Возврат РезультатПроверки;
	ИначеЕсли ВыделенныеСтроки.Количество() = 1 Тогда
		
		ТекущиеДанные = Элементы.СписокКОформлению.ТекущиеДанные;
		
		Если ТекущиеДанные = Неопределено Тогда
			Возврат РезультатПроверки;
		КонецЕсли;
		
		РезультатПроверки.РазрешенВвод = Истина;
		РезультатПроверки.Основание    = ТекущиеДанные.Ссылка;
		
		Возврат РезультатПроверки;
		
	Иначе
		
		Для Каждого ВыделеннаяСтрока Из ВыделенныеСтроки Цикл
		
			ДанныеСтроки = Элементы.СписокКОформлению.ДанныеСтроки(ВыделеннаяСтрока);
			
			Если ДанныеСтроки = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			Если РезультатПроверки.Основание = Неопределено Тогда
				РезультатПроверки.Основание = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ДанныеСтроки.Ссылка);
			Иначе
				РезультатПроверки.Основание.Добавить(ДанныеСтроки.Ссылка);
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	РезультатПроверки.РазрешенВвод = ПроверитьПоКлючевымРеквизитамЕдинообразностьПартий(РезультатПроверки.Основание);
	
	Если Не РезультатПроверки.РазрешенВвод Тогда
		
		ОбщегоНазначенияКлиент.СообщитьПользователю(
			НСтр("ru = 'Различаются ключевые реквизиты импортируемых партий. Выделенные строки должны быть включены в различные документы Импорта продукции'"),, "СписокКОформлению");
			Возврат РезультатПроверки;
		
	КонецЕсли;
	
	Возврат РезультатПроверки;
	
КонецФункции

&НаСервере
Функция СписокИмпортируемыхПартийПоОтбору(Организация, МестоХранения, ДатаВвоза)
	
	МассивИмпортируемыхПартий = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
		|	ИмпортируемаяПартияСАТУРНТовары.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.ИмпортируемаяПартияСАТУРН.Товары КАК ИмпортируемаяПартияСАТУРНТовары
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ИмпортируемаяПартияСАТУРН КАК ИмпортируемаяПартияСАТУРН
		|		ПО ИмпортируемаяПартияСАТУРНТовары.Ссылка = ИмпортируемаяПартияСАТУРН.Ссылка
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыОформленияДокументовСАТУРН КАК Статусы
		|		ПО ИмпортируемаяПартияСАТУРНТовары.Ссылка = Статусы.Основание
		|ГДЕ
		|	НЕ ИмпортируемаяПартияСАТУРН.ПометкаУдаления
		|	И ИмпортируемаяПартияСАТУРНТовары.ИдентификаторПартии = """"
		|	И Статусы.СтатусОформления В
		|	(ЗНАЧЕНИЕ(Перечисление.СтатусыОформленияДокументовГосИС.НеОформлено),
		|		ЗНАЧЕНИЕ(Перечисление.СтатусыОформленияДокументовГосИС.ОформленоЧастично),
		|		ЗНАЧЕНИЕ(Перечисление.СтатусыОформленияДокументовГосИС.ЕстьОшибкиОформления),
		|		ЗНАЧЕНИЕ(Перечисление.СтатусыОформленияДокументовГосИС.ТребуетсяСопоставлениеНоменклатуры))
		|	И ЕСТЬNULL(Статусы.Архивный, ЛОЖЬ) = ЛОЖЬ
		|	И ИмпортируемаяПартияСАТУРН.ОрганизацияСАТУРН = &ОрганизацияСАТУРН
		|	И ИмпортируемаяПартияСАТУРН.МестоХранения = &МестоХранения
		|	И ИмпортируемаяПартияСАТУРН.ДатаВвоза = &ДатаВвоза";
	
	Запрос.УстановитьПараметр("МестоХранения",     МестоХранения);
	Запрос.УстановитьПараметр("ДатаВвоза",         ДатаВвоза);
	Запрос.УстановитьПараметр("ОрганизацияСАТУРН", Организация);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		МассивИмпортируемыхПартий.Добавить(ВыборкаДетальныеЗаписи.Ссылка);
	КонецЦикла;
	
	Возврат МассивИмпортируемыхПартий;
	
КонецФункции

&НаСервереБезКонтекста
Функция ПроверитьПоКлючевымРеквизитамЕдинообразностьПартий(МассивОснований)
	
	РазрешеноОбъединение = Ложь;
	
	ТаблицаОснований = Новый ТаблицаЗначений;
	ТаблицаОснований.Колонки.Добавить("Ссылка", Метаданные.ОпределяемыеТипы.ОснованиеИмпортПродукцииСАТУРН.Тип);
	
	Для Каждого Основание Из МассивОснований Цикл
		
		НоваяСтрокаОснований        = ТаблицаОснований.Добавить();
		НоваяСтрокаОснований.Ссылка = Основание;
		
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ТаблицаОснований.Ссылка КАК Ссылка
		|ПОМЕСТИТЬ ВТ_ТаблицаОснований
		|ИЗ
		|	&ТаблицаОснований КАК ТаблицаОснований
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ИмпортируемаяПартияСАТУРН.Ссылка ЕСТЬ NULL                          КАК ЭтоПрикладнойДокумент,
		|	ЕСТЬNULL(ИмпортируемаяПартияСАТУРН.ОрганизацияСАТУРН, НЕОПРЕДЕЛЕНО) КАК ОрганизацияСАТУРН,
		|	ЕСТЬNULL(ИмпортируемаяПартияСАТУРН.МестоХранения, НЕОПРЕДЕЛЕНО)     КАК МестоХранения,
		|	ЕСТЬNULL(ИмпортируемаяПартияСАТУРН.ДатаВвоза, НЕОПРЕДЕЛЕНО)         КАК ДатаВвоза
		|ИЗ
		|	ВТ_ТаблицаОснований КАК ВТ_ТаблицаОснований
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ИмпортируемаяПартияСАТУРН КАК ИмпортируемаяПартияСАТУРН
		|		ПО ВТ_ТаблицаОснований.Ссылка = ИмпортируемаяПартияСАТУРН.Ссылка";
	
	Запрос.УстановитьПараметр("ТаблицаОснований", ТаблицаОснований);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
