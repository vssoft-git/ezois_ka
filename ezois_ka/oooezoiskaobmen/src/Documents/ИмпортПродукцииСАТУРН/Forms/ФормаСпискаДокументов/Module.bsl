&НаКлиенте
Процедура Оформить(Команда)
	
	ОчиститьСообщения();
	КлючиВыделенныхСтрок = Новый Массив;
	Основание            = Новый Массив;
	
	Если ТТНПродукция = 0 Тогда
		
		Если Не ОбщегоНазначенияИСКлиент.ВыборСтрокиСпискаКорректен(Элементы.СписокКОформлению) Тогда
			Возврат;
		КонецЕсли;
	
		Для Каждого ИдентификаторСтроки Из Элементы.СписокКОформлению.ВыделенныеСтроки Цикл
			
			КлючиВыделенныхСтрок.Добавить(ИдентификаторСтроки);
			
		КонецЦикла;
		
		РезультатПроверки = ВозможностьВводаПогашенияИмпортаПродукции(КлючиВыделенныхСтрок);
		
		Если НЕ РезультатПроверки.РазрешенВвод Тогда
			Возврат;
		КонецЕсли;
		
		Основание = РезультатПроверки.Основание;
		
	Иначе
		
		Если Не ОбщегоНазначенияИСКлиент.ВыборСтрокиСпискаКорректен(Элементы.СписокПоТоварнымНакладным) Тогда
			Возврат;
		КонецЕсли;
		
		ТекущиеДанные = Элементы.СписокПоТоварнымНакладным.ТекущиеДанные;
		Основание = СписокИмпортируемыхПартийПоОтбору(ТекущиеДанные.ОрганизацияСАТУРН, ТекущиеДанные.МестоХранения, ТекущиеДанные.ДатаВвоза);
		
		Если Основание.Количество() = 0 Тогда
			
			ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр( "ru = 'Нет данных для заполнения'"),, "СписокПоТоварнымНакладным");
			Возврат;
			
		КонецЕсли;
		
	КонецЕсли;
	
	ИнтеграцияСАТУРНКлиент.ОткрытьФормуСозданияДокумента(
		ОбщегоНазначенияИСКлиентСервер.ИмяОбъектаИзИмениФормы(ЭтотОбъект),
		Основание,
		ЭтотОбъект);
	
КонецПроцедуры

