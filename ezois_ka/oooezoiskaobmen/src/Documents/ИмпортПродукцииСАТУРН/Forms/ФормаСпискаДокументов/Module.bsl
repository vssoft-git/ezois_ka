&НаКлиенте
Процедура СписокКОформлениюВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ТекущиеДанные = Элементы.СписокКОформлению.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПоказатьЗначение(, ТекущиеДанные.Ссылка);
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура СписокКОформлениюПриПолученииДанныхНаСервере(ИмяЭлемента, Настройки, Строки)
	
	ТаблицаСопоставлений = ИнтеграцияСАТУРН.НоваяТаблицаОрганизацияКонтрагент();
	
	Для Каждого СтрокаДинамическогоСписка Из Строки Цикл
		
		ДанныеСтроки = СтрокаДинамическогоСписка.Значение.Данные;
		
		Если Не ДанныеСтроки.ТипДокумента = 1 Тогда
			Продолжить;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ДанныеСтроки.ОрганизацияСАТУРН) Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаСопоставленияОрганизация = ИнтеграцияСАТУРН.ДобавитьВТаблицуОтбораСопоставлений(
			ТаблицаСопоставлений, ДанныеСтроки.Организация);
		
	КонецЦикла;
	
	Справочники.КлассификаторОрганизацийСАТУРН.ЗаполнитьТаблицуСопоставленийКлассификаторамиСАТУРН(ТаблицаСопоставлений);
	
	Для Каждого СтрокаДинамическогоСписка Из Строки Цикл
		
		ДанныеСтроки             = СтрокаДинамическогоСписка.Значение.Данные;
		ОформлениеСтроки         = СтрокаДинамическогоСписка.Значение.Оформление;
		ШаблонСтроки             = НСтр("ru = '%1 (%2)'");
		ПредставлениеОрганизации = "";
		
		Если ДанныеСтроки.ТипДокумента = 0 Тогда
			
			Если ЗначениеЗаполнено(ДанныеСтроки.Организация) Тогда
				ПредставлениеОрганизации = СтрШаблон(ШаблонСтроки, ДанныеСтроки.ОрганизацияСАТУРН, ДанныеСтроки.Организация);
			Иначе
				ПредставлениеОрганизации = СтрШаблон(ШаблонСтроки, ДанныеСтроки.ОрганизацияСАТУРН, "<не сопоставлено>");
				ОформлениеСтроки["ПредставлениеОрганизации"].УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ЦветТекстаТребуетВниманияГосИС);
			КонецЕсли;
			
		Иначе
			
			СтруктураПоиска = Новый Структура("ОрганизацияКонтрагент", ДанныеСтроки.Организация);
			СтрокиСопоставлений = ТаблицаСопоставлений.НайтиСтроки(СтруктураПоиска);
			
			Если СтрокиСопоставлений.Количество() = 0 Тогда
				ПредставлениеОрганизации = СтрШаблон(ШаблонСтроки, "<не сопоставлено>", ДанныеСтроки.Организация);
				ОформлениеСтроки["ПредставлениеОрганизации"].УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ЦветТекстаТребуетВниманияГосИС);
			ИначеЕсли СтрокиСопоставлений.Количество() = 1 И ЗначениеЗаполнено(СтрокиСопоставлений[0].ОрганизацияСАТУРН) Тогда
				ПредставлениеОрганизации = СтрШаблон(ШаблонСтроки, СтрокиСопоставлений[0].ОрганизацияСАТУРН, ДанныеСтроки.Организация);
			ИначеЕсли СтрокиСопоставлений.Количество() = 1 Тогда
				ПредставлениеОрганизации = СтрШаблон(ШаблонСтроки, "<не сопоставлено>", ДанныеСтроки.Организация);
				ОформлениеСтроки["ПредставлениеОрганизации"].УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ЦветТекстаТребуетВниманияГосИС);
			Иначе
				ПредставлениеМножественногоСопоставления = СтрШаблон(НСтр("ru = '%1 ( + еще %2'"), СтрокиСопоставлений[0].ОрганизацияСАТУРН, СтрокиСопоставлений.Количество() - 1);
				ПредставлениеОрганизации = СтрШаблон(ШаблонСтроки, ПредставлениеМножественногоСопоставления, ДанныеСтроки.Организация);
				ОформлениеСтроки["ПредставлениеОрганизации"].УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ЦветТекстаТребуетВниманияГосИС);
			КонецЕсли;
			
		КонецЕсли;
		
		ДанныеСтроки.ПредставлениеОрганизации = ПредставлениеОрганизации;
		
	КонецЦикла;
	
КонецПроцедуры

