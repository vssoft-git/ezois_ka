    <name>Список</name>
    <id>1</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Список.Posted</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Список.Ref</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Список.ДальнейшееДействиеИСМП1</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Список.ДальнейшееДействиеИСМП2</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Список.ДальнейшееДействиеИСМП3</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Список.Контрагент</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Список.Организация</segments>
    </notDefaultUseAlwaysAttributes>
    <main>true</main>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	Таблица.Ссылка,
	Таблица.ПометкаУдаления,
	Таблица.Проведен,
	Таблица.НомерПервичногоДокумента  КАК НомерПервичногоДокумента,
	Таблица.ДатаПервичногоДокумента   КАК ДатаПервичногоДокумента,
	
	Таблица.ВидПродукции  КАК ВидПродукции,
	Таблица.Организация   КАК Организация,
	Таблица.Контрагент    КАК Контрагент,
	Таблица.Операция      КАК Операция,
	Таблица.Ответственный КАК Ответственный,
	
	СтатусыДокументовИСМП.Статус              КАК СтатусИСМП,
	СтатусыДокументовИСМП.ДальнейшееДействие1 КАК ДальнейшееДействиеИСМП1,
	СтатусыДокументовИСМП.ДальнейшееДействие2 КАК ДальнейшееДействиеИСМП2,
	СтатусыДокументовИСМП.ДальнейшееДействие3 КАК ДальнейшееДействиеИСМП3
ИЗ
	Документ.ПриемкаТоваровИСМП КАК Таблица
	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыДокументовИСМП КАК СтатусыДокументовИСМП
		ПО (СтатусыДокументовИСМП.Документ = Таблица.Ссылка)
//%СоединениеСОснованиями%
ГДЕ
	(Таблица.ДокументОснование В (&amp;ПустойДокументОснование)
//%ОтборПоДоступнымОснованиям%
	)
</queryText>
      <mainTable>Document.ПриемкаТоваровИСМП</mainTable>
      <dynamicDataRead>true</dynamicDataRead>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
