Функция ДанныеДляПроведения(Ссылка, СтруктураВидовУчета)
	
	ДанныеДляПроведения = Новый Структура("Организация, Сотрудник, ФизическоеЛицо, СуммаОблагаемойБазы, ПериодРегистрации");
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	РегистрацияОблагаемойБазыРуководителя.Организация КАК Организация,
	|	РегистрацияОблагаемойБазыРуководителя.Сотрудник КАК Сотрудник,
	|	РегистрацияОблагаемойБазыРуководителя.ФизическоеЛицо КАК ФизическоеЛицо,
	|	РегистрацияОблагаемойБазыРуководителя.ПериодРегистрации КАК ПериодРегистрации,
	|	РегистрацияОблагаемойБазыРуководителя.СуммаОблагаемойБазы КАК СуммаОблагаемойБазы
	|ИЗ
	|	Документ.РегистрацияОблагаемойБазыРуководителя КАК РегистрацияОблагаемойБазыРуководителя
	|ГДЕ
	|	РегистрацияОблагаемойБазыРуководителя.Ссылка = &Ссылка";
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	ВыборкаРеквизиты = Запрос.Выполнить().Выбрать();
	Если ВыборкаРеквизиты.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(ДанныеДляПроведения, ВыборкаРеквизиты);
	КонецЕсли;
	ДанныеДляПроведения.Вставить("СтраховыеВзносы", УчетСтраховыхВзносов.ДанныеОВзносахИзДокумента(Ссылка,,,,Истина));
	
	Возврат ДанныеДляПроведения;

КонецФункции

