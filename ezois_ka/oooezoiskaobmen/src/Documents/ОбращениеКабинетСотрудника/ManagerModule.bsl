Процедура ОбработкаПолученияПолейПредставления(Поля, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	Поля.Добавить("Дата");
	Поля.Добавить("Номер");
	Поля.Добавить("ШаблонДокумента");
	
КонецПроцедуры

Процедура ОбработкаПолученияПредставления(Данные, Представление, СтандартнаяОбработка)
	
	Если ЗначениеЗаполнено(Данные.ШаблонДокумента) Тогда
		Представление = СтрШаблон("%1 %2 %3 %4", Строка(Данные.ШаблонДокумента), Данные.Номер, НСтр("ru = 'от'"), Данные.Дата);
	Иначе
		Шаблон = НСтр("ru = 'Обращение сотрудника %1 от %2'");
		Представление = СтрШаблон(Шаблон, Данные.Номер, Данные.Дата);
	КонецЕсли;
	
	СтандартнаяОбработка = Ложь;
	
КонецПроцедуры

