    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	ЭлектронныйПутевойЛист.Ссылка,
	ЭлектронныйПутевойЛист.Номер КАК ВнутреннийНомер,
	ЭлектронныйПутевойЛист.ПометкаУдаления,
	ЭлектронныйПутевойЛист.Проведен,
	ЭлектронныйПутевойЛист.ТитулОформлениеНомерПутевогоЛиста,
	ЭлектронныйПутевойЛист.ТитулОформлениеДатаПутевогоЛиста,
	ЭлектронныйПутевойЛист.Организация,
	ЭлектронныйПутевойЛист.Комментарий,
	ЭлектронныйПутевойЛист.ТекущийШаг,
	ЭлектронныйПутевойЛист.ТекущийШагВыполнен,
	СостоянияЭД.СостояниеЭДО,
	СостоянияЭД.ПредставлениеСостояния
ИЗ
	Документ.ЭлектронныйПутевойЛист КАК ЭлектронныйПутевойЛист
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияПоОбъектамУчетаЭДО КАК СостоянияЭД
		ПО (СостоянияЭД.СсылкаНаОбъект = ЭлектронныйПутевойЛист.Ссылка)</queryText>
      <mainTable>Document.ЭлектронныйПутевойЛист</mainTable>
      <dynamicDataRead>true</dynamicDataRead>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
