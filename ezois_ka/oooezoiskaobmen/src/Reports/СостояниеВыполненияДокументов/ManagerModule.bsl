		Область.Параметры.Товар = НоменклатураКлиентСервер.ПредставлениеНоменклатуры(
					СтрокаТовар.НоменклатураПредставление,
					СтрокаТовар.ХарактеристикаПредставление,
					,
					СтрокаТовар.СерияПредставление);
		
