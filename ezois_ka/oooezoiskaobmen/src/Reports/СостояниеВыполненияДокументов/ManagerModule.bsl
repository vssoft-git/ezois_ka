					СтрокаТовар.НоменклатураПредставление,
					СтрокаТовар.ХарактеристикаПредставление);
		
		ОбластьСтроки.ЦветФона = ?(ЧетнаяСтрока, АльтернативныйЦветФонаПоля, ЦветФонаПоля);
		
		ТаблицаОтчета.Вывести(Область);
		ЧетнаяСтрока = НЕ ЧетнаяСтрока;
		
	КонецЦикла;
	
	ТаблицаОтчета.ЗакончитьГруппуСтрок();
	
	Возврат Истина;

КонецФункции

//-- НЕ УТ

#КонецОбласти

#Область Прочее

Процедура РаспределитьОплатыПоГрафику(Оплаты, ЭтапыГрафика)
	
	КоличествоЭтаповГрафикаОплаты = ЭтапыГрафика.Количество();
	Если КоличествоЭтаповГрафикаОплаты = 0 Тогда
		Возврат;
	КонецЕсли;
	
	МассивСтрокСФактическимиОплатами = Новый Массив;
	ЕстьОплатыНеПоГрафику = Ложь;
	Для Каждого Оплата Из Оплаты Цикл
		Если Оплата.ОплатаФакт <> 0 Тогда
			МассивСтрокСФактическимиОплатами.Добавить(Оплата);
			Если Оплата.ЭтапОплатыОтгрузки = "ОплатаНеПоГрафику" Тогда
				ЕстьОплатыНеПоГрафику = Истина;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Если НЕ ЕстьОплатыНеПоГрафику Тогда
		Возврат;
	КонецЕсли;
	
	ТекущаяСтрокаГрафикаОплат = 0;
	Для Каждого СтрокаСФактическойОплатой Из МассивСтрокСФактическимиОплатами Цикл
		
		Если ТекущаяСтрокаГрафикаОплат > КоличествоЭтаповГрафикаОплаты - 1 Тогда
			Возврат;
		КонецЕсли;
		
		Если СтрокаСФактическойОплатой.ОплатаФакт = ЭтапыГрафика[ТекущаяСтрокаГрафикаОплат].СуммаПлатежа Тогда
			
			Если СокрЛП(СтрокаСФактическойОплатой.ЭтапОплатыОтгрузки) = "ОплатаНеПоГрафику" Тогда
				СтрокаСФактическойОплатой.ЭтапОплатыОтгрузки = ЭтапыГрафика[ТекущаяСтрокаГрафикаОплат].ВариантОплаты;
			КонецЕсли;
			
			ТекущаяСтрокаГрафикаОплат = ТекущаяСтрокаГрафикаОплат + 1;
			
		ИначеЕсли СтрокаСФактическойОплатой.ОплатаФакт < ЭтапыГрафика[ТекущаяСтрокаГрафикаОплат].СуммаПлатежа Тогда
			
			Если СокрЛП(СтрокаСФактическойОплатой.ЭтапОплатыОтгрузки) = "ОплатаНеПоГрафику" Тогда
				СтрокаСФактическойОплатой.ЭтапОплатыОтгрузки = ЭтапыГрафика[ТекущаяСтрокаГрафикаОплат].ВариантОплаты;
			КонецЕсли;
			ЭтапыГрафика[ТекущаяСтрокаГрафикаОплат].СуммаПлатежа = ЭтапыГрафика[ТекущаяСтрокаГрафикаОплат].СуммаПлатежа - СтрокаСФактическойОплатой.ОплатаФакт;
			
		Иначе
			
			ОсталосьРаспределить = СтрокаСФактическойОплатой.ОплатаФакт;
			МассивВидовОплатыПоПлатежу = Новый Массив;
			
			Пока ОсталосьРаспределить >= ЭтапыГрафика[ТекущаяСтрокаГрафикаОплат].СуммаПлатежа Цикл
				ОсталосьРаспределить = ОсталосьРаспределить - ЭтапыГрафика[ТекущаяСтрокаГрафикаОплат].СуммаПлатежа;
				
				ВариантОплатыЭтапа = ЭтапыГрафика[ТекущаяСтрокаГрафикаОплат].ВариантОплаты;
				Если МассивВидовОплатыПоПлатежу.Найти(ВариантОплатыЭтапа) = Неопределено Тогда
					МассивВидовОплатыПоПлатежу.Добавить(ЭтапыГрафика[ТекущаяСтрокаГрафикаОплат].ВариантОплаты);
				КонецЕсли;
				 
				ТекущаяСтрокаГрафикаОплат = ТекущаяСтрокаГрафикаОплат + 1;
				Если ТекущаяСтрокаГрафикаОплат > КоличествоЭтаповГрафикаОплаты - 1 Тогда
					Прервать;
				КонецЕсли;
			КонецЦикла;
			
			Если ОсталосьРаспределить > 0 И (НЕ ТекущаяСтрокаГрафикаОплат > КоличествоЭтаповГрафикаОплаты - 1) Тогда
				ЭтапыГрафика[ТекущаяСтрокаГрафикаОплат].СуммаПлатежа = ЭтапыГрафика[ТекущаяСтрокаГрафикаОплат].СуммаПлатежа - ОсталосьРаспределить;
				ВариантОплатыЭтапа = ЭтапыГрафика[ТекущаяСтрокаГрафикаОплат].ВариантОплаты;
				Если МассивВидовОплатыПоПлатежу.Найти(ВариантОплатыЭтапа) = Неопределено Тогда
					МассивВидовОплатыПоПлатежу.Добавить(ЭтапыГрафика[ТекущаяСтрокаГрафикаОплат].ВариантОплаты);
				КонецЕсли;
			КонецЕсли;
			
			Если МассивВидовОплатыПоПлатежу.Количество() = 1
				И СокрЛП(СтрокаСФактическойОплатой.ЭтапОплатыОтгрузки) = "ОплатаНеПоГрафику" Тогда
				
				СтрокаСФактическойОплатой.ЭтапОплатыОтгрузки = МассивВидовОплатыПоПлатежу[0];
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// Параметры:
//  СтрокаДереваРасчетов - СтрокаДереваЗначений
//  ТаблицаРасчетов - ТаблицаЗначений
//  ЭтоОплаты - Булево
Процедура ОбработатьДанныеРасчетовПередВыводом(СтрокаДереваРасчетов, ТаблицаРасчетов, ЭтоОплаты)
	
	Если СтрокаДереваРасчетов.СуммаПлан <> 0 Тогда
		Если Не ЭтоОплаты Тогда
			ТаблицаПоРегистраторам = ТаблицаРасчетов.Скопировать(,"ДокументРегистратор, СуммаФакт");
			ТаблицаРасчетов.Индексы.Добавить("ДокументРегистратор");
			ТаблицаПоРегистраторам.Свернуть("ДокументРегистратор", "СуммаФакт");
			Для Каждого СтрокаОтгрузок Из ТаблицаПоРегистраторам Цикл
				
				Если СтрокаОтгрузок.СуммаФакт = 0 Тогда
					Продолжить;
				КонецЕсли;
				СуммаДокумента = 0;
				СтрокиДокумента = ТаблицаРасчетов.НайтиСтроки(Новый Структура("ДокументРегистратор", СтрокаОтгрузок.ДокументРегистратор));
				Для Каждого СтрокаДокумента Из СтрокиДокумента Цикл
					СуммаДокумента = Макс(СуммаДокумента, СтрокаДокумента.СуммаДокумента);
				КонецЦикла;
				Если СуммаДокумента = СтрокаОтгрузок.СуммаФакт Тогда
					Продолжить;
				КонецЕсли;
				// Необходимо уменьшить факт отгрузки, если есть зачеты аванса, которые не уменьшали план отгрузки
				// или увеличить факт отгрузки, если не весь аванс зачтен на отгрузки
				СуммаРасхождения = СтрокаОтгрузок.СуммаФакт - СуммаДокумента;
				Для Каждого СтрокаПлановойДаты Из СтрокаДереваРасчетов.Строки Цикл
					Для Каждого СтрокаВарианта Из СтрокаПлановойДаты.Строки Цикл
						Для Каждого СтрокаГрафика Из СтрокаВарианта.Строки Цикл
							Если СтрокаГрафика.ДокументРегистратор <> СтрокаОтгрузок.ДокументРегистратор
								// Добавляем только в строки факта
								Или СтрокаВарианта.Строки.Индекс(СтрокаГрафика) = 0 Тогда
								Продолжить;
							КонецЕсли;
							Если СуммаРасхождения > 0 Тогда
								СуммаКСписанию = Мин(СуммаРасхождения, СтрокаГрафика.СуммаФакт);
							Иначе
								СуммаКСписанию = Макс(
									СуммаРасхождения,
									СтрокаГрафика.СуммаФакт
									- СтрокаГрафика.КорректировкаГрафика
									- СтрокаПлановойДаты.СуммаПлан);
							КонецЕсли;
							СтрокаГрафика.СуммаФакт = СтрокаГрафика.СуммаФакт - СуммаКСписанию;
							СтрокаВарианта.СуммаФакт = СтрокаВарианта.СуммаФакт - СуммаКСписанию;
							СтрокаПлановойДаты.СуммаФакт = СтрокаПлановойДаты.СуммаФакт - СуммаКСписанию;
							СтрокаДереваРасчетов.СуммаФакт = СтрокаДереваРасчетов.СуммаФакт - СуммаКСписанию;
							Если СуммаРасхождения < 0 Тогда
								СтрокаГрафика.КорректировкаГрафика = СтрокаГрафика.КорректировкаГрафика - СуммаКСписанию;
								СтрокаВарианта.КорректировкаГрафика = СтрокаВарианта.КорректировкаГрафика - СуммаКСписанию;
								СтрокаПлановойДаты.КорректировкаГрафика = СтрокаПлановойДаты.КорректировкаГрафика - СуммаКСписанию;
								СтрокаДереваРасчетов.КорректировкаГрафика = СтрокаДереваРасчетов.КорректировкаГрафика - СуммаКСписанию;
							КонецЕсли;
							СуммаРасхождения = СуммаРасхождения - СуммаКСписанию;
							Если СтрокаГрафика.СуммаФакт = 0 Тогда
								СтрокаГрафика.ДатаФакт = Дата(1,1,1);
							Иначе
								СтрокаГрафика.ДатаФакт = СтрокаГрафика.Период;
							КонецЕсли;
							Если СуммаРасхождения = 0 Тогда
								Прервать;
							КонецЕсли;
						КонецЦикла;
						Если СуммаРасхождения = 0 Тогда
							Прервать;
						КонецЕсли;
					КонецЦикла;
					Если СуммаРасхождения = 0 Тогда
						Прервать;
					КонецЕсли;
				КонецЦикла;
				
			КонецЦикла;
			
		ИначеЕсли СтрокаДереваРасчетов.ПорядокРасчетов = Перечисления.ПорядокРасчетов.ПоЗаказамНакладным
				Или СтрокаДереваРасчетов.ПорядокРасчетов = Перечисления.ПорядокРасчетов.ПоДоговорамНакладным Тогда
			// Найдем строку с незаченными авансами и уменьшим корректировку в строках соответствующей накладной на сумму незачтенного аванса
			СтрокаНезачтенныхАвансов = СтрокаДереваРасчетов.Строки.Найти(3, "Порядок");
			Если СтрокаНезачтенныхАвансов <> Неопределено Тогда
				Для Каждого СтрокаВариантаНезачтенныхАвансов Из СтрокаНезачтенныхАвансов.Строки Цикл
					Для Каждого СтрокаГрафикаНезачтенныхАвансов Из СтрокаВариантаНезачтенныхАвансов.Строки Цикл
						
						СуммаРасхождения = -СтрокаГрафикаНезачтенныхАвансов.КорректировкаГрафика;
						Для Каждого СтрокаПлановойДаты Из СтрокаДереваРасчетов.Строки Цикл
							Для Каждого СтрокаВарианта Из СтрокаПлановойДаты.Строки Цикл
								// Проверяем, что есть, что списать
								Если СтрокаВарианта.СуммаПлан + СтрокаВарианта.КорректировкаГрафика - СтрокаВарианта.СуммаФакт <= 0 Тогда
									Продолжить;
								КонецЕсли;
								Для Каждого СтрокаГрафика Из СтрокаВарианта.Строки Цикл
									// Уменьшаем только соответствующие накладные
									Если СтрокаГрафика.ДокументРегистратор <> СтрокаГрафикаНезачтенныхАвансов.ДокументРегистратор Тогда
										Продолжить;
									КонецЕсли;
									СуммаКСписанию = Мин(
										СуммаРасхождения,
										СтрокаВарианта.СуммаПлан
										+ СтрокаВарианта.КорректировкаГрафика
										- СтрокаВарианта.СуммаФакт);
									СтрокаГрафика.КорректировкаГрафика = СтрокаГрафика.КорректировкаГрафика - СуммаКСписанию;
									СтрокаВарианта.КорректировкаГрафика = СтрокаВарианта.КорректировкаГрафика - СуммаКСписанию;
									СтрокаПлановойДаты.КорректировкаГрафика = СтрокаПлановойДаты.КорректировкаГрафика - СуммаКСписанию;
									СуммаРасхождения = СуммаРасхождения - СуммаКСписанию;
									Если СуммаРасхождения = 0 Тогда
										Прервать;
									КонецЕсли;
								КонецЦикла;
								Если СуммаРасхождения = 0 Тогда
									Прервать;
								КонецЕсли;
							КонецЦикла;
							Если СуммаРасхождения = 0 Тогда
								Прервать;
							КонецЕсли;
						КонецЦикла;
						
					КонецЦикла;
				КонецЦикла;
				
				СтрокаДереваРасчетов.Строки.Удалить(СтрокаНезачтенныхАвансов);
				
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если СтрокаДереваРасчетов.СуммаПлан = 0 Тогда
		
		// Если плана нет, то и отгрузка сверх заказа не актуальна, удаляем.
		Для Каждого СтрокаПлановойДаты Из СтрокаДереваРасчетов.Строки Цикл
			Индекс = СтрокаПлановойДаты.Строки.Количество();
			Пока Индекс > 0 Цикл
				Индекс = Индекс - 1;
				Если СтрокаПлановойДаты.Строки[Индекс].ВариантОплатыОтгрузки = 4
					Или ЭтоОплаты 
						И Не ЗначениеЗаполнено(СтрокаПлановойДаты.Строки[Индекс].ДатаПлан) Тогда
					СтрокаПлановойДаты.Строки.Удалить(Индекс);
					СтрокаПлановойДаты.СуммаФакт = СтрокаПлановойДаты.Строки.Итог("СуммаФакт");
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
		Индекс = СтрокаДереваРасчетов.Строки.Количество();
		Пока Индекс > 0 Цикл
			Индекс = Индекс - 1;
			Если СтрокаДереваРасчетов.Строки[Индекс].Строки.Количество() = 0 Тогда
				СтрокаДереваРасчетов.Строки.Удалить(Индекс);
			КонецЕсли;
		КонецЦикла;
		СтрокаДереваРасчетов.СуммаФакт = СтрокаДереваРасчетов.Строки.Итог("СуммаФакт");
		
	КонецЕсли;
	
	ОстатокИтого = 0;
	ОстатокПросроченоИтого = 0;
	Для Каждого СтрокаПлановойДаты Из СтрокаДереваРасчетов.Строки Цикл
		
		// Строки без варианта оплаты отгрузки необходимо объединить со строками плана, у которых есть отрицательные корректировки
		// таким образом, чтобы у итоговой строки корректировка стремилась к 0, если строка факта остается, то устанавливается вариант оплаты отгрузки по умолчанию
		// Если в реализации не изменили план оплаты, то вариант оплаты унаследуется для графика погашения фактической задолженности
		// Если в авансовой платежке не указали дату погашения, отличную от даты плановой отгрузки, то вариант отгрузки унаследуется
		Для Каждого СтрокаФактическогоГрафика Из СтрокаПлановойДаты.Строки Цикл
			Если ЗначениеЗаполнено(СтрокаФактическогоГрафика.ВариантОплатыОтгрузки)
				Или СтрокаФактическогоГрафика.КорректировкаГрафика <= 0 Тогда
				Продолжить;
			КонецЕсли;
			
			// Если в текущую плановую дату есть строки планового графика, то перенесем в них суммы корректировок, остатков и факта текущей строки
			Для Каждого СтрокаПлановогоГрафика Из СтрокаПлановойДаты.Строки Цикл
				Если Не ЗначениеЗаполнено(СтрокаПлановогоГрафика.ВариантОплатыОтгрузки)
					Или СтрокаПлановогоГрафика.КорректировкаГрафика >= 0 Тогда
					Продолжить;
				КонецЕсли;
				// Ограничим возможное уменьшение сумм фактической строки суммой уменьшения планового графика
				СуммаПереноса = Мин(СтрокаФактическогоГрафика.КорректировкаГрафика, - СтрокаПлановогоГрафика.КорректировкаГрафика);
				СтрокаФактическогоГрафика.КорректировкаГрафика = СтрокаФактическогоГрафика.КорректировкаГрафика - СуммаПереноса;
				СтрокаПлановогоГрафика.КорректировкаГрафика = СтрокаПлановогоГрафика.КорректировкаГрафика + СуммаПереноса;
				
				СуммаПереносаФакта = Мин(СуммаПереноса, СтрокаФактическогоГрафика.СуммаФакт);
				СтрокаПлановогоГрафика.СуммаФакт            = СтрокаПлановогоГрафика.СуммаФакт + СуммаПереносаФакта;
				СтрокаФактическогоГрафика.СуммаФакт         = СтрокаФактическогоГрафика.СуммаФакт - СуммаПереносаФакта;
				
				// 1я вложенная строка - это строка с пустой датой факт, остальные - это фактические постоплаты/погашения аванса
				СтрокаФактическогоГрафика.Строки[0].КорректировкаГрафика = СтрокаФактическогоГрафика.Строки[0].КорректировкаГрафика - СуммаПереноса;
				СтрокаПлановогоГрафика.Строки[0].КорректировкаГрафика = СтрокаПлановогоГрафика.Строки[0].КорректировкаГрафика + СуммаПереноса;
				// Перенесем строки фактических сумм на сумму не более суммы переноса
				ИндексВложеннойСтроки = 1;
				Пока ИндексВложеннойСтроки < СтрокаФактическогоГрафика.Строки.Количество()
					И СуммаПереноса > 0 Цикл
					ВложеннаяСтрокаИсточник = СтрокаФактическогоГрафика.Строки[ИндексВложеннойСтроки];
					Если ЗначениеЗаполнено(ВложеннаяСтрокаИсточник.ДатаФакт) Тогда
						НоваяСтрокаПолучатель = СтрокаПлановогоГрафика.Строки.Добавить();
						ЗаполнитьЗначенияСвойств(НоваяСтрокаПолучатель, СтрокаПлановогоГрафика, , "СуммаПлан, КорректировкаГрафика, ДатаФакт, СуммаФакт");
						НоваяСтрокаПолучатель.ДатаФакт = ВложеннаяСтрокаИсточник.ДатаФакт;
						НоваяСтрокаПолучатель.СуммаФакт = Мин(ВложеннаяСтрокаИсточник.СуммаФакт, СуммаПереноса);
						НоваяСтрокаПолучатель.СуммаПлан = 0;
						НоваяСтрокаПолучатель.КорректировкаГрафика = 0;
						ВложеннаяСтрокаИсточник.СуммаФакт = ВложеннаяСтрокаИсточник.СуммаФакт - НоваяСтрокаПолучатель.СуммаФакт;
						СуммаПереноса = СуммаПереноса - НоваяСтрокаПолучатель.СуммаФакт;
					КонецЕсли;
					ИндексВложеннойСтроки = ИндексВложеннойСтроки + 1;
				КонецЦикла;
				// Удалим строки фактических сумм с пустой суммой факт, если текущая строка фактического графика еще не пустая
				Если СтрокаФактическогоГрафика.КорректировкаГрафика = 0
					И СтрокаФактическогоГрафика.СуммаФакт = 0 Тогда
					// Строка к удалению - не имеет смысла обходить вложенные строки
					Продолжить;
				КонецЕсли;
				ИндексВложеннойСтроки = СтрокаФактическогоГрафика.Строки.Количество();
				Пока ИндексВложеннойСтроки > 0 Цикл
					ИндексВложеннойСтроки = ИндексВложеннойСтроки - 1;
					ВложеннаяСтрока = СтрокаФактическогоГрафика.Строки[ИндексВложеннойСтроки];
					Если ЗначениеЗаполнено(ВложеннаяСтрока.ДатаФакт) 
						И ВложеннаяСтрока.СуммаФакт = 0 Тогда
						СтрокаФактическогоГрафика.Строки.Удалить(ИндексВложеннойСтроки);
					КонецЕсли;
				КонецЦикла;
			КонецЦикла;
		КонецЦикла;
		
		// Свернем строки планового и фактического графика с одинаковыми датами факт
		Для Каждого СтрокаГрафика Из СтрокаПлановойДаты.Строки Цикл
			ДатыФакт = СтрокаГрафика.Строки.ВыгрузитьКолонку("ДатаФакт");
			ДатыФакт = ОбщегоНазначенияКлиентСервер.СвернутьМассив(ДатыФакт);
			СтрокиКУдалению = Новый Массив;
			Для Каждого ДатаФакт Из ДатыФакт Цикл
				СтрокиДаты = СтрокаГрафика.Строки.НайтиСтроки(Новый Структура("ДатаФакт", ДатаФакт));
				Если СтрокиДаты.Количество() > 1 Тогда
					ИндексСтроки = 1;
					Пока ИндексСтроки < СтрокиДаты.Количество() Цикл
						СтрокиДаты[0].КорректировкаГрафика = СтрокиДаты[0].КорректировкаГрафика + СтрокиДаты[ИндексСтроки].КорректировкаГрафика;
						СтрокиДаты[0].СуммаФакт = СтрокиДаты[0].СуммаФакт + СтрокиДаты[ИндексСтроки].СуммаФакт;
						СтрокиДаты[0].СуммаПлан = СтрокиДаты[0].СуммаПлан + СтрокиДаты[ИндексСтроки].СуммаПлан;
						СтрокиКУдалению.Добавить(СтрокиДаты[ИндексСтроки]);
						ИндексСтроки = ИндексСтроки + 1;
					КонецЦикла;
				КонецЕсли;
			КонецЦикла;
			Для Каждого СтрокаКУдалению Из СтрокиКУдалению Цикл
				СтрокаГрафика.Строки.Удалить(СтрокаКУдалению);
			КонецЦикла;
			СтрокаГрафика.КорректировкаГрафика = СтрокаГрафика.Строки.Итог("КорректировкаГрафика");
		КонецЦикла;
		СтрокаПлановойДаты.КорректировкаГрафика = СтрокаПлановойДаты.Строки.Итог("КорректировкаГрафика");
		
		// Удалим строки фактического графика, если в них не осталось сумм, или установим значение варианта оплаты/отгрузки
		// для фактического графика, если остались ненулевые суммы
		ИндексСтроки = СтрокаПлановойДаты.Строки.Количество();
		Пока ИндексСтроки > 0 Цикл
			ИндексСтроки = ИндексСтроки - 1;
			СтрокаГрафика = СтрокаПлановойДаты.Строки[ИндексСтроки];
			Если СтрокаГрафика.СуммаПлан + СтрокаГрафика.КорректировкаГрафика >= СтрокаГрафика.СуммаФакт Тогда
				СтрокаГрафика.Остаток = СтрокаГрафика.СуммаПлан + СтрокаГрафика.КорректировкаГрафика - СтрокаГрафика.СуммаФакт;
				СтрокаГрафика.Строки[0].Остаток = СтрокаГрафика.Остаток;
				Если СтрокаГрафика.Остаток > 0
					И ЗначениеЗаполнено(СтрокаГрафика.ДатаПлан)
					И СтрокаГрафика.ДатаПлан < НачалоДня(ТекущаяДатаСеанса()) Тогда
					СтрокаГрафика.ОстатокПросрочено = СтрокаГрафика.Остаток;
					СтрокаГрафика.ДнейПросрочено = ОбщегоНазначенияУТ.РазностьДат(СтрокаГрафика.ДатаПлан, НачалоДня(ТекущаяДатаСеанса()), Перечисления.Периодичность.День);
					СтрокаГрафика.Строки[0].ОстатокПросрочено = СтрокаГрафика.ОстатокПросрочено;
					СтрокаГрафика.Строки[0].ДнейПросрочено = СтрокаГрафика.ДнейПросрочено;
				КонецЕсли;
			КонецЕсли;
			ОстатокИтого = ОстатокИтого + СтрокаГрафика.Остаток;
			ОстатокПросроченоИтого = ОстатокПросроченоИтого + СтрокаГрафика.ОстатокПросрочено;
			Если ЗначениеЗаполнено(СтрокаГрафика.ВариантОплатыОтгрузки)
				И (СтрокаГрафика.СуммаПлан <> 0
					Или СтрокаГрафика.КорректировкаГрафика <> 0 
					Или СтрокаГрафика.СуммаФакт <> 0
					Или СтрокаГрафика.Строки.Количество() > 1) Тогда
				Продолжить;
			КонецЕсли;
			Если СтрокаГрафика.КорректировкаГрафика = 0
				И СтрокаГрафика.СуммаФакт = 0 Тогда
				СтрокаПлановойДаты.Строки.Удалить(ИндексСтроки);
			Иначе
				Если ТипЗнч(СтрокаГрафика.ВариантОплатыОтгрузки) <> Тип("ПеречислениеСсылка.ВариантыКонтроляОплатыКлиентом")
					И ТипЗнч(СтрокаГрафика.ВариантОплатыОтгрузки) <> Тип("ПеречислениеСсылка.ВариантыКонтроляОплатыПоставщику") Тогда
					СтрокаГрафика.ВариантОплатыОтгрузки = 1;
				КонецЕсли;
				Для Каждого ВложеннаяСтрока Из СтрокаГрафика.Строки Цикл
					ВложеннаяСтрока.ВариантОплатыОтгрузки = СтрокаГрафика.ВариантОплатыОтгрузки;
				КонецЦикла;
			КонецЕсли;
		КонецЦикла;
		
	КонецЦикла;
	
	Индекс = СтрокаДереваРасчетов.Строки.Количество();
	Пока Индекс > 0 Цикл
		Индекс = Индекс - 1;
		Если СтрокаДереваРасчетов.Строки[Индекс].Строки.Количество() = 0 Тогда
			СтрокаДереваРасчетов.Строки.Удалить(Индекс);
		КонецЕсли;
	КонецЦикла;
	
	// Для объектов расчетов без плановых оплат суммы фактической задолженности отображаем в колонке Сумма (план)
	Если СтрокаДереваРасчетов.СуммаПлан = 0 Тогда
		СтрокаДереваРасчетов.СуммаПлан = СтрокаДереваРасчетов.КорректировкаГрафика;
		СтрокаДереваРасчетов.КорректировкаГрафика = 0;
		Для Каждого СтрокаПлановойДаты Из СтрокаДереваРасчетов.Строки Цикл
			Для Каждого СтрокаВариантаОплаты Из СтрокаПлановойДаты.Строки Цикл
				Для Каждого СтрокаРасчетов Из СтрокаВариантаОплаты.Строки Цикл
					СтрокаРасчетов.СуммаПлан = СтрокаРасчетов.КорректировкаГрафика;
					СтрокаРасчетов.КорректировкаГрафика = 0;
				КонецЦикла;
			КонецЦикла;
			СтрокаПлановойДаты.СуммаПлан = СтрокаДереваРасчетов.КорректировкаГрафика;
			СтрокаПлановойДаты.КорректировкаГрафика = 0;
		КонецЦикла;
	КонецЕсли;
	
	СтрокаДереваРасчетов.КорректировкаГрафика = СтрокаДереваРасчетов.Строки.Итог("КорректировкаГрафика");
	СтрокаДереваРасчетов.Остаток = ОстатокИтого;
	СтрокаДереваРасчетов.ОстатокПросрочено = ОстатокПросроченоИтого;
	
КонецПроцедуры

Функция ЕстьПравоДоступаКНаборуДанных(ИмяНабораДанных, СтруктураПараметров)
	
	ЕстьПравоДоступа = Ложь;
	
	Если ИмяНабораДанных = "РасчетыСКлиентами" Тогда
		
		ЕстьПравоДоступа = ПравоДоступа("Чтение", Метаданные.РегистрыНакопления.РасчетыСКлиентами);
		
	ИначеЕсли ИмяНабораДанных = "ЗаявкиНаВозвратТоваровОтКлиентов" Тогда
		
		ЕстьПравоДоступа = ПравоДоступа("Чтение", Метаданные.РегистрыНакопления.ЗаявкиНаВозвратТоваровОтКлиентов);
		ЕстьПравоДоступа = ЕстьПравоДоступа И ПравоДоступа("Чтение", Метаданные.РегистрыНакопления.ТоварыКПоступлению);
		
	ИначеЕсли ИмяНабораДанных = "РасчетыСПоставщиками" Тогда
		
		ЕстьПравоДоступа = ПравоДоступа("Чтение", Метаданные.РегистрыНакопления.РасчетыСПоставщиками);
		
	ИначеЕсли ИмяНабораДанных = "Отгрузка" Тогда
		
		ЕстьПравоДоступа = ПравоДоступа("Чтение", Метаданные.РегистрыНакопления.ТоварыКОтгрузке);
		СтруктураПараметров.Вставить("ЕстьПравоНаТаблицуОтгрузки", ЕстьПравоДоступа);
		
		Если СтруктураПараметров.ИмяРегистраОтгрузкаУслуг = "РаспоряженияНаОтгрузку" Тогда
			
			ЕстьПравоДоступаРегистрОтгрузкаУслуг = ПравоДоступа("Чтение", Метаданные.РегистрыНакопления.РаспоряженияНаОтгрузку);
			ЕстьПравоДоступа = ЕстьПравоДоступа Или ЕстьПравоДоступаРегистрОтгрузкаУслуг;
			СтруктураПараметров.Вставить("ЕстьПравоДоступаРегистрОтгрузкаУслуг", ЕстьПравоДоступаРегистрОтгрузкаУслуг);
			
		ИначеЕсли СтруктураПараметров.ИмяРегистраОтгрузкаУслуг = "ЗаказыНаВнутреннееПотребление" Тогда
			
			ЕстьПравоДоступаРегистрОтгрузкаУслуг = ПравоДоступа("Чтение", Метаданные.РегистрыНакопления.ЗаказыНаВнутреннееПотребление);
			ЕстьПравоДоступа = ЕстьПравоДоступа Или ЕстьПравоДоступаРегистрОтгрузкаУслуг;
			СтруктураПараметров.Вставить("ЕстьПравоДоступаРегистрОтгрузкаУслуг", ЕстьПравоДоступаРегистрОтгрузкаУслуг);
			
		КонецЕсли;
		
	ИначеЕсли ИмяНабораДанных = "Поступление" Тогда
		
		ЕстьПравоДоступа = ПравоДоступа("Чтение", Метаданные.РегистрыНакопления.ТоварыКПоступлению);
		СтруктураПараметров.Вставить("ЕстьПравоНаТаблицуПоступления", ЕстьПравоДоступа);
		
		ЕстьПравоДоступаЗаказыПоставщикам = ПравоДоступа("Чтение", Метаданные.РегистрыНакопления.ЗаказыПоставщикам);
		СтруктураПараметров.Вставить("ЕстьПравоДоступаЗаказыПоставщикам", ЕстьПравоДоступаЗаказыПоставщикам);
		
		Если СтруктураПараметров.ИмяРегистраПоступлениеУслуг = "ЗаказыПоставщикам" Тогда
			
			ЕстьПравоДоступа = ЕстьПравоДоступа Или ЕстьПравоДоступаЗаказыПоставщикам;
			СтруктураПараметров.Вставить("ЕстьПравоДоступаРегистрПоступлениеУслуг", ЕстьПравоДоступаЗаказыПоставщикам);
			
		ИначеЕсли СтруктураПараметров.ИмяРегистраПоступлениеУслуг = "ЗаказыНаСборку" Тогда
			
			ЕстьПравоДоступаРегистрПоступлениеУслуг = ПравоДоступа("Чтение", Метаданные.РегистрыНакопления.ЗаказыНаСборку);
			ЕстьПравоДоступа = ЕстьПравоДоступа И ЕстьПравоДоступаРегистрПоступлениеУслуг;
			СтруктураПараметров.Вставить("ЕстьПравоДоступаРегистрПоступлениеУслуг", ЕстьПравоДоступаРегистрПоступлениеУслуг);
			
		ИначеЕсли СтруктураПараметров.ИмяРегистраПоступлениеУслуг = "ЗаказыНаПеремещение" Тогда
			
			ЕстьПравоДоступаРегистрПоступлениеУслуг = ПравоДоступа("Чтение", Метаданные.РегистрыНакопления.ЗаказыНаПеремещение);
			ЕстьПравоДоступа = ЕстьПравоДоступа И ЕстьПравоДоступаРегистрПоступлениеУслуг;
			СтруктураПараметров.Вставить("ЕстьПравоДоступаРегистрПоступлениеУслуг", ЕстьПравоДоступаРегистрПоступлениеУслуг);
			
		КонецЕсли;
		
	ИначеЕсли ИмяНабораДанных = "ОбеспечениеДополнительно" Тогда
		
		ЕстьПравоДоступа = ПравоДоступа("Просмотр", Метаданные.Обработки.СостояниеОбеспеченияЗаказов);
		

	//++ НЕ УТ
	ИначеЕсли ИмяНабораДанных = "ПродукцияКОформлениюВОтчетеПереработчику" Тогда
		
		СтруктураДопЗапросов = СтруктураПараметров.СтруктураДопЗапросов;
		
		ЕстьПравоДоступа = ЗначениеЗаполнено(СтруктураДопЗапросов)
						   И СтруктураДопЗапросов.Свойство("ТекстЗапросаТаблицаПродукцияКОформлениюВОтчетеПереработчику")
						   //++ Устарело_Переработка24
						   Или ПравоДоступа("Чтение", Метаданные.РегистрыНакопления.ТоварыПолученныеОтПереработчика)
						   //-- Устарело_Переработка24
						   Или Ложь;
		
	ИначеЕсли ИмяНабораДанных = "СырьеУПереработчика" Тогда
		
		СтруктураДопЗапросов = СтруктураПараметров.СтруктураДопЗапросов;
		
		ЕстьПравоДоступа = ЗначениеЗаполнено(СтруктураДопЗапросов)
						   И СтруктураДопЗапросов.Свойство("ТаблицаСырьеУПереработчика")
						   //++ Устарело_Переработка24
						   Или ПравоДоступа("Чтение", Метаданные.РегистрыНакопления.ТоварыПереданныеПереработчику)
						   //-- Устарело_Переработка24
						   Или Ложь;
	//-- НЕ УТ
	КонецЕсли;
	
	Возврат ЕстьПравоДоступа;
	
КонецФункции

Функция СтатусыБезОтгрузки(ИмяТаблицы)
	
	МассивСтатусов = Новый Массив();
	
	МассивСтатусов.Добавить(Перечисления.СтатусыЗаказовКлиентов.НеСогласован);
	
	МассивСтатусов.Добавить(Перечисления.СтатусыЗаявокНаВозвратТоваровОтКлиентов.НеСогласована);
	МассивСтатусов.Добавить(Перечисления.СтатусыЗаявокНаВозвратТоваровОтКлиентов.КВозврату);
	МассивСтатусов.Добавить(Перечисления.СтатусыЗаявокНаВозвратТоваровОтКлиентов.Отклонена);
	МассивСтатусов.Добавить(Перечисления.СтатусыВнутреннихЗаказов.НаСогласовании);
	//++ НЕ УТ
	МассивСтатусов.Добавить(Перечисления.СтатусыЗаказовНаРемонт.Создан);
	//-- НЕ УТ
	Возврат МассивСтатусов
	
КонецФункции

Функция ЭтапОплатыОтгрузкиСтрокой(ИдентификаторЭтапаОплатыОтгрузки)
	
	Если ИдентификаторЭтапаОплатыОтгрузки = "ОплатаПоГрафику" Тогда
		Возврат НСтр("ru = 'Оплата по графику'");
	ИначеЕсли ИдентификаторЭтапаОплатыОтгрузки = "ОплатаНеПоГрафику" Тогда
		Возврат НСтр("ru = 'Оплата не по графику'");
	ИначеЕсли ИдентификаторЭтапаОплатыОтгрузки = "Отгрузка" Тогда
		Возврат НСтр("ru = 'Отгрузка'");
	ИначеЕсли ИдентификаторЭтапаОплатыОтгрузки = "Поступление" Тогда
		Возврат НСтр("ru = 'Поступление'");
	ИначеЕсли ИдентификаторЭтапаОплатыОтгрузки = "ПереносАванса" Тогда
		Возврат НСтр("ru = 'Перенос аванса'");
	Иначе
		Возврат ИдентификаторЭтапаОплатыОтгрузки;
	КонецЕсли;
	
КонецФункции

Функция ТипыПлатежныхДокументов()
	
	СписокТипов = Новый СписокЗначений;
	СписокТипов.Добавить(Тип("ДокументСсылка.ПоступлениеБезналичныхДенежныхСредств"));
	СписокТипов.Добавить(Тип("ДокументСсылка.СписаниеБезналичныхДенежныхСредств"));
	СписокТипов.Добавить(Тип("ДокументСсылка.ПриходныйКассовыйОрдер"));
	СписокТипов.Добавить(Тип("ДокументСсылка.РасходныйКассовыйОрдер"));
	СписокТипов.Добавить(Тип("ДокументСсылка.ОперацияПоПлатежнойКарте"));
	//++ Локализация
	СписокТипов.Добавить(Тип("ДокументСсылка.ОперацияПоЯндексКассе"));
	//-- Локализация
	
	
	Возврат СписокТипов;
	
КонецФункции

