		Возврат СтруктураДопЗапросов.ТекстЗапросаТаблицаОтгрузка;
	КонецЕсли;
	
	ТекстЗапроса = "
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВТТоварыРаспоряженияОтгружено.Ссылка КАК Документ,
	|	ВТТоварыКОтгрузке.Склад КАК Склад,
	|	ВТТоварыКОтгрузке.Номенклатура КАК Номенклатура,
