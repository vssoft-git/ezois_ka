        <extendedTooltip>
          <name>РежимНастройкиРасширеннаяПодсказка</name>
          <id>93705</id>
          <title>
            <key>ru</key>
            <value>&lt;fontsize 10>В режиме настройки строк можно:&lt;/>
&lt;img 0:9232b43e-8282-4932-badb-272fa166364e/>&lt;fontsize 10> &lt;/>&lt;fontsize 10>добавить группу показателей;&lt;/>
&lt;img 0:5ada350d-3380-4ce3-b60a-2950b3e843dd/>&lt;fontsize 10> &lt;/>&lt;fontsize 10>добавить строку &quot;в том числе&quot;;&lt;/>
&lt;img 0:f5bfed7e-3161-4cc8-8e47-985a97761b96/>&lt;fontsize 10> &lt;/>&lt;fontsize 10>удалить строку;&lt;/>
&lt;img 0:e80d5667-e847-43dc-91ce-2ddbf5139f64/> &lt;fontsize 10>показать строку;
&lt;/>&lt;img 0:20ce7971-a836-4c7b-afa6-be7d8395236f/>&lt;fontsize 10> &lt;/>&lt;fontsize 10>скрыть строку&lt;/>&lt;fontsize 10>&lt;font DefaultFont--10-->.&lt;/>&lt;/></value>
          </title>
