				= СтруктураРеквизитовФормы.ЗаголовокДатаОтчетногоПериодаПрошлогоГода;
			
		КонецЕсли;
				
	ИначеЕсли НаимТекущегоРаздела = "ОЦИС" Тогда
		
		//ОТЧЕТ О ЦЕЛЕВОМ ИСПОЛЬЗОВАНИИ ПОЛУЧЕННЫХ СРЕДСТВ
		ДатаКонцаПериодаОтчета = ДобавитьМесяц(СтруктураРеквизитовФормы.мДатаКонцаПериодаОтчета, -12);
		
		Если НачалоГода(СтруктураРеквизитовФормы.мДатаНачалаПериодаОтчета)
		  <> НачалоДня(СтруктураРеквизитовФормы.мДатаНачалаПериодаОтчета) Тогда
			СтрПериод = Формат(СтруктураРеквизитовФормы.мДатаНачалаПериодаОтчета, "ДФ=dd.MM.yyyy") + " - "
					  + Формат(СтруктураРеквизитовФормы.мДатаКонцаПериодаОтчета, "ДФ='ММММ гггг'") + " г." ;
		Иначе
			Если НачалоМесяца(СтруктураРеквизитовФормы.мДатаКонцаПериодаОтчета)
			   = СтруктураРеквизитовФормы.мДатаНачалаПериодаОтчета Тогда
				СтрПериод = Формат(СтруктураРеквизитовФормы.мДатаКонцаПериодаОтчета, "ДФ = 'ММММ гггг'") + " г.";
			Иначе
				СтрПериод = "Январь - " + Формат(СтруктураРеквизитовФормы.мДатаКонцаПериодаОтчета, "ДФ = 'ММММ гггг'") + " г.";
			КонецЕсли;
		КонецЕсли;
		
		Если Месяц(ДатаКонцаПериодаОтчета) = 1 Тогда
			СтрПериодПрошлыйГод = Формат(ДатаКонцаПериодаОтчета, "ДФ = 'ММММ гггг'") + " г.";
		Иначе
			СтрПериодПрошлыйГод = "Январь - " + Формат(ДатаКонцаПериодаОтчета, "ДФ = 'ММММ гггг'") + " г.";
		КонецЕсли;
		
		ПериодОтчета = " за " + СтрПериод;
		
		//Заголовки таблиц.
		СтруктураРеквизитовФормы.ЗаголовокДатаОтчетногоПериода = "За " + СтрПериод;
		СтруктураРеквизитовФормы.ЗаголовокДатаОтчетногоПериодаПрошлогоГода = "За " + СтрПериодПрошлыйГод;
		
		Если ТипЗнч(СтруктураДанныхТитульный) = Тип("ТабличныйДокумент") Тогда
		
			// Период в заголовке.
			СтруктураДанныхТитульный.Области.ПериодОтчета.Значение = ПериодОтчета;
			
			// Период в списке кодов в форме отчета.
			СтруктураДанныхТитульный.Области.ДатаКонцаПериодаОтчетаГод.Значение
				= Формат(СтруктураРеквизитовФормы.мДатаКонцаПериодаОтчета, "ДФ = 'гггг'");
			СтруктураДанныхТитульный.Области.ДатаКонцаПериодаОтчетаМесяц.Значение
				= Формат(СтруктураРеквизитовФормы.мДатаКонцаПериодаОтчета, "ДФ = 'ММ'");
			СтруктураДанныхТитульный.Области.ДатаКонцаПериодаОтчетаЧисло.Значение
				= Формат(СтруктураРеквизитовФормы.мДатаКонцаПериодаОтчета, "ДФ = 'дд'");
			
			СтруктураДанныхТитульный.Области.ДатаОтчетногоПериода.Значение
				= СтруктураРеквизитовФормы.ЗаголовокДатаОтчетногоПериода;
			
			СтруктураДанныхТитульный.Области.ДатаОтчетногоПериодаПрошлогоГода.Значение
				= СтруктураРеквизитовФормы.ЗаголовокДатаОтчетногоПериодаПрошлогоГода;
			
		ИначеЕсли ТипЗнч(СтруктураДанныхТитульный) = Тип("Структура") Тогда
				
			// Период в заголовке.
			СтруктураДанныхТитульный.ПериодОтчета = ПериодОтчета;
			
			// Период в списке кодов в форме отчета.
			СтруктураДанныхТитульный.ДатаКонцаПериодаОтчетаГод
				= Формат(СтруктураРеквизитовФормы.мДатаКонцаПериодаОтчета, "ДФ = 'гггг'");
			СтруктураДанныхТитульный.ДатаКонцаПериодаОтчетаМесяц
				= Формат(СтруктураРеквизитовФормы.мДатаКонцаПериодаОтчета, "ДФ = 'ММ'");
			СтруктураДанныхТитульный.ДатаКонцаПериодаОтчетаЧисло
				= Формат(СтруктураРеквизитовФормы.мДатаКонцаПериодаОтчета, "ДФ = 'дд'");
			
			СтруктураДанныхТитульный.ДатаОтчетногоПериода = СтруктураРеквизитовФормы.ЗаголовокДатаОтчетногоПериода;
			
			СтруктураДанныхТитульный.ДатаОтчетногоПериодаПрошлогоГода
				= СтруктураРеквизитовФормы.ЗаголовокДатаОтчетногоПериодаПрошлогоГода;
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьСведенияОбОрганизации(ИмяФормы, РазделСРеквизитами, СтруктураРеквизитовФормы,
	ДатаПодписи, ВПрограммеИзмененаДатаПодписи = Ложь, СведенияОбОрганизации = Неопределено) Экспорт
	
	Организация = СтруктураРеквизитовФормы.Организация;
	ТипАдреса = СтруктураРеквизитовФормы.ТипАдреса;
	
	Если НЕ ЗначениеЗаполнено(Организация) Тогда
		Возврат;
	КонецЕсли;
	
	ИспользоватьАдресФИАС = (СтруктураРеквизитовФормы.мДатаКонцаПериодаОтчета >= '2019-01-01');
	
	ПереченьСведений = "ФИОРук, ФИОБух"
		+ ?(НЕ ВПрограммеИзмененаДатаПодписи, ", ИННЮЛ, НаимЮЛПол, ОКПО, ОКОПФ, ОКФС, ФормСобств, ОргПравФорм, " + ТипАдреса, "");
	
	Сведения = РегламентированнаяОтчетностьВызовСервера.ПолучитьСведенияОбОрганизации(
		Организация, ДатаПодписи, ПереченьСведений);
	
	Если СтруктураРеквизитовФормы.ИП = Истина Тогда
		Сведения.ОКПО = "";
	КонецЕсли;
	
	Если НЕ ВПрограммеИзмененаДатаПодписи Тогда
		Если ИспользоватьАдресФИАС Тогда
			АдресОрганизации = АдресОрганизацииПоУмолчанию(Организация).Представление;
		Иначе
			АдресОрганизации = Сведения[ТипАдреса];
		КонецЕсли;
		
		ЗаполнитьОбластьВРазделе(РазделСРеквизитами, "ОргИНН",         Сведения.ИННЮЛ);
		ЗаполнитьОбластьВРазделе(РазделСРеквизитами, "ОргНазв",        Сведения.НаимЮЛПол);
		ЗаполнитьОбластьВРазделе(РазделСРеквизитами, "ОргКодОКПО",     Сведения.ОКПО);
		ЗаполнитьОбластьВРазделе(РазделСРеквизитами, "ОргФорма",       Сведения.ОргПравФорм);
		ЗаполнитьОбластьВРазделе(РазделСРеквизитами, "ОргКодОКОПФ",    Сведения.ОКОПФ);
		ЗаполнитьОбластьВРазделе(РазделСРеквизитами, "ОргКодОКФС",     Сведения.ОКФС);
		ЗаполнитьОбластьВРазделе(РазделСРеквизитами, "ОргФормаСобств", Сведения.ФормСобств);
		ЗаполнитьОбластьВРазделе(РазделСРеквизитами, "ОргПочтАдрес",   АдресОрганизации);
	КонецЕсли;
	
	ЗаполнитьОбластьВРазделе(РазделСРеквизитами, "ОргДиректор",  Сведения.ФИОРук);
	ЗаполнитьОбластьВРазделе(РазделСРеквизитами, "ОргБухгалтер", Сведения.ФИОБух);
	
	ПараметрыЗаполненияОКВЭД = НовыеПараметрыЗаполненияСведенийОКВЭД();
	ПараметрыЗаполненияОКВЭД.РазделСРеквизитами            = РазделСРеквизитами;
	ПараметрыЗаполненияОКВЭД.СтруктураРеквизитовФормы      = СтруктураРеквизитовФормы;
	ПараметрыЗаполненияОКВЭД.ВПрограммеИзмененаДатаПодписи = ВПрограммеИзмененаДатаПодписи;
	ПараметрыЗаполненияОКВЭД.ДатаПодписи                   = ДатаПодписи;
	ПараметрыЗаполненияОКВЭД.СведенияОбОрганизации         = СведенияОбОрганизации;
	ЗаполнитьСведенияОбОКВЭД(ПараметрыЗаполненияОКВЭД);
	
	Если ТипЗнч(СведенияОбОрганизации) = Тип("Структура") Тогда
		СведенияОбОрганизации.Вставить("ОргДиректор", Сведения.ФИОРук);
		Если НЕ ВПрограммеИзмененаДатаПодписи Тогда
			СведенияОбОрганизации.Вставить("ОргИНН",         Сведения.ИННЮЛ);
			СведенияОбОрганизации.Вставить("ОргНазв",        Сведения.НаимЮЛПол);
			СведенияОбОрганизации.Вставить("ОргКодОКПО",     Сведения.ОКПО);
			СведенияОбОрганизации.Вставить("ОргФорма",       Сведения.ОргПравФорм);
			СведенияОбОрганизации.Вставить("ОргКодОКОПФ",    Сведения.ОКОПФ);
			СведенияОбОрганизации.Вставить("ОргКодОКФС",     Сведения.ОКФС);
			СведенияОбОрганизации.Вставить("ОргФормаСобств", Сведения.ФормСобств);
			СведенияОбОрганизации.Вставить("ОргПочтАдрес", ?(ИспользоватьАдресФИАС, АдресОрганизации,
				РегламентированнаяОтчетностьКлиентСервер.ПредставлениеАдресаВФормате9Запятых(Сведения[ТипАдреса])));
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Функция АдресОрганизацииПоУмолчанию(Организация)
	
	ПредставлениеАдреса = "";
	АдресПоПредставлению = Ложь;
	
	Если НЕ РегламентированнаяОтчетностьВызовСервера.ЭтоЮридическоеЛицо(Организация) Тогда
		ВидыАдресов = "АдрМЖ, АдрПрописки";
	Иначе
		ВидыАдресов = "АдрФакт_XML, АдрЮР_XML, АдрПочт_XML";
		АдресПоПредставлению = Истина;
	КонецЕсли;
	
	Адреса = РегламентированнаяОтчетностьВызовСервера.ПолучитьСведенияОбОрганизации(Организация, , ВидыАдресов);
	
	ИменаВидовАдресов = СтрРазделить(ВидыАдресов, ",");
	Для Каждого ИмяВидаАдреса Из ИменаВидовАдресов Цикл
		ИмяВидаАдреса = СокрЛП(ИмяВидаАдреса);
		
		ПолныйАдрес = Адреса[ИмяВидаАдреса];
		Если АдресПоПредставлению Тогда
			ПредставлениеАдреса = ПредставлениеАдресаИзXML(ПолныйАдрес);
			АдресЗаполнен = ЗначениеЗаполнено(ПредставлениеАдреса);
		Иначе
			ПредставлениеАдреса = РегламентированнаяОтчетностьКлиентСервер.ПредставлениеАдресаВФормате9Запятых(ПолныйАдрес);
			АдресЗаполнен = ЗначениеЗаполнено(СтрЗаменить(ПредставлениеАдреса, ",", ""));
		КонецЕсли;
		
		Если АдресЗаполнен Тогда
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Новый Структура("Адрес, Представление", ПолныйАдрес, ПредставлениеАдреса);
	
КонецФункции

Функция ПредставлениеАдресаИзXML(ТекстXML)
	
	ПредставлениеАдреса = "";
	
	Если ЗначениеЗаполнено(ТекстXML) Тогда
		ЧтениеXML = Новый ЧтениеXML;
		ЧтениеXML.УстановитьСтроку(ТекстXML);
		ПостроительDOM = Новый ПостроительDOM;
		
		КорневойУзел = ПостроительDOM.Прочитать(ЧтениеXML);
		
		Для Каждого Узел Из КорневойУзел.ДочерниеУзлы Цикл
			Если Узел.ИмяУзла <> "КонтактнаяИнформация" Тогда
				Продолжить;
			КонецЕсли;
			
			ПредставлениеАдреса = ПолучитьАтрибутКакСтроку("Неопределена", Узел, "Представление");
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат ПредставлениеАдреса;
	
КонецФункции

Функция НовыеПараметрыЗаполненияСведенийОКВЭД()
	
	ПараметрыЗаполненияОКВЭД = Новый Структура;
	ПараметрыЗаполненияОКВЭД.Вставить("РазделСРеквизитами");
	ПараметрыЗаполненияОКВЭД.Вставить("СтруктураРеквизитовФормы");
	ПараметрыЗаполненияОКВЭД.Вставить("ВПрограммеИзмененаДатаПодписи");
	ПараметрыЗаполненияОКВЭД.Вставить("ДатаПодписи");
	ПараметрыЗаполненияОКВЭД.Вставить("СведенияОбОрганизации");
	
	Возврат ПараметрыЗаполненияОКВЭД;
	
КонецФункции

Процедура ЗаполнитьСведенияОбОКВЭД(ПараметрыЗаполнения)
	
	РазделСРеквизитами            = ПараметрыЗаполнения.РазделСРеквизитами;
	СтруктураРеквизитовФормы      = ПараметрыЗаполнения.СтруктураРеквизитовФормы;
	ВПрограммеИзмененаДатаПодписи = ПараметрыЗаполнения.ВПрограммеИзмененаДатаПодписи;
	ДатаПодписи                   = ПараметрыЗаполнения.ДатаПодписи;
	СведенияОбОрганизации         = ПараметрыЗаполнения.СведенияОбОрганизации;
	
	КодОКВЭД = "";
	НаименованиеОКВЭД = "";
	РезультатПоискаКодаОКВЭД = Неопределено;
	
	Если ТипЗнч(РазделСРеквизитами) = Тип("ТабличныйДокумент") Тогда
		РезультатПоискаКодаОКВЭД = РазделСРеквизитами.Области.Найти("ОргКодОКВЭД");
		Если НЕ РезультатПоискаКодаОКВЭД = Неопределено Тогда
			КодОКВЭД = РазделСРеквизитами.Области.ОргКодОКВЭД.Значение;
		КонецЕсли;
		
		РезультатПоискаНаименованияОКВЭД = РазделСРеквизитами.Области.Найти("ОргОтрасль");
		Если НЕ РезультатПоискаНаименованияОКВЭД = Неопределено Тогда
			НаименованиеОКВЭД = РазделСРеквизитами.Области.ОргОтрасль.Значение;
		КонецЕсли;
		
	ИначеЕсли ТипЗнч(РазделСРеквизитами) = Тип("Структура") Тогда
		
		Если РазделСРеквизитами.Свойство("ОргКодОКВЭД", РезультатПоискаКодаОКВЭД) Тогда
			КодОКВЭД = РазделСРеквизитами.ОргКодОКВЭД;
		КонецЕсли;
		
		Если РазделСРеквизитами.Свойство("ОргОтрасль", РезультатПоискаНаименованияОКВЭД) Тогда
			НаименованиеОКВЭД = РазделСРеквизитами.ОргОтрасль;
		КонецЕсли;
		
	КонецЕсли;
	
	Если НЕ РезультатПоискаКодаОКВЭД = Неопределено
	     И (СтруктураРеквизитовФормы.мВПрограммеИзмененаОрганизация
	     ИЛИ ВПрограммеИзмененаДатаПодписи
	     ИЛИ НЕ ЗначениеЗаполнено(КодОКВЭД)) Тогда
		РегламентированнаяОтчетность.ПолучитьЗначениеОКВЭД(ДатаПодписи, СтруктураРеквизитовФормы);
		РегламентированнаяОтчетностьКлиентСервер.УстановитьЗначениеОКВЭД(ДатаПодписи,
			СтруктураРеквизитовФормы,
			?(ТипЗнч(РазделСРеквизитами) = Тип("ТабличныйДокумент"),
				РазделСРеквизитами.Области.ОргКодОКВЭД.Значение,
				РазделСРеквизитами.ОргКодОКВЭД));
	КонецЕсли;
	
	Если НЕ РезультатПоискаНаименованияОКВЭД = Неопределено
	     И (СтруктураРеквизитовФормы.мВПрограммеИзмененаОрганизация
	     ИЛИ ВПрограммеИзмененаДатаПодписи
	     ИЛИ НЕ ЗначениеЗаполнено(НаименованиеОКВЭД)) Тогда
		РегламентированнаяОтчетность.ПолучитьЗначениеВидаЭкономическойДеятельности(ДатаПодписи, СтруктураРеквизитовФормы);
		РегламентированнаяОтчетностьКлиентСервер.УстановитьЗначениеВидаЭкономическойДеятельности(ДатаПодписи,
			СтруктураРеквизитовФормы,
			?(ТипЗнч(РазделСРеквизитами) = Тип("ТабличныйДокумент"),
				РазделСРеквизитами.Области.ОргОтрасль.Значение,
				РазделСРеквизитами.ОргОтрасль));
		
	КонецЕсли;
	
	Если ТипЗнч(СведенияОбОрганизации) = Тип("Структура") Тогда
		Если ТипЗнч(РазделСРеквизитами) = Тип("ТабличныйДокумент") Тогда
			СведенияОбОрганизации.Вставить("ОргКодОКВЭД", РазделСРеквизитами.Области.ОргКодОКВЭД.Значение);
			СведенияОбОрганизации.Вставить("ОргОтрасль", РазделСРеквизитами.Области.ОргОтрасль.Значение);
		ИначеЕсли ТипЗнч(РазделСРеквизитами) = Тип("Структура") Тогда
			СведенияОбОрганизации.Вставить("ОргКодОКВЭД", РазделСРеквизитами.ОргКодОКВЭД);
			СведенияОбОрганизации.Вставить("ОргОтрасль", РазделСРеквизитами.ОргОтрасль);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьОбластьВРазделе(РазделСРеквизитами, ИмяОбласти, ЗначениеЗаполнения)
	
	Если ТипЗнч(РазделСРеквизитами) = Тип("ТабличныйДокумент") Тогда
		Если РазделСРеквизитами.Области.Найти(ИмяОбласти) <> Неопределено Тогда
			РазделСРеквизитами.Области[ИмяОбласти].Значение = ЗначениеЗаполнения;
		КонецЕсли;
		
	ИначеЕсли ТипЗнч(РазделСРеквизитами) = Тип("Структура") Тогда
		Если РазделСРеквизитами.Свойство(ИмяОбласти) Тогда
			РазделСРеквизитами[ИмяОбласти] = ЗначениеЗаполнения;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Функция СтруктураСтраницОтчета(ИмяФормыОтчета, СтруктураРеквизитовФормы, ДатаПодписи) Экспорт
	
	ДеревоСтраницОтчета = Новый ДеревоЗначений;
	
	ДеревоСтраницОтчета.Колонки.Добавить("Представление",
		Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(100)));
	ДеревоСтраницОтчета.Колонки.Добавить("ИмяСтраницы",
		Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(100)));
	ДеревоСтраницОтчета.Колонки.Добавить("АвторасчетПоказателей",
		Новый ОписаниеТипов("Булево"));
	ДеревоСтраницОтчета.Колонки.Добавить("ИмяОбластиТабличногоПоля",
		Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(100)));
	ДеревоСтраницОтчета.Колонки.Добавить("ОриентацияСтраницы");
	ДеревоСтраницОтчета.Колонки.Добавить("ВыводНаПечать",
		Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(1, 0)));
	ДеревоСтраницОтчета.Колонки.Добавить("ПоказатьСтраницу",
		Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(1, 0)));
	ДеревоСтраницОтчета.Колонки.Добавить("ВыгрузитьСтраницу",
		Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(1, 0)));
	
	ПараметрыСостава = Новый Структура;
	ПараметрыСостава.Вставить("ИмяФормыОтчета", ИмяФормыОтчета);
	ПараметрыСостава.Вставить("ЭтоБалансНекоммерческойОрганизации",
		СтруктураРеквизитовФормы.ЭтоБалансНекоммерческойОрганизации);
	ПараметрыСостава.Вставить("ДатаПодписи", ДатаПодписи);
	
	Если ИмяФормыОтчета = "ФормаОтчета2012Кв4_2" ИЛИ ИмяФормыОтчета = "ФормаОтчета2015Кв4" Тогда
		ЗаполнитьСоставОтчетности2012Кв4_2_2015Кв4(ДеревоСтраницОтчета, ПараметрыСостава);
	Иначе
		ВызватьИсключение НСтр("ru = 'Недопустимое имя формы при вызове процедуры СтруктураСтраницОтчета()'");
	КонецЕсли;
	
	ПараметрыОтчета = Новый Структура;
	ПараметрыОтчета.Вставить("ЭтоБалансНекоммерческойОрганизации",
		СтруктураРеквизитовФормы.ЭтоБалансНекоммерческойОрганизации);
	
	РегламентированнаяОтчетность.ИзменитьСоставОтчета(
		"РегламентированныйОтчетБухОтчетностьМП", ИмяФормыОтчета, ПараметрыОтчета, ДеревоСтраницОтчета);
	
	Возврат ДеревоСтраницОтчета;
	
КонецФункции

Процедура ЗаполнитьСоставОтчетности2012Кв4_2_2015Кв4(ДеревоСтраницОтчета, Параметры)
	
