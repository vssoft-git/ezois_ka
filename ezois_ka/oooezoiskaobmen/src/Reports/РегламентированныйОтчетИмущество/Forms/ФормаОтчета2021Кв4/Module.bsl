		КонецЦикла;
	КонецЕсли;
	
	Если ВыборкаР2.Следующий() Тогда
		СуммаР21 = ВыборкаР2.П000210005003;
		Выборка = ВыборкаР2.Выбрать();
		КоличествоР21 = Выборка.Количество();
