				//
				Строка250
				= РегламентированнаяОтчетностьКлиентСервер.ОкруглитьЧислоПоФормату(Форма, ВеткаР2.Данные["П000020025003"]);
				
				Строка260 = ?(Строка250 >= Разность220_240, 0, Разность220_240 - Строка250);
				
