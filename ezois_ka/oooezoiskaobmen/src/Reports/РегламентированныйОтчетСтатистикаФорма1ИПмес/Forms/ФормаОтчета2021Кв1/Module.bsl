&НаСервере
Процедура СформироватьСпискиВыбора()
	
	МакетСоставаПоказателей = ОбъектОтчета(ИмяФормы).ПолучитьМакет(СтруктураРеквизитовФормы["ИмяМакетаСписков"]);
	
	КоллекцияСписковВыбора = Новый Соответствие;
	Для Каждого Область Из МакетСоставаПоказателей.Области Цикл
		Если Область.ТипОбласти = ТипОбластиЯчеекТабличногоДокумента.Строки Тогда
			ВерхОбласти = Область.Верх;
			НизОбласти = Область.Низ;
			ТаблСписка = Новый ТаблицаЗначений;
			ТаблСписка.Колонки.Добавить(
				"Код"     , , , МакетСоставаПоказателей.Область(ВерхОбласти, 1, ВерхОбласти, 1).ШиринаКолонки);
			ТаблСписка.Колонки.Добавить(
				"Название", , , МакетСоставаПоказателей.Область(ВерхОбласти, 2, ВерхОбласти, 2).ШиринаКолонки);
			ТаблСписка.Колонки.Добавить(
				"Ключ"    , , , МакетСоставаПоказателей.Область(ВерхОбласти, 3, ВерхОбласти, 3).ШиринаКолонки);
			ТаблСписка.Колонки.Добавить("ПризнакОтбора" , , , );
			Для НомСтр = ВерхОбласти По НизОбласти Цикл
				КодПоказателя = СокрП(МакетСоставаПоказателей.Область(НомСтр, 1).Текст);
				Если КодПоказателя <> "###" Тогда
					НовСтрока = ТаблСписка.Добавить();
					НовСтрока.Код = КодПоказателя;
					НовСтрока.Название = СокрП(МакетСоставаПоказателей.Область(НомСтр, 2).Текст);
					НовСтрока.Ключ = СокрП(МакетСоставаПоказателей.Область(НомСтр, 3).Текст);
					НовСтрока.ПризнакОтбора = Ложь;
				КонецЕсли;
			КонецЦикла;
			КоллекцияСписковВыбора.Вставить(Область.Имя, ТаблСписка);
		КонецЕсли;
	КонецЦикла;
	
	СвойстваПоказателей.Очистить();

	РегламентированнаяОтчетность.ДобавитьСтрокуОписанияВвода(СвойстваПоказателей, "П002000100102",
		250, , "Выбор единицы измерения", КоллекцияСписковВыбора["СправочникЕдиницИзмерения"]);
	РегламентированнаяОтчетность.ДобавитьСтрокуОписанияВвода(СвойстваПоказателей, "П002000100103",
		250, , "Выбор единицы измерения", КоллекцияСписковВыбора["СправочникЕдиницИзмерения"]);
	РегламентированнаяОтчетность.ДобавитьСтрокуОписанияВвода(СвойстваПоказателей, "П002000100100",
		250, ,                          , КоллекцияСписковВыбора["СправочникПриложениеДляВводаОКПД"]);
	РегламентированнаяОтчетность.ДобавитьСтрокуОписанияВвода(СвойстваПоказателей, "П002000100101",
		250, , "Выбор продукции"        , КоллекцияСписковВыбора["СправочникОКПД"]);
	РегламентированнаяОтчетность.ДобавитьСтрокуОписанияВвода(СвойстваПоказателей, "П002000100104",
		250, , "Выбор продукции"        , КоллекцияСписковВыбора["СправочникОКПД"]);

КонецПроцедуры

&НаКлиенте
Процедура ВвестиПоказатель(Элемент, Область, КодПоказателя, Знач ЭтоСумма, Знач ТекстВыбора, ТаблицаВыбора, СтандартнаяОбработка, КолонкаПоиска = "Код") Экспорт
	
	Если ТаблицаВыбора = Неопределено ИЛИ СтруктураРеквизитовФормы.мАвтоВыборКодов Тогда
		Возврат;
	КонецЕсли;
	
	СтандартнаяОбработка = Ложь;
	
	Если Область.Имя = КодПоказателя Тогда
		ИсходноеЗначение = ?(ТипЗнч(Область.Значение) = Тип("Строка"), СокрЛП(Область.Значение), Область.Значение);
		
	ИначеЕсли (СтрНайти(Область.Имя, СтруктураРеквизитовФормы.мИдГруппы1) > 0) Тогда
		ИсходноеЗначение = ?(ТипЗнч(Область.Значение) = Тип("Строка"), СокрЛП(Область.Значение), Область.Значение);
		НомерСтроки = Сред(Область.Имя, 15, СтрДлина(Область.Имя)); 
		
	Иначе
		Разделитель = ?(Лев(Область.Имя, СтрДлина(КодПоказателя) + 1) = КодПоказателя + "_", "_", "");
		ИндексОбласти = 1;
		ИсходноеЗначение = "";
		Пока ЭтотОбъект[ТекущийЭлемент.Имя].Области.Найти(КодПоказателя + Разделитель + Формат(ИндексОбласти, "ЧГ=")) <> Неопределено Цикл
			ИсходноеЗначение = ИсходноеЗначение
				+ Строка(ЭтотОбъект[ТекущийЭлемент.Имя].Области[КодПоказателя + Разделитель + Формат(ИндексОбласти, "ЧГ=")].Значение);
			ИндексОбласти = ИндексОбласти + 1;
		КонецЦикла;
		ИсходноеЗначение = СокрЛП(ИсходноеЗначение);
	КонецЕсли;
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Заголовок",          ТекстВыбора);
	ПараметрыФормы.Вставить("ТаблицаЗначений",    ТаблицаВыбора);
	
	Если Сред(Область.Имя, 12, 2) = "01" Или Сред(Область.Имя, 12, 2) = "04" Тогда
		ПараметрыФормы.Вставить("СтруктураДляПоиска", Новый Структура(КолонкаПоиска, ТабличныйДокумент.Области[СтруктураРеквизитовФормы.мИдГруппы1 + "04_" + НомерСтроки].Значение));
	ИначеЕсли Сред(Область.Имя, 12, 2) = "02" Или Сред(Область.Имя, 12, 2) = "03" Тогда
		ПараметрыФормы.Вставить("СтруктураДляПоиска", Новый Структура(КолонкаПоиска, Формат(ТабличныйДокумент.Области[СтруктураРеквизитовФормы.мИдГруппы1 + "03_" + НомерСтроки].Значение, "ЧГ=")));
	Иначе
		ПараметрыФормы.Вставить("СтруктураДляПоиска", Новый Структура(КолонкаПоиска, ИсходноеЗначение));
	КонецЕсли;
	
	ДополнительныеПараметры = Новый Структура("НомерСтроки, Область", НомерСтроки, Область);
	ОписаниеОповещения = Новый ОписаниеОповещения("ВвестиПоказательЗавершение", ЭтотОбъект, ДополнительныеПараметры);
	
	ОткрытьФорму("Обработка.ОбщиеОбъектыРеглОтчетности.Форма.ФормаВыбораЗначенияИзТаблицы",
		ПараметрыФормы, ЭтотОбъект, , , , ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура ВвестиПоказательЗавершение(РезультатВыбора, ДополнительныеПараметры) Экспорт
    
    НомерСтроки = ДополнительныеПараметры.НомерСтроки;
    Область = ДополнительныеПараметры.Область;
    
	Если РезультатВыбора = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если СтрНайти(Область.Имя, СтруктураРеквизитовФормы.мИдГруппы1) > 0 Тогда
		
		Если Сред(Область.Имя, 12, 2) = "01" Или Сред(Область.Имя, 12, 2) = "04" Тогда
			
			ВыборКод = Строка(РезультатВыбора["Код"]);
			ВыборНазвание = Строка(РезультатВыбора["Название"]);
			ПредыдущееЗначениеВКолонке01 =
				ТабличныйДокумент.Области[СтруктураРеквизитовФормы.мИдГруппы1 + "01_" + НомерСтроки].Значение;
			ТабличныйДокумент.Области[СтруктураРеквизитовФормы.мИдГруппы1 + "01_"+НомерСтроки].Значение =
				?(ЗначениеЗаполнено(ВыборКод), ВыборНазвание, "");
			ТабличныйДокумент.Области[СтруктураРеквизитовФормы.мИдГруппы1 + "04_"+НомерСтроки].Значение = ВыборКод;
			
			// Приводим в соответствие зависимые ячейки - наим. единицы измерения и ее код.
			Если ЗначениеЗаполнено(ВыборКод) Тогда
				Если ПредыдущееЗначениеВКолонке01 <> ТабличныйДокумент.Области[СтруктураРеквизитовФормы.мИдГруппы1 + "01_" + НомерСтроки].Значение Тогда
					ТабличныйДокумент.Области[СтруктураРеквизитовФормы.мИдГруппы1 + "02_" + НомерСтроки].Значение = "";
					ТабличныйДокумент.Области[СтруктураРеквизитовФормы.мИдГруппы1 + "03_" + НомерСтроки].Значение = "";
				КонецЕсли;
			Иначе
				ТабличныйДокумент.Области[СтруктураРеквизитовФормы.мИдГруппы1 + "02_" + НомерСтроки].Значение = "";
				ТабличныйДокумент.Области[СтруктураРеквизитовФормы.мИдГруппы1 + "03_" + НомерСтроки].Значение = "";
			КонецЕсли;
			
		ИначеЕсли Сред(Область.Имя, 12, 2) = "02" Или Сред(Область.Имя, 12, 2) = "03" Тогда
			
			ТабличныйДокумент.Области[СтруктураРеквизитовФормы.мИдГруппы1 + "02_" + НомерСтроки].Значение =
				?(ЗначениеЗаполнено(РезультатВыбора["Код"]), РезультатВыбора["Название"], "");
			ТабличныйДокумент.Области[СтруктураРеквизитовФормы.мИдГруппы1 + "03_" + НомерСтроки].Значение =
				РезультатВыбора["Код"];
			
		КонецЕсли;
		
	КонецЕсли;
	
	Модифицированность = Истина;
	
КонецПроцедуры

