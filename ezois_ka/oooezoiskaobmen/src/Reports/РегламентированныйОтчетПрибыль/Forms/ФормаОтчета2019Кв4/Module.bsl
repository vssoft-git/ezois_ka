				Данные.Вставить("П000П20003303",
				Макс(0, ОкрЧФ(Форма, Данные["П000П20003103"]) - ОкрЧФ(Форма, Данные["П000П20003003"])));
				
				Данные.Вставить("П000П20003403",
				Макс(0, ОкрЧФ(Форма, Данные["П000П20003003"]) - ОкрЧФ(Форма, Данные["П000П20003103"])));
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Если ДеревоДанных <> Неопределено Тогда
		РегламентированнаяОтчетностьВызовСервера.ПоместитьВКэш(ДеревоДанных, Форма.УникальныйИдентификатор,
		Форма.СтруктураРеквизитовФормы["АдресВоВрХранилищеДеревоДанных" + ИмяКорневогоРаздела]);
	КонецЕсли;
	
КонецПроцедуры

