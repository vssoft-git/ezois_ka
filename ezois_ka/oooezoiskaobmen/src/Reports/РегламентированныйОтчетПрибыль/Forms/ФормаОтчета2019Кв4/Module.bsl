					НеЗаполнятьПоказатели_Зависимость_ВеличинаПрибыли_Б3 = (ВеличинаПрибыли <= 10000000);
					
					// Раздел Б3 (строки 090-130).
					//
					Если НеЗаполнятьПоказатели_Зависимость_ВеличинаПрибыли_Б3 Тогда
						
