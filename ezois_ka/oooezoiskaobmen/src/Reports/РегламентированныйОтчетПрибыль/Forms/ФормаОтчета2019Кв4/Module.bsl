	КонецЕсли;
	
	Если ИмяПоказателя = "П000П20000004" Тогда
		ИНН = СтрЗаменить(ЗначПоказателя, " ", "");
		ДлинаИНН = СтрДлина(ИНН);
		Если ДлинаИНН = 12 ИЛИ ДлинаИНН = 0 Тогда
