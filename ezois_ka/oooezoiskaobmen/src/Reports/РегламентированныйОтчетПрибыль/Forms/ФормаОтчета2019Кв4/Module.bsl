			СтрокаМнЧ.Данные.Вставить("П00011М108003", Макс(0, - СуммаНалогаВБюджСубРФ));
			
		ИначеЕсли ЭтоКонсолидированнаяГруппа Тогда
			
			ЭтоПерваяСтрокаМнЧ = Истина;
			
