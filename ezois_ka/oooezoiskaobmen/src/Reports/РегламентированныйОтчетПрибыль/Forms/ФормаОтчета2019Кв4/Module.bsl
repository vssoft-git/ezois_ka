						ИначеЕсли СокрЛП(Обл.Значение) = "2" Тогда
							
							РазделБ3Стр050 = ОкрЧФ(Форма, ТДО["П009Б30005003"].Значение);
							РазделБ3Стр080 = ОкрЧФ(Форма, ТДО["П009Б30008003"].Значение);
							Стр130 = Макс(РазделБ3Стр080, 0);
							
