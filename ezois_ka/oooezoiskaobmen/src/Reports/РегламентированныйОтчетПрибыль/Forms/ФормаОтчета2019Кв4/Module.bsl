				Настройки.ЭтоОшибка = ДанныеКС.ЭтоГоловнаяСОП И Лист02_5.РазделЗаполнен_Лист02_5 
					И РасчетнаяСумма1 < Показатели.П25С002.Значение И НЕ Показатели.П25С001.Значение = РасчетнаяСумма2;
