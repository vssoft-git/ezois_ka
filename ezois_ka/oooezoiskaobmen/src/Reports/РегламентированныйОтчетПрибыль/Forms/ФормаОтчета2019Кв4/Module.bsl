		// Вывод листов.
		Для НомЛиста = 1 По КолЛистовРаздела1 Цикл
			
			ТабличныйДокумент.Очистить();
			ТабличныйДокумент.Вывести(МакетРаздела);
			
			Для Ном = 1 По СтрокМнЧ1НаЛисте - 1 Цикл
				ИмяОбластиПреемника = "ДобавлениеСтроки"
				+ СтруктураРеквизитовФормы.мИдГруппыП1М1 + СтрокаСИндексомПоказателя(Ном);
				ВставитьДопСтроку(СтруктураРеквизитовФормы.мИдГруппыП1М1, ИмяОбластиПреемника);
			КонецЦикла;
			
			ДанныеМнЧ1ДляПечати = МассивДанныхМнЧ1ДляПечати[НомЛиста - 1];
			Для каждого Пок Из ДанныеМнЧ1ДляПечати Цикл
				Обл = ТабличныйДокумент.Области.Найти(Пок.Ключ);
				Если Обл <> Неопределено Тогда
					Обл.Значение = Пок.Значение;
				КонецЕсли;
			КонецЦикла;
			
			СтруктураПараметровРаздела = ОбщегоНазначения.СкопироватьРекурсивно(СтруктураПараметров);
			СтруктураПараметровРаздела.Вставить("ИмяСтраницы", ИмяТекРаздела);
			ВывестиНаПечатьЛист(СтруктураПараметровРаздела, ОбщиеРеквизитыРазделов, СтрПоля);
			
		КонецЦикла;
		
	ИначеЕсли ИмяТекРаздела = "Приложение2" Тогда
		
		МакетРаздела = ОбъектОтчета(ЭтаФорма.ИмяФормы).ПолучитьМакет(Сред(
		ЭтаФорма.ИмяФормы, СтрНайти(ЭтаФорма.ИмяФормы, "ФормаОтчета")) + "_" + ИмяТекРаздела);
		
		ИмяГруппыМнЧ1 = СтруктураРеквизитовФормы.мИдГруппыП2М1;
		ИмяГруппыМнЧ2 = СтруктураРеквизитовФормы.мИдГруппыП2М2;
		
		ИмяГруппыМнЧ3 = СтруктураРеквизитовФормы.мИдГруппыП2М3;
		
		Для каждого Ветка Из ДеревоДанныхРаздела.Строки Цикл
			
			Если НЕ СтраницаВключенаВСоставОтчета(Ветка) Тогда
				Продолжить;
			КонецЕсли;
			
			// Лист 1.
			//
			ТабличныйДокумент.Очистить();
			ТабличныйДокумент.Вывести(МакетРаздела);
			
			НемногострочныеДанные = Ветка.Данные;
			Для каждого Пок Из НемногострочныеДанные Цикл
				Обл = ТабличныйДокумент.Области.Найти(Пок.Ключ);
				Если Обл <> Неопределено Тогда
					Обл.Значение = Пок.Значение;
				КонецЕсли;
			КонецЦикла;
			
			УстановитьФорматВыводаНаСервере(ИмяТекРаздела);
			
			СтруктураПараметровРаздела = ОбщегоНазначения.СкопироватьРекурсивно(СтруктураПараметров);
			СтруктураПараметровРаздела.Вставить("ИмяСтраницы", ИмяТекРаздела);
			ВывестиНаПечатьЛист(СтруктураПараметровРаздела, ОбщиеРеквизитыРазделов, СтрПоля);
			
			// Лист(-ы) 2.
			//
			СтрокМнЧ1НаЛисте = 3;
			СтрокМнЧ2ВБлокеМнЧ1 = 5;
			СтрокМнЧ3НаЛисте = 2;
			
			МассивДанныхМнЧ1_МнЧ2 = Новый Массив;
			
			КолБлоковМнЧ1 = 0;
			ДанныеМнЧ1 = Ветка.ДанныеМногострочныхЧастей[ИмяГруппыМнЧ1];
			Для каждого СтрокаМнЧ1 Из ДанныеМнЧ1.Строки Цикл
				
				ДанныеМнЧ2 = СтрокаМнЧ1.ДанныеМногострочныхЧастей[ИмяГруппыМнЧ2];
				КолСтрокМнЧ2 = ДанныеМнЧ2.Строки.Количество();
				ДробКол = КолСтрокМнЧ2 / СтрокМнЧ2ВБлокеМнЧ1;
				ЦелКол  = Цел(КолСтрокМнЧ2 / СтрокМнЧ2ВБлокеМнЧ1);
				ТекКолБлоковМнЧ1 = ?(ДробКол = ЦелКол, ЦелКол, ЦелКол + 1);
				КолБлоковМнЧ1 = КолБлоковМнЧ1 + ТекКолБлоковМнЧ1;
				
				// Адаптирование многострочных данных (строки 040 - 043) для заполнения листов.
				Для НомБлокаМнЧ1 = 1 По ТекКолБлоковМнЧ1 Цикл
					
					ДанныеМнЧ1_МнЧ2 = Новый Структура;
					
					ДанныеМнЧ1_МнЧ2.Вставить("П000П2М104000", "");
					ДанныеМнЧ1_МнЧ2.Вставить("П000П2М104100", 0);
					Если НомБлокаМнЧ1 = 1 Тогда
						ДанныеМнЧ1_МнЧ2.Вставить("П000П2М104000", СтрокаМнЧ1.Данные["П000П2М104000"]);
						ДанныеМнЧ1_МнЧ2.Вставить("П000П2М104100", СтрокаМнЧ1.Данные["П000П2М104100"]);
					КонецЕсли;
					
					Мас_ДанныеМнЧ2 = Новый Массив;
					
					ИндСтрокиМнЧ2 = НомБлокаМнЧ1 * СтрокМнЧ2ВБлокеМнЧ1 - СтрокМнЧ2ВБлокеМнЧ1;
					Если КолСтрокМнЧ2 >= ИндСтрокиМнЧ2 + 1 Тогда
						СтрокаМнЧ2 = ДанныеМнЧ2.Строки[ИндСтрокиМнЧ2];
						Мас_ДанныеМнЧ2.Добавить(Новый Структура("П000П2М204200,П000П2М204300",
						СтрокаМнЧ2.Данные["П000П2М204200"], СтрокаМнЧ2.Данные["П000П2М204300"]));
					Иначе
						Мас_ДанныеМнЧ2.Добавить(Новый Структура("П000П2М204200,П000П2М204300", "", 0));
					КонецЕсли;
					ИндСтрокиМнЧ2 = ИндСтрокиМнЧ2 + 1;
					Если КолСтрокМнЧ2 >= ИндСтрокиМнЧ2 + 1 Тогда
						СтрокаМнЧ2 = ДанныеМнЧ2.Строки[ИндСтрокиМнЧ2];
						Мас_ДанныеМнЧ2.Добавить(Новый Структура("П000П2М204200,П000П2М204300",
						СтрокаМнЧ2.Данные["П000П2М204200"], СтрокаМнЧ2.Данные["П000П2М204300"]));
					Иначе
						Мас_ДанныеМнЧ2.Добавить(Новый Структура("П000П2М204200,П000П2М204300", "", 0));
					КонецЕсли;
					ИндСтрокиМнЧ2 = ИндСтрокиМнЧ2 + 1;
					Если КолСтрокМнЧ2 >= ИндСтрокиМнЧ2 + 1 Тогда
						СтрокаМнЧ2 = ДанныеМнЧ2.Строки[ИндСтрокиМнЧ2];
						Мас_ДанныеМнЧ2.Добавить(Новый Структура("П000П2М204200,П000П2М204300",
						СтрокаМнЧ2.Данные["П000П2М204200"], СтрокаМнЧ2.Данные["П000П2М204300"]));
					Иначе
						Мас_ДанныеМнЧ2.Добавить(Новый Структура("П000П2М204200,П000П2М204300", "", 0));
					КонецЕсли;
					ИндСтрокиМнЧ2 = ИндСтрокиМнЧ2 + 1;
					Если КолСтрокМнЧ2 >= ИндСтрокиМнЧ2 + 1 Тогда
						СтрокаМнЧ2 = ДанныеМнЧ2.Строки[ИндСтрокиМнЧ2];
						Мас_ДанныеМнЧ2.Добавить(Новый Структура("П000П2М204200,П000П2М204300",
						СтрокаМнЧ2.Данные["П000П2М204200"], СтрокаМнЧ2.Данные["П000П2М204300"]));
					Иначе
						Мас_ДанныеМнЧ2.Добавить(Новый Структура("П000П2М204200,П000П2М204300", "", 0));
					КонецЕсли;
					ИндСтрокиМнЧ2 = ИндСтрокиМнЧ2 + 1;
					Если КолСтрокМнЧ2 >= ИндСтрокиМнЧ2 + 1 Тогда
						СтрокаМнЧ2 = ДанныеМнЧ2.Строки[ИндСтрокиМнЧ2];
						Мас_ДанныеМнЧ2.Добавить(Новый Структура("П000П2М204200,П000П2М204300",
						СтрокаМнЧ2.Данные["П000П2М204200"], СтрокаМнЧ2.Данные["П000П2М204300"]));
					Иначе
						Мас_ДанныеМнЧ2.Добавить(Новый Структура("П000П2М204200,П000П2М204300", "", 0));
					КонецЕсли;
					
					ДанныеМнЧ1_МнЧ2.Вставить("Мас_ДанныеМнЧ2", Мас_ДанныеМнЧ2);
					
					МассивДанныхМнЧ1_МнЧ2.Добавить(ДанныеМнЧ1_МнЧ2);
					
				КонецЦикла;
				
			КонецЦикла;
			ДробКол = КолБлоковМнЧ1 / СтрокМнЧ1НаЛисте;
			ЦелКол  = Цел(КолБлоковМнЧ1 / СтрокМнЧ1НаЛисте);
			КолЛистовРаздела_ПоДаннымМнЧ1_МнЧ2 = ?(ДробКол = ЦелКол, ЦелКол, ЦелКол + 1);
			
			ДанныеМнЧ3 = Ветка.ДанныеМногострочныхЧастей[ИмяГруппыМнЧ3];
			КолСтрокМнЧ3 = ДанныеМнЧ3.Строки.Количество();
			ДробКол = КолСтрокМнЧ3 / СтрокМнЧ3НаЛисте;
			ЦелКол  = Цел(КолСтрокМнЧ3 / СтрокМнЧ3НаЛисте);
			КолЛистовРаздела_ПоДаннымМнЧ3 = ?(ДробКол = ЦелКол, ЦелКол, ЦелКол + 1);
			
			КолЛистовРаздела = Макс(КолЛистовРаздела_ПоДаннымМнЧ1_МнЧ2, КолЛистовРаздела_ПоДаннымМнЧ3, 1);
			
			// Подготовка многострочных данных для заполнения листов.
			МассивДанныхМнЧДляПечати = Новый Массив;
			
			// Строки 040 - 043.
			ИмяП000П2М104000 = "П000П2М104000";
			ИмяП000П2М104100 = "П000П2М104100";
			
			ИмяП000П2М204200 = "П000П2М204200";
			ИмяП000П2М204300 = "П000П2М204300";
			
			// Строки 051, 052.
			ИмяП000П2М305100 = "П000П2М305100";
			ИмяП000П2М305200 = "П000П2М305200";
			
			Для НомЛиста = 1 По КолЛистовРаздела Цикл
				
				ДанныеМнЧДляПечати = Новый Структура;
				
				// Строки 040 - 043.
				ПриращениеКНомеру = (НомЛиста - 1) * СтрокМнЧ1НаЛисте;
				Для ИндСтрокиМнЧ = 1 По СтрокМнЧ1НаЛисте Цикл
					_ИндСтрокиМнЧ = СтрокаСИндексомПоказателя(ИндСтрокиМнЧ);
					ИндСПриращением = ИндСтрокиМнЧ + ПриращениеКНомеру;
					
					НовИмяП000П2М104000 = ИмяП000П2М104000 + _ИндСтрокиМнЧ;
					НовИмяП000П2М104100 = ИмяП000П2М104100 + _ИндСтрокиМнЧ;
					
					ДанныеМнЧДляПечати.Вставить(НовИмяП000П2М104000, "");
					ДанныеМнЧДляПечати.Вставить(НовИмяП000П2М104100, 0);
					
					Для НомСтрМнЧ2ВБлокеМнЧ1 = 1 По СтрокМнЧ2ВБлокеМнЧ1 Цикл
						
						_ИндСтрМнЧ2ВБлокеМнЧ1 = СтрокаСИндексомПоказателя(НомСтрМнЧ2ВБлокеМнЧ1);
						
						НовИмяП000П2М204200 = ИмяП000П2М204200 + _ИндСтрокиМнЧ + _ИндСтрМнЧ2ВБлокеМнЧ1;
						НовИмяП000П2М204300 = ИмяП000П2М204300 + _ИндСтрокиМнЧ + _ИндСтрМнЧ2ВБлокеМнЧ1;
						
						ДанныеМнЧДляПечати.Вставить(НовИмяП000П2М204200, "");
						ДанныеМнЧДляПечати.Вставить(НовИмяП000П2М204300, 0);
						
					КонецЦикла;
					
					Если МассивДанныхМнЧ1_МнЧ2.Количество() >= ИндСПриращением Тогда
						
						ДанныеМнЧ1_МнЧ2 = МассивДанныхМнЧ1_МнЧ2[ИндСПриращением - 1];
						
						ДанныеМнЧДляПечати.Вставить(НовИмяП000П2М104000, ДанныеМнЧ1_МнЧ2[ИмяП000П2М104000]);
						ДанныеМнЧДляПечати.Вставить(НовИмяП000П2М104100, ДанныеМнЧ1_МнЧ2[ИмяП000П2М104100]);
						
						Мас_ДанныеМнЧ2 = ДанныеМнЧ1_МнЧ2["Мас_ДанныеМнЧ2"];
						
						Для НомСтрМнЧ2ВБлокеМнЧ1 = 1 По СтрокМнЧ2ВБлокеМнЧ1 Цикл
							
							_ИндСтрМнЧ2ВБлокеМнЧ1 = СтрокаСИндексомПоказателя(НомСтрМнЧ2ВБлокеМнЧ1);
							
							НовИмяП000П2М204200 = ИмяП000П2М204200 + _ИндСтрокиМнЧ + _ИндСтрМнЧ2ВБлокеМнЧ1;
							НовИмяП000П2М204300 = ИмяП000П2М204300 + _ИндСтрокиМнЧ + _ИндСтрМнЧ2ВБлокеМнЧ1;
							
							ДанныеМнЧДляПечати.Вставить(НовИмяП000П2М204200, Мас_ДанныеМнЧ2[НомСтрМнЧ2ВБлокеМнЧ1 - 1][ИмяП000П2М204200]);
							ДанныеМнЧДляПечати.Вставить(НовИмяП000П2М204300, Мас_ДанныеМнЧ2[НомСтрМнЧ2ВБлокеМнЧ1 - 1][ИмяП000П2М204300]);
							
						КонецЦикла;
						
					КонецЕсли;
				КонецЦикла;
				
				// Строки 051, 052.
				ПриращениеКНомеру = (НомЛиста - 1) * СтрокМнЧ3НаЛисте;
				Для ИндСтрокиМнЧ = 1 По СтрокМнЧ3НаЛисте Цикл
					_ИндСтрокиМнЧ = СтрокаСИндексомПоказателя(ИндСтрокиМнЧ);
					ИндСПриращением = ИндСтрокиМнЧ + ПриращениеКНомеру;
					НовИмяП000П2М305100 = ИмяП000П2М305100 + _ИндСтрокиМнЧ;
					НовИмяП000П2М305200 = ИмяП000П2М305200 + _ИндСтрокиМнЧ;
					ДанныеМнЧДляПечати.Вставить(НовИмяП000П2М305100, "");
					ДанныеМнЧДляПечати.Вставить(НовИмяП000П2М305200, 0);
					Если КолСтрокМнЧ3 >= ИндСПриращением Тогда
						ДанныеМнЧДляПечати.Вставить(НовИмяП000П2М305100,
						ДанныеМнЧ3.Строки[ИндСПриращением - 1].Данные[ИмяП000П2М305100]);
						ДанныеМнЧДляПечати.Вставить(НовИмяП000П2М305200,
						ДанныеМнЧ3.Строки[ИндСПриращением - 1].Данные[ИмяП000П2М305200]);
					КонецЕсли;
				КонецЦикла;
				
				МассивДанныхМнЧДляПечати.Добавить(ДанныеМнЧДляПечати);
				
			КонецЦикла;
			
			// Вывод листов.
			Для НомЛиста = 1 По КолЛистовРаздела Цикл
				ТабличныйДокумент.Очистить();
				ТабличныйДокумент.Вывести(МакетРаздела);
				
				Если НомЛиста = 1 Тогда
					НемногострочныеДанные = Ветка.Данные;
					Для каждого Пок Из НемногострочныеДанные Цикл
						Обл = ТабличныйДокумент.Области.Найти(Пок.Ключ);
						Если Обл <> Неопределено Тогда
							Обл.Значение = Пок.Значение;
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
				
				Для Ном = 1 По СтрокМнЧ1НаЛисте - 1 Цикл
					ИмяОбластиПреемника = "ДобавлениеСтроки" + ИмяГруппыМнЧ1 + СтрокаСИндексомПоказателя(Ном);
					ВставитьДопСтроку(ИмяГруппыМнЧ1, ИмяОбластиПреемника);
				КонецЦикла;
				Для Ном = 1 По СтрокМнЧ1НаЛисте Цикл
					Для ПодчНом = 1 По СтрокМнЧ2ВБлокеМнЧ1 - 1 Цикл
						ИмяОбластиПреемника
						= "ДобавлениеСтроки" + ИмяГруппыМнЧ2 + СтрокаСИндексомПоказателя(Ном) + СтрокаСИндексомПоказателя(ПодчНом);
						ВставитьДопСтроку(ИмяГруппыМнЧ2, ИмяОбластиПреемника);
					КонецЦикла;
				КонецЦикла;
				
				Для Ном = 1 По СтрокМнЧ3НаЛисте - 1 Цикл
					ИмяОбластиПреемника = "ДобавлениеСтроки" + ИмяГруппыМнЧ3 + СтрокаСИндексомПоказателя(Ном);
					ВставитьДопСтроку(ИмяГруппыМнЧ3, ИмяОбластиПреемника);
				КонецЦикла;
				
				ДанныеМнЧДляПечати = МассивДанныхМнЧДляПечати[НомЛиста - 1];
				Для каждого Пок Из ДанныеМнЧДляПечати Цикл
					Обл = ТабличныйДокумент.Области.Найти(Пок.Ключ);
					Если Обл <> Неопределено Тогда
						Обл.Значение = Пок.Значение;
					КонецЕсли;
					
					// Особая обработка в строке 052 (дробная часть ".00" не выводится, если значение целое).
					Если СтрНачинаетсяС(Обл.Имя, "П000П2М305200") И Обл.Значение = Цел(Обл.Значение) Тогда
						Обл.Формат = СтрЗаменить(Обл.Формат, " ЧДЦ=2;", "");
					КонецЕсли;
					
				КонецЦикла;
				
				СтруктураПараметровРаздела = ОбщегоНазначения.СкопироватьРекурсивно(СтруктураПараметров);
				СтруктураПараметровРаздела.Вставить("ИмяСтраницы", ИмяТекРаздела + "_прод");
				ВывестиНаПечатьЛист(СтруктураПараметровРаздела, ОбщиеРеквизитыРазделов, СтрПоля);
			КонецЦикла;
			
		КонецЦикла;
		
	КонецЕсли;
	
	ДеревоДанныхРаздела = Неопределено;
	
КонецПроцедуры

&НаСервере
Процедура ВывестиНаПечатьЛист(Парам1, ОбщиеРеквизитыРазделов, СтрПоля = Неопределено)
	
	ПрефиксИменМакетов = "ПечатныйБланк2019Кв4_";
	
	ИмяМЧБ = ПрефиксИменМакетов + Парам1.ИмяСтраницы;
	
	МакетМЧБ = ОбъектОтчета(ЭтаФорма.ИмяФормы).ПолучитьМакет(ИмяМЧБ);
	МакетМЧБ.ПолеСверху = 5;
	МакетМЧБ.ПолеСправа = 5;
	МакетМЧБ.ПолеСнизу  = 5;
	МакетМЧБ.ПолеСлева  = 5;
	
	ВремПоля = Новый Структура(СтрПоля);
	
	ЗаполнитьМакетМЧБ(Парам1, МакетМЧБ, ОбщиеРеквизитыРазделов);
	
	ЗаполнитьЗначенияСвойств(ВремПоля, ТабличныйДокумент, СтрПоля);
	ТабличныйДокумент.Очистить();
	ТабличныйДокумент.Вывести(МакетМЧБ);
	ЗаполнитьЗначенияСвойств(ТабличныйДокумент, МакетМЧБ, СтрПоля, "Макет");
	
	МакетМЧБ = Неопределено;
	
	РегламентированнаяОтчетность.ВывестиНаПечатьЛистОбщая(
	ЭтаФорма.Заголовок, Парам1, ТабличныйДокумент, СтруктураРеквизитовФормы.мПечатныеФормы);
	
КонецПроцедуры

