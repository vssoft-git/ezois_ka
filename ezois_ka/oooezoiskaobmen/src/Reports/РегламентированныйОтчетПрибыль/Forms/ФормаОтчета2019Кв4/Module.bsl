		ИЛИ СтрНачинаетсяС(ИмяПоказателя, "П0003ВМ100503") ИЛИ ИмяПоказателя = "П000080000201" Тогда
		ИНН = СтрЗаменить(ЗначПоказателя, " ", "");
		ДлинаИНН = СтрДлина(ИНН);
		Если ДлинаИНН = 10 ИЛИ ДлинаИНН = 0 Тогда
			Область.Значение = ИНН;
		Иначе
