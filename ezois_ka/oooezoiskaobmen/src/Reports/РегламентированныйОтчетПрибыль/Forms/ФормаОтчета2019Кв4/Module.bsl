				ТДО["П000П20003303"].Значение = Макс(0,
				ОкрЧФ(Форма, ТДО["П000П20003103"].Значение) - ОкрЧФ(Форма, ТДО["П000П20003003"].Значение));
				
				ТДО["П000П20003403"].Значение = Макс(0,
				ОкрЧФ(Форма, ТДО["П000П20003003"].Значение) - ОкрЧФ(Форма, ТДО["П000П20003103"].Значение));
				
