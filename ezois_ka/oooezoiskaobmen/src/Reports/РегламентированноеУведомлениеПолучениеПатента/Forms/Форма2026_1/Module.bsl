	НовСтр = ТаблицаОсобыхПолейВВыгрузке.Добавить();
	НовСтр.ПутьXML = "Файл/Документ/ЗПУСН/СвМестПД/КодНОУчет";
	
	НовСтр = ТаблицаОсобыхПолейВВыгрузке.Добавить();
	НовСтр.ПутьXML = "Файл/Документ/ЗПУСН/СвТСДеят1/КодНОУчет";
	
	НовСтр = ТаблицаОсобыхПолейВВыгрузке.Добавить();
	НовСтр.ПутьXML = "Файл/Документ/ЗПУСН/СвОбДеят2/КодНОУчет";
	
	Возврат ТаблицаОсобыхПолейВВыгрузке;
КонецФункции

&НаСервере
Процедура ОсобаяОбработкаЭлементов(Путь, СтрЗагружаемоеЗначение, Страница) Экспорт 
	Если Путь = "Файл/Документ/ЗПУСН/СвМестПД/КодРегион"
		Или Путь = "Файл/Документ/ЗПУСН/СвМестПД/КодНОУчет" Тогда
		ЭтотОбъект["ДанныеУведомления"].Титульная["ВключитьЛистА"] = Истина;
	КонецЕсли;
	Если Путь = "Файл/Документ/ЗПУСН/СвТСДеят1/КодРегион"
		Или Путь = "Файл/Документ/ЗПУСН/СвТСДеят1/КодНОУчет" Тогда
		ЭтотОбъект["ДанныеУведомления"].Титульная["ВключитьЛистБ"] = Истина;
	КонецЕсли;
	Если Путь = "Файл/Документ/ЗПУСН/СвОбДеят2/КодРегион"
		Или Путь = "Файл/Документ/ЗПУСН/СвОбДеят2/КодНОУчет" Тогда
		ЭтотОбъект["ДанныеУведомления"].Титульная["ВключитьЛистВ"] = Истина;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьИзXMLНаСервере(ПараметрыЗагрузкиXML)
	ДеревоЗагрузки = УведомлениеОСпецрежимахНалогообложения.СформироватьДеревоЗагрузки(ПараметрыЗагрузкиXML.ПредставлениеXML);
	СхемаВыгрузки = Документы.УведомлениеОСпецрежимахНалогообложения.ИзвлечьСтруктуруXMLУведомления(Объект.ИмяОтчета, "СхемаВыгрузкиФорма2026_1");
	УведомлениеОСпецрежимахНалогообложения.УстановитьОрганизациюПоПараметрамЗагрузки(ЭтотОбъект, ПараметрыЗагрузкиXML);
	ДеревоСтраниц.ПолучитьЭлементы().Очистить();
	СформироватьДеревоСтраниц();
	УведомлениеОСпецрежимахНалогообложения.СформироватьСтруктуруДанныхУведомленияНовогоОбразца(ЭтотОбъект);
	
	ЛистАВЗдание = Новый ТаблицаЗначений;
	ЛистАВЗдание.Колонки.Добавить("УИД");
	ЛистАВЗдание.Колонки.Добавить("Аддр_ЗданиеТип");
	ЛистАВЗдание.Колонки.Добавить("Аддр_ЗданиеНомер");
	ЭтотОбъект["ДанныеДопСтрок"].Вставить("ЛистАВЗдание", ПоместитьВоВременноеХранилище(ЛистАВЗдание));
	Для Инд = 0 По 1 Цикл 
		Для Каждого Элт Из ДеревоСтраниц.ПолучитьЭлементы()[1 + Инд*2].ПолучитьЭлементы() Цикл 
			Элт.Многострочность = Истина;
			Элт.МногострочныеЧасти.Добавить("ЛистАВЗдание");
		КонецЦикла;
	КонецЦикла;
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ТаблицаОсобыхПолейВВыгрузке", ПолучитьТаблицуОсобыхПолей());
	УведомлениеОСпецрежимахНалогообложения.ЗагрузитьОбычныеСтраницы(ЭтотОбъект, ДеревоЗагрузки, СхемаВыгрузки, ДополнительныеПараметры);
	УведомлениеОСпецрежимахНалогообложения.ЗагрузитьМногостраничныеСтраницы(ЭтотОбъект, ДеревоЗагрузки, СхемаВыгрузки, ДополнительныеПараметры);
	
	Для Каждого Элт Из СтрРазделить("ЛистА,ЛистВ", ",") Цикл 
		Для Каждого Стр Из ЭтотОбъект["ДанныеМногостраничныхРазделов"][Элт] Цикл 
			ЛистТек = Стр.Значение;
			СтрокиЗданий = ЛистАВЗдание.НайтиСтроки(Новый Структура("УИД", ЛистТек.УИД));
			Инд = 0;
			Для Каждого СтрокаЗдание Из СтрокиЗданий Цикл 
				Инд = Инд + 1;
				Если Инд > 3 Тогда 
					Прервать;
				КонецЕсли;
				
				ЛистТек["Аддр_ЗданиеТип" + Инд] = СтрокаЗдание["Аддр_ЗданиеТип"];
				ЛистТек["Аддр_ЗданиеНомер" + Инд] = СтрокаЗдание["Аддр_ЗданиеНомер"];
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
	ЭтотОбъект["ДанныеДопСтрок"].Удалить("ЛистАВЗдание");
	
	Для Инд = 0 По 1 Цикл 
		Для Каждого Элт Из ДеревоСтраниц.ПолучитьЭлементы()[1 + Инд*2].ПолучитьЭлементы() Цикл 
			Элт.Многострочность = Ложь;
			Элт.МногострочныеЧасти.Очистить();
		КонецЦикла;
	КонецЦикла;
	
	Модифицированность = Истина;
КонецПроцедуры

