Функция СформироватьНовоеУведомление_2026_1(Данные) Экспорт 
	Если Данные.Свойство("СсылкаНаДокумент")
		И ТипЗнч(Данные.СсылкаНаДокумент) = Тип("ДокументСсылка.УведомлениеОСпецрежимахНалогообложения") Тогда
		
		ДокОбъект = Данные.СсылкаНаДокумент.ПолучитьОбъект();
	Иначе
		ДокОбъект = Документы.УведомлениеОСпецрежимахНалогообложения.СоздатьДокумент();
	КонецЕсли;
	
	ДокОбъект.ВидУведомления = Перечисления.ВидыУведомленийОСпецрежимахНалогообложения.ЗаявлениеНаПолучениеПатентаРекомендованнаяФорма;
	Данные.Свойство("Организация", ДокОбъект.Организация);
	ДокОбъект.ИмяФормы = "Форма2026_1";
	ДокОбъект.ИмяОтчета = "РегламентированноеУведомлениеПолучениеПатента";
	ДокОбъект.ДатаПодписи = ТекущаяДатаСеанса();
	ДокОбъект.Дата = ТекущаяДатаСеанса();
	Данные.Свойство("ПодписантИмя", ДокОбъект.ПодписантИмя);
	Данные.Свойство("ПодписантФамилия", ДокОбъект.ПодписантФамилия);
	Данные.Свойство("ПодписантОтчество", ДокОбъект.ПодписантОтчество);
	Данные.Свойство("РегистрацияВИФНС", ДокОбъект.РегистрацияВИФНС);
	
	СтруктураПараметров = Новый Структура;
	
	ДанныеУведомления = Новый Структура;
	ДанныеМногостраничныхРазделов = Новый Структура;
	ИдентификаторыОбычныхСтраниц = Новый Структура;
	
	СтруктураПараметров.Вставить("ДеревоСтраниц", СформироватьДеревоСтраницПоДанным_2026_1(Данные));
	ПараметрыИнициализацииФормы = Новый Структура;
	ПараметрыИнициализацииФормы.Вставить("ДанныеУведомления");
	ПараметрыИнициализацииФормы.Вставить("ДанныеМногостраничныхРазделов");
	ПараметрыИнициализацииФормы.Вставить("ДанныеДопСтрок");
	ПараметрыИнициализацииФормы.Вставить("ДанныеДопСтрокСтраницы");
	ПараметрыИнициализацииФормы.Вставить("ИдентификаторыОбычныхСтраниц");
	ПараметрыИнициализацииФормы.Вставить("ИмяФормы", "Отчет.РегламентированноеУведомлениеПолучениеПатента.Форма.Форма2026_1");
	ПараметрыИнициализацииФормы.Вставить("ИмяОтчета", "РегламентированноеУведомлениеПолучениеПатента");
	ПараметрыИнициализацииФормы.Вставить("ДеревоСтраниц", СтруктураПараметров.ДеревоСтраниц);
	ПараметрыИнициализацииФормы.Вставить("Объект", Новый Структура("ИмяОтчета, ИмяФормы", "РегламентированноеУведомлениеПолучениеПатента", "Форма2026_1"));
	ПараметрыИнициализацииФормы.Вставить("ИмяМакетаАрхиваТабличныхДокументов", "ЭкранныеФормы26");
	ПараметрыИнициализацииФормы.Вставить("АдресВХранилищеЭкранныеФормы");
	ПараметрыИнициализацииФормы.Вставить("УникальныйИдентификатор", Новый УникальныйИдентификатор);
	УведомлениеОСпецрежимахНалогообложения.СформироватьСтруктуруДанныхУведомленияНовогоОбразца(ПараметрыИнициализацииФормы);
	
	МнгСтр1 = Новый ТаблицаЗначений;
	МнгСтр1.Колонки.Добавить("УИД", Новый ОписаниеТипов("УникальныйИдентификатор"));
	МнгСтр1.Колонки.Добавить("ИдНомТС", Новый ОписаниеТипов("Строка"));
	МнгСтр1.Колонки.Добавить("МаркаТС", Новый ОписаниеТипов("Строка"));
	МнгСтр1.Колонки.Добавить("РегЗнакТС", Новый ОписаниеТипов("Строка"));
	МнгСтр1.Колонки.Добавить("ГрузТС", Новый ОписаниеТипов("Число"));
	МнгСтр1.Колонки.Добавить("КолПосадМест", Новый ОписаниеТипов("Число"));
	
	Пока ПараметрыИнициализацииФормы.ДанныеМногостраничныхРазделов["ЛистА"].Количество() < Данные.ЛистыА.Количество() Цикл 
		СтруктураСтраницы = ОбщегоНазначенияКлиентСервер.СкопироватьСтруктуру(
			ПараметрыИнициализацииФормы.ДанныеМногостраничныхРазделов["ЛистА"][0].Значение);
		ДобавитьДополнительныеПоляАдреса(СтруктураСтраницы);
		ПараметрыИнициализацииФормы.ДанныеМногостраничныхРазделов["ЛистА"].Добавить(СтруктураСтраницы);
	КонецЦикла;
	Для Инд = 0 По Данные.ЛистыА.Количество() - 1 Цикл 
		ЛистА = Данные.ЛистыА[Инд];
		ДобавитьДополнительныеПоляАдреса(ПараметрыИнициализацииФормы.ДанныеМногостраничныхРазделов["ЛистА"][Инд].Значение);
		ЗаполнитьЗначенияСвойств(ПараметрыИнициализацииФормы.ДанныеМногостраничныхРазделов["ЛистА"][Инд].Значение, ЛистА);
		ПараметрыИнициализацииФормы.ДанныеМногостраничныхРазделов["ЛистА"][Инд].Значение.УИД = 
			СтруктураПараметров.ДеревоСтраниц.Строки[1].Строки[Инд].УИД;
		Если УведомлениеОСпецрежимахНалогообложенияКлиентСервер.СтраницаЗаполнена(ЛистА) Тогда 
			ПараметрыИнициализацииФормы.ДанныеУведомления["Титульная"].Вставить("ВключитьЛистА", Истина);
		КонецЕсли;
	КонецЦикла;
	
	СоответствиеЛистыБ = Новый Соответствие;
	Для Инд = 0 По Данные.ЛистыБ.Количество() - 1 Цикл 
		ЛистБ = Данные.ЛистыБ[Инд];
		Если ТипЗнч(ЛистБ) = Тип("СтрокаТаблицыЗначений") Тогда 
			ЛистБ = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(ЛистБ);
		КонецЕсли;
		Если Не УведомлениеОСпецрежимахНалогообложенияКлиентСервер.СтраницаЗаполнена(ЛистБ) Тогда 
			Продолжить;
		КонецЕсли;
		ПараметрыИнициализацииФормы.ДанныеУведомления["Титульная"].Вставить("ВключитьЛистБ", Истина);
		
		КодТС = ЛистБ["КодТС"];
		Если СоответствиеЛистыБ[КодТС] = Неопределено Тогда 
			СтруктураСтраницы = Новый Структура;
			СтруктураСтраницы.Вставить("ДаннныеСтраницы", 
				ОбщегоНазначения.СкопироватьРекурсивно(ПараметрыИнициализацииФормы.ДанныеМногостраничныхРазделов["ЛистБ"][0].Значение));
			СтруктураСтраницы["ДаннныеСтраницы"].Вставить("УИД", Новый УникальныйИдентификатор);
			СтруктураСтраницы.Вставить("МнгСтр", МнгСтр1.СкопироватьКолонки());
			СоответствиеЛистыБ.Вставить(КодТС, СтруктураСтраницы);
		КонецЕсли;
		
		СтруктураСтраницы = СоответствиеЛистыБ[КодТС];
		УИД = СтруктураСтраницы["ДаннныеСтраницы"]["УИД"];
		ЗаполнитьЗначенияСвойств(СтруктураСтраницы["ДаннныеСтраницы"], ЛистБ);
		СтруктураСтраницы["ДаннныеСтраницы"]["УИД"] = УИД;
		НовСтр = СтруктураСтраницы["МнгСтр"].Добавить();
		ЗаполнитьЗначенияСвойств(НовСтр, ЛистБ);
		НовСтр.УИД = УИД;
	КонецЦикла;
	
	Пока ПараметрыИнициализацииФормы.ДанныеМногостраничныхРазделов["ЛистБ"].Количество() < СоответствиеЛистыБ.Количество() Цикл 
		СтруктураСтраницы = ОбщегоНазначения.СкопироватьРекурсивно(
			ПараметрыИнициализацииФормы.ДанныеМногостраничныхРазделов["ЛистБ"][0].Значение);
