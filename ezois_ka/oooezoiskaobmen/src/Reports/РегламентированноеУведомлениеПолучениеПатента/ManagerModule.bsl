							"Не указана грузоподъемность транспортного средства", "ЛистБ", "ГрузТС" + ИндСтр, ЛистБ.УИД));
					КонецЕсли;
					Если ЗначениеЗаполнено(Стр.КолПосадМест) Тогда 
						ТаблицаОшибок.Добавить(Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюСтруктуруНавигацииПоОшибкам(
							"Для грузового транспорта количество посадочных мест не указывается", "ЛистБ", "КолПосадМест" + ИндСтр, ЛистБ.УИД));
					КонецЕсли;
				ИначеЕсли ЛистБ.КодТС = "02" Или ЛистБ.КодТС = "03" Тогда 
					Если ЗначениеЗаполнено(Стр.ГрузТС) Тогда 
						ТаблицаОшибок.Добавить(Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюСтруктуруНавигацииПоОшибкам(
							"Для пассажирского транспорта грузоподъемность не указывается", "ЛистБ", "ГрузТС" + ИндСтр, ЛистБ.УИД));
					КонецЕсли;
					Если Не ЗначениеЗаполнено(Стр.КолПосадМест) Тогда 
						ТаблицаОшибок.Добавить(Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюСтруктуруНавигацииПоОшибкам(
							"Не указано количество посадочных мест", "ЛистБ", "КолПосадМест" + ИндСтр, ЛистБ.УИД));
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
	КонецЕсли;
	
	Если ЕстьЛистВ = 1 Тогда
		Для Каждого Стр Из Данные.ДанныеМногостраничныхРазделов.ЛистВ Цикл 
			ЛистВ = Стр.Значение;
			Если Не ЗначениеЗаполнено(ЛистВ.КодОбъект) Тогда 
				ТаблицаОшибок.Добавить(Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюСтруктуруНавигацииПоОшибкам(
					"Не указан код объекта", "ЛистВ", "КодОбъект", ЛистВ.УИД));
			КонецЕсли;
			
			КодОбъектЧисло = ОТЧ.ПривестиЗначение(ЛистВ.КодОбъект);
			Если КодОбъектЧисло < 16 Или КодОбъектЧисло > 29
				Или (КодОбъектЧисло > 22 И КодОбъектЧисло < 29)
				Или УведомлениеОСпецрежимахНалогообложения.БлокЗаполнен(ЛистВ, ПоказателиАдреса) Тогда 
				
				УведомлениеОСпецрежимахНалогообложения.ПроверитьАдресВМногостраничнойСтранице(ТаблицаОшибок, ЛистВ, "ЛистВ");
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Если ЕстьЛистА + ЕстьЛистБ + ЕстьЛистВ <> 1 Тогда
		ТаблицаОшибок.Добавить(Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюСтруктуруНавигацииПоОшибкам(
			"Должны быть заполнены либо листы А, либо листы Б, либо листы В", "Титульная", "ВключитьЛистА"));
	ИначеЕсли ЗначениеЗаполнено(Титульная.КодНОУчет) Тогда 
		УведомлениеОСпецрежимахНалогообложенияСлужебный.ПроверкаКодаНО(Титульная.КодНОУчет, ТаблицаОшибок, "Титульная", "КодНОУчет");
	КонецЕсли;
	
	Возврат ТаблицаОшибок;
КонецФункции

Функция ОсновныеСведенияЭлектронногоПредставления_Форма2026_1(Объект, УникальныйИдентификатор)
	ОсновныеСведения = Документы.УведомлениеОСпецрежимахНалогообложения.НачальнаяИнициализацияОбщихРеквизитовВыгрузки(Объект);
	ИдентификаторФайла = ИдентификаторФайлаЭлектронногоПредставления(ОсновныеСведения);
	ОсновныеСведения.Вставить("ИдФайл", ИдентификаторФайла);
	
	Титульная = Объект.ДанныеУведомления.Получить().ДанныеУведомления["Титульная"];
	ОсновныеСведения.Вставить("ЛистА", Титульная["ВключитьЛистА"]);
	ОсновныеСведения.Вставить("ЛистБ", Титульная["ВключитьЛистБ"]);
	ОсновныеСведения.Вставить("ЛистВ", Титульная["ВключитьЛистВ"]);
	Возврат ОсновныеСведения;
КонецФункции

Процедура ДополнитьДанныеУведомления(ДанныеУведомления)
	ДанныеУведомления.ДанныеДопСтрокБД.Вставить("ЛистАВЗдание", Новый ТаблицаЗначений);
	ДанныеУведомления.ДанныеДопСтрокБД["ЛистАВЗдание"].Колонки.Добавить("УИД");
	ДанныеУведомления.ДанныеДопСтрокБД["ЛистАВЗдание"].Колонки.Добавить("Аддр_ЗданиеТип");
	ДанныеУведомления.ДанныеДопСтрокБД["ЛистАВЗдание"].Колонки.Добавить("Аддр_ЗданиеНомер");
	Для Каждого ТипЛиста Из СтрРазделить("ЛистА,ЛистВ", ",") Цикл
		Для Каждого Элт Из ДанныеУведомления.ДанныеМногостраничныхРазделов[ТипЛиста] Цикл
			ЛистТек = Элт.Значение;
			Для Ит = 1 По 3 Цикл 
				НовСтр = ДанныеУведомления.ДанныеДопСтрокБД["ЛистАВЗдание"].Добавить();
				НовСтр.УИД = ЛистТек.УИД;
				НовСтр.Аддр_ЗданиеТип = ЛистТек["Аддр_ЗданиеТип" + Ит];
				НовСтр.Аддр_ЗданиеНомер = ЛистТек["Аддр_ЗданиеНомер" + Ит];
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
КонецПроцедуры

Функция ЭлектронноеПредставление_Форма2026_1(Объект, УникальныйИдентификатор)
	СведенияЭлектронногоПредставления = УведомлениеОСпецрежимахНалогообложения.СведенияЭлектронногоПредставления();
	ДанныеУведомления = УведомлениеОСпецрежимахНалогообложения.ДанныеУведомленияДляВыгрузки(Объект);
	ДополнитьДанныеУведомления(ДанныеУведомления);
	Ошибки = ПроверитьДокументСВыводомВТаблицу_Форма2026_1(ДанныеУведомления, УникальныйИдентификатор);
	УведомлениеОСпецрежимахНалогообложения.СообщитьОшибкиПриПроверкеВыгрузки(Объект, Ошибки, ДанныеУведомления);
	
	ОсновныеСведения = ОсновныеСведенияЭлектронногоПредставления_Форма2026_1(Объект, УникальныйИдентификатор);
	СтруктураВыгрузки = Документы.УведомлениеОСпецрежимахНалогообложения.ИзвлечьСтруктуруXMLУведомления(Объект.ИмяОтчета, "СхемаВыгрузкиФорма2026_1");
	УведомлениеОСпецрежимахНалогообложения.ТиповоеЗаполнениеДанными(ДанныеУведомления, ОсновныеСведения, СтруктураВыгрузки);
	УведомлениеОСпецрежимахНалогообложения.ВыгрузитьДеревоВТаблицу(СтруктураВыгрузки, ОсновныеСведения, СведенияЭлектронногоПредставления);
	Возврат СведенияЭлектронногоПредставления;
КонецФункции

