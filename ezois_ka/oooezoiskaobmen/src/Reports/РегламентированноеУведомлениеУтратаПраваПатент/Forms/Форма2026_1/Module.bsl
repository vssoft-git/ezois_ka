&НаСервере
Процедура ЗаполнитьАвтоНаСервере(ПараметрыЗаполнения = Неопределено)
	Если ПараметрыЗаполнения <> Неопределено Тогда
		Титульная = ЭтотОбъект["ДанныеУведомления"].Титульная;
		Объект.РегистрацияВИФНС = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(
			ПараметрыЗаполнения, "НалоговыйОрган", Объект.РегистрацияВИФНС);
		Титульная.КодНО = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.РегистрацияВИФНС, "Код");
	КонецЕсли;
	
	ПараметрыОтчета = Новый Структура();
	ПараметрыОтчета.Вставить("Организация", Объект.Организация);
	ПараметрыОтчета.Вставить("КодНалоговогоОргана", Объект.РегистрацияВИФНС);
	ПараметрыОтчета.Вставить("ДатаПодписи", Объект.ДатаПодписи);
	ПараметрыОтчета.Вставить("УникальныйИдентификаторФормы", УникальныйИдентификатор);
	ПараметрыОтчета.Вставить("ПараметрыЗаполнения", ПараметрыЗаполнения);
	
	Контейнер = СформироватьКонтейнерДляАвтозаполнения();
	РегламентированнаяОтчетностьПереопределяемый.ЗаполнитьОтчет(Объект.ИмяОтчета, Объект.ИмяФормы, ПараметрыОтчета, Контейнер);
	ЗагрузитьПодготовленныеДанные(Контейнер);
КонецПроцедуры

&НаСервере
Функция СформироватьКонтейнерДляАвтозаполнения()
	Контейнер = Новый Структура;
	
	ДопСтроки = Новый ТаблицаЗначений;
	ДопСтроки.Колонки.Добавить("НомерПт");
	ДопСтроки.Колонки.Добавить("ДатаНачПт");
	ДопСтроки.Колонки.Добавить("ДатаКонПт");
	Контейнер.Вставить("ДопСтроки", ДопСтроки);
	
	Титульный = Новый Структура;
	Титульная = ЭтотОбъект["ДанныеУведомления"].Титульная;
	Титульный.Вставить("КодППункт", Титульная.КодППункт);
	Титульный.Вставить("ДатаУтрПСН", Титульная.ДатаУтрПСН);
	Титульный.Вставить("КодНО", Титульная.КодНО);
	Контейнер.Вставить("Титульный", Титульный);
	Возврат Контейнер;
КонецФункции

&НаСервере
Процедура ЗагрузитьПодготовленныеДанные(Контейнер)
	Титульная = ЭтотОбъект["ДанныеУведомления"].Титульная;
	ЗаполнитьЗначенияСвойств(Титульная, Контейнер.Титульный);
	
	МнгСтр = ПолучитьИзВременногоХранилища(ЭтотОбъект["ДанныеДопСтрок"].МнгСтр);
	МнгСтр.Очистить();
	УИД = ДеревоСтраниц.ПолучитьЭлементы()[1].УИД;
	Для Каждого Стр Из Контейнер.ДопСтроки Цикл 
		НовСтр = МнгСтр.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтр, Стр);
		НовСтр.УИД = УИД;
	КонецЦикла;
	ЭтотОбъект["ДанныеДопСтрок"].МнгСтр = ПоместитьВоВременноеХранилище(МнгСтр, ЭтотОбъект["ДанныеДопСтрок"].МнгСтр);
	Модифицированность = Истина;
КонецПроцедуры

#КонецОбласти
