		УдаляемыеПоля.Добавить("ПоступилоВР");
		УдаляемыеПоля.Добавить("ПоступилоПР");
		УдаляемыеПоля.Добавить("ПеремещенияНУ");
		УдаляемыеПоля.Добавить("ПеремещенияВР");
		УдаляемыеПоля.Добавить("ПеремещенияПР");
