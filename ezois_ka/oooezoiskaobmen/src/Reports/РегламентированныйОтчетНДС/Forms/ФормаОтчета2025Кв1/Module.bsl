#Область СверкаСчетовФактурВДекларации

&НаКлиенте
Процедура НеПодключенаСверкаТекстОбработкаНавигационнойСсылки(Элемент, НавигационнаяСсылкаФорматированнойСтроки, СтандартнаяОбработка)
	Если НавигационнаяСсылкаФорматированнойСтроки = "ПодключитьсяКСервисуСверки" Тогда
		СтандартнаяОбработка = Ложь;
		РегламентированнаяОтчетностьКлиентПереопределяемый.ОткрытьФормуПодключенияКСверке();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура КартинкаЗакрытьБаннерНажатие(Элемент)
	Элементы.ГруппаНеПодключенаСверка.Видимость = Ложь;
КонецПроцедуры

&НаКлиенте
Функция ВывестиРезультатСверкиСФ(РезультатСверкиДекларации, СоединениеСтрок = Ложь)
	
	Если Не ИспользуетсяСервисСверкиРасчетов Тогда
		Если СоединениеСтрок Тогда
			ТекстРезультатаСверки = НСтр("ru='. '");
		Иначе
			ТекстРезультатаСверки = "";
		КонецЕсли;
		
	Иначе
		Если СоединениеСтрок Тогда
			Если РезультатСверкиДекларации.НеУдалосьВыполнитьСверку Тогда
				
				ТекстРезультатаСверки = НСтр("ru=', не удалось произвести сверку счетов-фактур с контрагентами.'");
			ИначеЕсли РезультатСверкиДекларации.ЕстьРасхождения Тогда
				ТекстРезультатаСверки = Новый Массив();
				ТекстРезультатаСверки.Добавить(НСтр("ru=', и обнаружены '"));
				ТекстРезультатаСверки.Добавить(Новый ФорматированнаяСтрока(НСтр("ru='расхождения'"), , , , "ПоказатьРасхожденияСверки"));
				ТекстРезультатаСверки.Добавить(НСтр("ru=' в счетах-фактурах сервисом 1С:Сверка 2.0'"));
				
			ИначеЕсли РезультатСверкиДекларации.ЕстьНеСверенные Тогда
				ТекстРезультатаСверки = Новый Массив();
				ТекстРезультатаСверки.Добавить(НСтр("ru=', и есть '"));
				ТекстРезультатаСверки.Добавить(Новый ФорматированнаяСтрока(НСтр("ru='не сверенные'"), , , , "ПоказатьРасхожденияСверки"));
				ТекстРезультатаСверки.Добавить(НСтр("ru=' счета-фактуры сервисом 1С:Сверка 2.0'"));
			Иначе
				ТекстРезультатаСверки = НСтр("ru=', нет расхождений при сверке счетов-фактур с контрагентами'");
				
			КонецЕсли;
			
		Иначе
			
			Если РезультатСверкиДекларации.НеУдалосьВыполнитьСверку Тогда
				ТекстРезультатаСверки = НСтр("ru='. Не удалось произвести сверку счетов-фактур с контрагентами.'");
			ИначеЕсли РезультатСверкиДекларации.ЕстьРасхождения Тогда
				ТекстРезультатаСверки = Новый Массив();
				ТекстРезультатаСверки.Добавить(НСтр("ru='. Обнаружены '"));
				ТекстРезультатаСверки.Добавить(Новый ФорматированнаяСтрока(НСтр("ru='расхождения'"), , , , "ПоказатьРасхожденияСверки"));
				ТекстРезультатаСверки.Добавить(НСтр("ru=' в счетах-фактурах сервисом 1С:Сверка 2.0'"));
				
			ИначеЕсли РезультатСверкиДекларации.ЕстьНеСверенные Тогда
				ТекстРезультатаСверки = Новый Массив();
				ТекстРезультатаСверки.Добавить(НСтр("ru='. Есть '"));
				ТекстРезультатаСверки.Добавить(Новый ФорматированнаяСтрока(НСтр("ru='не сверенные'"), , , , "ПоказатьРасхожденияСверки"));
				ТекстРезультатаСверки.Добавить(НСтр("ru=' счета-фактуры сервисом 1С:Сверка 2.0'"));
			Иначе
				ТекстРезультатаСверки = НСтр("ru='. Нет расхождений при сверке счетов-фактур с контрагентами'");
				
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Возврат ТекстРезультатаСверки;

КонецФункции

&НаКлиенте
Функция РезультатСверкиДекларации()
	
	Если ИспользуетсяСервисСверкиРасчетов Тогда
		СтруктураРезультата = Новый Структура;
		СтруктураРезультата.Вставить("ЕстьНеСверенные",          ДанныеДляСверкиДеклараций.ЕстьНеСверенные);
		СтруктураРезультата.Вставить("ЕстьРасхождения",          ДанныеДляСверкиДеклараций.ЕстьРасхождения);
		СтруктураРезультата.Вставить("НеУдалосьВыполнитьСверку", ДанныеДляСверкиДеклараций.НеУдалосьВыполнитьСверку);
		СтруктураРезультата.Вставить("ПроверкаВыполнена",        ДанныеДляСверкиДеклараций.ПроверкаВыполнена Или Не ИспользуетсяСервисСверкиРасчетов);
	Иначе
		СтруктураРезультата = Новый Структура;
		СтруктураРезультата.Вставить("ЕстьНеСверенные",          Ложь);
		СтруктураРезультата.Вставить("ЕстьРасхождения",          Ложь);
		СтруктураРезультата.Вставить("НеУдалосьВыполнитьСверку", Ложь);
		СтруктураРезультата.Вставить("ПроверкаВыполнена",        Истина);
	КонецЕсли;
	
	Возврат СтруктураРезультата;
	
КонецФункции

