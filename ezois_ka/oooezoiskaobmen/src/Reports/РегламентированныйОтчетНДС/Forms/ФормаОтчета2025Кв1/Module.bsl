		СтруктураРеквизитовФормы.Организация, ДатаПодписи, "ПрименяетсяУСН"); 
	ПрименяетсяУСН = ?(Сведения.ПрименяетсяУСН = Истина ИЛИ Сведения.ПрименяетсяУСН = 1, Истина, Ложь);
		
	Если НЕ ПрименяетсяУСН Тогда 
		Возврат;
	КонецЕсли;
	
	ИменаПоказателей = Новый Структура;
	ИменаПоказателей.Вставить("Р08С010"		, Неопределено);
	ИменаПоказателей.Вставить("Р81С010"		, Неопределено);
	ИменаПоказателей.Вставить("Р09С211"		, Неопределено);
	ИменаПоказателей.Вставить("Р09С212"		, Неопределено);
	ИменаПоказателей.Вставить("Р91С291"		, Неопределено);
	ИменаПоказателей.Вставить("Р91С292"		, Неопределено);
	
	Показатели = СформироватьПоказатели(ИменаПоказателей);
	ЗарегистрироватьПроверку();
	
	ЗаполнитьИРасшифроватьПоказатель(Показатели.Р09С211, ДанныеКС.ДанныеР09);
	ЗаполнитьИРасшифроватьПоказатель(Показатели.Р09С212, ДанныеКС.ДанныеР09);
	ЗаполнитьИРасшифроватьПоказатель(Показатели.Р91С291, ДанныеКС.ДанныеР91);
	ЗаполнитьИРасшифроватьПоказатель(Показатели.Р91С292, ДанныеКС.ДанныеР91);
	
	РасчетнаяСумма = Показатели.Р09С211.Значение + Показатели.Р09С212.Значение + Показатели.Р91С291.Значение + 
		Показатели.Р91С292.Значение;
	УсловиеВыполнено = РасчетнаяСумма > 0;
	
	Если НЕ УсловиеВыполнено Тогда
		Возврат;
	КонецЕсли;
	
	СтрокаКодовПлан1 = "16,17,18,22,26,43"; 
	СтрокаКодовПлан2 = "16, 17, 18, 22, 26, 43, 01";
	Коллекция1 = Новый Структура("ТаблицаР08,ТаблицаР81", "Р08С010", "Р81С010");
	МассивКодовФакт2 = Новый Массив;
	СчетчикОшибок = 0;  
	
	Для каждого Элемент1 Из Коллекция1 Цикл
		Если НЕ ДанныеКС[Элемент1.Ключ] = Неопределено И ТипЗнч(ДанныеКС[Элемент1.Ключ]) = Тип("ТаблицаЗначений") Тогда
			Для Каждого СтрокаПоказателей Из ДанныеКС[Элемент1.Ключ] Цикл 
				
				Если СчетчикОшибок = 50 Тогда 
					Прервать;
				КонецЕсли;
				
				КодОшибочный 	= Ложь; 
				Код01		 	= Истина;
				НесовпадениеРеквизитов = Ложь;
				Если ТипЗнч(СтрокаПоказателей.КодВидОпер) = Тип("Массив") Тогда
					Для каждого ЭлементМассива Из СтрокаПоказателей.КодВидОпер Цикл
						КодОшибочный 	= КодОшибочный ИЛИ СтрНайти(СтрокаКодовПлан1, ЭлементМассива) = 0;
						Код01 			= Код01 И ЭлементМассива = "01";
						Если КодОшибочный Тогда
							Если МассивКодовФакт2.Найти(ЭлементМассива) = Неопределено Тогда
								МассивКодовФакт2.Добавить(ЭлементМассива);
							КонецЕсли;
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
				
				Если Код01 Тогда
					СовпадениеРеквизитов = СтрокаПоказателей.НомСчФПрод = СтрокаПоказателей.НомКСчФПрод И
						СтрокаПоказателей.ДатаСчФПрод = СтрокаПоказателей.ДатаКСчФПрод;
				КонецЕсли;
					
				Если НЕ КодОшибочный ИЛИ (Код01 И СовпадениеРеквизитов) Тогда
				    Продолжить;
				КонецЕсли;	
					
				НомерСтроки = ДанныеКС[Элемент1.Ключ].Индекс(СтрокаПоказателей) + 1;
				СтрокаКодовФакт = СтрСоединить(СтрокаПоказателей.КодВидОпер, ", ");
				ПредставлениеКодов = ?(ЗначениеЗаполнено(СтрокаКодовФакт), СтрокаКодовФакт, "(...)");
				Показатели[Элемент1.Значение].Значение = СтрокаКодовФакт;
				Показатели[Элемент1.Значение].ЗначениеСтр = ПредставлениеКодов; 
				Показатели[Элемент1.Значение].НомерСтраницы = 1;
				Если КодОшибочный Тогда
					Показатели[Элемент1.Значение].Дополнение = "п." + НомерСтроки;
				КонецЕсли;
				Если Код01 И НЕ СовпадениеРеквизитов Тогда
					Показатели[Элемент1.Значение].Дополнение = "п." + НомерСтроки + ", несовпадение реквизитов счетов-фактур"; 
				КонецЕсли;
				
				СчетчикОшибок = СчетчикОшибок + 1;
				РасшифроватьПоказатель(Показатели[Элемент1.Значение]);
				
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	
	СтрокаКодовФакт2 = СтрСоединить(МассивКодовФакт2, ", ");
	НастройкиКС.ЭтоОшибка = СчетчикОшибок > 0;
	НастройкиКС.Детализация = СтрШаблон(НастройкиКС.ШаблонДетализации,
		СтрокаКодовФакт2, СтрокаКодовПлан2, РасчетнаяСумма, Показатели.Р09С211.Значение, Показатели.Р09С212.Значение, 
		Показатели.Р91С291.Значение, Показатели.Р91С292.Значение);
	ДополнитьТаблицуРезультата();
	
КонецПроцедуры

