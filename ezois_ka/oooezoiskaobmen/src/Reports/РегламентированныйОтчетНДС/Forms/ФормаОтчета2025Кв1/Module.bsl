		"Уточните код операции в стр.010 Раздела 6. В стр.010 Раздела 6 не указываются коды корректировок и возвратов");
	Заголовки.Вставить("Основание"			, НСтр("ru='Проверка носит справочный характер'"));
	ПодготовитьНастройки(Заголовки);
	
	Если Документирование Тогда
		Возврат;
	КонецЕсли;
	
	МассивЗначений = СтрРазделить(
		"1010447,1010448,1010449,1010450,1010494,1010495,1010496,1010497,1010498,1010499,1011401,1011402,1011403,1011404,1011405,1011406",
		",");
	
	ИменаПоказателей = Новый Структура;
	ИменаПоказателей.Вставить("Р06С010"	, "П0006М1001003_");
	
	Показатели = СформироватьПоказатели(ИменаПоказателей);
	
	КоличествоСтрок = КоличествоСтрок(ДанныеКС.ДанныеР06, Лев(Показатели.Р06С010.ИмяПоказателя, 14));
	Для НомерСтроки = 1 По КоличествоСтрок Цикл 
		
		ЗарегистрироватьПроверку();
		ЗаполнитьИРасшифроватьПоказатель(Показатели.Р06С010, ДанныеКС.ДанныеР06, НомерСтроки); 
		
		НастройкиКС.ЭтоОшибка = НЕ МассивЗначений.Найти(Показатели.Р06С010.Значение) = Неопределено;
		НастройкиКС.Детализация = СтрШаблон(НастройкиКС.ШаблонДетализации,
			Показатели.Р06С010.ЗначениеСтр);
		ДополнитьТаблицуРезультата();
	
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

