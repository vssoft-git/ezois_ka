&НаСервере
Процедура ПроверкаКС_1_21_код()
	
	ШаблонДетализацииКУплате = НСтр("ru='%1 + %2 + %3'");
	ШаблонДетализацииКВычету = НСтр("ru='%1 + %2 + %3 + %4 +%5'");
	СуммаКУплате = 0;
	СуммаКВычету = 0;
	
	ИменаПоказателейИтога = Новый Структура;
	ИменаПоказателейИтога.Вставить("Р01С040"	, "П000100004003");
	ИменаПоказателейИтога.Вставить("Р01С050"	, "П000100005003");
	ИменаПоказателейИтога.Удалить(НастройкиКС.КлючУдаления);
	
	ИменаПоказателейКУплате = Новый Структура;
	ИменаПоказателейКУплате.Вставить("Р03С200"	, "П000300020003");
	ИменаПоказателейКУплате.Вставить("Р04С130"	, "П000400013003");
	ИменаПоказателейКУплате.Вставить("Р06С160"	, "П000600016003");
	
	ИменаПоказателейКВычету = Новый Структура;
	ИменаПоказателейКВычету.Вставить("Р03С210"	, "П000300021003");
	ИменаПоказателейКВычету.Вставить("Р04С120"	, "П000400012003");
	ИменаПоказателейКВычету.Вставить("Р05С080"	, "П000500008003");
	ИменаПоказателейКВычету.Вставить("Р05С090"	, "П000500009003");
	ИменаПоказателейКВычету.Вставить("Р06С170"	, "П000600017003");
	
	ПоказателиИтога 	= СформироватьПоказатели(ИменаПоказателейИтога);
	ПоказателиКУплате 	= СформироватьПоказатели(ИменаПоказателейКУплате);
	ПоказателиКВычету 	= СформироватьПоказатели(ИменаПоказателейКВычету);
	ЗарегистрироватьПроверку();
	
	ЗаполнитьИРасшифроватьПоказатели(ПоказателиИтога			, ДанныеКС.ДанныеР01);
	ЗаполнитьИРасшифроватьПоказатель(ПоказателиКУплате.Р03С200	, ДанныеКС.ДанныеР03);
	ЗаполнитьИРасшифроватьПоказатель(ПоказателиКУплате.Р04С130	, ДанныеКС.ДанныеР04);
	ЗаполнитьИРасшифроватьПоказатель(ПоказателиКУплате.Р06С160	, ДанныеКС.ДанныеР06);
	ЗаполнитьИРасшифроватьПоказатель(ПоказателиКВычету.Р03С210	, ДанныеКС.ДанныеР03);
	ЗаполнитьИРасшифроватьПоказатель(ПоказателиКВычету.Р04С120	, ДанныеКС.ДанныеР04);
	ЗаполнитьИРасшифроватьПоказатель(ПоказателиКВычету.Р05С080	, ДанныеКС.ДанныеР05[0]);
	ЗаполнитьИРасшифроватьПоказатель(ПоказателиКВычету.Р05С090	, ДанныеКС.ДанныеР05[0]);
	ЗаполнитьИРасшифроватьПоказатель(ПоказателиКВычету.Р06С170	, ДанныеКС.ДанныеР06);
	
	Для каждого Показатель Из ПоказателиКУплате Цикл
		СуммаКУплате = СуммаКУплате + Показатель.Значение.Итог;
	КонецЦикла;
	
	Для каждого Показатель Из ПоказателиКВычету Цикл
		СуммаКВычету = СуммаКВычету + Показатель.Значение.Итог;
	КонецЦикла;
	
	РасчетнаяСумма = Макс(?(НастройкиКС.КлючИтога = "Р01С040", СуммаКУплате - СуммаКВычету, 
		СуммаКВычету - СуммаКУплате), 0);
	РасшифровкаКУплате = СтрШаблон(ШаблонДетализацииКУплате,
		ПоказателиКУплате.Р03С200.Итог, ПоказателиКУплате.Р04С130.Итог, ПоказателиКУплате.Р06С160.Итог);
	РасшифровкаКВычету = СтрШаблон(ШаблонДетализацииКВычету,
		ПоказателиКВычету.Р03С210.Итог, ПоказателиКВычету.Р04С120.Итог, ПоказателиКВычету.Р05С080.Итог, 
		ПоказателиКВычету.Р05С090.Значение, ПоказателиКВычету.Р06С170.Итог);
	НастройкиКС.Детализация = СтрШаблон(НастройкиКС.ШаблонДетализации,
		ПоказателиИтога[НастройкиКС.КлючИтога].Итог, РасшифровкаКУплате, СуммаКУплате, РасшифровкаКВычету, СуммаКВычету,
		РасчетнаяСумма);
	НастройкиКС.ЭтоОшибка = НЕ ПоказателиИтога[НастройкиКС.КлючИтога].Итог = РасчетнаяСумма;
	ДополнитьТаблицуРезультата();
	
КонецПроцедуры

