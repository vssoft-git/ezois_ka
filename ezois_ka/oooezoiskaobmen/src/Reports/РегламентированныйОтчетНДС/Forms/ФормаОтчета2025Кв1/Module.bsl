	РегламентированнаяОтчетность.ПриЗакрытииРегламентированногоОтчета(ЭтаФорма);
	
	//ПроверкаКонтрагентовБРО
	ПроверкаКонтрагентовБРО.ПриЗакрытииОтчета(ЭтотОбъект);
	//Конец ПроверкаКонтрагентовБРО
	
