							<v8:content>Количество затрат на единицу продукции</v8:content>
						</v8:item>
					</dcsset:lwsTitle>
				</dcsset:item>
				<dcsset:viewMode>Normal</dcsset:viewMode>
				<dcsset:userSettingID>4850481c-9258-4b3d-adf1-caa878307304</dcsset:userSettingID>
