			<dataSource>ИсточникДанных1</dataSource>
			<query>// !!! ИСПОЛЬЗУЮТСЯ ТЕГИ !!!
ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	Сегменты.Номенклатура КАК Номенклатура,
	Сегменты.Характеристика КАК Характеристика,
	ИСТИНА КАК ИспользуетсяОтборПоСегментуНоменклатуры
ПОМЕСТИТЬ ОтборПоСегментуНоменклатуры
ИЗ
	РегистрСведений.НоменклатураСегмента КАК Сегменты
{ГДЕ
	Сегменты.Сегмент.* КАК СегментНоменклатуры,
	Сегменты.Номенклатура.* КАК Номенклатура,
	Сегменты.Характеристика.* КАК Характеристика}

ИНДЕКСИРОВАТЬ ПО
	Номенклатура,
	Характеристика,
	ИспользуетсяОтборПоСегментуНоменклатуры
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	СебестоимостьТоваров.Организация КАК Организация,
	НАЧАЛОПЕРИОДА(СебестоимостьТоваров.Период, МЕСЯЦ) КАК ПериодДействия
ПОМЕСТИТЬ ПериодыДействияСреднескользящей
ИЗ
	РегистрНакопления.СебестоимостьТоваров КАК СебестоимостьТоваров
ГДЕ
	СебестоимостьТоваров.СпособОпределенияСебестоимости = ЗНАЧЕНИЕ(Перечисление.СпособыОпределенияСебестоимостиТоваров.ПоСреднескользящей)
	И (СебестоимостьТоваров.Период МЕЖДУ &amp;НачалоПериода И &amp;КонецПериода ИЛИ &amp;КонецПериода = ДАТАВРЕМЯ(1,1,1))
{ГДЕ
	СебестоимостьТоваров.Организация.*
}

ИНДЕКСИРОВАТЬ ПО
	ПериодДействия,
	Организация
;

//++ Устарело_Переработка24
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ДД.Регистратор КАК Регистратор,
	ДД.АналитикаУчетаНоменклатуры КАК АналитикаУчетаНоменклатуры,
	ДД.ВидЗапасов КАК ВидЗапасов,
	ДД.АналитикаУчетаПартий КАК АналитикаУчетаПартий,
	МАКСИМУМ(ДД.КорАналитикаУчетаНоменклатуры) КАК КорАналитикаУчетаНоменклатуры,
	МАКСИМУМ(ДД.КорВидЗапасов) КАК КорВидЗапасов
ПОМЕСТИТЬ
	РаботыДляДавальца
ИЗ
	РегистрНакопления.СебестоимостьТоваров КАК ДД
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.КлючиАналитикиУчетаНоменклатуры КАК АналитикаВыпуска
		ПО АналитикаВыпуска.Ссылка = ДД.КорАналитикаУчетаНоменклатуры
		ЛЕВОЕ СОЕДИНЕНИЕ Константы КАК Константы
		ПО ИСТИНА
ГДЕ
	(ДД.Период МЕЖДУ &amp;НачалоПериода И &amp;КонецПериода ИЛИ &amp;КонецПериода = ДАТАВРЕМЯ(1,1,1))
	И ДД.Активность
	И ДД.ТипЗаписи = ЗНАЧЕНИЕ(Перечисление.ТипыЗаписейПартий.Партия)
	И ДД.ХозяйственнаяОперация В (ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ВыпускПродукции),
									ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ВыпускПродукцииНаСклад),
									ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ВыпускПродукцииВПодразделение))
	И ДД.РазделУчета = ЗНАЧЕНИЕ(Перечисление.РазделыУчетаСебестоимостиТоваров.ПроизводственныеЗатраты)
	И ДД.КорАналитикаУчетаНоменклатуры &lt;&gt; ЗНАЧЕНИЕ(Справочник.КлючиАналитикиУчетаНоменклатуры.ПустаяСсылка)
	И &amp;ПартионныйУчетВерсии22
	И ДД.Период &gt;= &amp;ДатаПереходаНаПартионныйУчетВерсии22
{ГДЕ
	(АналитикаВыпуска.Номенклатура, АналитикаВыпуска.Характеристика) В (
		ВЫБРАТЬ
			ОтборПоСегментуНоменклатуры.Номенклатура,
			ОтборПоСегментуНоменклатуры.Характеристика
		ИЗ
			ОтборПоСегментуНоменклатуры
		ГДЕ
			ОтборПоСегментуНоменклатуры.ИспользуетсяОтборПоСегментуНоменклатуры = &amp;ИспользуетсяОтборПоСегментуНоменклатуры
	)
}

СГРУППИРОВАТЬ ПО
	ДД.Регистратор,
	ДД.АналитикаУчетаНоменклатуры,
	ДД.ВидЗапасов,
	ДД.АналитикаУчетаПартий

ИНДЕКСИРОВАТЬ ПО
	Регистратор,
	АналитикаУчетаНоменклатуры,
	ВидЗапасов,
	АналитикаУчетаПартий
;
//-- Устарело_Переработка24

////////////////////////////////////////////////////////////////////////////////

// трудозатраты на выпуск без заказа
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ЗатратыНЗП.Организация КАК Организация,
	ВЫБОР
		КОГДА НЕ Константы.ИспользоватьУправлениеПроизводством2_2
			ТОГДА НЕОПРЕДЕЛЕНО
		КОГДА Аналитика.ТипМестаХранения = ЗНАЧЕНИЕ(Перечисление.ТипыМестХранения.Подразделение)
			ТОГДА Аналитика.Подразделение
		ИНАЧЕ Аналитика.СкладскаяТерритория.Подразделение
	КОНЕЦ КАК ПодразделениеПродукции,
	ЗатратыНЗП.КорАналитикаУчетаПродукции КАК АналитикаПродукции,
	Аналитика.Номенклатура КАК Продукция,
	Аналитика.Характеристика КАК ХарактеристикаПродукции,
	Аналитика.Номенклатура.ЕдиницаИзмерения КАК ЕдиницаИзмеренияПродукции,
	ВЫБОР 
		КОГДА &amp;ДетализироватьПоСериямВыпуска 
			ТОГДА Аналитика.Серия 
		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка) 
	КОНЕЦ КАК СерияПродукции,
	Аналитика.Назначение КАК НазначениеПродукции,
	ВЫБОР
		КОГДА НЕ &amp;ДетализироватьПоНазначениям
			ТОГДА ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
		КОГДА ИСТИНА
			ТОГДА Аналитика.Назначение
	КОНЕЦ КАК НазначениеПолучателяПродукции,
	ВЫБОР
		КОГДА ЗатратыНЗП.СтатьяКалькуляцииБезЗаказа &lt;&gt; ЗНАЧЕНИЕ(Справочник.СтатьиКалькуляции.ПустаяСсылка)
			ТОГДА ЗатратыНЗП.СтатьяКалькуляцииБезЗаказа
		ИНАЧЕ 
			ЗатратыНЗП.СтатьяКалькуляции
	КОНЕЦ КАК СтатьяКалькуляции,
	"Трудозатраты" КАК ВидЗатрат,
	ЗатратыНЗП.ВидРабот КАК Затрата,
	ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка) КАК ХарактеристикаЗатраты,
	ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка) КАК СерияЗатраты,
	ЗатратыНЗП.ВидРабот.ЕдиницаИзмерения КАК ЕдиницаИзмеренияЗатраты,
	ЗатратыНЗП.Подразделение,
	(ВЫБОР
		КОГДА ЗатратыНЗП.ЗаказНаПроизводство ЕСТЬ NULL ТОГДА НЕОПРЕДЕЛЕНО
		КОГДА ТИПЗНАЧЕНИЯ(ЗатратыНЗП.ЗаказНаПроизводство) = ТИП(Строка) ТОГДА НЕОПРЕДЕЛЕНО
		ИНАЧЕ ЗатратыНЗП.ЗаказНаПроизводство КОНЕЦ) КАК ЗаказНаПроизводство,
	ВЫБОР 
		КОГДА &amp;ДетализироватьПоПартиямПроизводства 
			ТОГДА ЗатратыНЗП.ПартияПроизводства 
		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ПартииПроизводства.ПустаяСсылка) 
	КОНЕЦ КАК ПартияПроизводства,
	0 КАК КодСтрокиПродукция,
	ЗНАЧЕНИЕ(Справочник.ЭтапыПроизводства.ПустаяСсылка) КАК Этап,
	ЗатратыНЗП.ГруппаПродукции,
	ЗатратыНЗП.Количество КАК КоличествоЗатрат,
	ВЫБОР
		КОГДА &amp;ДанныеПоСебестоимости = 4
			ТОГДА ЗатратыНЗП.СтоимостьРегл
		ИНАЧЕ ЗатратыНЗП.Стоимость
	КОНЕЦ КАК СтоимостьЗатрат,
	ВЫБОР
		КОГДА &amp;ДанныеПоСебестоимости = 4
			ТОГДА ЗатратыНЗП.ВременнаяРазница
		ИНАЧЕ 0
	КОНЕЦ КАК ВременнаяРазница,
	ВЫБОР
		КОГДА &amp;ДанныеПоСебестоимости = 4
			ТОГДА ЗатратыНЗП.ПостояннаяРазница
		ИНАЧЕ 0
	КОНЕЦ КАК ПостояннаяРазница,
	ВЫБОР
		КОГДА &amp;ДанныеПоСебестоимости = 4
			ТОГДА ЗатратыНЗП.СтоимостьНДД
		ИНАЧЕ 0
	КОНЕЦ КАК НДД,
	ВЫБОР
		КОГДА ПериодыДействияСреднескользящей.Организация ЕСТЬ NULL
			ТОГДА ЗатратыНЗП.Регистратор
		ИНАЧЕ НЕОПРЕДЕЛЕНО
	КОНЕЦ КАК Регистратор
ИЗ
	РегистрНакопления.ТрудозатратыНезавершенногоПроизводства КАК ЗатратыНЗП
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.КлючиАналитикиУчетаНоменклатуры КАК Аналитика
			ПО (Аналитика.Ссылка = ЗатратыНЗП.КорАналитикаУчетаПродукции)
		ЛЕВОЕ СОЕДИНЕНИЕ Константы КАК Константы
			ПО (ИСТИНА)
		ЛЕВОЕ СОЕДИНЕНИЕ ПериодыДействияСреднескользящей КАК ПериодыДействияСреднескользящей
			ПО ПериодыДействияСреднескользящей.Организация = ЗатратыНЗП.Организация
			И ПериодыДействияСреднескользящей.ПериодДействия = НАЧАЛОПЕРИОДА(ЗатратыНЗП.Период, МЕСЯЦ)
		//++ Устарело_Переработка24
		ЛЕВОЕ СОЕДИНЕНИЕ РаботыДляДавальца КАК РаботыДляДавальца
			ПО РаботыДляДавальца.Регистратор = ЗатратыНЗП.Регистратор
			И РаботыДляДавальца.ВидЗапасов = ЗатратыНЗП.КорВидЗапасовПродукции
			И РаботыДляДавальца.АналитикаУчетаНоменклатуры = ЗатратыНЗП.КорАналитикаУчетаПродукции
			И РаботыДляДавальца.АналитикаУчетаПартий = ЗатратыНЗП.КорАналитикаУчетаПартий
		//-- Устарело_Переработка24
		
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РеестрДокументов КАК Реестр
		ПО Реестр.СторнируемыйДокумент = ЗатратыНЗП.Регистратор
			И Реестр.СторноИсправление
			И (Реестр.ДатаДокументаИБ &lt;= &amp;КонецПериода ИЛИ &amp;КонецПериода = ДАТАВРЕМЯ(1,1,1))
			И Реестр.Проведен
ГДЕ
	ЗатратыНЗП.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
	И (ЗатратыНЗП.Период МЕЖДУ &amp;НачалоПериода И &amp;КонецПериода ИЛИ &amp;КонецПериода = ДАТАВРЕМЯ(1,1,1))
	И ЗатратыНЗП.КодСтрокиПродукция = 0
	//++ Устарело_Переработка24
	И РаботыДляДавальца.Регистратор ЕСТЬ NULL
	//-- Устарело_Переработка24
	
	// Исключаем документы, по которым введено исправление или сторно в текущем периоде.
	И Реестр.Ссылка ЕСТЬ NULL
	И НЕ ЗатратыНЗП.Сторно
{ГДЕ
	((Аналитика.Номенклатура, Аналитика.Характеристика) В
			(ВЫБРАТЬ
				ОтборПоСегментуНоменклатуры.Номенклатура,
				ОтборПоСегментуНоменклатуры.Характеристика
			ИЗ
				ОтборПоСегментуНоменклатуры
			ГДЕ
				ОтборПоСегментуНоменклатуры.ИспользуетсяОтборПоСегментуНоменклатуры = &amp;ИспользуетсяОтборПоСегментуНоменклатуры))}
//++ Устарело_Переработка24

ОБЪЕДИНИТЬ ВСЕ
	
ВЫБРАТЬ
	ЗатратыНЗП.Организация КАК Организация,
	ВЫБОР
		КОГДА НЕ Константы.ИспользоватьУправлениеПроизводством2_2
			ТОГДА НЕОПРЕДЕЛЕНО
		КОГДА Аналитика.ТипМестаХранения = ЗНАЧЕНИЕ(Перечисление.ТипыМестХранения.Подразделение)
			ТОГДА Аналитика.Подразделение
		ИНАЧЕ Аналитика.СкладскаяТерритория.Подразделение
	КОНЕЦ КАК ПодразделениеПродукции,
	ЗатратыНЗП.КорАналитикаУчетаПродукции КАК АналитикаПродукции,
	Аналитика.Номенклатура КАК Продукция,
	Аналитика.Характеристика КАК ХарактеристикаПродукции,
	Аналитика.Номенклатура.ЕдиницаИзмерения КАК ЕдиницаИзмеренияПродукции,
	ВЫБОР 
		КОГДА &amp;ДетализироватьПоСериямВыпуска 
			ТОГДА Аналитика.Серия 
		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка) 
	КОНЕЦ КАК СерияПродукции,
	Аналитика.Назначение КАК НазначениеПродукции,
	ВЫБОР
		КОГДА НЕ &amp;ДетализироватьПоНазначениям
			ТОГДА ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
		КОГДА ИСТИНА
			ТОГДА Аналитика.Назначение
	КОНЕЦ КАК НазначениеПолучателяПродукции,
	ВЫБОР
		КОГДА ЗатратыНЗП.СтатьяКалькуляцииБезЗаказа &lt;&gt; ЗНАЧЕНИЕ(Справочник.СтатьиКалькуляции.ПустаяСсылка)
			ТОГДА ЗатратыНЗП.СтатьяКалькуляцииБезЗаказа
		ИНАЧЕ 
			ЗатратыНЗП.СтатьяКалькуляции
	КОНЕЦ КАК СтатьяКалькуляции,
	"Трудозатраты" КАК ВидЗатрат,
	ЗатратыНЗП.ВидРабот КАК Затрата,
	ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка) КАК ХарактеристикаЗатраты,
	ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка) КАК СерияЗатраты,
	ЗатратыНЗП.ВидРабот.ЕдиницаИзмерения КАК ЕдиницаИзмеренияЗатраты,
	ЗатратыНЗП.Подразделение,
	(ВЫБОР
		КОГДА ЗатратыНЗП.ЗаказНаПроизводство ЕСТЬ NULL ТОГДА НЕОПРЕДЕЛЕНО
		КОГДА ТИПЗНАЧЕНИЯ(ЗатратыНЗП.ЗаказНаПроизводство) = ТИП(Строка) ТОГДА НЕОПРЕДЕЛЕНО
		ИНАЧЕ ЗатратыНЗП.ЗаказНаПроизводство КОНЕЦ) КАК ЗаказНаПроизводство,
	ВЫБОР 
		КОГДА &amp;ДетализироватьПоПартиямПроизводства 
			ТОГДА ЗатратыНЗП.ПартияПроизводства 
		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ПартииПроизводства.ПустаяСсылка) 
	КОНЕЦ КАК ПартияПроизводства,
	0 КАК КодСтрокиПродукция,
	ЗНАЧЕНИЕ(Справочник.ЭтапыПроизводства.ПустаяСсылка) КАК Этап,
	ЗатратыНЗП.ГруппаПродукции,
	ЗатратыНЗП.Количество КАК КоличествоЗатрат,
	ВЫБОР
		КОГДА &amp;ДанныеПоСебестоимости = 4
			ТОГДА ЗатратыНЗП.СтоимостьРегл
		ИНАЧЕ ЗатратыНЗП.Стоимость
	КОНЕЦ КАК СтоимостьЗатрат,
	ВЫБОР
		КОГДА &amp;ДанныеПоСебестоимости = 4
			ТОГДА ЗатратыНЗП.ВременнаяРазница
		ИНАЧЕ 0
	КОНЕЦ КАК ВременнаяРазница,
	ВЫБОР
		КОГДА &amp;ДанныеПоСебестоимости = 4
			ТОГДА ЗатратыНЗП.ПостояннаяРазница
		ИНАЧЕ 0
	КОНЕЦ КАК ПостояннаяРазница,
	ВЫБОР
		КОГДА &amp;ДанныеПоСебестоимости = 4
			ТОГДА ЗатратыНЗП.СтоимостьНДД
		ИНАЧЕ 0
	КОНЕЦ КАК НДД,
	ВЫБОР
		КОГДА ПериодыДействияСреднескользящей.Организация ЕСТЬ NULL
			ТОГДА ЗатратыНЗП.Регистратор
		ИНАЧЕ НЕОПРЕДЕЛЕНО
	КОНЕЦ КАК Регистратор
ИЗ
	РегистрНакопления.ТрудозатратыНезавершенногоПроизводства КАК ЗатратыНЗП
		ЛЕВОЕ СОЕДИНЕНИЕ Константы КАК Константы
			ПО (ИСТИНА)
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РаботыДляДавальца КАК РаботыДляДавальца
			ПО РаботыДляДавальца.Регистратор = ЗатратыНЗП.Регистратор
			И РаботыДляДавальца.ВидЗапасов = ЗатратыНЗП.КорВидЗапасовПродукции
			И РаботыДляДавальца.АналитикаУчетаНоменклатуры = ЗатратыНЗП.КорАналитикаУчетаПродукции
			И РаботыДляДавальца.АналитикаУчетаПартий = ЗатратыНЗП.КорАналитикаУчетаПартий
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.КлючиАналитикиУчетаНоменклатуры КАК Аналитика
			ПО Аналитика.Ссылка = РаботыДляДавальца.КорАналитикаУчетаНоменклатуры
		ЛЕВОЕ СОЕДИНЕНИЕ ПериодыДействияСреднескользящей КАК ПериодыДействияСреднескользящей
			ПО ПериодыДействияСреднескользящей.Организация = ЗатратыНЗП.Организация
			И ПериодыДействияСреднескользящей.ПериодДействия = НАЧАЛОПЕРИОДА(ЗатратыНЗП.Период, МЕСЯЦ)
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РеестрДокументов КАК Реестр
		ПО Реестр.СторнируемыйДокумент = ЗатратыНЗП.Регистратор
			И Реестр.СторноИсправление
			И (Реестр.ДатаДокументаИБ &lt;= &amp;КонецПериода ИЛИ &amp;КонецПериода = ДАТАВРЕМЯ(1,1,1))
			И Реестр.Проведен
ГДЕ
	ЗатратыНЗП.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
	И (ЗатратыНЗП.Период МЕЖДУ &amp;НачалоПериода И &amp;КонецПериода ИЛИ &amp;КонецПериода = ДАТАВРЕМЯ(1,1,1))
	И ЗатратыНЗП.КодСтрокиПродукция = 0
	// Исключаем документы, по которым введено исправление или сторно в текущем периоде.
	И Реестр.Ссылка ЕСТЬ NULL
	И НЕ ЗатратыНЗП.Сторно
{ГДЕ
	((Аналитика.Номенклатура, Аналитика.Характеристика) В
			(ВЫБРАТЬ
				ОтборПоСегментуНоменклатуры.Номенклатура,
				ОтборПоСегментуНоменклатуры.Характеристика
			ИЗ
				ОтборПоСегментуНоменклатуры
			ГДЕ
				ОтборПоСегментуНоменклатуры.ИспользуетсяОтборПоСегментуНоменклатуры = &amp;ИспользуетсяОтборПоСегментуНоменклатуры))}
//-- Устарело_Переработка24

</query>
		</item>
		<item xsi:type="DataSetQuery">
			<name>ПрочиеРасходы</name>
			<field xsi:type="DataSetFieldField">
				<dataPath>ЗаказНаПроизводство</dataPath>
				<field>ЗаказНаПроизводство</field>
				<role>
					<dcscom:dimension>true</dcscom:dimension>
					<dcscom:required>true</dcscom:required>
				</role>
				<appearance>
					<dcscor:item xsi:type="dcsset:SettingsParameterValue">
						<dcscor:parameter>МаксимальнаяШирина</dcscor:parameter>
						<dcscor:value xsi:type="xs:decimal">35</dcscor:value>
					</dcscor:item>
				</appearance>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>Организация</dataPath>
				<field>Организация</field>
				<role>
					<dcscom:dimension>true</dcscom:dimension>
				</role>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>СтатьяКалькуляции</dataPath>
				<field>СтатьяКалькуляции</field>
				<role>
					<dcscom:dimension>true</dcscom:dimension>
				</role>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>Этап</dataPath>
				<field>Этап</field>
				<role>
					<dcscom:dimension>true</dcscom:dimension>
				</role>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>Подразделение</dataPath>
				<field>Подразделение</field>
				<title xsi:type="v8:LocalStringType">
					<v8:item>
						<v8:lang>ru</v8:lang>
						<v8:content>Подразделение</v8:content>
					</v8:item>
				</title>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>Номенклатура</dataPath>
				<field>Номенклатура</field>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>СегментНоменклатуры</dataPath>
				<field>СегментНоменклатуры</field>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>Характеристика</dataPath>
				<field>Характеристика</field>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>СтоимостьЗатрат</dataPath>
				<field>СтоимостьЗатрат</field>
				<appearance>
					<dcscor:item xsi:type="dcsset:SettingsParameterValue">
						<dcscor:parameter>Формат</dcscor:parameter>
						<dcscor:value xsi:type="v8:LocalStringType">
							<v8:item>
								<v8:lang>ru</v8:lang>
								<v8:content>ЧДЦ=2</v8:content>
							</v8:item>
						</dcscor:value>
					</dcscor:item>
				</appearance>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>Регистратор</dataPath>
				<field>Регистратор</field>
				<role>
					<dcscom:periodNumber>1</dcscom:periodNumber>
					<dcscom:periodType>Main</dcscom:periodType>
					<dcscom:ignoreNullValues>true</dcscom:ignoreNullValues>
				</role>
				<appearance>
					<dcscor:item xsi:type="dcsset:SettingsParameterValue">
						<dcscor:parameter>МаксимальнаяШирина</dcscor:parameter>
						<dcscor:value xsi:type="xs:decimal">35</dcscor:value>
					</dcscor:item>
				</appearance>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>КодСтрокиПродукция</dataPath>
				<field>КодСтрокиПродукция</field>
				<role>
					<dcscom:dimension>true</dcscom:dimension>
					<dcscom:required>true</dcscom:required>
				</role>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>ГруппаПродукции</dataPath>
				<field>ГруппаПродукции</field>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>КоличествоЗатрат</dataPath>
				<field>КоличествоЗатрат</field>
				<title xsi:type="v8:LocalStringType">
					<v8:item>
						<v8:lang>ru</v8:lang>
						<v8:content>Количество затрат</v8:content>
					</v8:item>
				</title>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>ВидЗатрат</dataPath>
				<field>ВидЗатрат</field>
				<title xsi:type="v8:LocalStringType">
					<v8:item>
						<v8:lang>ru</v8:lang>
						<v8:content>Вид затрат</v8:content>
					</v8:item>
				</title>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>ХарактеристикаЗатраты</dataPath>
				<field>ХарактеристикаЗатраты</field>
				<title xsi:type="v8:LocalStringType">
					<v8:item>
						<v8:lang>ru</v8:lang>
						<v8:content>Характеристика затраты</v8:content>
					</v8:item>
				</title>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>СерияЗатраты</dataPath>
				<field>СерияЗатраты</field>
				<title xsi:type="v8:LocalStringType">
					<v8:item>
						<v8:lang>ru</v8:lang>
						<v8:content>Серия затраты</v8:content>
					</v8:item>
				</title>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>Затрата</dataPath>
				<field>Затрата</field>
				<title xsi:type="v8:LocalStringType">
					<v8:item>
						<v8:lang>ru</v8:lang>
						<v8:content>Затрата</v8:content>
					</v8:item>
				</title>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>СерияПродукции</dataPath>
				<field>СерияПродукции</field>
				<title xsi:type="v8:LocalStringType">
					<v8:item>
						<v8:lang>ru</v8:lang>
						<v8:content>Серия продукции</v8:content>
					</v8:item>
				</title>
				<role>
					<dcscom:dimension>true</dcscom:dimension>
				</role>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>ХарактеристикаПродукции</dataPath>
				<field>ХарактеристикаПродукции</field>
				<title xsi:type="v8:LocalStringType">
					<v8:item>
						<v8:lang>ru</v8:lang>
						<v8:content>Характеристика продукции</v8:content>
					</v8:item>
				</title>
				<role>
					<dcscom:dimension>true</dcscom:dimension>
				</role>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>Продукция</dataPath>
				<field>Продукция</field>
				<title xsi:type="v8:LocalStringType">
					<v8:item>
						<v8:lang>ru</v8:lang>
						<v8:content>Продукция</v8:content>
					</v8:item>
				</title>
				<role>
					<dcscom:dimension>true</dcscom:dimension>
				</role>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>ЕдиницаИзмеренияПродукции</dataPath>
				<field>ЕдиницаИзмеренияПродукции</field>
				<title xsi:type="v8:LocalStringType">
					<v8:item>
						<v8:lang>ru</v8:lang>
						<v8:content>Единица измерения продукции</v8:content>
					</v8:item>
				</title>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>ЕдиницаИзмеренияЗатраты</dataPath>
				<field>ЕдиницаИзмеренияЗатраты</field>
				<title xsi:type="v8:LocalStringType">
					<v8:item>
						<v8:lang>ru</v8:lang>
						<v8:content>Единица измерения затраты</v8:content>
					</v8:item>
				</title>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>ПартияПроизводства</dataPath>
				<field>ПартияПроизводства</field>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>ПодразделениеПродукции</dataPath>
				<field>ПодразделениеПродукции</field>
				<title xsi:type="v8:LocalStringType">
					<v8:item>
						<v8:lang>ru</v8:lang>
						<v8:content>Подразделение продукции</v8:content>
					</v8:item>
				</title>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>НазначениеПродукции</dataPath>
				<field>НазначениеПродукции</field>
				<title xsi:type="v8:LocalStringType">
					<v8:item>
						<v8:lang>ru</v8:lang>
						<v8:content>Назначение продукции</v8:content>
					</v8:item>
				</title>
				<role>
					<dcscom:dimension>true</dcscom:dimension>
				</role>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>НазначениеПолучателяПродукции</dataPath>
				<field>НазначениеПолучателяПродукции</field>
				<title xsi:type="v8:LocalStringType">
					<v8:item>
						<v8:lang>ru</v8:lang>
						<v8:content>Назначение получателя продукции</v8:content>
					</v8:item>
				</title>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>АналитикаПродукции</dataPath>
				<field>АналитикаПродукции</field>
				<title xsi:type="v8:LocalStringType">
					<v8:item>
						<v8:lang>ru</v8:lang>
						<v8:content>Аналитика продукции</v8:content>
					</v8:item>
				</title>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>ВременнаяРазница</dataPath>
				<field>ВременнаяРазница</field>
				<title xsi:type="v8:LocalStringType">
					<v8:item>
						<v8:lang>ru</v8:lang>
						<v8:content>Временная разница</v8:content>
					</v8:item>
				</title>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>ПостояннаяРазница</dataPath>
				<field>ПостояннаяРазница</field>
				<title xsi:type="v8:LocalStringType">
					<v8:item>
						<v8:lang>ru</v8:lang>
						<v8:content>Постоянная разница</v8:content>
					</v8:item>
				</title>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>НДД</dataPath>
				<field>НДД</field>
				<title xsi:type="v8:LocalStringType">
					<v8:item>
						<v8:lang>ru</v8:lang>
						<v8:content>НДД</v8:content>
					</v8:item>
				</title>
			</field>
			<dataSource>ИсточникДанных1</dataSource>
			<query>// !!! ИСПОЛЬЗУЮТСЯ ТЕГИ !!!
ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	Сегменты.Номенклатура КАК Номенклатура,
	Сегменты.Характеристика КАК Характеристика,
	ИСТИНА КАК ИспользуетсяОтборПоСегментуНоменклатуры
ПОМЕСТИТЬ ОтборПоСегментуНоменклатуры
ИЗ
	РегистрСведений.НоменклатураСегмента КАК Сегменты
{ГДЕ
	Сегменты.Сегмент.* КАК СегментНоменклатуры,
	Сегменты.Номенклатура.* КАК Номенклатура,
	Сегменты.Характеристика.* КАК Характеристика}

ИНДЕКСИРОВАТЬ ПО
	Номенклатура,
	Характеристика,
	ИспользуетсяОтборПоСегментуНоменклатуры
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	СебестоимостьТоваров.Организация КАК Организация,
	НАЧАЛОПЕРИОДА(СебестоимостьТоваров.Период, МЕСЯЦ) КАК ПериодДействия
ПОМЕСТИТЬ ПериодыДействияСреднескользящей
ИЗ
	РегистрНакопления.СебестоимостьТоваров КАК СебестоимостьТоваров
ГДЕ
	СебестоимостьТоваров.СпособОпределенияСебестоимости = ЗНАЧЕНИЕ(Перечисление.СпособыОпределенияСебестоимостиТоваров.ПоСреднескользящей)
	И (СебестоимостьТоваров.Период МЕЖДУ &amp;НачалоПериода И &amp;КонецПериода ИЛИ &amp;КонецПериода = ДАТАВРЕМЯ(1,1,1))
{ГДЕ
	СебестоимостьТоваров.Организация.*
}

ИНДЕКСИРОВАТЬ ПО
	ПериодДействия,
	Организация
;

//++ Устарело_Переработка24
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ДД.Регистратор КАК Регистратор,
	ДД.АналитикаУчетаНоменклатуры КАК АналитикаУчетаНоменклатуры,
	ДД.ВидЗапасов КАК ВидЗапасов,
	ДД.АналитикаУчетаПартий КАК АналитикаУчетаПартий,
	МАКСИМУМ(ДД.КорАналитикаУчетаНоменклатуры) КАК КорАналитикаУчетаНоменклатуры,
	МАКСИМУМ(ДД.КорВидЗапасов) КАК КорВидЗапасов
ПОМЕСТИТЬ
	РаботыДляДавальца
ИЗ
	РегистрНакопления.СебестоимостьТоваров КАК ДД
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.КлючиАналитикиУчетаНоменклатуры КАК АналитикаВыпуска
		ПО АналитикаВыпуска.Ссылка = ДД.КорАналитикаУчетаНоменклатуры
		ЛЕВОЕ СОЕДИНЕНИЕ Константы КАК Константы
		ПО ИСТИНА
ГДЕ
	(ДД.Период МЕЖДУ &amp;НачалоПериода И &amp;КонецПериода ИЛИ &amp;КонецПериода = ДАТАВРЕМЯ(1,1,1))
	И ДД.Активность
	И ДД.ТипЗаписи = ЗНАЧЕНИЕ(Перечисление.ТипыЗаписейПартий.Партия)
	И ДД.ХозяйственнаяОперация В (ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ВыпускПродукции),
									ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ВыпускПродукцииНаСклад),
									ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ВыпускПродукцииВПодразделение))
	И ДД.РазделУчета = ЗНАЧЕНИЕ(Перечисление.РазделыУчетаСебестоимостиТоваров.ПроизводственныеЗатраты)
	И ДД.КорАналитикаУчетаНоменклатуры &lt;&gt; ЗНАЧЕНИЕ(Справочник.КлючиАналитикиУчетаНоменклатуры.ПустаяСсылка)
	И &amp;ПартионныйУчетВерсии22
	И ДД.Период &gt;= &amp;ДатаПереходаНаПартионныйУчетВерсии22
{ГДЕ
	(АналитикаВыпуска.Номенклатура, АналитикаВыпуска.Характеристика) В (
		ВЫБРАТЬ
			ОтборПоСегментуНоменклатуры.Номенклатура,
			ОтборПоСегментуНоменклатуры.Характеристика
		ИЗ
			ОтборПоСегментуНоменклатуры
		ГДЕ
			ОтборПоСегментуНоменклатуры.ИспользуетсяОтборПоСегментуНоменклатуры = &amp;ИспользуетсяОтборПоСегментуНоменклатуры
	)
}

СГРУППИРОВАТЬ ПО
	ДД.Регистратор,
	ДД.АналитикаУчетаНоменклатуры,
	ДД.ВидЗапасов,
	ДД.АналитикаУчетаПартий

ИНДЕКСИРОВАТЬ ПО
	Регистратор,
	АналитикаУчетаНоменклатуры,
	ВидЗапасов,
	АналитикаУчетаПартий
;
//-- Устарело_Переработка24

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ЗатратыНЗП.Организация,
	ВЫБОР
		КОГДА НЕ Константы.ИспользоватьУправлениеПроизводством2_2
			ТОГДА НЕОПРЕДЕЛЕНО
		КОГДА АналитикаВыпуска.ТипМестаХранения = ЗНАЧЕНИЕ(Перечисление.ТипыМестХранения.Подразделение)
			ТОГДА АналитикаВыпуска.Подразделение
		КОГДА АналитикаВыпуска.ТипМестаХранения = ЗНАЧЕНИЕ(Перечисление.ТипыМестХранения.Партнер)
			ТОГДА АналитикаВыпуска.Партнер
		ИНАЧЕ АналитикаВыпуска.СкладскаяТерритория.Подразделение
	КОНЕЦ КАК ПодразделениеПродукции,
	ЗатратыНЗП.АналитикаУчетаПродукции КАК АналитикаПродукции,
	АналитикаВыпуска.Номенклатура КАК Продукция,
	АналитикаВыпуска.Характеристика КАК ХарактеристикаПродукции,
	АналитикаВыпуска.Номенклатура.ЕдиницаИзмерения КАК ЕдиницаИзмеренияПродукции,
	ВЫБОР 
		КОГДА &amp;ДетализироватьПоСериямВыпуска 
			ТОГДА АналитикаВыпуска.Серия 
		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка) 
	КОНЕЦ КАК СерияПродукции,
	АналитикаВыпуска.Назначение КАК НазначениеПродукции,
	ВЫБОР
		КОГДА НЕ &amp;ДетализироватьПоНазначениям
			ТОГДА ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
		КОГДА ИСТИНА
			ТОГДА АналитикаВыпуска.Назначение
	КОНЕЦ КАК НазначениеПолучателяПродукции,
	ЗатратыНЗП.СтатьяКалькуляции,
	"ПрочиеРасходы" КАК ВидЗатрат,
	ЗатратыНЗП.СтатьяРасходов КАК Затрата,
	ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка) КАК ХарактеристикаЗатраты,
	ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка) КАК СерияЗатраты,
	НЕОПРЕДЕЛЕНО КАК ЕдиницаИзмеренияЗатраты,
	ЗатратыНЗП.Подразделение,
	(ВЫБОР
		КОГДА ЗатратыНЗП.ЗаказНаПроизводство ЕСТЬ NULL ТОГДА НЕОПРЕДЕЛЕНО
		КОГДА ЗатратыНЗП.ЗаказНаПроизводство = ЗНАЧЕНИЕ(Справочник.РесурсныеСпецификации.ПустаяСсылка) Тогда НЕОПРЕДЕЛЕНО
		//++ Устарело_Производство21
		КОГДА ЗатратыНЗП.ЗаказНаПроизводство ССЫЛКА Документ.ВыпускПродукции ТОГДА НЕОПРЕДЕЛЕНО
		//-- Устарело_Производство21

		ИНАЧЕ ЗатратыНЗП.ЗаказНаПроизводство КОНЕЦ) КАК ЗаказНаПроизводство,
	ВЫБОР 
		КОГДА &amp;ДетализироватьПоПартиямПроизводства 
			ТОГДА ЗатратыНЗП.ПартияПроизводства 
		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ПартииПроизводства.ПустаяСсылка) 
	КОНЕЦ КАК ПартияПроизводства,
	ЗатратыНЗП.КодСтрокиПродукция,
	ЗатратыНЗП.Этап,
	ЗатратыНЗП.ГруппаПродукции,
	0 КАК КоличествоЗатрат,
	ВЫБОР КОГДА &amp;ДанныеПоСебестоимости = 1 ТОГДА
		ЗатратыНЗП.Стоимость
	КОГДА &amp;ДанныеПоСебестоимости = 2 ТОГДА
		ЗатратыНЗП.СтоимостьБезНДС
	КОГДА &amp;ДанныеПоСебестоимости = 3 ТОГДА
		ЗатратыНЗП.СтоимостьУпр
	КОГДА &amp;ДанныеПоСебестоимости = 4 ТОГДА
		ЗатратыНЗП.СтоимостьРегл
	ИНАЧЕ
		ВЫБОР КОГДА &amp;ПоПредприятию
			ТОГДА ЗатратыНЗП.СтоимостьБезНДС
			ИНАЧЕ ЗатратыНЗП.СтоимостьУпр
		КОНЕЦ
	КОНЕЦ КАК СтоимостьЗатрат,
	ВЫБОР
		КОГДА &amp;ДанныеПоСебестоимости = 4
			ТОГДА ЗатратыНЗП.ВременнаяРазница
		ИНАЧЕ 0
	КОНЕЦ КАК ВременнаяРазница,
	ВЫБОР
		КОГДА &amp;ДанныеПоСебестоимости = 4
			ТОГДА ЗатратыНЗП.ПостояннаяРазница
		ИНАЧЕ 0
	КОНЕЦ КАК ПостояннаяРазница,
	ВЫБОР
		КОГДА &amp;ДанныеПоСебестоимости = 4
			ТОГДА ЗатратыНЗП.СтоимостьНДД
		ИНАЧЕ 0
	КОНЕЦ КАК НДД,
	ВЫБОР
		КОГДА ПериодыДействияСреднескользящей.Организация ЕСТЬ NULL
			ТОГДА ЗатратыНЗП.Регистратор
		ИНАЧЕ НЕОПРЕДЕЛЕНО
	КОНЕЦ КАК Регистратор
ИЗ
	РегистрНакопления.ПрочиеРасходыНезавершенногоПроизводства КАК ЗатратыНЗП
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.КлючиАналитикиУчетаНоменклатуры КАК АналитикаВыпуска
		ПО ЗатратыНЗП.АналитикаУчетаПродукции = АналитикаВыпуска.Ссылка
		ЛЕВОЕ СОЕДИНЕНИЕ Константы КАК Константы
		ПО (ИСТИНА)
		ЛЕВОЕ СОЕДИНЕНИЕ ПериодыДействияСреднескользящей КАК ПериодыДействияСреднескользящей
			ПО ПериодыДействияСреднескользящей.Организация = ЗатратыНЗП.Организация
			И ПериодыДействияСреднескользящей.ПериодДействия = НАЧАЛОПЕРИОДА(ЗатратыНЗП.Период, МЕСЯЦ)
		//++ Устарело_Переработка24
		ЛЕВОЕ СОЕДИНЕНИЕ РаботыДляДавальца КАК РаботыДляДавальца
			ПО РаботыДляДавальца.Регистратор = ЗатратыНЗП.Регистратор
			И РаботыДляДавальца.ВидЗапасов = ЗатратыНЗП.ВидЗапасов
			И РаботыДляДавальца.АналитикаУчетаНоменклатуры = ЗатратыНЗП.АналитикаУчетаПродукции
			И РаботыДляДавальца.АналитикаУчетаПартий = ЗатратыНЗП.КорАналитикаУчетаПартий
		//-- Устарело_Переработка24
		
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РеестрДокументов КАК Реестр
		ПО Реестр.СторнируемыйДокумент = ЗатратыНЗП.Регистратор
			И Реестр.СторноИсправление
			И (Реестр.ДатаДокументаИБ &lt;= &amp;КонецПериода ИЛИ &amp;КонецПериода = ДАТАВРЕМЯ(1,1,1))
			И Реестр.Проведен
ГДЕ
	ЗатратыНЗП.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
	И (ЗатратыНЗП.Период МЕЖДУ &amp;НачалоПериода И &amp;КонецПериода ИЛИ &amp;КонецПериода = ДАТАВРЕМЯ(1,1,1))
	//++ Устарело_Переработка24
	И РаботыДляДавальца.Регистратор ЕСТЬ NULL
	//-- Устарело_Переработка24
	
	// Исключаем документы, по которым введено исправление или сторно в текущем периоде.
	И Реестр.Ссылка ЕСТЬ NULL
	И НЕ ЗатратыНЗП.Сторно
{ГДЕ
	((ЗатратыНЗП.Продукция, ЗатратыНЗП.ХарактеристикаПродукции) В
			(ВЫБРАТЬ
				ОтборПоСегментуНоменклатуры.Номенклатура,
				ОтборПоСегментуНоменклатуры.Характеристика
			ИЗ
				ОтборПоСегментуНоменклатуры
			ГДЕ
				ОтборПоСегментуНоменклатуры.ИспользуетсяОтборПоСегментуНоменклатуры = &amp;ИспользуетсяОтборПоСегментуНоменклатуры))}
//++ Устарело_Переработка24

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	ЗатратыНЗП.Организация,
	ВЫБОР
		КОГДА НЕ Константы.ИспользоватьУправлениеПроизводством2_2
			ТОГДА НЕОПРЕДЕЛЕНО
		КОГДА АналитикаВыпуска.ТипМестаХранения = ЗНАЧЕНИЕ(Перечисление.ТипыМестХранения.Подразделение)
			ТОГДА АналитикаВыпуска.Подразделение
		ИНАЧЕ АналитикаВыпуска.СкладскаяТерритория.Подразделение
	КОНЕЦ КАК ПодразделениеПродукции,
	ЗатратыНЗП.АналитикаУчетаПродукции КАК АналитикаПродукции,
	АналитикаВыпуска.Номенклатура КАК Продукция,
	АналитикаВыпуска.Характеристика КАК ХарактеристикаПродукции,
	АналитикаВыпуска.Номенклатура.ЕдиницаИзмерения КАК ЕдиницаИзмеренияПродукции,
	ВЫБОР 
		КОГДА &amp;ДетализироватьПоСериямВыпуска 
			ТОГДА АналитикаВыпуска.Серия 
		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка) 
	КОНЕЦ КАК СерияПродукции,
	АналитикаВыпуска.Назначение КАК НазначениеПродукции,
	ВЫБОР
		КОГДА НЕ &amp;ДетализироватьПоНазначениям
			ТОГДА ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
		КОГДА ИСТИНА
			ТОГДА АналитикаВыпуска.Назначение
	КОНЕЦ КАК НазначениеПолучателяПродукции,
	ЗатратыНЗП.СтатьяКалькуляции,
	"ПрочиеРасходы" КАК ВидЗатрат,
	ЗатратыНЗП.СтатьяРасходов КАК Затрата,
	ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка) КАК ХарактеристикаЗатраты,
	ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка) КАК СерияЗатраты,
	НЕОПРЕДЕЛЕНО КАК ЕдиницаИзмеренияЗатраты,
	ЗатратыНЗП.Подразделение,
	(ВЫБОР
		КОГДА ЗатратыНЗП.ЗаказНаПроизводство ЕСТЬ NULL ТОГДА НЕОПРЕДЕЛЕНО
		КОГДА ЗатратыНЗП.ЗаказНаПроизводство = ЗНАЧЕНИЕ(Справочник.РесурсныеСпецификации.ПустаяСсылка) Тогда НЕОПРЕДЕЛЕНО
		//++ Устарело_Производство21
		КОГДА ЗатратыНЗП.ЗаказНаПроизводство ССЫЛКА Документ.ВыпускПродукции ТОГДА НЕОПРЕДЕЛЕНО
		//-- Устарело_Производство21

		ИНАЧЕ ЗатратыНЗП.ЗаказНаПроизводство КОНЕЦ) КАК ЗаказНаПроизводство,
	ВЫБОР 
		КОГДА &amp;ДетализироватьПоПартиямПроизводства 
			ТОГДА ЗатратыНЗП.ПартияПроизводства 
		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ПартииПроизводства.ПустаяСсылка) 
	КОНЕЦ КАК ПартияПроизводства,
	ЗатратыНЗП.КодСтрокиПродукция,
	ЗатратыНЗП.Этап,
	ЗатратыНЗП.ГруппаПродукции,
	0 КАК КоличествоЗатрат,
	ВЫБОР КОГДА &amp;ДанныеПоСебестоимости = 1 ТОГДА
		ЗатратыНЗП.Стоимость
	КОГДА &amp;ДанныеПоСебестоимости = 2 ТОГДА
		ЗатратыНЗП.СтоимостьБезНДС
	КОГДА &amp;ДанныеПоСебестоимости = 3 ТОГДА
		ЗатратыНЗП.СтоимостьУпр
	КОГДА &amp;ДанныеПоСебестоимости = 4 ТОГДА
		ЗатратыНЗП.СтоимостьРегл
	ИНАЧЕ
		ВЫБОР КОГДА &amp;ПоПредприятию
			ТОГДА ЗатратыНЗП.СтоимостьБезНДС
			ИНАЧЕ ЗатратыНЗП.СтоимостьУпр
		КОНЕЦ
	КОНЕЦ КАК СтоимостьЗатрат,
	ВЫБОР
		КОГДА &amp;ДанныеПоСебестоимости = 4
			ТОГДА ЗатратыНЗП.ВременнаяРазница
		ИНАЧЕ 0
	КОНЕЦ КАК ВременнаяРазница,
	ВЫБОР
		КОГДА &amp;ДанныеПоСебестоимости = 4
			ТОГДА ЗатратыНЗП.ПостояннаяРазница
		ИНАЧЕ 0
	КОНЕЦ КАК ПостояннаяРазница,
	ВЫБОР
		КОГДА &amp;ДанныеПоСебестоимости = 4
			ТОГДА ЗатратыНЗП.СтоимостьНДД
		ИНАЧЕ 0
	КОНЕЦ КАК НДД,
	ВЫБОР
		КОГДА ПериодыДействияСреднескользящей.Организация ЕСТЬ NULL
			ТОГДА ЗатратыНЗП.Регистратор
		ИНАЧЕ НЕОПРЕДЕЛЕНО
	КОНЕЦ КАК Регистратор
ИЗ
	РегистрНакопления.ПрочиеРасходыНезавершенногоПроизводства КАК ЗатратыНЗП
		ЛЕВОЕ СОЕДИНЕНИЕ Константы КАК Константы
		ПО (ИСТИНА)
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РаботыДляДавальца КАК РаботыДляДавальца
			ПО РаботыДляДавальца.Регистратор = ЗатратыНЗП.Регистратор
			И РаботыДляДавальца.ВидЗапасов = ЗатратыНЗП.ВидЗапасов
			И РаботыДляДавальца.АналитикаУчетаНоменклатуры = ЗатратыНЗП.АналитикаУчетаПродукции
			И РаботыДляДавальца.АналитикаУчетаПартий = ЗатратыНЗП.КорАналитикаУчетаПартий
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.КлючиАналитикиУчетаНоменклатуры КАК АналитикаВыпуска
		ПО РаботыДляДавальца.КорАналитикаУчетаНоменклатуры = АналитикаВыпуска.Ссылка
		ЛЕВОЕ СОЕДИНЕНИЕ ПериодыДействияСреднескользящей КАК ПериодыДействияСреднескользящей
			ПО ПериодыДействияСреднескользящей.Организация = ЗатратыНЗП.Организация
			И ПериодыДействияСреднескользящей.ПериодДействия = НАЧАЛОПЕРИОДА(ЗатратыНЗП.Период, МЕСЯЦ)
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РеестрДокументов КАК Реестр
		ПО Реестр.СторнируемыйДокумент = ЗатратыНЗП.Регистратор
			И Реестр.СторноИсправление
			И (Реестр.ДатаДокументаИБ &lt;= &amp;КонецПериода ИЛИ &amp;КонецПериода = ДАТАВРЕМЯ(1,1,1))
			И Реестр.Проведен
ГДЕ
	ЗатратыНЗП.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
	И (ЗатратыНЗП.Период МЕЖДУ &amp;НачалоПериода И &amp;КонецПериода ИЛИ &amp;КонецПериода = ДАТАВРЕМЯ(1,1,1))
	// Исключаем документы, по которым введено исправление или сторно в текущем периоде.
	И Реестр.Ссылка ЕСТЬ NULL
	И НЕ ЗатратыНЗП.Сторно
{ГДЕ
	((ЗатратыНЗП.Продукция, ЗатратыНЗП.ХарактеристикаПродукции) В
			(ВЫБРАТЬ
				ОтборПоСегментуНоменклатуры.Номенклатура,
				ОтборПоСегментуНоменклатуры.Характеристика
			ИЗ
				ОтборПоСегментуНоменклатуры
			ГДЕ
				ОтборПоСегментуНоменклатуры.ИспользуетсяОтборПоСегментуНоменклатуры = &amp;ИспользуетсяОтборПоСегментуНоменклатуры))}
//-- Устарело_Переработка24
</query>
