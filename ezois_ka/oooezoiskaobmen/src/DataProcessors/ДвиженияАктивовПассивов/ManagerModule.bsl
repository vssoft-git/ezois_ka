Процедура ДобавитьПростойТекстЗапросаПоРегистру(Запрос, ТаблицаДвижений, ПараметрыЗапроса)
	
	ИмяТаблицы = ПараметрыЗапроса.ИмяТаблицы;
	ИмяРесурса = ПараметрыЗапроса.ИмяРесурса;
	ИмяСтатьиАП = "ОсновныеСредства";
	Если ПараметрыЗапроса.Свойство("ИмяСтатьиАП") Тогда
		ИмяСтатьиАП = ПараметрыЗапроса.ИмяСтатьиАП;
	КонецЕсли;
	ИмяПоляАналитики = ПараметрыЗапроса.ИмяПоляАналитики;
	ИмяВидаИсточника = "ДвиженияБаланса";
	Если ПараметрыЗапроса.Свойство("ВидИсточника") Тогда
		ИмяВидаИсточника = ПараметрыЗапроса.ВидИсточника;
	КонецЕсли;
	ПервичныйОтбор = "";
	Если ПараметрыЗапроса.Свойство("ПервичныйОтбор") Тогда
		ПервичныйОтбор = ПараметрыЗапроса.ПервичныйОтбор;
	КонецЕсли;
	ИмяВременнойТаблицы = "";
	Если ПараметрыЗапроса.Свойство("ИмяВременнойТаблицы") Тогда
		ИмяВременнойТаблицы = ПараметрыЗапроса.ИмяВременнойТаблицы;
	КонецЕсли;
	
	ПервичныеДвижения = "РегистрНакопления."+ИмяТаблицы;
	
	Если ТипЗнч(ТаблицаДвижений) = Тип("Строка") Тогда
		ПервичныеДвижения = ТаблицаДвижений;
	ИначеЕсли ТипЗнч(ТаблицаДвижений) = Тип("ТаблицаЗначений") Тогда
	
		Если ТаблицаДвижений.Количество() = 0 Тогда
			Возврат;
		КонецЕсли;
		
		ТекстЗапроса =
		"// ПервичныеДвижения
		|ВЫБРАТЬ
		|	&Регистратор КАК Регистратор,
		|	Т.ВидДвижения КАК ВидДвижения,
		|	Т.Период КАК Период,
		|	Т.Организация КАК Организация,
		|	Т.Подразделение КАК Подразделение,
		|	Т.НаправлениеДеятельности КАК НаправлениеДеятельности,
		|	Т.Аналитика КАК Аналитика,
		|	Т.ИмяРесурса КАК ИмяРесурса
		|ПОМЕСТИТЬ ПервичныеДвижения
		|ИЗ
		|	&ИмяТаблицы КАК Т
		|ГДЕ
		|	Т.ИмяРесурса <> 0
		|	И &ПервичныйОтбор";
		
		ПервичныеДвижения = "Первичные" + ?(ИмяВременнойТаблицы = "", ИмяТаблицы, ИмяВременнойТаблицы);
		ЗаменитьПодстановки(ТекстЗапроса, ИмяТаблицы, ПервичныеДвижения);
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ИмяРесурса", ИмяРесурса);
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "Аналитика", ИмяПоляАналитики);
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И &ПервичныйОтбор", ПервичныйОтбор);
		ПервичныйОтбор = "";
		
		Запрос.УстановитьПараметр(ИмяТаблицы, ТаблицаДвижений);
		ДобавитьЗначениеВПараметр(Запрос, "ТекстыЗапросов", ТекстЗапроса);
		ДобавитьЗначениеВПараметр(Запрос, "ВсеТаблицы", ПервичныеДвижения);
	
	КонецЕсли;
	
	ТекстЗапроса =
	"// %1
	|ВЫБРАТЬ
	|	Т.Регистратор КАК Регистратор,
	|	&ВидДвижения КАК ВидДвижения,
	|	Т.Период КАК Период,
	|	Т.Организация КАК Организация,
	|	Т.Подразделение КАК Подразделение,
	|	Т.НаправлениеДеятельности КАК НаправлениеДеятельности,
	|	ЗНАЧЕНИЕ(ПланВидовХарактеристик.СтатьиАктивовПассивов.УпрБалансОсновныеСредства) КАК Статья,
	|	Т.Аналитика КАК Аналитика,
	|	СУММА(Т.ИмяРесурса) КАК Сумма,
	|	СУММА(ВЫБОР КОГДА &ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) 
	|				ТОГДА -Т.ИмяРесурса 
	|				ИНАЧЕ Т.ИмяРесурса
	|		КОНЕЦ) КАК СуммаБаланса,
	|	ЗНАЧЕНИЕ(Перечисление.ВидыИсточниковДвижений.ДвиженияБаланса) КАК ВидИсточника,
	|	&Источник КАК Источник,
	|	ЛОЖЬ КАК РасчетСебестоимости,
	|	ЛОЖЬ КАК Сторно
	|
	|ПОМЕСТИТЬ ИмяТаблицы
	|ИЗ
	|	ПервичныеДвижения КАК Т
	|ГДЕ
	|	Т.ИмяРесурса <> 0
	|	И &Отбор
	|
	|СГРУППИРОВАТЬ ПО
	|	Т.Регистратор,
	|	&ВидДвижения,
	|	Т.Период,
	|	Т.Организация,
	|	Т.Подразделение,
	|	Т.Аналитика,
	|	Т.НаправлениеДеятельности";
	
	Если НЕ ПустаяСтрока(ПервичныйОтбор) Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И &Отбор", "И &Отбор" + ПервичныйОтбор);
	КонецЕсли;
	ТекстВидаДвижения = "Т.ВидДвижения";
	Если ПараметрыЗапроса.Свойство("ПоложительныйРесурс") Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса,"Т.ИмяРесурса", "ВЫБОР КОГДА Т.ИмяРесурса < 0 ТОГДА -Т.ИмяРесурса ИНАЧЕ Т.ИмяРесурса КОНЕЦ");
	КонецЕсли;
	Если ПараметрыЗапроса.Свойство("ИнвертироватьВидДвижения") Тогда
		ТекстВидаДвижения = "ВЫБОР КОГДА Т.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
							|		ТОГДА ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
							|		ИНАЧЕ ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
							|	КОНЕЦ";
	КонецЕсли;
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса,"&ВидДвижения", ТекстВидаДвижения);
	
	ДобавитьСоединениеРегистраторов(Запрос, ТекстЗапроса, ПервичныеДвижения);
	ДобавитьОтбор(Запрос, ТекстЗапроса);
	
	ЗаменитьПодстановки(ТекстЗапроса, ИмяТаблицы, ПервичныеДвижения);
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ИмяРесурса", ИмяРесурса);
	Если ПараметрыЗапроса.ИмяСтатьиАП = "ПрибылиИУбытки" Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "Т.Аналитика", "НЕОПРЕДЕЛЕНО");
	Иначе
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "Т.Аналитика", "Т." + ИмяПоляАналитики);
	КонецЕсли;
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, 
						"ЗНАЧЕНИЕ(ПланВидовХарактеристик.СтатьиАктивовПассивов.УпрБалансОсновныеСредства)", 
						"ЗНАЧЕНИЕ(ПланВидовХарактеристик.СтатьиАктивовПассивов." + ИмяСтатьиАП + ")");
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ДвиженияБаланса", ИмяВидаИсточника);
	
	Если ПустаяСтрока(ИмяВременнойТаблицы) Тогда
		ДобавитьЗначениеВПараметр(Запрос, "ТаблицыДвиженийНаправлений", ИмяТаблицы);
		ДобавитьЗначениеВПараметр(Запрос, "ВсеТаблицы", ИмяТаблицы);
	Иначе
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "/"+"/ " + ИмяТаблицы, "/"+"/ " + ИмяВременнойТаблицы);
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ПОМЕСТИТЬ " + ИмяТаблицы, "ПОМЕСТИТЬ " + ИмяВременнойТаблицы);
		ДобавитьЗначениеВПараметр(Запрос, "ТаблицыДвиженийНаправлений", ИмяВременнойТаблицы);
		ДобавитьЗначениеВПараметр(Запрос, "ВсеТаблицы", ИмяВременнойТаблицы);
		Запрос.Параметры.ИсточникВременнойТаблицы.Вставить(ИмяВременнойТаблицы, ИмяТаблицы);
	КонецЕсли;
	
	ДобавитьЗначениеВПараметр(Запрос, "ТекстыЗапросов", ТекстЗапроса);
	
КонецПроцедуры
