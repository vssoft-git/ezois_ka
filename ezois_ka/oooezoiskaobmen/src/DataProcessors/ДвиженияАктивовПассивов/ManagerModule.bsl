// ТрудозатратыНезавершенногоПроизводства
// 
// Параметры:
// 	Запрос - Запрос -
// 	ТаблицаДвижений - Произвольный - Описание
Процедура ДобавитьТекстЗапросаТрудозатратыНезавершенногоПроизводства(Запрос, ТаблицаДвижений)
	
	ИмяТаблицы = Метаданные.РегистрыНакопления.ТрудозатратыНезавершенногоПроизводства.Имя;
	ПервичныеДвижения = "РегистрНакопления."+ИмяТаблицы;
	
	Если ТипЗнч(ТаблицаДвижений) = Тип("Строка") Тогда
		ПервичныеДвижения = ТаблицаДвижений;
	ИначеЕсли ТипЗнч(ТаблицаДвижений) = Тип("ТаблицаЗначений") Тогда
	
		Если ТаблицаДвижений.Количество() = 0 Тогда
			Возврат;
		КонецЕсли;
		
		ТекстЗапроса =
		"// ПервичныеДвижения
		|ВЫБРАТЬ
		|	&Регистратор КАК Регистратор,
		|	Т.ВидДвижения КАК ВидДвижения,
		|	Т.Период КАК Период,
		|	Т.Организация КАК Организация,
		|	Т.Подразделение КАК Подразделение,
		|	Т.ЗаказНаПроизводство КАК ЗаказНаПроизводство,
		|	Т.ПартияПроизводства КАК ПартияПроизводства,
		|	Т.Сторно КАК Сторно,
		|	Т.Стоимость КАК Стоимость
		|ПОМЕСТИТЬ ПервичныеДвижения
		|ИЗ
		|	&ИмяТаблицы КАК Т
		|ГДЕ
		|	Т.Стоимость <> 0";
		
		ПервичныеДвижения = ПодготовитьПервичныеДвижения(Запрос, ТекстЗапроса, ИмяТаблицы, ТаблицаДвижений);
	
	КонецЕсли;
	
	ТекстЗапроса =
	"// %1
	|ВЫБРАТЬ
	|	Т.Регистратор КАК Регистратор,
	|	Т.ВидДвижения КАК ВидДвижения,
	|	Т.Период КАК Период,
	|	Т.Организация КАК Организация,
	|	Т.Подразделение КАК Подразделение,
	|	&НаправлениеДеятельности КАК НаправлениеДеятельности,
	|	ЗНАЧЕНИЕ(ПланВидовХарактеристик.СтатьиАктивовПассивов.УпрБалансНезавершенноеПроизводство) КАК Статья,
	|	НЕОПРЕДЕЛЕНО КАК Аналитика,
	|	СУММА(Т.Стоимость) КАК Сумма,
	|	СУММА(ВЫБОР КОГДА Т.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) ТОГДА -Т.Стоимость ИНАЧЕ Т.Стоимость КОНЕЦ) КАК СуммаБаланса,
	|	ЗНАЧЕНИЕ(Перечисление.ВидыИсточниковДвижений.РасчетСебестоимости) КАК ВидИсточника,
	|	&Источник КАК Источник,
	|	&РасчетСебестоимости КАК РасчетСебестоимости,
	|	Т.Сторно КАК Сторно
	|
	|ПОМЕСТИТЬ ИмяТаблицы
	|ИЗ
	|	ПервичныеДвижения КАК Т
	|ГДЕ
	|	Т.Стоимость <> 0
	|	И &Отбор
	|
	|СГРУППИРОВАТЬ ПО
	|	Т.Регистратор,
	|	Т.ВидДвижения,
	|	Т.Период,
	|	Т.Организация,
	|	Т.Подразделение,
	|	&НаправлениеДеятельности,
	|	Т.Сторно";
	
	Если ПолучитьФункциональнуюОпцию("УправлениеПредприятием") И ПолучитьФункциональнуюОпцию("ЛокализацияРФ")Тогда
		ПолеНаправленияДеятельности = "ЕСТЬNULL(Т.ЗаказНаПроизводство.НаправлениеДеятельности, ЗНАЧЕНИЕ(Справочник.НаправленияДеятельности.ПустаяСсылка))";
		Если Запрос.Параметры.Производство2_2 Тогда
			ПолеНаправленияДеятельности = "ЕСТЬNULL(Т.ПартияПроизводства.НаправлениеДеятельности, ЗНАЧЕНИЕ(Справочник.НаправленияДеятельности.ПустаяСсылка))";
		КонецЕсли;
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&НаправлениеДеятельности", ПолеНаправленияДеятельности);
	Иначе
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса,"&НаправлениеДеятельности", "ЗНАЧЕНИЕ(Справочник.НаправленияДеятельности.ПустаяСсылка)");
	КонецЕсли;
	
	ПодготовитьДвиженияНаправлений(Запрос, ТекстЗапроса, ИмяТаблицы, ПервичныеДвижения);
	
КонецПроцедуры

