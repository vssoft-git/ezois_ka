Функция ОтборПрибылиУбыткиДооценкиАмортизации()
	
	Возврат
	"
	|	//Дооценка накопленной амортизации
	|	И (Т.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
	|		И Т.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.УвеличениеАмортизацииОС)
	|		И (Т.Амортизация <> 0 ИЛИ НЕ Т.НачислятьИзнос И Т.АмортизацияРегл <> 0))";
	
КонецФункции

Функция ОтборПрибылиУбыткиДооценкиСтоимости()
	
	Возврат
	"
	|	//Дооценка восстановительной стоимости
	|	И (Т.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|		И Т.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.УвеличениеСтоимостиОС)
	|		И (Т.РезервПереоценкиСтоимостиРегл <> 0 ИЛИ Т.РезервПереоценкиСтоимости <> 0))";
	
КонецФункции

Функция ОтборПрибылиУбыткиРезерваПереоценкиСтоимостиОС()
	
	Возврат
	"
	|	//Резерв дооценки ОС
	|	И Т.ХозяйственнаяОперация В (
	|		ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ВводОстатковСтоимостиОС),
	|		ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.УменьшениеСтоимостиОСЗаСчетДооценки))";
	
КонецФункции

Функция ОтборПрибылиУбыткиРезерваПереоценкиСтоимостиНМА()
	
	Возврат
	"
	|	//Резерв дооценки НМА
	|	И Т.ХозяйственнаяОперация В (
	|		ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ВводОстатковНМАиРасходовНаНИОКР),
	|		ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.УменьшениеСтоимостиНМАЗаСчетДооценки))";
	
КонецФункции

