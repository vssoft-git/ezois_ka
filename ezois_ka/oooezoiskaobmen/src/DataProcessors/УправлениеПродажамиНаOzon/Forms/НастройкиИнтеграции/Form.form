  <attributes>
    <name>РегистрОграничениеОстатка</name>
    <title>
      <key>ru</key>
      <value>Регистр ограничение остатка</value>
    </title>
    <id>6</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>РегистрОграничениеОстатка.ОбластьДействия</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>РегистрОграничениеОстатка.ТипОбластиДействия</segments>
    </notDefaultUseAlwaysAttributes>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ВЫБОР
		КОГДА ТИПЗНАЧЕНИЯ(ОграниченияВыгрузкиОстатковМаркетплейсов.ОбластьДействия) = ТИП(Справочник.Номенклатура)
			ТОГДА СправНоменклатура.Наименование
		КОГДА ТИПЗНАЧЕНИЯ(ОграниченияВыгрузкиОстатковМаркетплейсов.ОбластьДействия) = ТИП(Справочник.ТоварныеКатегории)
			ТОГДА СправТоварныеКатегории.Наименование
		КОГДА ТИПЗНАЧЕНИЯ(ОграниченияВыгрузкиОстатковМаркетплейсов.ОбластьДействия) = ТИП(Справочник.ВидыНоменклатуры)
			ТОГДА СправВидыНоменклатуры.Наименование
		ИНАЧЕ &quot;&quot;
	КОНЕЦ КАК ПредставлениеОбластиДействия,
	ОграниченияВыгрузкиОстатковМаркетплейсов.ОбластьДействия КАК ОбластьДействия,
	ВЫБОР
		КОГДА ТИПЗНАЧЕНИЯ(ОграниченияВыгрузкиОстатковМаркетплейсов.ОбластьДействия) = ТИП(Справочник.Номенклатура)
				И НЕ ВЫРАЗИТЬ(ОграниченияВыгрузкиОстатковМаркетплейсов.ОбластьДействия КАК Справочник.Номенклатура).ЭтоГруппа
			ТОГДА &amp;ОписаниеНоменклатура
		КОГДА ТИПЗНАЧЕНИЯ(ОграниченияВыгрузкиОстатковМаркетплейсов.ОбластьДействия) = ТИП(Справочник.Номенклатура)
				И ВЫРАЗИТЬ(ОграниченияВыгрузкиОстатковМаркетплейсов.ОбластьДействия КАК Справочник.Номенклатура).ЭтоГруппа
			ТОГДА &amp;ОписаниеГруппаНоменклатуры
		КОГДА ТИПЗНАЧЕНИЯ(ОграниченияВыгрузкиОстатковМаркетплейсов.ОбластьДействия) = ТИП(Справочник.ТоварныеКатегории)
			ТОГДА &amp;ОписаниеТоварнаяКатегория
		КОГДА ТИПЗНАЧЕНИЯ(ОграниченияВыгрузкиОстатковМаркетплейсов.ОбластьДействия) = ТИП(Справочник.ВидыНоменклатуры)
			ТОГДА &amp;ОписаниеВидНоменклатуры
	КОНЕЦ КАК ТипОбластиДействия,
	ОграниченияВыгрузкиОстатковМаркетплейсов.ПредставлениеОграничения КАК ПредставлениеОграничения
ИЗ
	РегистрСведений.ОграниченияВыгрузкиОстатковМаркетплейсов КАК ОграниченияВыгрузкиОстатковМаркетплейсов
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СправНоменклатура
		ПО ОграниченияВыгрузкиОстатковМаркетплейсов.ОбластьДействия = СправНоменклатура.Ссылка
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВидыНоменклатуры КАК СправВидыНоменклатуры
		ПО ОграниченияВыгрузкиОстатковМаркетплейсов.ОбластьДействия = СправВидыНоменклатуры.Ссылка
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ТоварныеКатегории КАК СправТоварныеКатегории
		ПО ОграниченияВыгрузкиОстатковМаркетплейсов.ОбластьДействия = СправТоварныеКатегории.Ссылка
ГДЕ
	ОграниченияВыгрузкиОстатковМаркетплейсов.УчетнаяЗаписьМаркетплейса = &amp;УчетнаяЗаписьМаркетплейса</queryText>
      <mainTable>InformationRegister.ОграниченияВыгрузкиОстатковМаркетплейсов</mainTable>
      <dynamicDataRead>true</dynamicDataRead>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
  </attributes>
