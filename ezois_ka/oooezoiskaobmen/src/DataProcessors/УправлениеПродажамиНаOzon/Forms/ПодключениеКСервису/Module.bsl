
#Область ОписаниеПеременных

&НаКлиенте
Перем РезультатАвторизации;

&НаКлиенте
Перем ПутьКФайлуАвторизации;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	ЭтоРедактированиеНастроек = ЗначениеЗаполнено(Параметры.УчетнаяЗапись);
	Если ЭтоРедактированиеНастроек Тогда
		УчетнаяЗаписьСсылка = Параметры.УчетнаяЗапись;
		Реквизиты = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(
			УчетнаяЗаписьСсылка,
			"Организация, ВидМаркетплейса, ИдентификаторКлиента, НеОбновлятьДанныеТорговойПлощадки");
		ЗаполнитьЗначенияСвойств(УчетнаяЗаписьМаркетплейса, Реквизиты);
		
		КлючAPI = НСтр("ru = 'Ключ API сохранен в настройках подключения.'");
	Иначе
		УчетнаяЗаписьМаркетплейса.ВидМаркетплейса = ПредопределенноеЗначение("Перечисление.ВидыМаркетплейсов.МаркетплейсOzon");
		Элементы.КлючAPI.ОбновлениеТекстаРедактирования = ОбновлениеТекстаРедактирования.НеИспользовать;
	КонецЕсли;
	
	ОбменДанными = Не УчетнаяЗаписьМаркетплейса.НеОбновлятьДанныеТорговойПлощадки;
	
	НастроитьФорму(Не ЭтоРедактированиеНастроек);

КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)

	Если ИмяСобытия = "УчетнаяЗаписьДеактивирована"
			И Параметр = УчетнаяЗаписьСсылка Тогда
		КлючAPI = "";
		ПроверкаПройдена = Ложь;
		
		НастроитьФорму();
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ОрганизацияПриИзменении(Элемент)

	ПроверитьНаличиеУчетнойЗаписи();

КонецПроцедуры

&НаКлиенте
Процедура ИдентификаторКлиентаПриИзменении(Элемент)

	ПроверитьНаличиеУчетнойЗаписи();

КонецПроцедуры

&НаКлиенте
Процедура КлючAPIНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)

	КлючAPI = "";
	ПроверкаПройдена = Ложь;
	Модифицированность = Истина;
	
	ИзменитьПоведениеЭлементовФормы();
	
	Элементы.КлючAPI.ОбновлениеТекстаРедактирования = ОбновлениеТекстаРедактирования.НеИспользовать;

КонецПроцедуры

&НаКлиенте
Процедура КлючAPIИзменениеТекстаРедактирования(Элемент, Текст, СтандартнаяОбработка)

	СтандартнаяОбработка = Ложь;
	
	Если Не Элементы.ДекорацияТребуетсяПроверка.Видимость Тогда
		ПодключитьОбработчикОжидания("ИзменитьРезультатПодключения", 0.01, Истина);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ОбменДаннымиПриИзменении(Элемент)

	Если ЗначениеЗаполнено(УчетнаяЗаписьСсылка) Тогда
		ИзменениеВыполнено =
			ИнтеграцияСМаркетплейсомOzonВызовСервера.ИзменитьКонтрольОбновленияДанныхТорговойПлощадки(
				УчетнаяЗаписьСсылка,
				Не ОбменДанными);
		
		Если ИзменениеВыполнено Тогда
			Оповестить("ОбновитьСписокПодключений");
			Оповестить("Запись_УчетныеЗаписиМаркетплейсов", УчетнаяЗаписьСсылка);
		Иначе
			ОбменДанными = Не ОбменДанными;
		КонецЕсли;
	КонецЕсли;
	
	УчетнаяЗаписьМаркетплейса.НеОбновлятьДанныеТорговойПлощадки = Не ОбменДанными;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Подключить(Команда)

	ОчиститьСообщения();

	Если Не ЗначениеЗаполнено(УчетнаяЗаписьМаркетплейса.Организация)
		Или Не ЗначениеЗаполнено(УчетнаяЗаписьМаркетплейса.ИдентификаторКлиента)
		Или Не ЗначениеЗаполнено(КлючAPI) Тогда

		ТекстСообщения = НСтр("ru = 'Заполните все поля для подключения к маркетплейсу Ozon'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);

		Возврат;
	КонецЕсли;

	ВыполнитьПодключение(Истина, Истина);
	
	Если ПроверкаПройдена Тогда
		Оповестить("ОбновитьСписокПодключений");
		
		Элементы.КлючAPI.ОбновлениеТекстаРедактирования = ОбновлениеТекстаРедактирования.Авто;
	КонецЕсли;
	
	Модифицированность = Не ПроверкаПройдена;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ПроверитьНаличиеУчетнойЗаписи()

	ЭтоДубль = Ложь;

	УчетнаяЗаписьСсылка = Справочники.УчетныеЗаписиМаркетплейсов.ПустаяСсылка();

	Если ЗначениеЗаполнено(УчетнаяЗаписьМаркетплейса.ИдентификаторКлиента) Тогда
		Запрос = Новый Запрос; 
		Запрос.УстановитьПараметр("ИдентификаторКлиента", УчетнаяЗаписьМаркетплейса.ИдентификаторКлиента);
		Запрос.Текст =
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	УчетныеЗаписиМаркетплейсов.Ссылка КАК УчетнаяЗаписьМаркетплейса,
			|	УчетныеЗаписиМаркетплейсов.Организация КАК Организация,
			|	УчетныеЗаписиМаркетплейсов.ПометкаУдаления КАК ПометкаУдаления
			|ИЗ
			|	Справочник.УчетныеЗаписиМаркетплейсов КАК УчетныеЗаписиМаркетплейсов
			|ГДЕ
			|	УчетныеЗаписиМаркетплейсов.ВидМаркетплейса = Значение(Перечисление.ВидыМаркетплейсов.МаркетплейсOzon)
			|	И УчетныеЗаписиМаркетплейсов.ИдентификаторКлиента = &ИдентификаторКлиента
			|
			|УПОРЯДОЧИТЬ ПО
			|	ПометкаУдаления";
		
		УстановитьПривилегированныйРежим(Истина);
		ВыборкаДанныхПроверки = Запрос.Выполнить().Выбрать();
		УстановитьПривилегированныйРежим(Ложь);
		
		Если ВыборкаДанныхПроверки.Следующий() Тогда
			Если ВыборкаДанныхПроверки.ПометкаУдаления Тогда
				УчетнаяЗаписьСсылка = ВыборкаДанныхПроверки.УчетнаяЗаписьМаркетплейса;
			Иначе
				ЭтоДубль = Истина;

				ИнформацияОДубле = НСтр("ru = 'Для указанного клиентского идентификатора уже существует активная учетная запись для организации <%1>. Создание новой учетной записи невозможно.'");
				Элементы.ДекорацияИнформацияОДубле.Заголовок = 
						СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ИнформацияОДубле, ВыборкаДанныхПроверки.Организация);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;

	Элементы.ГруппаДанныеКлючаAPI.Видимость = Не ЭтоДубль;
	Элементы.ГруппаИнформацияОДубле.Видимость = ЭтоДубль;
	Элементы.Подключить.Доступность = Не ЭтоДубль;

КонецПроцедуры

&НаСервере
Процедура ВыполнитьПодключение(СохранитьНастройки = Ложь, НастроитьФорму = Ложь)

	Если Не ПроверкаПройдена Тогда
		Если СохранитьНастройки Тогда
			ДанныеУчетнойЗаписи = Новый Структура;
			ДанныеУчетнойЗаписи.Вставить("Организация", УчетнаяЗаписьМаркетплейса.Организация);
			ДанныеУчетнойЗаписи.Вставить("ИдентификаторКлиента", УчетнаяЗаписьМаркетплейса.ИдентификаторКлиента);
			ДанныеУчетнойЗаписи.Вставить("КлючAPI", КлючAPI);
			ДанныеУчетнойЗаписи.Вставить("УникальныйИдентификатор", Неопределено);
		Иначе
			ДанныеУчетнойЗаписи = УчетнаяЗаписьСсылка;
		КонецЕсли;
		
		ПроверкаПройдена = ИнтеграцияСМаркетплейсомOzonСервер.ПроверитьСвязьСМаркетплейсом(ДанныеУчетнойЗаписи);
	КонецЕсли;
	
	Если СохранитьНастройки
			И ПроверкаПройдена Тогда
		ПроверкаПройдена = ЗаписатьДанныеВХранилище();
	КонецЕсли;
	
	Если НастроитьФорму Тогда
		Если ПроверкаПройдена Тогда
			НастроитьФорму(Ложь);
		Иначе
			ИзменитьПоведениеЭлементовФормы(, ПроверкаПройдена);
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаСервере
Функция ЗаписатьДанныеВХранилище()

	ЗаписьУспешна = Истина;

	НачатьТранзакцию(РежимУправленияБлокировкойДанных.Управляемый);

	Попытка

		Если ЗначениеЗаполнено(УчетнаяЗаписьСсылка) Тогда
			БлокировкаДанных = Новый БлокировкаДанных;
			ЗаблокироватьДанныеДляРедактирования(УчетнаяЗаписьСсылка);
			ЭлементБлокировки = БлокировкаДанных.Добавить("Справочник.УчетныеЗаписиМаркетплейсов");
			ЭлементБлокировки.УстановитьЗначение("Ссылка", УчетнаяЗаписьСсылка);
			БлокировкаДанных.Заблокировать();

			УчетнаяЗаписьОбъект = УчетнаяЗаписьСсылка.ПолучитьОбъект();
			УстановитьНаименование = УчетнаяЗаписьОбъект.Организация <> УчетнаяЗаписьМаркетплейса.Организация;
			УчетнаяЗаписьОбъект.Организация = УчетнаяЗаписьМаркетплейса.Организация;
			УчетнаяЗаписьОбъект.ПометкаУдаления = Ложь;
			
			Если УстановитьНаименование Тогда
				ПроверитьСохраненныеНастройкиУчетнойЗаписи(
					УчетнаяЗаписьОбъект,
					УчетнаяЗаписьСсылка,
					УчетнаяЗаписьМаркетплейса.Организация);
			КонецЕсли;
		Иначе
			БлокировкаДанных = Новый БлокировкаДанных;
			ЗаблокироватьДанныеДляРедактирования(УчетнаяЗаписьМаркетплейса.Ссылка);
			ЭлементБлокировки = БлокировкаДанных.Добавить("Справочник.УчетныеЗаписиМаркетплейсов");
			ЭлементБлокировки.УстановитьЗначение("Ссылка", УчетнаяЗаписьМаркетплейса.Ссылка);
			БлокировкаДанных.Заблокировать();

			УчетнаяЗаписьОбъект = РеквизитФормыВЗначение("УчетнаяЗаписьМаркетплейса", Тип("СправочникОбъект.УчетныеЗаписиМаркетплейсов"));
			УчетнаяЗаписьОбъект.ВалютаУчета = ЗначениеНастроекКлиентСерверПовтИсп.ВалютаРегламентированногоУчетаОрганизации(УчетнаяЗаписьОбъект.Организация);
			УчетнаяЗаписьОбъект.ИсточникКатегории = Перечисления.ИсточникиКатегорийДляМаркетплейса.ИерархияНоменклатуры;
			УстановитьНаименование = Истина;
		КонецЕсли;

		Если УстановитьНаименование Тогда
			УчетнаяЗаписьОбъект.Наименование = Строка(УчетнаяЗаписьОбъект.Организация) + " (" + Строка(УчетнаяЗаписьОбъект.ИдентификаторКлиента) + ")";
		КонецЕсли;

		УчетнаяЗаписьОбъект.ВидМаркетплейса = Перечисления.ВидыМаркетплейсов.МаркетплейсOzon;
		УчетнаяЗаписьОбъект.НеОбновлятьДанныеТорговойПлощадки = Не ОбменДанными;
		УчетнаяЗаписьОбъект.Записать();

		ИнтеграцияСМаркетплейсомOzonСервер.ЗаписатьКлючАвторизации(УчетнаяЗаписьОбъект.Ссылка, КлючAPI);

		ЗафиксироватьТранзакцию();

	Исключение

		ОтменитьТранзакцию();

		ЗаписьУспешна = Ложь;

		ШаблонСообщения = НСтр("ru = 'Не удалось выполнить подключение по причине: %1'");
		ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонСообщения, ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
	КонецПопытки;

	Возврат ЗаписьУспешна;

КонецФункции

&НаСервереБезКонтекста
Процедура ПроверитьСохраненныеНастройкиУчетнойЗаписи(ПриемникНастроек, ИсточникНастроек, Организация)

	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	УчетныеЗаписиМаркетплейсов.Соглашение.Организация КАК СоглашениеОрганизация,
		|	УчетныеЗаписиМаркетплейсов.ДоговорПродажиЧерезСкладыТорговойПлощадки.Организация КАК ДоговорFBOОрганизация,
		|	УчетныеЗаписиМаркетплейсов.ДоговорПродажиЧерезСкладыСобственные.Организация КАК ДоговорFBSОрганизация,
		|	ЕСТЬNULL(ДоговорыКонтрагентов.Организация, ЕСТЬNULL(СоглашенияСКлиентами.Организация, НЕОПРЕДЕЛЕНО)) КАК ОрганизацияНастройки,
		|	ЕСТЬNULL(УчетныеЗаписиМаркетплейсовДополнительныеНастройки.ИдентификаторНастройки, """") КАК ИдентификаторНастройки
		|ИЗ
		|	Справочник.УчетныеЗаписиМаркетплейсов.ДополнительныеНастройки КАК УчетныеЗаписиМаркетплейсовДополнительныеНастройки
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.УчетныеЗаписиМаркетплейсов КАК УчетныеЗаписиМаркетплейсов
		|		ПО УчетныеЗаписиМаркетплейсовДополнительныеНастройки.Ссылка = УчетныеЗаписиМаркетплейсов.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
		|		ПО УчетныеЗаписиМаркетплейсовДополнительныеНастройки.ЗначениеНастройкиСсылка = ДоговорыКонтрагентов.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СоглашенияСКлиентами КАК СоглашенияСКлиентами
		|		ПО УчетныеЗаписиМаркетплейсовДополнительныеНастройки.ЗначениеНастройкиСсылка = СоглашенияСКлиентами.Ссылка
		|ГДЕ
		|	УчетныеЗаписиМаркетплейсов.Ссылка = &Ссылка
		|ИТОГИ ПО
		|	СоглашениеОрганизация,
		|	ДоговорFBOОрганизация,
		|	ДоговорFBSОрганизация";
	Запрос.УстановитьПараметр("Ссылка", ИсточникНастроек);
	
	УстановитьПривилегированныйРежим(Истина);
	ВыборкаОсновныхНастроек = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	УстановитьПривилегированныйРежим(Ложь);
	
	Если ВыборкаОсновныхНастроек.Следующий() Тогда
		Если ЗначениеЗаполнено(ВыборкаОсновныхНастроек.СоглашениеОрганизация)
				И ВыборкаОсновныхНастроек.СоглашениеОрганизация <> Организация Тогда
			ПриемникНастроек.Соглашение = Справочники.СоглашенияСКлиентами.ПустаяСсылка();
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ВыборкаОсновныхНастроек.ДоговорFBOОрганизация)
				И ВыборкаОсновныхНастроек.ДоговорFBOОрганизация <> Организация Тогда
			ПриемникНастроек.ДоговорПродажиЧерезСкладыТорговойПлощадки = Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ВыборкаОсновныхНастроек.ДоговорFBSОрганизация)
				И ВыборкаОсновныхНастроек.ДоговорFBSОрганизация <> Организация Тогда
			ПриемникНастроек.ДоговорПродажиЧерезСкладыСобственные = Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
		КонецЕсли;
		
		ВыборкаДополнительныхНастроек = ВыборкаОсновныхНастроек.Выбрать();
		Пока ВыборкаДополнительныхНастроек.Следующий() Цикл
			Если ЗначениеЗаполнено(ВыборкаДополнительныхНастроек.ОрганизацияНастройки)
					И ВыборкаДополнительныхНастроек.ОрганизацияНастройки <> Организация Тогда
				СтрокаНастройки = ПриемникНастроек.ДополнительныеНастройки.Найти(
					ВыборкаДополнительныхНастроек.ИдентификаторНастройки,
					"ИдентификаторНастройки");
				
				Если СтрокаНастройки <> Неопределено Тогда
					ПриемникНастроек.ДополнительныеНастройки.Удалить(СтрокаНастройки);
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура НастроитьФорму(ЭтоПодключение = Истина)

	Если ЭтоПодключение Тогда
		
		ЭтотОбъект.Заголовок = НСтр("ru = 'Подключение к Ozon'");
		
		Элементы.ДекорацияЛоготип.Подсказка =
			НСтр("ru = 'Для подключения к Ozon укажите организацию, введите клиентский идентификатор и уникальный ключ API.'");
		
		Элементы.Организация.Заголовок = НСтр("ru = 'Выберите организацию'");
		Элементы.Организация.ОтображениеПодсказки = ОтображениеПодсказки.ОтображатьСнизу;
		Элементы.Организация.ТолькоПросмотр = Ложь;
		
		Элементы.ИдентификаторКлиента.Заголовок = НСтр("ru = 'Введите клиентский идентификатор'");
		Элементы.ИдентификаторКлиента.ТолькоПросмотр = Ложь;
		Элементы.ИдентификаторКлиента.ОтображениеПодсказки = ОтображениеПодсказки.ОтображатьСнизу;
		
		РезультатПодключения = Неопределено;
		
	Иначе
		
		ЭтотОбъект.Заголовок = НСтр("ru = 'Изменение подключения к Ozon'");
		
		Элементы.ДекорацияЛоготип.Подсказка =
			НСтр("ru = 'Для текущего подключения к Ozon можно изменить уникальный ключ API, если используемый ключ неактуален или работает с недостаточным составом методов API.'");
		
		Элементы.Организация.Заголовок = НСтр("ru = 'Организация'");
		Элементы.Организация.ОтображениеПодсказки = ОтображениеПодсказки.Нет;
		Элементы.Организация.ТолькоПросмотр = Истина;
		
		Элементы.ИдентификаторКлиента.Заголовок = НСтр("ru = 'Клиентский идентификатор'");
		Элементы.ИдентификаторКлиента.ТолькоПросмотр = Истина;
		Элементы.ИдентификаторКлиента.ОтображениеПодсказки = ОтображениеПодсказки.Нет;
		
		Если Не ПроверкаПройдена Тогда
			ВыполнитьПодключение(Ложь);
		КонецЕсли;
		
		РезультатПодключения = ПроверкаПройдена;
		
	КонецЕсли;
	
	ИзменитьПоведениеЭлементовФормы(ЭтоПодключение, РезультатПодключения);

КонецПроцедуры

&НаСервере
Процедура ИзменитьПоведениеЭлементовФормы(ЭтоПодключение = Истина, РезультатПодключения = Неопределено)

	Элементы.Подключить.Видимость = ЭтоПодключение;
	Элементы.ОчиститьНастройкиАвторизации.Видимость = Не ЭтоПодключение;
	
	Если ЭтоПодключение Тогда
		Элементы.КлючAPI.Заголовок = НСтр("ru = 'Введите уникальный ключ API'");
		Элементы.КлючAPI.ОтображениеПодсказки = ОтображениеПодсказки.ОтображатьСнизу;
	Иначе
		Элементы.КлючAPI.Заголовок = НСтр("ru = 'Уникальный ключ API'");
		Элементы.КлючAPI.ОтображениеПодсказки = ОтображениеПодсказки.Нет;
	КонецЕсли;
	
	Элементы.КлючAPI.РежимПароля = Не ЭтоПодключение;
	Элементы.КлючAPI.КнопкаВыбора = Не ЭтоПодключение;
	Элементы.КлючAPI.РедактированиеТекста = ЭтоПодключение И РезультатПодключения <> Истина;
	
	Если ЭтоПодключение Тогда
		Элементы.Закрыть.Заголовок = НСтр("ru = 'Отмена'");
	Иначе
		Элементы.Закрыть.Заголовок = НСтр("ru = 'Закрыть'");
	КонецЕсли;
	
	ОтобразитьРезультатПодключения(РезультатПодключения);

КонецПроцедуры

&НаКлиенте
Процедура ИзменитьРезультатПодключения()

	ОчиститьСообщения();
	ОтобразитьРезультатПодключения();

КонецПроцедуры

&НаСервере
Процедура ОтобразитьРезультатПодключения(РезультатПодключения = Неопределено)

	Если РезультатПодключения = Неопределено Тогда
		Элементы.ДекорацияТребуетсяПроверка.Видимость = Истина;
		Элементы.ДекорацияПроверкаПройдена.Видимость = Ложь;
		Элементы.ДекорацияПроверкаЗавершенаСОшибкой.Видимость = Ложь;
	ИначеЕсли РезультатПодключения = Истина Тогда
		Элементы.ДекорацияТребуетсяПроверка.Видимость = Ложь;
		Элементы.ДекорацияПроверкаПройдена.Видимость = Истина;
		Элементы.ДекорацияПроверкаЗавершенаСОшибкой.Видимость = Ложь;
	Иначе
		Элементы.ДекорацияТребуетсяПроверка.Видимость = Ложь;
		Элементы.ДекорацияПроверкаПройдена.Видимость = Ложь;
		Элементы.ДекорацияПроверкаЗавершенаСОшибкой.Видимость = Истина;
		
		Если Не ПустаяСтрока(КлючAPI) Тогда
			Элементы.КлючAPI.УстановитьГраницыВыделения(1, СтрДлина(КлючAPI) + 1);
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

#КонецОбласти
