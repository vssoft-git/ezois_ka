Функция НоваяТаблицаКодовСимволовРасширенийФайлов() 
	
	ТаблицаКодов = Новый ТаблицаЗначений;
	ТаблицаКодов.Колонки.Добавить("Расширение", ОбщегоНазначения.ОписаниеТипаСтрока(13));
	ТаблицаКодов.Колонки.Добавить("УникальныйНаборСимволов", ОбщегоНазначения.ОписаниеТипаСтрока(0));
	Возврат ТаблицаКодов;
	
КонецФункции

