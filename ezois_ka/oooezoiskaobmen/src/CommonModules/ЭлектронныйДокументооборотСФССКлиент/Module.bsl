Процедура ОткрытьЗаявлениеНаДобавлениеНаправленияСФР(Организация, Оповещение = Неопределено) Экспорт
	
	ПараметрыОткрытияФормы = Новый Структура();
	ПараметрыОткрытияФормы.Вставить("Организация", Организация);
	
	ФлагиВМастер = Новый Структура();
	ФлагиВМастер.Вставить("ПодключаемоеНаправление",
		ПредопределенноеЗначение("Перечисление.ТипыКонтролирующихОрганов.ФСС"));
	ФлагиВМастер.Вставить("ПродлитьСертификат", 						Ложь);
	ФлагиВМастер.Вставить("ИзменитьРеквизитыПодключенияК1СОтчетности", 	Ложь);
	ФлагиВМастер.Вставить("ПродлитьЛицензиюНа1СОтчетность", 			Ложь);
	//ФлагиВМастер.Вставить("ОтпечатокСертификата", 						"");
	
	ДополнительныеПараметры = Новый Структура();
	ДополнительныеПараметры.Вставить("ФлагиВМастер", ФлагиВМастер);
	
	ПараметрыОткрытияФормы.Вставить("АктивироватьФлагиМастера", ДополнительныеПараметры);
	
	ЭлектронныйДокументооборотСКонтролирующимиОрганамиКлиент.ОткрытьФормуМастераЗаявленияНаПодключение(
		Организация,
		, , ПредопределенноеЗначение("Перечисление.ТипыЗаявленияАбонентаСпецоператораСвязи.Изменение"),
		ПараметрыОткрытияФормы, Оповещение);
		
КонецПроцедуры

Процедура ОткрытьФормуПереключенияОрганизацийНаОператораСЭДО(Владелец) Экспорт
	
	ОткрытьФорму("ОбщаяФорма.ПереключениеОрганизацийНаОператораСЭДО", , Владелец);
	
КонецПроцедуры

Процедура ОткрытьФормуПодробнееОПереключенияНаОператораСЭДО(Владелец, Организация = Неопределено) Экспорт
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Организация", Организация);
	ПараметрыФормы.Вставить("РезультатАнализа", Неопределено);
	ПараметрыФормы.Вставить("НеВыводитьДействия", Ложь);
	
	Если Владелец.ИмяФормы = "ОбщаяФорма.ПереключениеОрганизацийНаОператораСЭДО" Тогда
		ПараметрыФормы.НеВыводитьДействия = Истина;
	КонецЕсли;
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Владелец,
			"НадписьПереходНаОператораСЭДО_ДанныеАнализа") Тогда
		ДанныеАнализа = Владелец.НадписьПереходНаОператораСЭДО_ДанныеАнализа;
		ПараметрыФормы.РезультатАнализа = ДанныеАнализа;
	КонецЕсли;
	
	ОткрытьФорму("ОбщаяФорма.ПодробнеОПереходеНаОператораСЭДО",
		ПараметрыФормы, Владелец, , , , ,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

Процедура ОткрытьФормуПередПереключениемНаОператораСЭДО(Владелец, Знач Организация = Неопределено,
			ПодключатьДругиеОрганизации = Истина) Экспорт
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Организация", Неопределено);
	ПараметрыФормы.Вставить("ПредлагатьПодключатьДругиеОрганизации", ПодключатьДругиеОрганизации);
	
	Если НЕ Организация = Неопределено Тогда
		ПараметрыФормы.Организация = Организация;
	Иначе
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Владелец,
				"НадписьПереходНаОператораСЭДО_ДанныеАнализа") Тогда
			ДанныеАнализа = Владелец.НадписьПереходНаОператораСЭДО_ДанныеАнализа;
			Если ДанныеАнализа.ОрганизацииОбменНапрямую.Количество() > 1 Тогда
				ОткрытьФормуПереключенияОрганизацийНаОператораСЭДО(Владелец);
				Возврат;
			ИначеЕсли ДанныеАнализа.ОднаОрганизация
				И ДанныеАнализа.ОрганизацииОбменНапрямую.Количество() > 0 Тогда
				Организация = ДанныеАнализа.ОрганизацииОбменНапрямую[0];
				ПараметрыФормы.Организация = Организация;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	ОткрытьФорму("ОбщаяФорма.ПередПереключениемНаОператораСЭДО",
		ПараметрыФормы, Владелец, , , , , РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

Асинх Функция ЗаписатьНастройкуПоказаПанелиПереключениеНаОператораСЭДО(Форма, ЗначениеНастройки) Экспорт
	
	ТекстВопроса = НСтр("ru='Вы уверены, что хотите скрыть панель навсегда?'")
		+ Символы.ПС + Символы.ПС + НСтр("ru='При необходимости вы сможете подключиться к 1С-Отчетности позже из раздела ""Настройки"" формы ""1С-Отчетность"".'");
		
	//ТекстВопроса = НСтр("ru='Подключение 1С-Отчетности позволит обмениваться документами с СЭДО СФР без ошибок. Настоятельно рекомендуем подключить. Продолжить?'");
	Кнопки = Новый СписокЗначений;
	Кнопки.Добавить("ПерейтиКПодключению",
		НСтр("ru='Перейти к подключению'"));
	Кнопки.Добавить("БольшеНеПоказывать",
		НСтр("ru='Больше не показывать'"));
	Кнопки.Добавить("Отмена",
		НСтр("ru='Отмена'"));
		
	//ДополнительныеПараметры = Новый Структура;
	//ДополнительныеПараметры.Вставить("Форма", Форма);
	//ДополнительныеПараметры.Вставить("ЗначениеНастройки", ЗначениеНастройки);
	
	//Оповещение = Новый ОписаниеОповещения("ЗаписатьНастройкуПоказаПанелиПереключениеНаОператораСЭДОПослеВопроса",
	//	ЭтотОбъект, ДополнительныеПараметры);
	//
	//ОткрытьФорму("ОбщаяФорма.ВопросОбОтключенииПоказаПанелиПереходаНаОператораСЭДО",
	//	, Форма, Форма.УникальныйИдентификатор, , , Оповещение, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
	РезультВопроса = Ждать ВопросАсинх(ТекстВопроса, РежимДиалогаВопрос.ОКОтмена, 0, КодВозвратаДиалога.ОК);
	
	Если РезультВопроса = КодВозвратаДиалога.ОК Тогда
		ИмяНастройки = ЭлектронныйДокументооборотСФССКлиентСервер.НастройкаЗакрытьПанельПереходаНаОператораСЭДО(
					Форма.ИмяФормы);
		ДокументооборотСКОВызовСервера.СохранитьНастройку(
			ИмяНастройки,
			ЗначениеНастройки);
		ЭлектронныйДокументооборотСФССКлиентСервер.ПрорисоватьПанельПереходаНаОператораСЭДО(Форма);
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

Процедура ЗаписатьНастройкуПоказаПанелиПереключениеНаОператораСЭДОПослеВопроса(РезультВопроса, ДополнительныеПараметры) Экспорт
	
	Если РезультВопроса = "ПерейтиКПодключению" Тогда
		ОткрытьФорму("ОбщаяФорма.ПереключениеОрганизацийНаОператораСЭДО");
	ИначеЕсли РезультВопроса = "БольшеНеПоказывать" Тогда
		ИмяНастройки = ЭлектронныйДокументооборотСФССКлиентСервер.НастройкаЗакрытьПанельПереходаНаОператораСЭДО(
					ДополнительныеПараметры.Форма.ИмяФормы);
		ДокументооборотСКОВызовСервера.СохранитьНастройку(
			ИмяНастройки,
			ДополнительныеПараметры.ЗначениеНастройки);
		ЭлектронныйДокументооборотСФССКлиентСервер.ПрорисоватьПанельПереходаНаОператораСЭДО(ДополнительныеПараметры.Форма);
	КонецЕсли;
		
КонецПроцедуры

Асинх Функция ПереключениеНаОператораСЭДООбработкаНавигационнойСсылки(Форма, Знач Элемент,
					НавигационнаяСсылкаФорматированнойСтроки) Экспорт
					
	Если Элемент = Неопределено Тогда
		Элемент = Форма.ТекущийЭлемент;
	КонецЕсли;
	
	Если Элемент.Имя = "КартинкаЗакрытьПереходНаОператораСЭДО" Тогда
		Ждать ЗаписатьНастройкуПоказаПанелиПереключениеНаОператораСЭДО(
			Форма, Ложь);
		Возврат Истина;
	КонецЕсли;
	
	Если СтрНайти(НавигационнаяСсылкаФорматированнойСтроки, "ПереключениеНаОператораПодробнее") > 0 Тогда
		
		ОткрытьФормуПодробнееОПереключенияНаОператораСЭДО(Форма);
		
	ИначеЕсли СтрНайти(НавигационнаяСсылкаФорматированнойСтроки, "ПереключениеНаОператораСЭДО") > 0 Тогда
		
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Форма,
				"НадписьПереходНаОператораСЭДО_ДанныеАнализа") Тогда
			ДанныеАнализа = Форма.НадписьПереходНаОператораСЭДО_ДанныеАнализа;
			Если НЕ ДанныеАнализа.ОднаОрганизация Тогда
				// Несколько организаций.
				ОткрытьФормуПереключенияОрганизацийНаОператораСЭДО(Форма);
				Возврат Истина;
			КонецЕсли;
			Если ДанныеАнализа.ОднаОрганизация
				И ДанныеАнализа.ОрганизацииБезНаправленияФСС.Количество() > 0 Тогда
				// Одна организация без направления СФР.
				Организация = ДанныеАнализа.ОрганизацииБезНаправленияФСС[0];
				ОткрытьЗаявлениеНаДобавлениеНаправленияСФР(Организация);
				Возврат Истина;
			КонецЕсли;
		КонецЕсли;
		
		ОткрытьФормуПередПереключениемНаОператораСЭДО(Форма);
		
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

