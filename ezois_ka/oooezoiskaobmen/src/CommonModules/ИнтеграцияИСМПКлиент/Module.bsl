// Предупредить об отсутствии необходимости оформления разрешения на отгрузку ГИС МТ
// 
// Параметры:
//  ФормаВладелец - ФормаКлиентскогоПриложения - Форма владелец
//  ОбъектУчета - ОпределяемыйТип.ОснованияЭлектронныхДокументовЭДО.
Процедура ОтказатьВОформленииРазрешенияНаОтгрузкуГИСМТ(ФормаВладелец, ОбъектУчета) Экспорт
	
	ДополнительныеПараметры = Новый Структура();
	ДополнительныеПараметры.Вставить("ОбъектУчета",         ОбъектУчета);
	ДополнительныеПараметры.Вставить("ФормаВладелец",       ФормаВладелец);
	
	ОтказФормированияРазрешенияНаОтгрузкуИСМП = Новый ОписаниеОповещения(
		"ОтказФормированияРазрешенияНаОтгрузкуИСМПЗавершение", ЭтотОбъект, ДополнительныеПараметры);
	ПоказатьВопрос(
		ОтказФормированияРазрешенияНаОтгрузкуИСМП,
		НСтр("ru = 'По результатам проверки ГИС МТ по данному документу не требуется оформление разрешения на отгрузку:
		|
		|Коды маркировки оформлены/введены в оборот до наступления даты контроля перемещений между местами осуществления деятельности.'"),
		РежимДиалогаВопрос.ОК);
	
