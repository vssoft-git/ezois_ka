// Функция - Отчет использует механизм актуализации
//
// Параметры:
//  Форма	 - ФормаКлиентскогоПриложения
// 
// Возвращаемое значение:
//  Булево - истина, если использует
//
Функция ОтчетИспользуетМеханизмАктуализации(Форма) Экспорт
	
	Возврат Форма.Элементы.Найти("Актуализация") <> Неопределено;
	
КонецФункции

// Вызывается в контексте формы.
//  Предварительно требует проверки ОтчетИспользуетМеханизмАктуализации()
//
// Параметры:
//  Форма	 - ФормаКлиентскогоПриложения
//
Процедура СкрытьПанельАктуализации(Форма) Экспорт
	
	Форма.Элементы.Актуализация.Видимость = Ложь;
	
КонецПроцедуры

//-- НЕ УТ

//-- Локализация

// Представление периода в формате "Месяц год".
// 
// Параметры:
//  Период - Дата - Период
// 
// Возвращаемое значение:
//  Строка - Представление периода
Функция ПредставлениеПериодаМесяцГод(Период) Экспорт
	
	Если НЕ ЗначениеЗаполнено(Период) ИЛИ ТипЗнч(Период) <> Тип("Дата") Тогда
		Возврат "";
	КонецЕсли;
	
	Месяцы = Новый Массив;
	Месяцы.Добавить(НСтр("ru='Январь'"));
	Месяцы.Добавить(НСтр("ru='Февраль'"));
	Месяцы.Добавить(НСтр("ru='Март'"));
	Месяцы.Добавить(НСтр("ru='Апрель'"));
	Месяцы.Добавить(НСтр("ru='Май'"));
	Месяцы.Добавить(НСтр("ru='Июнь'"));
	Месяцы.Добавить(НСтр("ru='Июль'"));
	Месяцы.Добавить(НСтр("ru='Август'"));
	Месяцы.Добавить(НСтр("ru='Сентябрь'"));
	Месяцы.Добавить(НСтр("ru='Октябрь'"));
	Месяцы.Добавить(НСтр("ru='Ноябрь'"));
	Месяцы.Добавить(НСтр("ru='Декабрь'"));
	
	Возврат Месяцы[Месяц(Период)-1] + " " + Формат(Год(Период), "ЧН=0; ЧГ=");
	
КонецФункции

// Проверяет использование в отчете нового механизма работы с длительными операциями.
//
// Параметры:
//  Форма        - ФормаКлиентскогоПриложения - проверяемая форма.
//
// Возвращаемое значение:
//   Булево      - Истина, новый программный интерфейс; Ложь, устаревший программный интерфейс.
//
Функция ИспользуетсяОписаниеЗаданияАктуализации(Форма) Экспорт
	
	Возврат ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Форма, "ОписаниеЗаданияАктуализации");
	
КонецФункции

#КонецОбласти
