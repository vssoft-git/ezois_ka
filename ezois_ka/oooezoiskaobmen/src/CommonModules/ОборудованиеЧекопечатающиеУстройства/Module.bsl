// ++ Локализация

Процедура ОбработатьПолучениеРезультатаПроверкиКодаМаркировки(ДанныеОперации, РезультатВыполнения)
	
	Если ОбщегоНазначенияБПО.ИспользуетсяМаркировка() Тогда
		МодульМенеджерОборудованияМаркировка = ОбщегоНазначенияБПО.ОбщийМодуль("МенеджерОборудованияМаркировка");
		РезультатВыполнения = МодульМенеджерОборудованияМаркировка.ПолучитьРезультатыОИСМКМИзXMLПакета(ДанныеОперации.РезультатXML, РезультатВыполнения);
		РезультатВыполнения.СтатусРезультата = МодульМенеджерОборудованияМаркировка.СтатусРезультатаЗапросаКМПоКоду(ДанныеОперации.СтатусРезультатаКод);
		РезультатВыполнения.Вставить("РезультатXML", ДанныеОперации.РезультатXML);
		
		Попытка
			Если РезультатВыполнения.Свойство("ЗапросКМ") И РезультатВыполнения.ЗапросКМ <> Неопределено Тогда
				СтатусРезультатаКод = ДанныеОперации.СтатусРезультатаКод;
				Если СтатусРезультатаКод = 0 Или СтатусРезультатаКод = 2 Тогда
					РезультатВыполненияЗапросаКМ = РезультатВыполнения.ЗапросКМ.РезультатВыполнения;
					ДанныеОперацииЗапросаКМ = РезультатВыполнения.ЗапросКМ.ДанныеОперации;
					
					МодульМенеджерОборудованияМаркировка = ОбщегоНазначенияБПО.ОбщийМодуль("МенеджерОборудованияМаркировка");
					ПараметрыЗаписи = МодульМенеджерОборудованияМаркировка.ПараметрыЗаписиРезультатаПроверкиКМ();
					ПараметрыЗаписи.Ключ.ИдентификаторСессии = РезультатВыполненияЗапросаКМ.ИдентификаторСессии;
					ПараметрыЗаписи.Ключ.ИдентификаторЗапроса = РезультатВыполненияЗапросаКМ.ИдентификаторЗапроса;
					ПараметрыЗаписи.Результат = РезультатВыполнения.Результат;
					ПараметрыЗаписи.ЗапросКМ = ДанныеОперацииЗапросаКМ;
					ПараметрыЗаписи.ФлагиПроверкиОИСМ = РезультатВыполнения.РезультатПроверкиОИСМПредставление;
					ПараметрыЗаписи.ЛокальныйОтветXML = РезультатВыполненияЗапросаКМ.РезультатXML;
					ПараметрыЗаписи.УдаленныйОтветXML = РезультатВыполнения.РезультатXML;
					ПараметрыЗаписи.ПокупкаПодтверждена = Истина;
					МассивПараметровЗаписей = Новый Массив();
					МассивПараметровЗаписей.Добавить(ПараметрыЗаписи);
					
					МодульМенеджерОборудованияМаркировка.ДобавитьРезультатыПроверкиКодаМаркировкиВРегистр(МассивПараметровЗаписей);
				КонецЕсли;
			КонецЕсли;
		Исключение
			
			ОбщегоНазначенияБПО.ЗаписатьОшибкуВЖурналРегистрации(
			НСтр("ru = 'Ошибка записи в журнал проверки кода маркировки.'"),
			ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
			
		КонецПопытки;
		
	КонецЕсли;

КонецПроцедуры

Процедура ОбработатьПроверкуКодаМаркировки(РезультатВыполнения)
	
	Если ОбщегоНазначенияБПО.ИспользуетсяМаркировка() Тогда
		
		Если Не РезультатВыполнения.Результат Тогда
			Возврат;
		КонецЕсли;
		
		МодульМенеджерОборудованияМаркировка = ОбщегоНазначенияБПО.ОбщийМодуль("МенеджерОборудованияМаркировка");
		МассивПараметровЗаписей = Новый Массив();
		МассивДанныхОбмена = Новый Массив();
		Для каждого Результат Из РезультатВыполнения.РезультатыОпераций Цикл
			Параметры = Новый Структура();
			МодульМенеджерОборудованияМаркировка.ПолучитьРезультатыОИСМКМИзXMLПакета(Результат.Служебная.УдаленныйОтветXML, Параметры);
			Результат.Вставить("РезультатПроверкиСведенийОТоваре", Параметры.РезультатПроверкиСведенийОТоваре);
			Результат.Вставить("РезультатПроверкиСведенийОТовареПФ", Параметры.РезультатПроверкиСведенийОТовареПФ);
			Результат.Вставить("СтатусОбработкиЗапроса", Параметры.СтатусОбработкиЗапроса);
			Результат.Вставить("СтатусТовара", Параметры.СтатусТовара);
			Результат.Вставить("СтатусРезультата", МодульМенеджерОборудованияМаркировка.СтатусРезультатаЗапросаКМПоКоду(Результат.Служебная.СтатусРезультатаКод));

			// для обратной совместимости
			ДанныеСтруктура = МодульМенеджерОборудованияМаркировка.ПолучитьРезультатыЗапросаКМИзXMLПакета(Результат.Служебная.ЛокальныйОтветXML);
			Результат.Вставить("КодМаркировкиПроверен", ДанныеСтруктура.КодМаркировкиПроверен);  
			Результат.Вставить("РезультатПроверки", ДанныеСтруктура.РезультатПроверки);
			
			Результат.Вставить("РезультатПроверкиОИСМ", Параметры.РезультатПроверкиОИСМ);
			Результат.Вставить("КодРезультатаПроверкиОИСМ", Параметры.КодРезультатаПроверкиОИСМ);
			Результат.Вставить("РезультатПроверкиОИСМПредставление", Параметры.РезультатПроверкиОИСМПредставление); 
			Результат.Вставить("КодОбработкиЗапроса", Параметры.КодОбработкиЗапроса); 
			
			ПараметрыЗаписи = МодульМенеджерОборудованияМаркировка.ПараметрыЗаписиРезультатаПроверкиКМ();
			ПараметрыЗаписи.Ключ.ИдентификаторСессии = РезультатВыполнения.ИдентификаторСессии;
			ПараметрыЗаписи.Ключ.ИдентификаторЗапроса = Результат.ИдентификаторЗапроса;
			ПараметрыЗаписи.Результат = Результат.Результат;
			ПараметрыЗаписи.ЗапросКМ = Результат.Служебная.ЗапросКМ;
			ПараметрыЗаписи.ФлагиПроверкиОИСМ = Параметры.РезультатПроверкиОИСМПредставление;
			ПараметрыЗаписи.ЛокальныйОтветXML = Результат.Служебная.ЛокальныйОтветXML;
			ПараметрыЗаписи.УдаленныйОтветXML = Результат.Служебная.УдаленныйОтветXML;
			ПараметрыЗаписи.ПокупкаПодтверждена = Результат.Служебная.ПокупкаПодтверждена;
			МассивПараметровЗаписей.Добавить(ПараметрыЗаписи);
			
			ДанныеОбмена = Новый Структура();
			ДанныеОбмена.Вставить("ЗапросКМ", ПараметрыЗаписи.ЗапросКМ.ПараметрыXML);
			ДанныеОбмена.Вставить("ЛокальныйОтветКМ", ПараметрыЗаписи.ЛокальныйОтветXML);
			ДанныеОбмена.Вставить("УдаленныйОтветКМ", ПараметрыЗаписи.УдаленныйОтветXML); 
			МассивДанныхОбмена.Добавить(ДанныеОбмена);
			
		КонецЦикла;
		
		МенеджерОборудованияВызовСервераПереопределяемый.ПослеПроверкиКодовМаркировки(МассивДанныхОбмена);
		МодульМенеджерОборудованияМаркировка.ДобавитьРезультатыПроверкиКодаМаркировкиВРегистр(МассивПараметровЗаписей);
		
	КонецЕсли;

КонецПроцедуры

