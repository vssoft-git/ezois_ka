// Возвращает возможные варианты статусов чеков в очереди
// 
// Возвращаемое значение:
//  Соответствие из КлючИЗначение
Функция СтатусыЧекаВОчереди() Экспорт
	
	Результат = Новый Соответствие();
	
	Результат.Вставить("Фискализирован" , ПредопределенноеЗначение("Перечисление.СтатусЧекаККТВОчереди.Фискализирован"));
	Результат.Вставить("Ошибка"         , ПредопределенноеЗначение("Перечисление.СтатусЧекаККТВОчереди.Ошибка"));
	Результат.Вставить("Новый"          , ПредопределенноеЗначение("Перечисление.СтатусЧекаККТВОчереди.Новый"));
	Результат.Вставить("Фискализируется", ПредопределенноеЗначение("Перечисление.СтатусЧекаККТВОчереди.Фискализируется"));
	Результат.Вставить("Отменен"        , ПредопределенноеЗначение("Перечисление.СтатусЧекаККТВОчереди.Отменен"));
	
	Возврат Результат;
	
КонецФункции

