//
// Параметры:
//  Организация - ОпределяемыйТип.ОрганизацияБПО
//
// Возвращаемое значение:
//  Структура:
//   * Наименование - Строка - Наименование организации
Функция СведенияОбОрганизации(Организация) Экспорт
	
	Сведения = Новый Структура();
	Сведения.Вставить("Наименование", "");
	СтандартнаяОбработка = Истина;
	МенеджерОборудованияВызовСервераПереопределяемый.СведенияОбОрганизации(Организация, Сведения, СтандартнаяОбработка);
	Если СтандартнаяОбработка Тогда
		Сведения.Наименование = Строка(Организация);
	КонецЕсли;
	Возврат Сведения;
	
