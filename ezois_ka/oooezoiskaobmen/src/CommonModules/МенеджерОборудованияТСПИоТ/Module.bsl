// Функция возвращает созданный ТС ПИоТ по подключаемому оборудованию
//
// Параметры:
//  ПодключаемоеОборудование - СправочникСсылка.ПодключаемоеОборудование.
//
// Возвращаемое значение:
//  - Произвольный
//
Функция ПолучитьТСПИоТ(ПодключаемоеОборудование) Экспорт
	
	Возврат Справочники.ТСПИоТ.ПолучитьТСПИоТ(ПодключаемоеОборудование);
	
КонецФункции

// Процедура создает элемент в справочнике ТС ПИоТ.
//
// Параметры:
//  ПараметрыСоздания - Структура - параметры создания подключаемог оборудования.
//
// Возвращаемое значение:
//  СправочникСсылка.ТСПИоТ - 
//        
Функция СоздатьНовыйТСПИоТ(ПараметрыСоздания) Экспорт
	
	Возврат Справочники.ТСПИоТ.СоздатьНовыйТСПИоТ(ПараметрыСоздания);
	
КонецФункции             

Функция ПараметрыСозданияСПИоТ() Экспорт
	
	ПараметрыСоздания = Новый Структура();
	ПараметрыСоздания.Вставить("УровеньЛога", 0);
	ПараметрыСоздания.Вставить("ФискальноеУстройство");
	ПараметрыСоздания.Вставить("Тип");       
	ПараметрыСоздания.Вставить("Наименование");     
	ПараметрыСоздания.Вставить("РабочийКаталог"); 
	Возврат ПараметрыСоздания;
	
КонецФункции

Функция СформироватьПутиВнутреннегоПИоТ(ИдентификаторЭкземпляра, РабочийКаталогДанныхПользователя) Экспорт 
	
	РабочийКаталог = Лев(РабочийКаталогДанныхПользователя, СтрНайти(РабочийКаталогДанныхПользователя, "\1cv8"));      
	
	Если ОбщегоНазначенияБПО.ЭтоУчебнаяПлатформа() Тогда
		ПутьКДрайверу = РабочийКаталог + "1cv8t\ExtCompT";   
	Иначе
		ПутьКДрайверу = РабочийКаталог + "1cv8\ExtCompT";
	КонецЕсли;
	
	ПутьДанныхЭкземпляра = РабочийКаталог + "1CPIoT\" + ИдентификаторЭкземпляра;
	
	Результат = Новый Структура();
	Результат.Вставить("ПутьКДрайверу", ПутьКДрайверу);
	Результат.Вставить("ПутьДанныхЭкземпляра", ПутьДанныхЭкземпляра);
	Возврат Результат;
	
КонецФункции

// Получить параметры подключения ПИоТ в XML
//
// Параметры:    
//   ПодключаемоеОборудование - СправочникСсылка.ПодключаемоеОборудование.
//   ИдентификаторОбъекта - Строка -
//   ТСПИоТ - Структура -     
// Возвращаемое значение:
//   Структура -
//
Функция ПолучитьПараметрыПИоТXML(ПодключаемоеОборудование, ИдентификаторОбъекта, ТСПИоТ) Экспорт
	
	ПараметрыТСПИоТ = Новый Структура();    
	ПараметрыТСПИоТ.Вставить("DriverProgID", ИдентификаторОбъекта); // ProgID подключаемый интеграционный компоненты для работы с ТС ПИоТ     
	ПараметрыТСПИоТ.Вставить("DriverFileName", ""); // Имя подключаемый интеграционный компоненты для работы с ТС ПИоТ
	ПараметрыТСПИоТ.Вставить("DriverPath"  , ТСПИоТ.ПутьКДрайверу); // Путь расположения подключаемый интеграционный компоненты для работы с ТС ПИоТ
	ПараметрыТСПИоТ.Вставить("InstancePath", ТСПИоТ.ПутьДанныхЭкземпляра); // Папка данных экземпляра ТС ПИоТ
	ПараметрыТСПИоТ.Вставить("GUID"        , ТСПИоТ.ИдентификаторЭкземпляра); // Статический уникальный идентификатор экземпляра ТС ПИоТ  
	ПараметрыТСПИоТ.Вставить("LogLevel"    , ТСПИоТ.УровеньЛога); // Уровень логирования
	
	ПроверкаКорневыхСертификатов = ТСПИоТ.ИсключитьПроверкуКорневыхСертификатов;
	ПараметрыТСПИоТ.Вставить("CheckRootCertificates", ПроверкаКорневыхСертификатов); // Проверять корневые сертификаты
	
	Если ОбщегоНазначенияБПО.ИспользуетсяГосИС() Тогда
		// ЛМ ЧЗ, если есть используется ГосИС
		ПараметрыЛМЧЗ = ПолучитьПараметрыЛМЧЗ(ПодключаемоеОборудование);
		ЛМЧЗАдрес        = ПараметрыЛМЧЗ.Сервер;     
		ЛМЧЗПорт         = ПараметрыЛМЧЗ.Порт;     
		ЛМЧЗПользователь = ПараметрыЛМЧЗ.Пользователь;   
		ЛМЧЗПароль       = ПараметрыЛМЧЗ.Пароль;  
	Иначе
		ЛМЧЗАдрес        = ТСПИоТ.ЛМЧЗАдрес;     
		ЛМЧЗПорт         = ТСПИоТ.ЛМЧЗПорт;     
		ЛМЧЗПользователь = ТСПИоТ.ЛМЧЗПользователь;   
		ЛМЧЗПароль       = ТСПИоТ.ЛМЧЗПароль;  
	КонецЕсли;
	
	ПараметрыТСПИоТ.Вставить("LMCHZAdress"  , ЛМЧЗАдрес); // Адрес подключения ЛМ ЧЗ        
	ПараметрыТСПИоТ.Вставить("LMCHZPort"    , ЛМЧЗПорт); // Порт подключения ЛМ Ч        
	ПараметрыТСПИоТ.Вставить("LMCHZUser"    , ЛМЧЗПользователь); // Пользователь ЛМ ЧЗ        
	ПараметрыТСПИоТ.Вставить("LMCHZPassword", ЛМЧЗПароль); // Пароль пользователя ЛМ ЧЗ    
	
	Если ОбщегоНазначенияБПО.ИспользуетсяБСП() Тогда 
		// Прокси, если есть используется БСП
		НастройкиПрокси = ОбщегоНазначенияБПО.НастройкиПроксиНаКлиенте();
		ПроксиСервер       = НастройкиПрокси.Сервер;
		ПроксиПорт         = НастройкиПрокси.Порт;
		ПроксиПользователь = НастройкиПрокси.Пользователь;
		ПроксиПароль       = НастройкиПрокси.Пароль;   
	Иначе
		ПроксиСервер       = ТСПИоТ.ПроксиСервер;
		ПроксиПорт         = ТСПИоТ.ПроксиПорт;     
		ПроксиПользователь = ТСПИоТ.ПроксиПользователь; 
		ПроксиПароль       = ТСПИоТ.ПроксиПароль;
	КонецЕсли;
	
	ПараметрыТСПИоТ.Вставить("Proxy"        , ПроксиСервер); // Адрес прокси сервера        
	ПараметрыТСПИоТ.Вставить("ProxyPort"    , ПроксиПорт); // Порт прокси сервера        
	ПараметрыТСПИоТ.Вставить("ProxyUser"    , ПроксиПользователь); // Пользователь прокси сервера        
	ПараметрыТСПИоТ.Вставить("ProxyPassword", ПроксиПароль); // Пароль прокси сервера    

	ПараметрыТСПИоТ.Вставить("ApplicationName", ""); // ГОСИС
	ПараметрыТСПИоТ.Вставить("ApplicationVersion", ""); // ГОСИС
	ПараметрыТСПИоТ.Вставить("ConfigurationName", Метаданные.КраткаяИнформация); // Название прикладной конфирмации 
	
	ТСПИоТПараметрыXML = МенеджерОборудования.ПолучитьПараметрыXML(ПараметрыТСПИоТ, Неопределено, Ложь);    
	Возврат ТСПИоТПараметрыXML;
	
КонецФункции       

// Получить параметры подключения ЛМЧЗ
//
// Параметры:    
//   ПодключаемоеОборудование - СправочникСсылка.ПодключаемоеОборудование.
// Возвращаемое значение:
//   Структура -
//
Функция ПолучитьПараметрыЛМЧЗ(ПодключаемоеОборудование) Экспорт
	
	ПараметрыЛМЧЗ = Новый Структура();
	ПараметрыЛМЧЗ.Вставить("Использовать", Ложь);
	ПараметрыЛМЧЗ.Вставить("Сервер");
	ПараметрыЛМЧЗ.Вставить("Порт");
	ПараметрыЛМЧЗ.Вставить("Пользователь");
	ПараметрыЛМЧЗ.Вставить("Пароль");

	Если ОбщегоНазначенияБПО.ИспользуетсяГосИС() Тогда
		
		СтруктураРеквизитовПодключаемогоОборудования = ОбщегоНазначенияБПО.ЗначенияРеквизитовОбъекта(ПодключаемоеОборудование, "Организация, РабочееМесто");
		Организация  = СтруктураРеквизитовПодключаемогоОборудования.Организация;
		РабочееМесто = СтруктураРеквизитовПодключаемогоОборудования.РабочееМесто;
		
		МодульОбщегоНазначенияИСМП = ОбщегоНазначенияБПО.ОбщийМодуль("ОбщегоНазначенияИСМП");
		НастройкиЛокальногоМодуля = МодульОбщегоНазначенияИСМП.НастройкиОсновногоПодключенияЛокальномуМодулюЧестныйЗнакПоОрганизацииРабочемуМесту(Организация, РабочееМесто);
		
		НастроеноПодключениеЛМЧЗ = НастройкиЛокальногоМодуля.НастроеноПодключение;
		Если НастройкиЛокальногоМодуля.НастроеноПодключение Тогда
			ПараметрыЛМЧЗ.Использовать = Истина;
			ПараметрыЛМЧЗ.Сервер       = НастройкиЛокальногоМодуля.Настройки.Сервер;   
			ПараметрыЛМЧЗ.Порт         = НастройкиЛокальногоМодуля.Настройки.Порт;   
			ПараметрыЛМЧЗ.Пользователь = НастройкиЛокальногоМодуля.Настройки.Логин;   
			ПараметрыЛМЧЗ.Пароль       = НастройкиЛокальногоМодуля.Настройки.Пароль;   
		КонецЕсли;
		
	КонецЕсли;  
	
	Возврат ПараметрыЛМЧЗ;
	
КонецФункции 

