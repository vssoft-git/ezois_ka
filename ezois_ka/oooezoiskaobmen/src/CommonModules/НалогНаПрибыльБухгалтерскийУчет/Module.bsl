#Область Коллекции

// Конструктор таблицы расчета ПБУ 18 в разрезе вариантов н/о.
// Если раздельный учет не используется, должна быть заполнена одна строка с пустым вариантом н/о.
// 
// Возвращаемое значение:
// 	ТаблицаЗначений - Содержит:
// 		* ВариантНалогообложенияПрибыли - СправочникСсылка.ВариантыНалогообложенияПрибыли -
// 		* НачисленныйНалог              - Число -
// 		* СуммыНалоговойБазы            - Структура - содержит:
// 			** Сумма   - Число - Сумма по бухгалтерскому учету
// 			** СуммаНУ - Число - Сумма по налоговому учету
// 			** СуммаПР - Число - Сумма постоянных разниц (если используется учет разниц)
// 			** СуммаВР - Число - Сумма временных разниц (если используется учет разниц)
// 		* УбытокПеренесенныйНаБудущее   - Число -
// 		* РасчетОтложенногоНалога       - см. НовыйРасчетОтложенногоНалога
// 		* РасчетРасходаПоНалогу         - см. НовыйРасчетРасходаПоНалогу
//
Функция НовыйРасчетПоВариантамНалогообложения()
	
	Расчет = Новый ТаблицаЗначений;
	
	ОписаниеТипаЧисло     = ОбщегоНазначенияУТ.ОписаниеТипаДенежногоПоля();
	ОписаниеТипаСтруктура = Новый ОписаниеТипов("Структура");
	
	Расчет.Колонки.Добавить("ВариантНалогообложенияПрибыли",
		Новый ОписаниеТипов("СправочникСсылка.ВариантыНалогообложенияПрибыли"));
	
	// Кэшированные суммы для расчета
	Расчет.Колонки.Добавить("НачисленныйНалог",            ОписаниеТипаЧисло);
	Расчет.Колонки.Добавить("СуммыНалоговойБазы",          ОписаниеТипаСтруктура);
	Расчет.Колонки.Добавить("УбытокПеренесенныйНаБудущее", ОписаниеТипаЧисло);
	
	// Данные расчетов по ПБУ 18/02
	Расчет.Колонки.Добавить("РасчетОтложенногоНалога", ОписаниеТипаСтруктура);
	Расчет.Колонки.Добавить("РасчетРасходаПоНалогу",   ОписаниеТипаСтруктура);
	
	Возврат Расчет;
	
КонецФункции

// При добавлении строки производит инициализацию колонок
// 
// Параметры:
// 	ТаблицаРасчета - см. НовыйРасчетПоВариантамНалогообложения
// 	ВариантНалогообложенияПрибыли - СправочникСсылка.ВариантыНалогообложенияПрибыли - добавляемый вариант н/о
//
// Возвращаемое значение:
// 	СтрокаТаблицыЗначений Из см. НовыйРасчетПоВариантамНалогообложения
//
Функция ДобавитьСтрокуРасчетаПоВариантамНалогообложения(ТаблицаРасчета, ВариантНалогообложенияПрибыли)
	
	НоваяСтрока = ТаблицаРасчета.Добавить();
	
	НоваяСтрока.ВариантНалогообложенияПрибыли = ВариантНалогообложенияПрибыли;
	
	НоваяСтрока.СуммыНалоговойБазы      = КоллекцииСумм.НовыйКоллекцияСумм(ОписаниеКоллекцииСумм());
	НоваяСтрока.РасчетОтложенногоНалога = НовыйРасчетОтложенногоНалога();
	НоваяСтрока.РасчетРасходаПоНалогу   = НовыйРасчетРасходаПоНалогу();
	
	Возврат НоваяСтрока;
	
КонецФункции

// В роли КонтекстРасчета используется РасчетНалогаНаПрибыль.НовыйКонтекстРасчета
// 
// Возвращаемое значение:
// 	Структура - Описание:
// * ВариантНалогообложенияПрибыли - СправочникСсылка.ВариантыНалогообложенияПрибыли -
//                расчет отложенных налогов происходит в разрезе вариантов н/о
// * НачисленныйНалог             - Число - Начисленный налог по варианту н/о
// * НачальныеДанныеПериодРасчета - Дата -
// * НачальныеДанныеОтчетнаяДата - Дата -
// * СтавкиНалога - Соответствие - содержит:
// 		** Ключ - ПеречислениеСсылка.ВидыСтавокОтложенногоНалога -
// 		** Значение - Число -
// * ПротоколРасчетаСтавокНалога - Соответствие - содержит:
// 		** Ключ - ПеречислениеСсылка.ВидыСтавокОтложенногоНалога -
// 		** Значение - Структура -
// * ЭффектИзмененияСтавокНалогаНаПрибыль - ТаблицаЗначений -
// * ВременныеРазницы - ТаблицаЗначений -
// * ОтложенныйНалог - см. НовыйИзменениеОтложенногоНалога
// * ОтложенныйНалогВДобавочномКапитале - см. НовыйИзменениеОтложенногоНалога
//
Функция НовыйРасчетОтложенногоНалога()
	
	Расчет = Новый Структура;
	
	Расчет.Вставить("ВариантНалогообложенияПрибыли", Справочники.ВариантыНалогообложенияПрибыли.ПустаяСсылка());
	
	// Начисленный налог по варианту н/о
	Расчет.Вставить("НачисленныйНалог", 0);
	
	// Все сведения о расчете отложенного налога с детализацией, как на счетах 09 и 77
	Расчет.Вставить("ОтложенныйНалог", НовыйИзменениеОтложенногоНалога());

	// Все сведения о расчете отложенного налога с детализацией, как на счетах отложенного налога в добавочном капитале
	Расчет.Вставить("ОтложенныйНалогВДобавочномКапитале", НовыйИзменениеОтложенногоНалога());

	// Строки таблицы временных разниц по активам / обязательствам по выбывшим ВНА
	Расчет.Вставить("СтрокиРазницНалогаВДобавочномКапиталеПоВыбывшимВНА", Новый Соответствие);

	// Часть сведений о расчете отложенного налога, определяемая с большей детализацией, чем на счетах 09 и 77:
	// - величина отложенных налоговых активов и обязательств на отчетную дату
	// - эффект изменения временных разниц
	Расчет.Вставить(
		"ВременныеРазницы",
		ЗакрытиеМесяца.НовыйЗаписиВспомогательногоРегистраСведений(Метаданные.РегистрыСведений.РасчетОтложенногоНалога));
		
	// Часть сведений, раскрывающая эффект изменения ставок налога - с детализацией, как на счетах 09 и 77
	Расчет.Вставить(
		"ЭффектИзмененияСтавокНалогаНаПрибыль",
		ЗакрытиеМесяца.НовыйЗаписиВспомогательногоРегистраСведений(Метаданные.РегистрыСведений.РасчетЭффектаИзмененияСтавокНалогаНаПрибыль));
	
	// IAS12.46 "Обязательства (активы) по текущему налогу за текущий и предыдущие периоды оцениваются в сумме,
	//           которую ожидается уплатить налоговым органам (истребовать к возмещению налоговыми органами),
	//           рассчитанной с использованием ставок налога (и налогового законодательства),
	//           действующих или по существу принятых по состоянию на конец отчетного периода."
	//
	// ПБУ18.14 "ставку налога на прибыль, установленную законодательством Российской Федерации о налогах и сборах и действующую на отчетную дату"
	Расчет.Вставить("СтавкиНалога",                Новый Соответствие);
	Расчет.Вставить("ПротоколРасчетаСтавокНалога", Новый Соответствие);
	Для Каждого МетаданныеВидСтавки Из Метаданные.Перечисления.ВидыСтавокОтложенногоНалога.ЗначенияПеречисления Цикл
		ВидСтавки = Перечисления.ВидыСтавокОтложенногоНалога[МетаданныеВидСтавки.Имя];
		Расчет.СтавкиНалога.Вставить(ВидСтавки, 0);
		Расчет.ПротоколРасчетаСтавокНалога.Вставить(ВидСтавки, НовыйПротоколРасчетаСтавкиНалога());
	КонецЦикла;
	
	// Данные о начале отчетного периода, приведенные в соответствии с соглашениями регистра РасчетОтложенногоНалога
	Расчет.Вставить("НачальныеДанныеОтчетнаяДата",  '0001-01-01'); // соответствует измерению ОтчетнаяДата
	Расчет.Вставить("НачальныеДанныеПериодРасчета", '0001-01-01'); // соответствует измерению ПериодРасчета
	
	Возврат Расчет;
	
КонецФункции

// Функция-конструктор таблицы изменений отложенных налогов
// 
// Возвращаемое значение:
// 	ТаблицаЗначений - Описание:
// * ВариантНалогообложенияПрибыли - СправочникСсылка.ВариантыНалогообложенияПрибыли -
// * Счет - ПланСчетовСсылка.Хозрасчетный -
// * КорСчет - ПланСчетовСсылка.Хозрасчетный -
// * АктивОбязательство - ПланВидовХарактеристикСсылка.ВидыСубконтоХозрасчетные -
// * ВидАктивовИОбязательств - ПеречислениеСсылка.ВидыАктивовИОбязательств -
// * ВидОперацииРасчетаНалога - ПеречислениеСсылка.ВидыОперацийРасчетаНалога -
// * ОтложенныйНалог                     - Число -
// * ЭффектУвеличенияВременныхРазниц     - Число -
// * ЭффектУменьшенияВременныхРазниц     - Число -
// * ЭффектИзмененияСтавкиБудущегоНалога - Число -
// * ЭффектИзмененияСтавкиТекущегоНалога - Число -
// * ЭффектВключенияСуммыОперацииВНераспределеннуюПрибыль - Число -
// * ПогрешностьОкругления               - Число -
// * УвеличениеОтложенногоНалога         - Число -
// * УменьшениеОтложенногоНалога         - Число -
// * Пересчет                            - Число -
Функция НовыйИзменениеОтложенногоНалога()
	
	Изменение = Новый ТаблицаЗначений;
	
	// Изменение
	Измерения     = Метаданные.РегистрыСведений.РасчетЭффектаИзмененияСтавокНалогаНаПрибыль.Измерения;
	РесурсыРазниц = Метаданные.РегистрыСведений.РасчетОтложенногоНалога.Ресурсы;
	РесурсыСтавок = Метаданные.РегистрыСведений.РасчетЭффектаИзмененияСтавокНалогаНаПрибыль.Ресурсы;
	
	Изменение.Колонки.Добавить("ВариантНалогообложенияПрибыли",       Измерения.ВариантНалогообложенияПрибыли.Тип);
	Изменение.Колонки.Добавить("Счет",                                Измерения.Счет.Тип);
	Изменение.Колонки.Добавить("КорСчет",                             Измерения.Счет.Тип);
	Изменение.Колонки.Добавить("АктивОбязательство");
	Изменение.Колонки.Добавить("ВидАктивовИОбязательств",             Измерения.ВидАктивовИОбязательств.Тип);
	Изменение.Колонки.Добавить("ВидОперацииРасчетаНалога",            Новый ОписаниеТипов("ПеречислениеСсылка.ВидыОперацийРасчетаНалога"));
	
	// на отчетную дату
	Изменение.Колонки.Добавить("ОтложенныйНалог",                     РесурсыРазниц.ОтложенныйНалог.Тип);
	// за налоговый период
	Изменение.Колонки.Добавить("ЭффектУвеличенияВременныхРазниц",     РесурсыРазниц.ЭффектУвеличенияВременныхРазниц.Тип);
	Изменение.Колонки.Добавить("ЭффектУменьшенияВременныхРазниц",     РесурсыРазниц.ЭффектУменьшенияВременныхРазниц.Тип);
	Изменение.Колонки.Добавить("ЭффектИзмененияСтавкиБудущегоНалога", РесурсыСтавок.ЭффектИзмененияСтавкиБудущегоНалога.Тип);
	Изменение.Колонки.Добавить("ЭффектИзмененияСтавкиТекущегоНалога", РесурсыСтавок.ЭффектИзмененияСтавкиТекущегоНалога.Тип);
	Изменение.Колонки.Добавить("ЭффектВключенияСуммыОперацииВНераспределеннуюПрибыль", РесурсыРазниц.ЭффектВключенияСуммыОперацииВНераспределеннуюПрибыль.Тип);
	Изменение.Колонки.Добавить("ПогрешностьОкругления",               РесурсыРазниц.ПогрешностьОкругления.Тип);
	// для формирования проводок
	Изменение.Колонки.Добавить("УвеличениеОтложенногоНалога",         РесурсыРазниц.ЭффектУвеличенияВременныхРазниц.Тип);
	Изменение.Колонки.Добавить("УменьшениеОтложенногоНалога",         РесурсыРазниц.ЭффектУменьшенияВременныхРазниц.Тип);
	Изменение.Колонки.Добавить("Пересчет",                            РесурсыРазниц.ОтложенныйНалог.Тип);
	
	Возврат Изменение;
	
КонецФункции

#КонецОбласти

#Область НалоговыеСтавки

Процедура ОпределитьСтавкиНалога(ТаблицаРасчета, КонтекстРасчета)
	
	ДатаРасчетаСтавкиТекущегоНалога = ДатаРасчетаСтавкиТекущегоНалога(КонтекстРасчета);
	ДатаРасчетаСтавкиБудущегоНалога = ДатаРасчетаСтавкиБудущегоНалога(КонтекстРасчета);
	
	РасчетРаспределенияНалоговойБазыОП = Неопределено;
	
	Если КонтекстРасчета.ИспользуетсяРаздельныйУчет Тогда
		НалоговыйУчетОбособленныхПодразделений.ПрочитатьРасчетРаспределенияНалоговойБазыПоВариантамНалогообложения(
			РасчетРаспределенияНалоговойБазыОП,
			КонтекстРасчета.КонецПериода,
			КонтекстРасчета.Организация);
	Иначе
		НалоговыйУчетОбособленныхПодразделений.ПрочитатьРасчетРаспределенияНалоговойБазы(
			РасчетРаспределенияНалоговойБазыОП,
			КонтекстРасчета.КонецПериода,
			КонтекстРасчета.Организация);
	КонецЕсли;
	
	ПоказателиРасчетаСтавкиТекущегоНалога =
		ПолучитьПоказателиРасчетаЭффективнойСтавки(
			КонтекстРасчета,
			РасчетРаспределенияНалоговойБазыОП,
			ДатаРасчетаСтавкиТекущегоНалога);
	
	ПоказателиРасчетаСтавкиБудущегоНалога =
		ПолучитьПоказателиРасчетаЭффективнойСтавки(
			КонтекстРасчета,
			РасчетРаспределенияНалоговойБазыОП,
			ДатаРасчетаСтавкиБудущегоНалога);
	
	Для Каждого ОбщийРасчет Из ТаблицаРасчета Цикл
		
		Расчет = ОбщийРасчет.РасчетОтложенногоНалога; // см. НовыйРасчетОтложенногоНалога
		
		ПараметрыОтбораПоВариантуНО = Новый Структура("ВариантНалогообложенияПрибыли",
			Расчет.ВариантНалогообложенияПрибыли);
		
		ПоказателиРасчетаСтавкиТекущегоНалогаПоВариантуНО =
			ПоказателиРасчетаСтавкиТекущегоНалога.Скопировать(ПараметрыОтбораПоВариантуНО);
		ПоказателиРасчетаСтавкиБудущегоНалогаПоВариантуНО =
			ПоказателиРасчетаСтавкиБудущегоНалога.Скопировать(ПараметрыОтбораПоВариантуНО);
		
		// ТекущийНалог
		Расчет.СтавкиНалога[Перечисления.ВидыСтавокОтложенногоНалога.ТекущийНалог] = СтавкаТекущегоНалога(
			КонтекстРасчета,
			Расчет.ВариантНалогообложенияПрибыли,
			ПоказателиРасчетаСтавкиТекущегоНалогаПоВариантуНО,
			Расчет.НачисленныйНалог,
			Расчет.ПротоколРасчетаСтавокНалога[Перечисления.ВидыСтавокОтложенногоНалога.ТекущийНалог]);
		
		// БудущийНалог
		Расчет.СтавкиНалога[Перечисления.ВидыСтавокОтложенногоНалога.БудущийНалог] =
			Расчет.СтавкиНалога[Перечисления.ВидыСтавокОтложенногоНалога.ТекущийНалог];
			
		УточнитьСтавкуБудущегоНалога(
			Расчет.СтавкиНалога[Перечисления.ВидыСтавокОтложенногоНалога.БудущийНалог],
			КонтекстРасчета,
			Расчет.ВариантНалогообложенияПрибыли,
			ПоказателиРасчетаСтавкиБудущегоНалогаПоВариантуНО,
			Расчет.ПротоколРасчетаСтавокНалога[Перечисления.ВидыСтавокОтложенногоНалога.БудущийНалог]);
			
		// ПредыдущаяОценка
		Расчет.СтавкиНалога[Перечисления.ВидыСтавокОтложенногоНалога.ПредыдущаяОценка] =
			Расчет.СтавкиНалога[Перечисления.ВидыСтавокОтложенногоНалога.ТекущийНалог];
			
		УточнитьСтавкуНачалоПериода(
			Расчет.СтавкиНалога[Перечисления.ВидыСтавокОтложенногоНалога.ПредыдущаяОценка],
			КонтекстРасчета,
			Расчет.ВариантНалогообложенияПрибыли,
			Расчет.НачальныеДанныеОтчетнаяДата,
			Расчет.НачальныеДанныеПериодРасчета,
			Расчет.ПротоколРасчетаСтавокНалога[Перечисления.ВидыСтавокОтложенногоНалога.ПредыдущаяОценка]);
		
	КонецЦикла;
	
КонецПроцедуры

// Заполнение показателей для расчета эффективной ставки
// 
// Параметры:
// 	КонтекстРасчета                    - см. РасчетНалогаНаПрибыль.НовыйКонтекстРасчета
// 	РасчетРаспределенияНалоговойБазыОП - ТаблицаЗначений -
// 	ДатаПолученияСтавокВБюджетыРФ      - Дата -
//
// Возвращаемое значение:
// 	ТаблицаЗначений - Описание:
// * ВариантНалогообложенияПрибыли - СправочникСсылка.ВариантыНалогообложенияПрибыли -
// * РегистрацияВНалоговомОргане - СправочникСсылка.РегистрацииВНалоговомОргане -
// * СтавкаФедеральныйБюджет - Число -
// * СтавкаРегиональныйБюджет - Число -
// * НалоговаяБаза - Число -
// * ДоляФНС - Число -
// * Закрыто - Булево -
//
Функция ПолучитьПоказателиРасчетаЭффективнойСтавки(
	КонтекстРасчета, РасчетРаспределенияНалоговойБазыОП, ДатаПолученияСтавокВБюджетыРФ)
	
	ПоказателиРасчетаСтавки = Новый ТаблицаЗначений;
	
	ПоказателиРасчетаСтавки.Колонки.Добавить("ВариантНалогообложенияПрибыли",
		Новый ОписаниеТипов("СправочникСсылка.ВариантыНалогообложенияПрибыли"));
	ПоказателиРасчетаСтавки.Колонки.Добавить("РегистрацияВНалоговомОргане",
		Новый ОписаниеТипов("СправочникСсылка.РегистрацииВНалоговомОргане"));
	ПоказателиРасчетаСтавки.Колонки.Добавить("СтавкаФедеральныйБюджет",       Новый ОписаниеТипов("Число"));
	ПоказателиРасчетаСтавки.Колонки.Добавить("СтавкаРегиональныйБюджет",      Новый ОписаниеТипов("Число"));
	ПоказателиРасчетаСтавки.Колонки.Добавить("НалоговаяБаза",                 Новый ОписаниеТипов("Число"));
	ПоказателиРасчетаСтавки.Колонки.Добавить("ДоляФНС",                       Новый ОписаниеТипов("Число"));
	ПоказателиРасчетаСтавки.Колонки.Добавить("Закрыто",                       Новый ОписаниеТипов("Булево"));
	
	Если КонтекстРасчета.ИспользуетсяРаздельныйУчет Тогда
		
		// Структура таблицы показателей расчета совпадает с таблицей распределения по ОП
		ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(
			РасчетРаспределенияНалоговойБазыОП,
			ПоказателиРасчетаСтавки);
		
	Иначе
		
		Для Каждого СтрокаРаспределения Из РасчетРаспределенияНалоговойБазыОП Цикл
			
			НоваяСтрока = ПоказателиРасчетаСтавки.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаРаспределения);
			
			НоваяСтрока.ДоляФНС = СтрокаРаспределения.ДоляНалоговойБазы;
			
		КонецЦикла;
		
	КонецЕсли;
	
	ПоказателиРасчетаСтавки.Индексы.Добавить("ВариантНалогообложенияПрибыли");
	
	
	Если ПоказателиРасчетаСтавки.Количество() Тогда
		НалоговыйУчетОбособленныхПодразделений.ЗаполнитьНалоговыеСтавкиВБюджетыРФ(
			ПоказателиРасчетаСтавки,
			ДатаПолученияСтавокВБюджетыРФ,
			КонтекстРасчета.Организация);
	КонецЕсли;
	
	Возврат ПоказателиРасчетаСтавки;
	
КонецФункции

Функция ДатаРасчетаСтавкиТекущегоНалога(КонтекстРасчета)
	
	Возврат Макс(КонтекстРасчета.КонецПериода, КонтекстРасчета.НалоговыйПериод);
	
КонецФункции

Функция ДатаРасчетаСтавкиБудущегоНалога(КонтекстРасчета)
	
    // С учетом того, что в рекомендациях БМЦ Р-166 и Р-8 момент пересчета увязан с датой начала применения новых ставок,
    // ставки будущего отчетного периода принимаем во внимание только в годовой отчетности.
    //
    // При необходимости учесть изменение ставки в промежуточной отчетности,
    // непосредственно следующей за моментом принятия (установления) новых ставок, эту функцию рекомендуется переопределить.
    
    Возврат КонецМесяца(КонтекстРасчета.КонецПериода) + 1;
	
КонецФункции

// IAS12.46 "Обязательства (активы) по текущему налогу за текущий и предыдущие периоды оцениваются в сумме,
//           которую ожидается уплатить налоговым органам (истребовать к возмещению налоговыми органами),
//           рассчитанной с использованием ставок налога (и налогового законодательства),
//           действующих или по существу принятых по состоянию на конец отчетного периода."
//
// ПБУ18.14 "ставку налога на прибыль, установленную законодательством Российской Федерации о налогах и сборах
//          и действующую на отчетную дату"
//
Функция СтавкаТекущегоНалога(
	КонтекстРасчета, ВариантНалогообложенияПрибыли, ПоказателиРасчетаЭффективнойСтавки, ОбщаяСуммаНалога, Протокол)
	
	Протокол.ДанныеАлгоритма.Вставить(
		"ДатаРасчетаСтавки",
		ДатаРасчетаСтавкиТекущегоНалога(КонтекстРасчета));
	
	ОбщаяСтавкаФедеральныйБюджет = НалоговыйУчет.НалоговаяСтавкаФедеральныйБюджет(
		Протокол.ДанныеАлгоритма.ДатаРасчетаСтавки,
		КонтекстРасчета.Организация,
		,
		ВариантНалогообложенияПрибыли);
	
	ОбщаяСтавкаРегиональныйБюджет = НалоговыйУчет.НалоговаяСтавкаРегиональныйБюджет(
		Протокол.ДанныеАлгоритма.ДатаРасчетаСтавки,
		КонтекстРасчета.Организация,
		,
		ВариантНалогообложенияПрибыли);
	
	СтавкаНалога = ОбщаяСтавкаФедеральныйБюджет + ОбщаяСтавкаРегиональныйБюджет;
	
	Если ЗначениеЗаполнено(ПоказателиРасчетаЭффективнойСтавки) Тогда
		
		// Могут быть установлены разные ставки для разных регионов и вариантов н/о
		// Следует учесть эти различия (предварительно проверив, что они фактически есть).
		// В таблице уже предварительно посчитаны ставки.
		
		ФактическиИспользуетсяЕдинаяСтавка = Истина;
		СтавкаФедеральныйБюджет            = Неопределено;
		СтавкаРегиональныйБюджет           = Неопределено;
		Для Каждого ОписаниеСтавки Из ПоказателиРасчетаЭффективнойСтавки Цикл
			
			Если СтавкаФедеральныйБюджет = Неопределено Тогда
				СтавкаФедеральныйБюджет           = ОписаниеСтавки.СтавкаФедеральныйБюджет;
			ИначеЕсли СтавкаФедеральныйБюджет <> ОписаниеСтавки.СтавкаФедеральныйБюджет Тогда
				ФактическиИспользуетсяЕдинаяСтавка = Ложь;
				Прервать;
			КонецЕсли;
			
			Если СтавкаРегиональныйБюджет = Неопределено Тогда
				СтавкаРегиональныйБюджет           = ОписаниеСтавки.СтавкаРегиональныйБюджет;
			ИначеЕсли СтавкаРегиональныйБюджет <> ОписаниеСтавки.СтавкаРегиональныйБюджет Тогда
				ФактическиИспользуетсяЕдинаяСтавка = Ложь;
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
		
		Если ФактическиИспользуетсяЕдинаяСтавка Тогда
			
			Протокол.АлгоритмРасчета = Перечисления.АлгоритмыРасчетаСтавкиОтложенногоНалога.Установленная;
			
			Если СтавкаРегиональныйБюджет <> Неопределено Тогда
				
				// Региональная ставка в единственном регионе фактической деятельности организации
				// может быть иной, чем установлена для организации в целом.
				// Рассчитаем суммарную ставку исходя из региональной ставки.
				
				Протокол.ДанныеАлгоритма.Вставить("СтавкаРегиональныйБюджет", СтавкаРегиональныйБюджет);
				Протокол.ДанныеАлгоритма.Вставить("СтавкаФедеральныйБюджет",  СтавкаФедеральныйБюджет);
				
				СтавкаНалога = Протокол.ДанныеАлгоритма.СтавкаФедеральныйБюджет + Протокол.ДанныеАлгоритма.СтавкаРегиональныйБюджет;
					
			КонецЕсли;
			
		Иначе
			
			// В территориально-распределенной организации при наличии разных ставок налога в разных регионах 
			// определить ставку "установленную законодательством Российской Федерации о налогах и сборах"
			// опираясь непосредственно на законодательство непросто,
			// так как следует учесть
			// - влияние подразделений, закрытых в течение периода
			// - влияние округления суммы налоговой базы и налога. 
			// Поэтому, когда это возможно, для определения фактически действующей ставки за отчетный период
			// рассчитаем ее как отношение суммы налога к налоговой базе.
			
			Протокол.ДанныеАлгоритма.Вставить(
				"НалоговаяБаза",
				ПоказателиРасчетаЭффективнойСтавки.Итог("НалоговаяБаза"));
				
			Протокол.ДанныеАлгоритма.Вставить(
				"ОбщаяСуммаНалога",
				ОбщаяСуммаНалога);
				
			Если Протокол.ДанныеАлгоритма.НалоговаяБаза > 0 И Протокол.ДанныеАлгоритма.ОбщаяСуммаНалога > 0 Тогда
				// Рассчитываем через фактические показатели налоговой базы и начисленного налога
				Протокол.АлгоритмРасчета = Перечисления.АлгоритмыРасчетаСтавкиОтложенногоНалога.ПоНалоговойБазе;
				СтавкаНалога = ОкруглитьСтавкуНалога(
					Протокол.ДанныеАлгоритма.ОбщаяСуммаНалога
					/ Протокол.ДанныеАлгоритма.НалоговаяБаза);
			Иначе
				// Применяем ставки, установленные в отчетном периоде
				СкорректироватьСтавкуПоДолямНалоговойБазы(
					СтавкаНалога,
					ОбщаяСтавкаРегиональныйБюджет,
					ПоказателиРасчетаЭффективнойСтавки,
					Протокол);
			КонецЕсли;
			
		КонецЕсли;
	
	Иначе
		
		Протокол.АлгоритмРасчета = Перечисления.АлгоритмыРасчетаСтавкиОтложенногоНалога.Установленная;
		
	КонецЕсли;
	
	Возврат СтавкаНалога;
		
КонецФункции

// В общем случае, отложенный налог должен быть оценен по ставке,
// которая будет действовать при погашении отложенных налоговых активов и обязательств.
//
// Как правило, сложно определить, когда именно они будут погашены и какая будет ставка.
// Поэтому, в типовом решении используем ставку, установленную на следующий отчетный период.
// Если в разных регионах деятельности предприятия отличаются ставки, то корректируем ставку 
// в соответствии с правилами распределения налоговой базы, установленными НК.
// При этом
// - используем те показатели, что сложились на отчетную дату
// - исключаем из них показатели закрытых подразделений -
//   очевидно, они не повлияют на распределение прибыли в будущем.
// 
// При необходимости учитывать другие параметры, эту процедуру рекомендуется переопределить.
//
Процедура УточнитьСтавкуБудущегоНалога(
	Ставка, КонтекстРасчета, ВариантНалогообложенияПрибыли, ПоказателиРасчетаЭффективнойСтавки, Протокол)
	
	Протокол.ДанныеАлгоритма.Вставить("ДатаРасчетаСтавки", ДатаРасчетаСтавкиБудущегоНалога(КонтекстРасчета));
	
	ОбщаяСтавкаФедеральныйБюджет = НалоговыйУчет.НалоговаяСтавкаФедеральныйБюджет(
		Протокол.ДанныеАлгоритма.ДатаРасчетаСтавки,
		КонтекстРасчета.Организация,
		,
		ВариантНалогообложенияПрибыли);
	
	ОбщаяСтавкаРегиональныйБюджет = НалоговыйУчет.НалоговаяСтавкаРегиональныйБюджет(
		Протокол.ДанныеАлгоритма.ДатаРасчетаСтавки,
		КонтекстРасчета.Организация,
		,
		ВариантНалогообложенияПрибыли);
	
	Ставка = ОбщаяСтавкаФедеральныйБюджет + ОбщаяСтавкаРегиональныйБюджет;
	
	Протокол.АлгоритмРасчета = Перечисления.АлгоритмыРасчетаСтавкиОтложенногоНалога.Установленная;
	Если ЗначениеЗаполнено(ПоказателиРасчетаЭффективнойСтавки) Тогда
		СкорректироватьСтавкуПоДолямНалоговойБазы(
			Ставка,
			ОбщаяСтавкаРегиональныйБюджет,
			ПоказателиРасчетаЭффективнойСтавки,
			Протокол);
	КонецЕсли;
		
КонецПроцедуры

Процедура УточнитьСтавкуНачалоПериода(
	Ставка,
	КонтекстРасчета,
	ВариантНалогообложенияПрибыли,
	НачальныеДанныеОтчетнаяДата,
	НачальныеДанныеПериодРасчета,
	Протокол)
	
	Если Не ЗначениеЗаполнено(НачальныеДанныеПериодРасчета) Тогда
		// Ранее установили, что данных нет.
		Возврат;
	КонецЕсли;
	
	ОписаниеПериода = Новый Структура;
	ОписаниеПериода.Вставить("ОтчетнаяДата",  НачальныеДанныеОтчетнаяДата);
	ОписаниеПериода.Вставить("ПериодРасчета", НачальныеДанныеПериодРасчета);
	
	ПрочитаннаяСтавка = РегистрыСведений.ПримененныеСтавкиОтложенногоНалога.ПрочитатьСтавки(
		ОписаниеПериода,
		КонтекстРасчета.Организация,
		ВариантНалогообложенияПрибыли,
		"Доля",
		Перечисления.ВидыСтавокОтложенногоНалога.БудущийНалог);
		
	Если ПрочитаннаяСтавка <> Неопределено Тогда
		Протокол.АлгоритмРасчета = Перечисления.АлгоритмыРасчетаСтавкиОтложенногоНалога.ПредыдущийРасчет;
		Протокол.ДанныеАлгоритма.Вставить("ОтчетнаяДата",  НачальныеДанныеОтчетнаяДата);
		Протокол.ДанныеАлгоритма.Вставить("ПериодРасчета", НачальныеДанныеПериодРасчета);
		Ставка = ПрочитаннаяСтавка;
	КонецЕсли;
		
КонецПроцедуры

Функция НовыйПротоколРасчетаСтавкиНалога()
	
	Протокол = Новый Структура;
	Протокол.Вставить("АлгоритмРасчета",  Перечисления.АлгоритмыРасчетаСтавкиОтложенногоНалога.ПустаяСсылка());
	Протокол.Вставить("ДанныеАлгоритма",  Новый Структура);
	
	Возврат Протокол;
	
КонецФункции

// Закрытые подразделения не учитываем, так как в будущих периодах они уже не повлияют на распределение прибыли.
Процедура СкорректироватьСтавкуПоДолямНалоговойБазы(
	Ставка, ОбщаяСтавкаРегиональныйБюджет, ПоказателиРасчетаЭффективнойСтавки, Протокол)
	
	Протокол.АлгоритмРасчета = Перечисления.АлгоритмыРасчетаСтавкиОтложенногоНалога.УстановленнаяПоДолямНалоговойБазы;
	Протокол.ДанныеАлгоритма.Вставить("ОбщаяСтавка", Ставка);
	
	// В отдельных подразделениях региональная ставка может отличаться от общеустановленной
	// Чтобы сократить ошибки округления, среднюю ставку рассчитываем как разницу между
	// - общеустановленной ставкой
	// - отклонением региональных ставок от общеустановленной.
	// Рассчитаем отклонение региональных ставок от общеустановленных, взвешенное с учетом доли налоговой базы подразделений.
	// Закрытые подразделения не учитываем, так как в будущих периодах они уже не повлияют на распределение прибыли.
	
	ВзвешеннаяСуммаОтклоненийСтавки = 0;
	СуммаДолейНалоговойБазы         = 0;
	
	Протокол.ДанныеАлгоритма.Вставить("ОтклоненияСтавки",  Новый Соответствие);
	Протокол.ДанныеАлгоритма.Вставить("ДолиНалоговойБазы", Новый Соответствие);
		
	Для Каждого ПоказательРасчета Из ПоказателиРасчетаЭффективнойСтавки Цикл
		
		Если ПоказательРасчета.Закрыто Тогда
			// не учитываем показатели вовсе
			Продолжить;
		КонецЕсли;
		
		Протокол.ДанныеАлгоритма.ДолиНалоговойБазы.Вставить(
			ПоказательРасчета.РегистрацияВНалоговомОргане,
			ПоказательРасчета.ДоляФНС);
		
		СуммаДолейНалоговойБазы = СуммаДолейНалоговойБазы + ПоказательРасчета.ДоляФНС;
		
		СтавкаРегиональныйБюджет = ПоказательРасчета.СтавкаРегиональныйБюджет;
		Если Не ЗначениеЗаполнено(СтавкаРегиональныйБюджет) Тогда
			Продолжить;
		КонецЕсли;
		
		ОтклонениеСтавки = СтавкаРегиональныйБюджет - ОбщаяСтавкаРегиональныйБюджет;
		Если ОтклонениеСтавки = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		Протокол.ДанныеАлгоритма.ОтклоненияСтавки.Вставить(
			ПоказательРасчета.РегистрацияВНалоговомОргане,
			ОтклонениеСтавки);
		
		ВзвешеннаяСуммаОтклоненийСтавки = ОтклонениеСтавки * ПоказательРасчета.ДоляФНС
			+ ВзвешеннаяСуммаОтклоненийСтавки;
		
	КонецЦикла;
	
	Если СуммаДолейНалоговойБазы <> 0 Тогда
		ОтклонениеСтавки = ОкруглитьСтавкуНалога(ВзвешеннаяСуммаОтклоненийСтавки / СуммаДолейНалоговойБазы);
		Ставка = Ставка + ОтклонениеСтавки;
	КонецЕсли;
	
КонецПроцедуры

Функция СуммаПоСтавкеНалога(База, Ставка)
	
	Возврат Окр(База * Ставка, 2);
	
КонецФункции

Функция ОкруглитьСтавкуНалога(ТочноеЗначение)
	
	ТипСтавкиНалога = Метаданные.РегистрыСведений.ПримененныеСтавкиОтложенногоНалога.Ресурсы.СтавкаНалога.Тип;
	
	КвалификаторыЧислаЛюбойЗнак = Новый КвалификаторыЧисла(
		ТипСтавкиНалога.КвалификаторыЧисла.Разрядность,
		ТипСтавкиНалога.КвалификаторыЧисла.РазрядностьДробнойЧасти,
		ДопустимыйЗнак.Любой);
	ТипДляОкругления = Новый ОписаниеТипов(ТипСтавкиНалога,,,КвалификаторыЧислаЛюбойЗнак);
	
	Возврат ТипДляОкругления.ПривестиЗначение(ТочноеЗначение);
	
КонецФункции

#КонецОбласти

#Область РасходПоНалогу

// Функция-конструктор расчет расхода по налогу на прибыль
// 
// Возвращаемое значение:
// 	Структура - Описание:
// * ВариантНалогообложенияПрибыли - СправочникСсылка.ВариантыНалогообложенияПрибыли -
// * КодЯзыка - Строка -
// * КодыПоказателей - Неопределено -
// * ПорядокРасчета - Соответствие -
// * ЕстьДанныеНалогаВДобавочномКапитале - Булево -
// * ОблагаемыйФинансовыйРезультат - Структура - содержит:
// 		** Сумма   - Число - Сумма по бухгалтерскому учету
// 		** СуммаНУ - Число - Сумма по налоговому учету
// 		** СуммаПР - Число - Сумма постоянных разниц (если используется учет разниц)
// 		** СуммаВР - Число - Сумма временных разниц (если используется учет разниц)
// * Ставка - Число -
//
Функция НовыйРасчетРасходаПоНалогу()
	
	Расчет = Новый Структура;
	Расчет.Вставить("ВариантНалогообложенияПрибыли", Справочники.ВариантыНалогообложенияПрибыли.ПустаяСсылка());
	Расчет.Вставить("Ставка",                        0);
	Расчет.Вставить("ОблагаемыйФинансовыйРезультат", КоллекцииСумм.НовыйКоллекцияСумм(ОписаниеКоллекцииСумм()));
	Расчет.Вставить("ПорядокРасчета",                Новый Соответствие); // Ключ - показатель, Значение - строка, порядок расчета
	Расчет.Вставить("ЕстьДанныеНалогаВДобавочномКапитале", Ложь);
	
	Для Каждого ОписаниеПоказателя Из Метаданные.Перечисления.ПоказателиОтложенногоНалога.ЗначенияПеречисления Цикл
		Расчет.Вставить(ОписаниеПоказателя.Имя, 0);
	КонецЦикла;
	
	// Некоторые показатели из Перечисления.ПоказателиОтложенногоНалога не имеют кодов.
	// Такие не должны быть частью формул (на них не следует ссылаться в ПорядокРасчета)
	
	Расчет.Вставить("КодыПоказателей", Неопределено); // Кеш для использования Перечисления.ПоказателиОтложенногоНалога.Код()
	
	Расчет.Вставить("КодЯзыка",        ОбщегоНазначения.КодОсновногоЯзыка()); // данные расчета записываются в информационную базу
	
	Возврат Расчет;
	
КонецФункции

Процедура РассчитатьРасходПоНалогу(ТаблицаРасчета, КонтекстРасчета)
	
	// Текущий налог определяется по данным налоговой декларации по налогу на прибыль
	// (в соответствии с вторым вариантом из предложенных в ПБУ18.22).
	
	// Расход по налогу на прибыль рассчитывается в соответствии с приложением к ПБУ18
	// (показатели, вычитаемые из прибыли, отражаются с отрицательным знаком).
	
	ИнвестиционныйНалоговыйВычетЗаПериодПоВариантамНО = ИнвестиционныйНалоговыйВычетЗаПериодПоВариантамНО(КонтекстРасчета);
	
	Для каждого ОбщийРасчет Из ТаблицаРасчета Цикл
		
		ДанныеИНВ = ИнвестиционныйНалоговыйВычетЗаПериодПоВариантамНО.Получить(ОбщийРасчет.ВариантНалогообложенияПрибыли);
		ЕстьДанныеИНВ = ДанныеИНВ <> Неопределено 
			И (ДанныеИНВ.СуммаВычетаПеренесенногоНаБудущее <> 0 ИЛИ ДанныеИНВ.СуммаУменьшенияНалогаНаПрибыль <> 0);
		
		РасчетОтложенногоНалога = ОбщийРасчет.РасчетОтложенногоНалога; // см. НовыйРасчетОтложенногоНалога
		
		Расчет                               = ОбщийРасчет.РасчетРасходаПоНалогу;
		Расчет.ВариантНалогообложенияПрибыли = ОбщийРасчет.ВариантНалогообложенияПрибыли;
		
		Расчет.Ставка          = РасчетОтложенногоНалога.СтавкиНалога[Перечисления.ВидыСтавокОтложенногоНалога.ТекущийНалог];
		
		Если ЕстьДанныеИНВ Тогда
			Расчет.ИнвестиционныйВычет = ДанныеИНВ.СуммаУменьшенияНалогаНаПрибыль;
			ПорядокРасчета = СтрШаблон(
				НСтр("ru = 'Оборот по дебету счета %1 в корреспонденции со счетом %2'", Расчет.КодЯзыка),
				КодСчета(ПланыСчетов.Хозрасчетный.РасчетыСБюджетом),
				КодСчета(ПланыСчетов.Хозрасчетный.ИнвестиционныйВычетПоНалогуНаПрибыль));
			ДобавитьЗаписьПротоколаРасчета(Расчет, "ИнвестиционныйВычет", ПорядокРасчета);
			
			Расчет.ОтложенныйНалоговыйАктивИнвестиционныйВычет = ДанныеИНВ.СуммаВычетаПеренесенногоНаБудущее;
			ПорядокРасчета = СтрШаблон(
				НСтр("ru = 'Оборот по дебету счета %1 в корреспонденции со счетом %2'", Расчет.КодЯзыка),
				КодСчета(ПланыСчетов.Хозрасчетный.ОтложенныеНалоговыеАктивы),
				КодСчета(ПланыСчетов.Хозрасчетный.ИнвестиционныйВычетПоНалогуНаПрибыль));
			ДобавитьЗаписьПротоколаРасчета(Расчет, "ОтложенныйНалоговыйАктивИнвестиционныйВычет", ПорядокРасчета);
			
			Расчет.ТекущийНалог = - ОбщийРасчет.НачисленныйНалог + ДанныеИНВ.СуммаУменьшенияНалогаНаПрибыль;
		Иначе
			Расчет.ТекущийНалог    = - ОбщийРасчет.НачисленныйНалог;			
		КонецЕсли;
		
		КоррСчетДляРасчетыСБюджетом = СчетТекущегоНалогаНаПрибыль(КонтекстРасчета.ВариантУчетаОтложенногоНалога);
		
		ПорядокРасчета = СтрШаблон(
			НСтр("ru = 'Оборот по кредиту счета %1 в корреспонденции со счетом %2 (со знаком ""минус"")'", Расчет.КодЯзыка),
			КодСчета(ПланыСчетов.Хозрасчетный.РасчетыСБюджетом),
			КодСчета(КоррСчетДляРасчетыСБюджетом));
		
		Если ЕстьДанныеИНВ Тогда
			ПорядокРасчета = СтрШаблон(
				НСтр("ru = 'Оборот по кредиту счета %1 в корреспонденции со счетом %2 (со знаком ""минус"") + (%3)'", Расчет.КодЯзыка),
				КодСчета(ПланыСчетов.Хозрасчетный.РасчетыСБюджетом),
				КодСчета(КоррСчетДляРасчетыСБюджетом),
				Перечисления.ПоказателиОтложенногоНалога.Код(Перечисления.ПоказателиОтложенногоНалога.ИнвестиционныйВычет, Расчет.КодыПоказателей));
		КонецЕсли;
		
		ДобавитьЗаписьПротоколаРасчета(Расчет, "ТекущийНалог", ПорядокРасчета);
		
		// Прибыль до налогообложения, налоговая база
		Расчет.ОблагаемыйФинансовыйРезультат = ОбщийРасчет.СуммыНалоговойБазы;
			
		Расчет.ПрибыльДоНалогообложения = Расчет.ОблагаемыйФинансовыйРезультат.Сумма;
		ДобавитьЗаписьПротоколаРасчета(Расчет, "ПрибыльДоНалогообложения", ПорядокРасчетаФинансовыйРезультат(Расчет.КодЯзыка));
		
		// Отложенный налог
		Расчет.ЭффектИзмененияВременныхРазниц = РасчетОтложенногоНалога.ОтложенныйНалог.Итог("ЭффектУвеличенияВременныхРазниц")
		                                      + РасчетОтложенногоНалога.ОтложенныйНалог.Итог("ЭффектУменьшенияВременныхРазниц");
		Расчет.ЭффектИзмененияСтавкиБудущегоНалога = РасчетОтложенногоНалога.ОтложенныйНалог.Итог("ЭффектИзмененияСтавкиБудущегоНалога");
		Расчет.ЭффектИзмененияСтавкиТекущегоНалога = РасчетОтложенногоНалога.ОтложенныйНалог.Итог("ЭффектИзмененияСтавкиТекущегоНалога");
		
		ЗаполнитьПоказателиОтложенногоНалогаВДобавочномКапитале(КонтекстРасчета, Расчет, РасчетОтложенногоНалога);
		
		Если ЗначениеЗаполнено(Расчет.ЭффектИзмененияСтавкиБудущегоНалога)
			Или ЗначениеЗаполнено(Расчет.ЭффектИзмененияСтавкиТекущегоНалога) Тогда
			// В протокол выводим детальные записи об эффектах, если они несут дополнительную информацию.
			// Если случай тривиальный - т.е. все изменение обуславливается только изменением разниц -
			// то это не выводим в протокол.
			// Это повторяет и логику пояснений в СправкаРасчетОтложенногоНалога - какие-либо эффекты упоминаются,
			// если есть влияние изменения ставок.
			ДобавитьЗаписьПротоколаРасчета(Расчет, "ЭффектИзмененияВременныхРазниц");
			ДобавитьЗаписьПротоколаРасчета(Расчет, "ЭффектИзмененияСтавкиТекущегоНалога");
			ДобавитьЗаписьПротоколаРасчета(Расчет, "ЭффектИзмененияСтавкиБудущегоНалога");
			
			Если Расчет.ЕстьДанныеНалогаВДобавочномКапитале Тогда
				ДобавитьЗаписьПротоколаРасчета(Расчет, "ЭффектИзмененияСуммыОперацийНеВключаемыхВЧистуюПрибыль");
			КонецЕсли;
		КонецЕсли;
		
		Расчет.ОтложенныйНалог = РасчетОтложенногоНалога.ОтложенныйНалог.Итог("УвеличениеОтложенногоНалога")
		                       + РасчетОтложенногоНалога.ОтложенныйНалог.Итог("УменьшениеОтложенногоНалога")
		                       + РасчетОтложенногоНалога.ОтложенныйНалог.Итог("Пересчет")
		                       + Расчет.НалогНаПрибыльОтОперацийКоторыеНеВключаютсяВЧистуюПрибыль
		                       + Расчет.ОтложенныйНалоговыйАктивИнвестиционныйВычет;
		
		// 34 Отложенный налоговый актив должен признаваться в отношении перенесенных на будущие периоды
		//    неиспользованных налоговых убытков
		Расчет.ВлияниеУбыткаТекущегоПериода = ВлияниеУбыткаТекущегоПериода(
			Расчет.ОблагаемыйФинансовыйРезультат,
			ОбщийРасчет.УбытокПеренесенныйНаБудущее,
			Расчет.Ставка,
			КонтекстРасчета);
			
		Расчет.ОтложенныйНалог = Расчет.ОтложенныйНалог + Расчет.ВлияниеУбыткаТекущегоПериода;
		
		// Для справки-расчета приводим другой порядок расчета отложенного налога
		ДобавитьОписаниеРасчетаОтложенногоНалога(Расчет, РасчетОтложенногоНалога.ОтложенныйНалог, КонтекстРасчета, ЕстьДанныеИНВ);
		
		// РасходПоНалогу
		Расчет.РасходПоНалогу = Расчет.ОтложенныйНалог + Расчет.ТекущийНалог;
		
		ПорядокРасчета = СтрШаблон(
			НСтр("ru = '(%1) + (%2)'", Расчет.КодЯзыка),
			Перечисления.ПоказателиОтложенногоНалога.Код(Перечисления.ПоказателиОтложенногоНалога.ОтложенныйНалог, Расчет.КодыПоказателей),
			Перечисления.ПоказателиОтложенногоНалога.Код(Перечисления.ПоказателиОтложенногоНалога.ТекущийНалог, Расчет.КодыПоказателей));
		ДобавитьЗаписьПротоколаРасчета(Расчет, "РасходПоНалогу", ПорядокРасчета);
		
		// 20. Условный расход (условный доход) по налогу на прибыль равняется величине,
		//     определяемой как произведение бухгалтерской прибыли,
		//     сформированной в отчетном периоде, на ставку налога на прибыль
		
		РассчитатьНалоговыйРасход(Расчет, "УсловныйРасход", "ПрибыльДоНалогообложения");
		
		// 7. Для целей Положения под постоянным налоговым расходом (доходом) понимается сумма налога,
		//    которая приводит к увеличению (уменьшению) налоговых платежей по налогу на прибыль в отчетном периоде.
		
		Расчет.ПостоянныйНалоговыйРасход = Расчет.РасходПоНалогу
		                                 - Расчет.УсловныйРасход
		                                 - Расчет.ЭффектИзмененияСтавкиБудущегоНалога
		                                 - Расчет.ЭффектИзмененияСтавкиТекущегоНалога;
		
		ПорядокРасчета = СтрШаблон(
			НСтр("ru = '(%1) - (%2)'", Расчет.КодЯзыка),
			Перечисления.ПоказателиОтложенногоНалога.Код(Перечисления.ПоказателиОтложенногоНалога.РасходПоНалогу, Расчет.КодыПоказателей),
			Перечисления.ПоказателиОтложенногоНалога.Код(Перечисления.ПоказателиОтложенногоНалога.УсловныйРасход, Расчет.КодыПоказателей));
		
		Если ЗначениеЗаполнено(Расчет.ЭффектИзмененияСтавкиБудущегоНалога)
			Или ЗначениеЗаполнено(Расчет.ЭффектИзмененияСтавкиТекущегоНалога) Тогда
			
			ПорядокРасчета = СтрШаблон(
				НСтр("ru = '%1 - (%2) - (%3)'", Расчет.КодЯзыка),
				ПорядокРасчета,
				Перечисления.ПоказателиОтложенногоНалога.Код(Перечисления.ПоказателиОтложенногоНалога.ЭффектИзмененияСтавкиТекущегоНалога, Расчет.КодыПоказателей),
				Перечисления.ПоказателиОтложенногоНалога.Код(Перечисления.ПоказателиОтложенногоНалога.ЭффектИзмененияСтавкиБудущегоНалога, Расчет.КодыПоказателей));
			
		КонецЕсли;
		
		ДобавитьЗаписьПротоколаРасчета(Расчет, "ПостоянныйНалоговыйРасход", ПорядокРасчета);
		
		// Для иллюстрации приводим показатель прибыли, очищенной от налога - как показано в Приложении 1 к ПБУ 18
		Расчет.ЧистаяПрибыль = Расчет.ПрибыльДоНалогообложения + Расчет.РасходПоНалогу;
		ПорядокРасчета = СтрШаблон(
			НСтр("ru = '(%1) + (%2)'", Расчет.КодЯзыка),
			Перечисления.ПоказателиОтложенногоНалога.Код(Перечисления.ПоказателиОтложенногоНалога.ПрибыльДоНалогообложения, Расчет.КодыПоказателей),
			Перечисления.ПоказателиОтложенногоНалога.Код(Перечисления.ПоказателиОтложенногоНалога.РасходПоНалогу, Расчет.КодыПоказателей));
		ДобавитьЗаписьПротоколаРасчета(Расчет, "ЧистаяПрибыль", ПорядокРасчета);
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьПоказателиОтложенногоНалогаВДобавочномКапитале(КонтекстРасчета, РасчетРасходаПоНалогу, РасчетОтложенногоНалога)	
	ОтложенныйНалогВДобавочномКапитале = РасчетОтложенногоНалога.ОтложенныйНалогВДобавочномКапитале;
	Расчет = РасчетРасходаПоНалогу;
	
	Расчет.ИзменениеНалогаНаПрибыльОтОперацийКоторыеНеВключаютсяВЧистуюПрибыль = ОтложенныйНалогВДобавочномКапитале.Итог("ЭффектУвеличенияВременныхРазниц")
		+ ОтложенныйНалогВДобавочномКапитале.Итог("ЭффектУменьшенияВременныхРазниц")
		- ОтложенныйНалогВДобавочномКапитале.Итог("ЭффектВключенияСуммыОперацииВНераспределеннуюПрибыль");
		
	Расчет.ПересчетНалогаОтОперацийКоторыеНеВключаютсяВЧистуюПрибыльПриИзмененииВарианта = 
		ПересчетНалогаОтОперацийКоторыеНеВключаютсяВЧистуюПрибыльПриИзмененииВарианта(Расчет.ВариантНалогообложенияПрибыли, КонтекстРасчета);	
		
	Расчет.НалогНаПрибыльОтОперацийКоторыеНеВключаютсяВЧистуюПрибыль = Расчет.ИзменениеНалогаНаПрибыльОтОперацийКоторыеНеВключаютсяВЧистуюПрибыль
		- Расчет.ПересчетНалогаОтОперацийКоторыеНеВключаютсяВЧистуюПрибыльПриИзмененииВарианта;  
		
	Расчет.ЭффектИзмененияСуммыОперацийНеВключаемыхВЧистуюПрибыль = Расчет.НалогНаПрибыльОтОперацийКоторыеНеВключаютсяВЧистуюПрибыль;

	РасчетРасходаПоНалогу.ЕстьДанныеНалогаВДобавочномКапитале = ЗначениеЗаполнено(РасчетРасходаПоНалогу.НалогНаПрибыльОтОперацийКоторыеНеВключаютсяВЧистуюПрибыль)
		ИЛИ Расчет.ПересчетНалогаОтОперацийКоторыеНеВключаютсяВЧистуюПрибыльПриИзмененииВарианта;
		
	Если РасчетРасходаПоНалогу.ЕстьДанныеНалогаВДобавочномКапитале Тогда
		Если ЗначениеЗаполнено(Расчет.ПересчетНалогаОтОперацийКоторыеНеВключаютсяВЧистуюПрибыльПриИзмененииВарианта) Тогда
			ПорядокРасчета = СтрШаблон(
				НСтр("ru = '(%1) - (%2)'", Расчет.КодЯзыка),
				Перечисления.ПоказателиОтложенногоНалога.Код(Перечисления.ПоказателиОтложенногоНалога.ИзменениеНалогаНаПрибыльОтОперацийКоторыеНеВключаютсяВЧистуюПрибыль, Расчет.КодыПоказателей),
				Перечисления.ПоказателиОтложенногоНалога.Код(Перечисления.ПоказателиОтложенногоНалога.ПересчетНалогаОтОперацийКоторыеНеВключаютсяВЧистуюПрибыльПриИзмененииВарианта, Расчет.КодыПоказателей));
			ДобавитьЗаписьПротоколаРасчета(Расчет, "НалогНаПрибыльОтОперацийКоторыеНеВключаютсяВЧистуюПрибыль", ПорядокРасчета);		
		Иначе	
			ДобавитьЗаписьПротоколаРасчета(Расчет, "НалогНаПрибыльОтОперацийКоторыеНеВключаютсяВЧистуюПрибыль");		
		КонецЕсли;
	КонецЕсли;
		
КонецПроцедуры

Процедура РассчитатьТекущийНалог(ТаблицаРасчета, КонтекстРасчета)
	
	// Проводки иллюстрируют расчет текущего налога на прибыль рассчитывается по данным бухгалтерского учета
	// в соответствии с первым вариантом, из предложенных в ПБУ18.22.
	// Его сумма может расходиться от начисленного налога за счет разницы в округлении.
	
	// ПБУ18.22
	
	// 22. ... определения величины текущего налога на прибыль ... на основе данных, сформированных в бухгалтерском учете
	//     При этом величина текущего налога на прибыль должна соответствовать сумме исчисленного налога на прибыль,
	//     отраженного в налоговой декларации по налогу на прибыль;
	
	// Такой расчет основан на транзакционном правиле БУ = НУ + ПР + ВР, где каждый компонент умножается на ставку налога:
	// БУ * Ставка = НУ * Ставка + ПР * Ставка + ВР * Ставка.
	///
	// При этом
	// - ТекущийНалог                   = НУ * Ставка
	// - УсловныйРасход                 = БУ * Ставка
	// - ПостоянныйНалоговыйРасход      = ПР * Ставка
	//
	// 7. Постоянный налоговый расход (доход) равняется величине, определяемой как произведение постоянной разницы,
	//    возникшей в отчетном периоде, на ставку налога на прибыль
	//
	// РасходПоНалогу = БУ - ПР = НУ + ВР
	// Поэтому сумма ПР выбирается с отрицательным знаком
	
	Для Каждого ОбщийРасчет Из ТаблицаРасчета Цикл
	
		Расчет                   = ОбщийРасчет.РасчетРасходаПоНалогу;
		
		Расчет.ПостояннаяРазница = - Расчет.ОблагаемыйФинансовыйРезультат.СуммаПР;
		
		ВидУчета = НСтр("ru = 'данные по учету постоянных разниц'", Расчет.КодЯзыка);
		ДобавитьЗаписьПротоколаРасчета(Расчет, "ПостояннаяРазница", ПорядокРасчетаФинансовыйРезультат(Расчет.КодЯзыка, ВидУчета));
		
		РассчитатьНалоговыйРасход(Расчет, "ПостоянныйНалоговыйРасход", "ПостояннаяРазница");
		
		// Формула балансируется значением ВР * Ставка, которое в идеальных условиях будет
		// численно равно ЭффектИзмененияВременныхРазниц, определенному балансовым методом. 
		// Но в условиях разного рода погрешностей в учете они могут отличаться.
		//
		// Поэтому вводится условное понятие ОтложенныйРасход - влияние изменения временных разниц на расчет финансового результата.
		
		Расчет.ВременнаяРазница = Расчет.ОблагаемыйФинансовыйРезультат.СуммаВР;
		ДобавитьЗаписьПротоколаРасчета(Расчет, "ВременнаяРазница");
		
		Расчет.ОтложенныйРасход = - СуммаПоСтавкеНалога(Расчет.ОблагаемыйФинансовыйРезультат.СуммаВР, Расчет.Ставка);
		ДобавитьЗаписьПротоколаРасчета(Расчет, "ОтложенныйРасход");
		
		// Далее эти погрешности раскладываются по влияющим факторам
		Если НЕ КонтекстРасчета.ИспользуетсяРаздельныйУчет И КонтекстРасчета.ПрименяютсяСпециальныеРежимы Тогда
			
			// При использовании раздельного учета, налоговая база на 99.01.1 делится по вариантам н/о,
			// в том числе по льготируемым.
			
			// Влияние изменения разниц может потребоваться скорректировать, когда не выполняется требование ПБУ18.16:
			//   В случае, если законодательством ... предусмотрены разные ставки налога на прибыль по отдельным видам доходов,
			//   то при оценке отложенного налогового актива или отложенного налогового обязательства
			//   ставка налога на прибыль должна соответствовать тому виду дохода,
			//   который ведет к уменьшению ... временной разницы в ... последующих отчетных периодах.
			
			// В программе принято, что на балансовых счетах отражаются разницы, которые относятся к видам деятельности,
			// облагаемым налогом на прибыль.
			
			// Если соответствующие активы и обязательства повлияли на финансовый результат по видам деятельности,
			// облагаемым в рамках специальных режимов, то это следует учесть при числовой сверке сумму текущего налога.
			
			// Такое влияние описано в ПБУ18.17, ПБУ18.18 отдельно, поэтому и в расчете покажем его обособленно.
			
			НеОблагаемыйФинансовыйРезультат = РасчетНалогаНаПрибыль.СуммыНалоговойБазы(
				КонтекстРасчета.НачалоНалоговогоПериода,
				КонтекстРасчета.КонецПериода,
				КонтекстРасчета.Организация,
				ОписаниеКоллекцииСумм(),
				ПланыСчетов.Хозрасчетный.ПрибылиИУбыткиЕНВД);
				
			Расчет.ВыбытиеПоСпециальнымРежимам = - СуммаПоСтавкеНалога(НеОблагаемыйФинансовыйРезультат.СуммаВР, Расчет.Ставка);
			
			Если ЗначениеЗаполнено(Расчет.ВыбытиеПоСпециальнымРежимам) Тогда
				
				ДобавитьЗаписьПротоколаРасчета(Расчет, "ВыбытиеПоСпециальнымРежимам");
				
			КонецЕсли;
			
		КонецЕсли;
		
		ДобавитьЗаписьПротоколаРасчета(Расчет, "ОтложенныйРасход");
		
		Расчет.РасчетныйТекущийНалог = Расчет.УсловныйРасход + Расчет.ПостоянныйНалоговыйРасход - Расчет.ОтложенныйРасход;
		Расчет.РасчетныйТекущийНалог = Расчет.РасчетныйТекущийНалог - Расчет.ВлияниеУбыткаТекущегоПериода; // при убытке текущий налог равен нулю, поэтому требуется балансировать суммой убытка
		Расчет.РасчетныйТекущийНалог = Расчет.РасчетныйТекущийНалог + Расчет.ИнвестиционныйВычет;
		
		ДобавитьЗаписьПротоколаРасчета(Расчет, "РасчетныйТекущийНалог");
		
		// Суммарная величина погрешностей может быть определена, как разница в расчете сумм текущего налога двумя способами из ПБУ18.22
		Расчет.КорректировкаТекущегоНалога = Расчет.РасчетныйТекущийНалог - Расчет.ТекущийНалог;
		Если ЗначениеЗаполнено(Расчет.КорректировкаТекущегоНалога) Тогда
			ДобавитьЗаписьПротоколаРасчета(Расчет, "КорректировкаТекущегоНалога");
		КонецЕсли;
		
		// На практике могут быть допущены разного рода ошибки, неточности в учете.
		// Покажем влияние этих ошибок.
		
		// Ошибка учета разниц заключается в том, что не выполняется равенство БУ=НУ+ПР+ВР.
		// Т.е. какие-то расхождения между налоговой и бухгалтерской прибылью оказались "незамеченными"
		// для целей ПБУ 18.
		ОшибкаУчетаРазниц = Расчет.ОблагаемыйФинансовыйРезультат.Сумма
			              - Расчет.ОблагаемыйФинансовыйРезультат.СуммаНУ
			              - Расчет.ОблагаемыйФинансовыйРезультат.СуммаВР
			              - Расчет.ОблагаемыйФинансовыйРезультат.СуммаПР;
		
		Расчет.ВлияниеОшибокУчетаРазниц = - СуммаПоСтавкеНалога(ОшибкаУчетаРазниц, Расчет.Ставка);
		
		Если ЗначениеЗаполнено(Расчет.ВлияниеОшибокУчетаРазниц) Тогда
			ДобавитьЗаписьПротоколаРасчета(Расчет, "ВлияниеОшибокУчетаРазниц");
		КонецЕсли;
		
		// Ошибка учета отложенного налога показывает разницу между разными методами определением суммы изменения отложенного налога.
		// Если учет построен верно, то разницы не должно быть.
		// Как правило, разница вызвана отражением временных разниц на балансовых счетах
		// без отражения их совокупного влияния на счетах доходов и расходов.
		// Корректный порядок учета предполагает, что возникновение и погашение разниц может быть при корреспонденции
		// - либо двух балансовых счетов, при этом суммарный баланс разниц не меняется;
		// - либо балансового и счета доходов (расходов).
		// - либо с счетом учета операций, результат которых не включается в чистую прибыль (убыток) периода
		РасчетныйЭффектИзмененияВременныхРазниц = Расчет.ОтложенныйРасход;
		Если ЗначениеЗаполнено(Расчет.ВыбытиеПоСпециальнымРежимам) Тогда
			РасчетныйЭффектИзмененияВременныхРазниц = РасчетныйЭффектИзмененияВременныхРазниц + Расчет.ВыбытиеПоСпециальнымРежимам;
		КонецЕсли;
		
		Если Расчет.ЕстьДанныеНалогаВДобавочномКапитале Тогда
			РасчетныйЭффектИзмененияВременныхРазниц = РасчетныйЭффектИзмененияВременныхРазниц 
				- Расчет.НалогНаПрибыльОтОперацийКоторыеНеВключаютсяВЧистуюПрибыль;	
		КонецЕсли;
		
		Расчет.ПересчетОтложенногоНалогаПриИзмененииВариантаНалогообложенияПрибыли = ПересчетОтложенногоНалогаПриИзмененииВариантаНалогообложенияПрибыли(КонтекстРасчета.ДанныеПроводокИзмененияВарианта,
			Расчет.ВариантНалогообложенияПрибыли, КонтекстРасчета.ДанныеПредыдущегоПересчетаОтложенногоНалогаПриИзмененииВариантаНО);		
			
		Если ЗначениеЗаполнено(Расчет.ПересчетОтложенногоНалогаПриИзмененииВариантаНалогообложенияПрибыли) Тогда
			РасчетныйЭффектИзмененияВременныхРазниц = РасчетныйЭффектИзмененияВременныхРазниц 
				+ Расчет.ПересчетОтложенногоНалогаПриИзмененииВариантаНалогообложенияПрибыли;
			ДобавитьЗаписьПротоколаРасчета(Расчет, "ПересчетОтложенногоНалогаПриИзмененииВариантаНалогообложенияПрибыли");
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Расчет.ПересчетНалогаОтОперацийКоторыеНеВключаютсяВЧистуюПрибыльПриИзмененииВарианта) Тогда
			ДобавитьЗаписьПротоколаРасчета(Расчет, "ПересчетНалогаОтОперацийКоторыеНеВключаютсяВЧистуюПрибыльПриИзмененииВарианта");
			ДобавитьЗаписьПротоколаРасчета(Расчет, "ИзменениеНалогаНаПрибыльОтОперацийКоторыеНеВключаютсяВЧистуюПрибыль");
		КонецЕсли;

		Расчет.ВлияниеОшибокУчетаОтложенногоНалога = РасчетныйЭффектИзмененияВременныхРазниц - Расчет.ЭффектИзмененияВременныхРазниц;
		Если ЗначениеЗаполнено(Расчет.ВлияниеОшибокУчетаОтложенногоНалога) Тогда
			ДобавитьЗаписьПротоколаРасчета(Расчет, "ВлияниеОшибокУчетаОтложенногоНалога");
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// Возвращает структуру данных предыдущего расчета отложенного налога при изменении варианта налогообложения прибыли.
// 
// Возвращаемое значение:
// 	Структура - Описание:
// * ДанныеПересчетаОтложенногоНалога - Соответствие из СправочникСсылка.ВариантыНалогообложенияПрибыли
// * ДанныеПересчетаОтложенногоНалогаВДобавичномКапитале - Соответствие из СправочникСсылка.ВариантыНалогообложенияПрибыли
//
Функция ДанныеПредыдущегоПересчетаОтложенногоНалога()

	Данные = Новый Структура;
	Данные.Вставить("ДанныеПересчетаОтложенногоНалога", Новый Соответствие);
	Данные.Вставить("ДанныеПересчетаОтложенногоНалогаВДобавичномКапитале", Новый Соответствие);
	
	Возврат Данные;
	
КонецФункции

Функция КодСчета(Счет)
	Возврат ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Счет, "Код");
КонецФункции

Процедура ДобавитьЗаписьПротоколаРасчета(Расчет, ИмяПоказателя, ПорядокРасчета = "")
	
	Расчет.ПорядокРасчета.Вставить(Перечисления.ПоказателиОтложенногоНалога[ИмяПоказателя], ПорядокРасчета);
	
КонецПроцедуры

Процедура РассчитатьНалоговыйРасход(Расчет, ИмяРассчитываемогоПоказателя, ИмяПоказателяБазы)
	
	// Налоговый расход определяется исходя из некоторой базы - прибыли или ее компонента.
	// Для этого база умножается на ставку налога.
	// Кроме того, база и налоговый расход имеют противоположные знаки,
	// так как, например, прибыль увеличивает чистую прибыль, а налог - уменьшает.
	
	Расчет[ИмяРассчитываемогоПоказателя] = - СуммаПоСтавкеНалога(Расчет[ИмяПоказателяБазы], Расчет.Ставка);
	
	ПорядокРасчета = СтрШаблон(
		НСтр("ru = '- (%1) * %2%%'", Расчет.КодЯзыка),
		Перечисления.ПоказателиОтложенногоНалога.Код(Перечисления.ПоказателиОтложенногоНалога[ИмяПоказателяБазы], Расчет.КодыПоказателей),
		Формат(Расчет.Ставка * 100, "ЧН=0"));
		
	ДобавитьЗаписьПротоколаРасчета(Расчет, ИмяРассчитываемогоПоказателя, ПорядокРасчета);
	
КонецПроцедуры

Функция ПорядокРасчетаФинансовыйРезультат(КодЯзыка, ВидУчета = "")
	
	ПорядокРасчета = СтрШаблон(
		НСтр("ru = 'Оборот по счету %1 в корреспонденции со счетами %2,%3'", КодЯзыка),
		КодСчета(ПланыСчетов.Хозрасчетный.ПрибылиИУбытки),
		КодСчета(ПланыСчетов.Хозрасчетный.Продажи),
		КодСчета(ПланыСчетов.Хозрасчетный.ПрочиеДоходыИРасходы));
		
	Если ПустаяСтрока(ВидУчета) Тогда
		Возврат ПорядокРасчета;
	КонецЕсли;
	
	Шаблон = НСтр("ru = '%1 (%2)'", КодЯзыка); // Оборот (по такому-то виду учета)
	Возврат СтрШаблон(Шаблон, ПорядокРасчета, ВидУчета);
	
КонецФункции

Процедура ДобавитьОписаниеРасчетаОтложенногоНалога(Расчет, ОтложенныйНалог, КонтекстРасчета, ЕстьДанныеИНВ)
	
	// Фактически для расчета определяется конечное сальдо по счетам 09 и 77 и изменения (эффекты).
	// Но для иллюстрации расчета покажем начальное и конечное сальдо.
	
	ОтложенныйНалоговыйАктивИзменение         = 0;
	ОтложенноеНалоговоеОбязательствоИзменение = 0;
	
	Для Каждого Запись Из ОтложенныйНалог Цикл
		
		ИзменениеОтложенногоНалога = СуммарноеИзменениеОтложенногоНалога(Запись);
		
		Если Запись.Счет = ПланыСчетов.Хозрасчетный.ОтложенныеНалоговыеАктивы Тогда
			Расчет.ОтложенныйНалоговыйАктивКонецПериода = Расчет.ОтложенныйНалоговыйАктивКонецПериода + Запись.ОтложенныйНалог;
			ОтложенныйНалоговыйАктивИзменение = ОтложенныйНалоговыйАктивИзменение + ИзменениеОтложенногоНалога;
		Иначе
			Расчет.ОтложенноеНалоговоеОбязательствоКонецПериода = Расчет.ОтложенноеНалоговоеОбязательствоКонецПериода + Запись.ОтложенныйНалог;
			ОтложенноеНалоговоеОбязательствоИзменение = ОтложенноеНалоговоеОбязательствоИзменение + ИзменениеОтложенногоНалога;
		КонецЕсли;
		
	КонецЦикла;
	
	Расчет.ОтложенныйНалоговыйАктивНачалоПериода         = Расчет.ОтложенныйНалоговыйАктивКонецПериода         - ОтложенныйНалоговыйАктивИзменение;
	Расчет.ОтложенноеНалоговоеОбязательствоНачалоПериода = Расчет.ОтложенноеНалоговоеОбязательствоКонецПериода - ОтложенноеНалоговоеОбязательствоИзменение;
	
	// Такой расчет отложенного налогового актива не включает специальный налоговый актив по убытку,
	// учтенный на счете 09 в течение отчетного периода до переноса убытка.
	// Включим.
	Расчет.ОтложенныйНалоговыйАктивКонецПериода = Расчет.ОтложенныйНалоговыйАктивКонецПериода + Расчет.ВлияниеУбыткаТекущегоПериода;
	
	// Для описания расчета инвертируем знаки отложенного обязательства
	Расчет.ОтложенноеНалоговоеОбязательствоНачалоПериода = - Расчет.ОтложенноеНалоговоеОбязательствоНачалоПериода;
	Расчет.ОтложенноеНалоговоеОбязательствоКонецПериода  = - Расчет.ОтложенноеНалоговоеОбязательствоКонецПериода;
	
	// Описание расчета
	КодСчетаОтложенныеНалоговыеАктивы        = КодСчета(ПланыСчетов.Хозрасчетный.ОтложенныеНалоговыеАктивы);
	КодСчетаОтложенныеНалоговыеОбязательства = КодСчета(ПланыСчетов.Хозрасчетный.ОтложенныеНалоговыеОбязательства);
	
	// - на начало периода
	Расчет.ОтложенныйНалогНачалоПериода = Расчет.ОтложенныйНалоговыйАктивНачалоПериода - Расчет.ОтложенноеНалоговоеОбязательствоНачалоПериода;
	ПорядокРасчета = СтрШаблон(
		НСтр("ru = '(%1) - (%2)'", Расчет.КодЯзыка),
		Перечисления.ПоказателиОтложенногоНалога.Код(Перечисления.ПоказателиОтложенногоНалога.ОтложенныйНалоговыйАктивНачалоПериода, Расчет.КодыПоказателей),
		Перечисления.ПоказателиОтложенногоНалога.Код(Перечисления.ПоказателиОтложенногоНалога.ОтложенноеНалоговоеОбязательствоНачалоПериода, Расчет.КодыПоказателей));
	ДобавитьЗаписьПротоколаРасчета(Расчет, "ОтложенныйНалогНачалоПериода", ПорядокРасчета);
		
	ПорядокРасчета = СтрШаблон(
		НСтр("ru = 'Сальдо на начало периода по дебету счета %1'", Расчет.КодЯзыка),
		КодСчетаОтложенныеНалоговыеАктивы);
	ДобавитьЗаписьПротоколаРасчета(Расчет, "ОтложенныйНалоговыйАктивНачалоПериода", ПорядокРасчета);
		
	ПорядокРасчета = СтрШаблон(
		НСтр("ru = 'Сальдо на начало периода по кредиту счета %1'", Расчет.КодЯзыка),
		КодСчетаОтложенныеНалоговыеОбязательства);
	ДобавитьЗаписьПротоколаРасчета(Расчет, "ОтложенноеНалоговоеОбязательствоНачалоПериода", ПорядокРасчета);
		
	// - на конец периода
	Расчет.ОтложенныйНалогКонецПериода = Расчет.ОтложенныйНалоговыйАктивКонецПериода - Расчет.ОтложенноеНалоговоеОбязательствоКонецПериода;
	ПорядокРасчета = СтрШаблон(
		НСтр("ru = '(%1) - (%2)'", Расчет.КодЯзыка),
		Перечисления.ПоказателиОтложенногоНалога.Код(Перечисления.ПоказателиОтложенногоНалога.ОтложенныйНалоговыйАктивКонецПериода, Расчет.КодыПоказателей),
		Перечисления.ПоказателиОтложенногоНалога.Код(Перечисления.ПоказателиОтложенногоНалога.ОтложенноеНалоговоеОбязательствоКонецПериода, Расчет.КодыПоказателей));
	ДобавитьЗаписьПротоколаРасчета(Расчет, "ОтложенныйНалогКонецПериода", ПорядокРасчета);
		
	ПорядокРасчета = СтрШаблон(
		НСтр("ru = 'Сальдо на конец периода по дебету счета %1'", Расчет.КодЯзыка),
		КодСчетаОтложенныеНалоговыеАктивы);
	ДобавитьЗаписьПротоколаРасчета(Расчет, "ОтложенныйНалоговыйАктивКонецПериода", ПорядокРасчета);
		
	ПорядокРасчета = СтрШаблон(
		НСтр("ru = 'Сальдо на конец периода по кредиту счета  %1'", Расчет.КодЯзыка),
		КодСчетаОтложенныеНалоговыеОбязательства);
	ДобавитьЗаписьПротоколаРасчета(Расчет, "ОтложенноеНалоговоеОбязательствоКонецПериода", ПорядокРасчета);
		
	// - отложенный налог за период
	ПорядокРасчета = СтрШаблон(
		НСтр("ru = '(%1) - (%2)'", Расчет.КодЯзыка),
		Перечисления.ПоказателиОтложенногоНалога.Код(Перечисления.ПоказателиОтложенногоНалога.ОтложенныйНалогКонецПериода, Расчет.КодыПоказателей),
		Перечисления.ПоказателиОтложенногоНалога.Код(Перечисления.ПоказателиОтложенногоНалога.ОтложенныйНалогНачалоПериода, Расчет.КодыПоказателей));

	Если ЕстьДанныеИНВ Тогда
		ПорядокРасчета = СтрШаблон(
			НСтр("ru = '(%1) - (%2) + (%3)'", Расчет.КодЯзыка),
			Перечисления.ПоказателиОтложенногоНалога.Код(Перечисления.ПоказателиОтложенногоНалога.ОтложенныйНалогКонецПериода, Расчет.КодыПоказателей),
			Перечисления.ПоказателиОтложенногоНалога.Код(Перечисления.ПоказателиОтложенногоНалога.ОтложенныйНалогНачалоПериода, Расчет.КодыПоказателей),
			Перечисления.ПоказателиОтложенногоНалога.Код(Перечисления.ПоказателиОтложенногоНалога.ОтложенныйНалоговыйАктивИнвестиционныйВычет, Расчет.КодыПоказателей));		
	КонецЕсли;
	
	Если Расчет.ЕстьДанныеНалогаВДобавочномКапитале Тогда
		ПорядокРасчета = СтрШаблон(
			НСтр("ru = '(%1) - (%2) + (%3)'", Расчет.КодЯзыка),
			Перечисления.ПоказателиОтложенногоНалога.Код(Перечисления.ПоказателиОтложенногоНалога.ОтложенныйНалогКонецПериода, Расчет.КодыПоказателей),
			Перечисления.ПоказателиОтложенногоНалога.Код(Перечисления.ПоказателиОтложенногоНалога.ОтложенныйНалогНачалоПериода, Расчет.КодыПоказателей),
			Перечисления.ПоказателиОтложенногоНалога.Код(Перечисления.ПоказателиОтложенногоНалога.НалогНаПрибыльОтОперацийКоторыеНеВключаютсяВЧистуюПрибыль, Расчет.КодыПоказателей));
		
		Если ЕстьДанныеИНВ Тогда
			ПорядокРасчета = СтрШаблон(
				НСтр("ru = '(%1) - (%2) + (%3) + (%4)'", Расчет.КодЯзыка),
				Перечисления.ПоказателиОтложенногоНалога.Код(Перечисления.ПоказателиОтложенногоНалога.ОтложенныйНалогКонецПериода, Расчет.КодыПоказателей),
				Перечисления.ПоказателиОтложенногоНалога.Код(Перечисления.ПоказателиОтложенногоНалога.ОтложенныйНалогНачалоПериода, Расчет.КодыПоказателей),
				Перечисления.ПоказателиОтложенногоНалога.Код(Перечисления.ПоказателиОтложенногоНалога.НалогНаПрибыльОтОперацийКоторыеНеВключаютсяВЧистуюПрибыль, Расчет.КодыПоказателей),
				Перечисления.ПоказателиОтложенногоНалога.Код(Перечисления.ПоказателиОтложенногоНалога.ОтложенныйНалоговыйАктивИнвестиционныйВычет, Расчет.КодыПоказателей));			
		КонецЕсли;
	КонецЕсли;

	ДобавитьЗаписьПротоколаРасчета(Расчет, "ОтложенныйНалог", ПорядокРасчета);
	
	// - специальный налоговый актив
	Если ЗначениеЗаполнено(Расчет.ВлияниеУбыткаТекущегоПериода) Тогда
		
		ПорядокРасчета = СтрШаблон(
			НСтр("ru = 'Сальдо на конец периода по дебету счета  %1 - вид актива %2'", Расчет.КодЯзыка),
			КодСчетаОтложенныеНалоговыеАктивы,
			Перечисления.ВидыАктивовИОбязательств.УбытокТекущегоПериода);
		ДобавитьЗаписьПротоколаРасчета(Расчет, "ВлияниеУбыткаТекущегоПериода", ПорядокРасчета);
		
	КонецЕсли;
	
КонецПроцедуры

Функция СуммарноеИзменениеОтложенногоНалога(Изменение)
	
	Возврат Изменение.УвеличениеОтложенногоНалога
		  + Изменение.УменьшениеОтложенногоНалога
		  + Изменение.Пересчет;
	
КонецФункции

Функция ВлияниеУбыткаТекущегоПериода(ОблагаемыйФинансовыйРезультат, ПереносУбыткаТекущегоПериода, СтавкаНалога, КонтекстРасчета)
	
	// 34 Отложенный налоговый актив должен признаваться в отношении перенесенных на будущие периоды
	//    неиспользованных налоговых убытков
	
	// В течение налогового периода признаем сумму такого отложенного актива условно -
	// только для выполнения технологических равенств на счетах учета
	
	Если ОблагаемыйФинансовыйРезультат.СуммаНУ >= 0 Тогда
		Возврат 0;
	КонецЕсли;
		
	УбытокТекущегоПериода = - ОблагаемыйФинансовыйРезультат.СуммаНУ;
	
	// Убыток текущего периода, перенесенный на будущие периоды, уже может быть отражен на балансовом счете как расход будущих периодов.
	// Поэтому, влияние убытка текущего периода уточняется с учетом уже перенесенного убытка.
	НеПеренесенныйУбыток = Макс(0, УбытокТекущегоПериода - ПереносУбыткаТекущегоПериода);
		
	Возврат СуммаПоСтавкеНалога(НеПеренесенныйУбыток, СтавкаНалога);
		
КонецФункции

Процедура ЗаписатьРасчетНалога(Проводки, ТаблицаРасчета, КонтекстРасчета)
	
	Если КонтекстРасчета.ВариантУчетаОтложенногоНалога = Перечисления.ВариантыУчетаОтложенногоНалога.БалансовыйМетод Тогда
		// Р-102 позволяет обойтись без таких проводок
		Возврат;
	КонецЕсли;
	
	// Все проводки - в корреспонденции со счетом 68.04.2
	СчетРасчетаНалога = ПланыСчетов.Хозрасчетный.РасчетНалогаНаПрибыль;
	
	// Представления записываются в ИБ, поэтому локализуются основным языком конфигурации.
	СхемаРасчета = Новый ТаблицаЗначений;
	СхемаРасчета.Колонки.Добавить("Имя",             Новый ОписаниеТипов("Строка"));
	СхемаРасчета.Колонки.Добавить("ПредставлениеКт", Новый ОписаниеТипов("Строка"));
	СхемаРасчета.Колонки.Добавить("КорСчетКт",       Новый ОписаниеТипов("ПланСчетовСсылка.Хозрасчетный")); // По Кт счета 68.04.2
	СхемаРасчета.Колонки.Добавить("ПредставлениеДт", Новый ОписаниеТипов("Строка"));
	СхемаРасчета.Колонки.Добавить("КорСчетДт",       Новый ОписаниеТипов("ПланСчетовСсылка.Хозрасчетный")); // По Дт счета 68.04.2
	СхемаРасчета.Колонки.Добавить("КорСубконто",     Новый ОписаниеТипов("Соответствие"));
	
	// Начисление условного расхода (дохода)
	// Дт 99.02.1 Кт 68.04.2
	// или
	// Дт 68.04.2 Кт 99.02.2
	ВариантПроводки = СхемаРасчета.Добавить();
	ВариантПроводки.Имя             = "УсловныйРасход";
	ВариантПроводки.ПредставлениеКт = НСтр("ru = 'Условный расход по налогу на прибыль'", Метаданные.ОсновнойЯзык.КодЯзыка);
	ВариантПроводки.КорСчетКт       = ПланыСчетов.Хозрасчетный.УсловныйРасходПоНалогуНаПрибыль;
	ВариантПроводки.ПредставлениеДт = НСтр("ru = 'Условный доход по налогу на прибыль'", Метаданные.ОсновнойЯзык.КодЯзыка);
	ВариантПроводки.КорСчетДт       = ПланыСчетов.Хозрасчетный.УсловныйДоходПоНалогуНаПрибыль;
	
	// Начисление постоянного расхода (дохода)
	// Дт 99.02.3 Кт 68.04.2
	// или
	// Дт 68.04.2 Кт 99.02.3 
	ВариантПроводки = СхемаРасчета.Добавить();
	ВариантПроводки.Имя             = "ПостоянныйНалоговыйРасход";
	ВариантПроводки.ПредставлениеКт = НСтр("ru = 'Постоянный налоговый расход'", Метаданные.ОсновнойЯзык.КодЯзыка);
	ВариантПроводки.КорСчетКт       = ПланыСчетов.Хозрасчетный.ПостоянноеНалоговоеОбязательство;
	ВариантПроводки.ПредставлениеДт = НСтр("ru = 'Постоянный налоговый доход'", Метаданные.ОсновнойЯзык.КодЯзыка);
	ВариантПроводки.КорСчетДт       = ПланыСчетов.Хозрасчетный.ПостоянноеНалоговоеОбязательство;
		
	// Списание сумм отложенных налоговых активов и обязательств при выбытии активов, по которым они начислены,
	// в ходе деятельности, не облагаемой налогом на прибыль.
	// Дт 99.01.2 Кт 68.04.2
	// или
	// Дт 68.04.2 Кт 99.01.2 
	ВариантПроводки = СхемаРасчета.Добавить();
	ВариантПроводки.Имя             = "ВыбытиеПоСпециальнымРежимам";
	ВариантПроводки.ПредставлениеКт = НСтр("ru = 'Корректировка отложенного налога в связи с выбытием активов и обязательств по деятельности, не облагаемой налогом на прибыль'", Метаданные.ОсновнойЯзык.КодЯзыка);
	ВариантПроводки.КорСчетКт       = ПланыСчетов.Хозрасчетный.ПрибылиИУбыткиЕНВД;
	ВариантПроводки.ПредставлениеДт = ВариантПроводки.ПредставлениеКт;
	ВариантПроводки.КорСчетДт       = ПланыСчетов.Хозрасчетный.ПрибылиИУбыткиЕНВД;
	ВариантПроводки.КорСубконто.Вставить(
		ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ПрибылиИУбытки,
		Перечисления.ПрибылиИУбытки.НалогНаПрибыль);
		
	// Скорректируем на суммы ранее сформированных проводок.
	
	КорСчетаВариантов = Новый Соответствие; // Ключ - счет, Значение - имя варианта
	КорСчета          = Новый Массив;
	Для Каждого ВариантПроводки Из СхемаРасчета Цикл
		
		КорСчетаВарианта = Новый Массив;
		
		Если ЗначениеЗаполнено(ВариантПроводки.КорСчетКт) Тогда
			КорСчетаВарианта.Добавить(ВариантПроводки.КорСчетКт);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ВариантПроводки.КорСчетДт) Тогда
			КорСчетаВарианта.Добавить(ВариантПроводки.КорСчетДт);
		КонецЕсли;
		
		КорСчетаВарианта = БухгалтерскийУчет.СформироватьМассивСубсчетов(КорСчетаВарианта);
		
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(КорСчета, КорСчетаВарианта);
		
		Для Каждого Счет Из КорСчетаВарианта Цикл
			КорСчетаВариантов.Вставить(Счет, ВариантПроводки.Имя);
		КонецЦикла;
		
	КонецЦикла;
	
	ВидыСубконто = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("НачалоПериода",     КонтекстРасчета.НачалоНалоговогоПериода);
	Запрос.УстановитьПараметр("КонецПериода",      КонтекстРасчета.КонецПериода);
	Запрос.УстановитьПараметр("Организация",       КонтекстРасчета.Организация);
	Запрос.УстановитьПараметр("СчетРасчетаНалога", СчетРасчетаНалога);
	Запрос.УстановитьПараметр("КорСчета",          КорСчета);
	Запрос.УстановитьПараметр("ВидыСубконто",      ВидыСубконто);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	&ПолеВариантНалогообложенияПрибыли КАК ВариантНалогообложенияПрибыли,
	|	ХозрасчетныйОбороты.КорСчет КАК КорСчет,
	|	СУММА(ХозрасчетныйОбороты.СуммаОборот) КАК Сумма
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.Обороты(
	|		&НачалоПериода,
	|		&КонецПериода,
	|		,
	|		Счет = &СчетРасчетаНалога,
	|		&ВидыСубконто,
	|		Организация = &Организация,
	|		КорСчет В (&КорСчета),
	|	) КАК ХозрасчетныйОбороты
	|
	|СГРУППИРОВАТЬ ПО
	|	&ПолеВариантНалогообложенияПрибыли,
	|	ХозрасчетныйОбороты.КорСчет
	|
	|ИТОГИ
	|ПО
	|	ВариантНалогообложенияПрибыли
	|
	|";
	
	РаздельныйУчетПоНалогуНаПрибыль.ОбработатьПолеВариантаНалогообложенияВЗапросе(
		Запрос,
		КонтекстРасчета.ИспользуетсяРаздельныйУчет,
		"ХозрасчетныйОбороты.Субконто1",
		ВидыСубконто);
	
	
	ВыборкаВариантНалогообложенияПрибыли = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Для Каждого ОбщийРасчет Из ТаблицаРасчета Цикл
	
		РасчетТекущегоНалога = ОбщийРасчет.РасчетРасходаПоНалогу;
		
		// Определим суммы проводок
		СуммыПроводок = Новый Структура; // Ключ - имя варианта, Значение - сумма
		СуммыПроводок.Вставить("УсловныйРасход",              РасчетТекущегоНалога.УсловныйРасход);
		СуммыПроводок.Вставить("ПостоянныйНалоговыйРасход",   РасчетТекущегоНалога.ПостоянныйНалоговыйРасход);
		СуммыПроводок.Вставить("ВыбытиеПоСпециальнымРежимам", РасчетТекущегоНалога.ВыбытиеПоСпециальнымРежимам);
		
		Если ВыборкаВариантНалогообложенияПрибыли.НайтиСледующий(
				ОбщийРасчет.ВариантНалогообложенияПрибыли, "ВариантНалогообложенияПрибыли") Тогда
			
			Выборка = ВыборкаВариантНалогообложенияПрибыли.Выбрать();
			Пока Выборка.Следующий() Цикл
				
				ИмяВарианта = КорСчетаВариантов[Выборка.КорСчет];
				
				Если ИмяВарианта = Неопределено Тогда
					Продолжить;
				КонецЕсли;
				
				Если СуммыПроводок.Свойство(ИмяВарианта) Тогда
					СуммыПроводок[ИмяВарианта] = СуммыПроводок[ИмяВарианта] - Выборка.Сумма;
				Иначе
					СуммыПроводок.Вставить(ИмяВарианта, - Выборка.Сумма);
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЕсли;
		
		ВыборкаВариантНалогообложенияПрибыли.Сбросить();
		
		// Сформируем проводки на суммы корректировки
		
		Для Каждого ВариантПроводки Из СхемаРасчета Цикл
			
			Если Не СуммыПроводок.Свойство(ВариантПроводки.Имя) Тогда
				Продолжить;
			КонецЕсли;
			
			Сумма = СуммыПроводок[ВариантПроводки.Имя];
			
			Если Сумма = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			Проводки.Записывать = Истина;
			
			Проводка = Проводки.Добавить();
			Проводка.Период      = КонтекстРасчета.КонецПериода;
			Проводка.Организация = КонтекстРасчета.Организация;
			
			Если Сумма > 0 Тогда
				
				// По Дт счета расчета налога
				
				Проводка.Сумма       = Сумма;
				Проводка.Содержание  = ВариантПроводки.ПредставлениеДт;
				
				Проводка.СчетДт = СчетРасчетаНалога;
				Проводка.СчетКт = ВариантПроводки.КорСчетДт;
				
				Для Каждого ЗначениеСубконто Из ВариантПроводки.КорСубконто Цикл
					Проводка.СубконтоКт.Вставить(ЗначениеСубконто.Ключ, ЗначениеСубконто.Значение);
				КонецЦикла;
				
			Иначе
				
				// По Кт счета расчета налога
				
				Проводка.Сумма       = - Сумма;
				Проводка.Содержание  = ВариантПроводки.ПредставлениеКт; 
				
				Проводка.СчетДт = ВариантПроводки.КорСчетКт;
				Проводка.СчетКт = СчетРасчетаНалога;
				Для Каждого ЗначениеСубконто Из ВариантПроводки.КорСубконто Цикл
					Проводка.СубконтоДт.Вставить(ЗначениеСубконто.Ключ, ЗначениеСубконто.Значение);
				КонецЦикла;
				
			КонецЕсли;
			
			БухгалтерскийУчет.УстановитьСубконто(
				Проводка.СчетДт,
				Проводка.СубконтоДт,
				ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ВариантыНалогообложенияПрибыли,
				ОбщийРасчет.ВариантНалогообложенияПрибыли);
			
			БухгалтерскийУчет.УстановитьСубконто(
				Проводка.СчетКт,
				Проводка.СубконтоКт,
				ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ВариантыНалогообложенияПрибыли,
				ОбщийРасчет.ВариантНалогообложенияПрибыли);
		
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаписатьВлияниеУбыткаТекущегоПериода(Проводки, ТаблицаРасчета, КонтекстРасчета)
	
	// Начисление или погашение специального отложенного налогового актива
	// Дт 09 Кт 68.04.2 (99.02.О)
	// или
	// Дт 68.04.2 (99.02.О) Кт 09
	// на разницу между переданной суммой влияния убытка и ранее отраженной на счете 09.
	
	Если КонтекстРасчета.ВариантУчетаОтложенногоНалога = Перечисления.ВариантыУчетаОтложенногоНалога.БалансовыйМетод Тогда
		СчетРасчетаНалога = ПланыСчетов.Хозрасчетный.ОтложенныйНалогНаПрибыль;
	Иначе
		СчетРасчетаНалога = ПланыСчетов.Хозрасчетный.РасчетНалогаНаПрибыль;
	КонецЕсли;
	
	СчетОтложенногоНалога = ПланыСчетов.Хозрасчетный.ОтложенныеНалоговыеАктивы;
	
	ВидыСубконто = Новый Массив;
	ВидыСубконто.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ВидыАктивовИОбязательств);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("СчетОтложенногоНалога", СчетОтложенногоНалога);
	Запрос.УстановитьПараметр("ОтчетнаяДата",          КонтекстРасчета.КонецПериода + 1);
	Запрос.УстановитьПараметр("Организации",           КонтекстРасчета.Организации);
	Запрос.УстановитьПараметр("ВидыСубконто",          ВидыСубконто);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	&ПолеВариантНалогообложенияПрибыли КАК ВариантНалогообложенияПрибыли,
	|	СУММА(Сальдо.СуммаОстаток)         КАК ОтложенныйНалог
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.Остатки(
	|			&ОтчетнаяДата,
	|			Счет = &СчетОтложенногоНалога,
	|			&ВидыСубконто,
	|			Организация В (&Организации)
	|				И Субконто1 = Значение(Перечисление.ВидыАктивовИОбязательств.УбытокТекущегоПериода)) КАК Сальдо
	|
	|СГРУППИРОВАТЬ ПО
	|	&ПолеВариантНалогообложенияПрибыли
	|";
	
	РаздельныйУчетПоНалогуНаПрибыль.ОбработатьПолеВариантаНалогообложенияВЗапросе(
		Запрос,
		КонтекстРасчета.ИспользуетсяРаздельныйУчет,
		"Сальдо.Субконто2",
		ВидыСубконто);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Для каждого ОбщийРасчет Из ТаблицаРасчета Цикл
	
		РасчетРасходаПоНалогу = ОбщийРасчет.РасчетРасходаПоНалогу;
		
		РанееОтраженныйОтложенныйНалог = 0;
		
		Если Выборка.НайтиСледующий(ОбщийРасчет.ВариантНалогообложенияПрибыли, "ВариантНалогообложенияПрибыли")
			И ЗначениеЗаполнено(Выборка.ОтложенныйНалог) Тогда
			РанееОтраженныйОтложенныйНалог = Выборка.ОтложенныйНалог;
		КонецЕсли;
		
		Выборка.Сбросить();
		
		Корректировка = РасчетРасходаПоНалогу.ВлияниеУбыткаТекущегоПериода - РанееОтраженныйОтложенныйНалог;
		Если Корректировка = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		ВидДвижения = ВидДвиженияБухгалтерии.Дебет;
		Если Корректировка < 0 Тогда
			ВидДвижения = ВидДвиженияБухгалтерии.Кредит;
			Корректировка = -Корректировка;
		КонецЕсли;
		
		// Представление записывается в ИБ, поэтому локализуются основным языком конфигурации.
		Представление = НСтр("ru = 'Убыток текущего периода'", Метаданные.ОсновнойЯзык.КодЯзыка);
		
		ПараметрыЗаполнения = ПараметрыЗаполненияПроводокОтложенногоНалога();
		ПараметрыЗаполнения.Проводки = Проводки;
		ПараметрыЗаполнения.ВариантНалогообложенияПрибыли = ОбщийРасчет.ВариантНалогообложенияПрибыли;
		ПараметрыЗаполнения.Сумма = Корректировка;
		ПараметрыЗаполнения.Содержание = Представление;
		ПараметрыЗаполнения.ВидДвижения = ВидДвижения;
		ПараметрыЗаполнения.Счет = СчетОтложенногоНалога;
		ПараметрыЗаполнения.ВидАктивовИОбязательств = Перечисления.ВидыАктивовИОбязательств.УбытокТекущегоПериода;
		ПараметрыЗаполнения.КорСчет = СчетРасчетаНалога;
		ПараметрыЗаполнения.КонтекстРасчета = КонтекстРасчета;

		ДобавитьПроводкуОтложенныйНалог(ПараметрыЗаполнения);
		
	КонецЦикла;
	
КонецПроцедуры

Процедура НачисленныйНалог(МенеджерВременныхТаблиц, КонтекстРасчета)
	
	// При применении ПБУ 18 налог начисляется проводкой
	// Дт 68.04.2 Кт 68.04.1
	// или
	// Дт 99.02.Т Кт 68.04.1
	
	ВидыСубконто = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("НачалоПериода",       КонтекстРасчета.НачалоНалоговогоПериода);
	Запрос.УстановитьПараметр("КонецПериода",        КонтекстРасчета.КонецПериода);
	Запрос.УстановитьПараметр("Организация",         КонтекстРасчета.Организация);
	Запрос.УстановитьПараметр("СчетаТекущегоНалога", СчетаТекущегоНалога());
	Запрос.УстановитьПараметр("ВидыСубконто",        ВидыСубконто);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	&ПолеВариантНалогообложенияПрибыли                      КАК ВариантНалогообложенияПрибыли,
	|	ЕСТЬNULL(СУММА(ХозрасчетныйОборотыДтКт.СуммаОборот), 0) КАК Сумма
	|ПОМЕСТИТЬ НачисленныйНалог
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.ОборотыДтКт(
	|		&НачалоПериода,
	|		&КонецПериода,
	|		,
	|		СчетДт В (&СчетаТекущегоНалога),
	|		&ВидыСубконто,
	|		СчетКт = ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.РасчетыСБюджетом),
	|		,
	|		Организация = &Организация) КАК ХозрасчетныйОборотыДтКт
	|
	|СГРУППИРОВАТЬ ПО
	|	&ПолеВариантНалогообложенияПрибыли
	|";
	
	РаздельныйУчетПоНалогуНаПрибыль.ОбработатьПолеВариантаНалогообложенияВЗапросе(
		Запрос,
		КонтекстРасчета.ИспользуетсяРаздельныйУчет,
		"ХозрасчетныйОборотыДтКт.СубконтоДт1",
		ВидыСубконто);
	
	Запрос.Выполнить();
	
КонецПроцедуры

Процедура ОбработатьИзменениеВариантаНалогообложенияПрибыли(ТаблицаРасчета, КонтекстРасчета)

	Если НЕ КонтекстРасчета.ИспользуетсяРаздельныйУчет 
		ИЛИ КонтекстРасчета.ВариантУчетаОтложенногоНалога <> Перечисления.ВариантыУчетаОтложенногоНалога.БалансовыйМетодПостоянныеРазницы Тогда 
		Возврат;
	КонецЕсли;  
	
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	ОтчетнаяДата = КонтекстРасчета.КонецПериода + 1;
	
	ПланГруппировки = ПланГруппировки(КонтекстРасчета);
	СоздатьТаблицуПравилГруппировки(ПланГруппировки, МенеджерВременныхТаблиц);
	
	СоздатьТаблицуПроводокКОбработке(МенеджерВременныхТаблиц, КонтекстРасчета);
		
	ЕстьНастройкиПоОбъектамУчета =
		РаздельныйУчетПоНалогуНаПрибыль.ЕстьНастройкиПоОбъектамУчета(КонтекстРасчета.Организация, ОтчетнаяДата);

	НастройкиНалогообложенияПрибыли(
		МенеджерВременныхТаблиц,
		ОтчетнаяДата,
		КонтекстРасчета.ИспользуетсяРаздельныйУчет,
		ЕстьНастройкиПоОбъектамУчета);     
		
	ДанныеПроводок = ДанныеПроводокИзмененияВарианта(МенеджерВременныхТаблиц, 
		ТаблицаРасчета, КонтекстРасчета, ЕстьНастройкиПоОбъектамУчета);
				
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(
		ДанныеПроводок.ДанныеИзмененияВарианта,
		КонтекстРасчета.ДанныеПроводокИзмененияВарианта);
		
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(
		ДанныеПроводок.ДанныеИзмененияВариантаНалогаВДобавочномКапитале,
		КонтекстРасчета.ДанныеПроводокИзмененияВариантаНалогаВДобавочномКапитале);
		
	ОбщегоНазначенияУТ.УничтожитьВременныеТаблицы(МенеджерВременныхТаблиц);
	
КонецПроцедуры

Функция ДанныеПроводокИзмененияВарианта(МенеджерВременныхТаблиц, 
	ТаблицаРасчета, КонтекстРасчета, ЕстьНастройкиПоОбъектамУчета)
	
	Запрос = Новый Запрос;    
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст = ТекстЗапроса_ДанныеПроводокПриИзмененииВариантаНалогообложенияПрибыли(КонтекстРасчета, 
		ЕстьНастройкиПоОбъектамУчета);
		
	РаздельныйУчетПоНалогуНаПрибыль.ОбработатьПолеВариантНалогообложенияПоУмолчаниюВЗапросе(
		Запрос, КонтекстРасчета.ИспользуетсяРаздельныйУчет);
		
	Результат = Запрос.Выполнить(); 
	Выборка = Результат.Выбрать();
	
	ТекущиеСтавкиНалогаПоВариантам = ТекущиеСтавкиНалогаПоВариантам(ТаблицаРасчета);
	
	ДанныеИзмененияВарианта = ТаблицаДанныхПроводокИзмененияВарианта();
	ДанныеИзмененияВариантаНалогаВДобавочномКапитале = ТаблицаДанныхПроводокИзмененияВариантаНалогаВДобавочномКапитале();
	
	Пока Выборка.Следующий() Цикл
		СтавкаНалогаДт = ТекущиеСтавкиНалогаПоВарианту(ТекущиеСтавкиНалогаПоВариантам, Выборка.ВариантНалогообложенияПрибылиДт); 	
		СтавкаНалогаКт = ТекущиеСтавкиНалогаПоВарианту(ТекущиеСтавкиНалогаПоВариантам, Выборка.ВариантНалогообложенияПрибылиКт); 	
		
		Если СтавкаНалогаКт = СтавкаНалогаДт Тогда
			Продолжить;
		КонецЕсли;    
		
		РазницаСтавок = ?(СтавкаНалогаКт - СтавкаНалогаДт > 0, 
			СтавкаНалогаКт - СтавкаНалогаДт, СтавкаНалогаДт - СтавкаНалогаКт);  
			
		Если Выборка.ЭтоДанныеНалогаВДобавочномКапитале Тогда
			НоваяСтрока = ДанныеИзмененияВариантаНалогаВДобавочномКапитале.Добавить();
			НоваяСтрока.ВариантНалогообложения = Выборка.ВариантНалогообложенияПрибылиКт;			
			НоваяСтрока.ОбъектВНА = Выборка.ОбъектУчета;
			НоваяСтрока.Сумма = Выборка.СуммаВР * СтавкаНалогаКт;  
			
			НоваяСтрока = ДанныеИзмененияВариантаНалогаВДобавочномКапитале.Добавить();
			НоваяСтрока.ВариантНалогообложения = Выборка.ВариантНалогообложенияПрибылиДт;			
			НоваяСтрока.ОбъектВНА = Выборка.ОбъектУчета;
			НоваяСтрока.Сумма = - Выборка.СуммаВР * СтавкаНалогаДт;  
			Продолжить;	
		КонецЕсли;                                                     
		
		НоваяСтрока = ДанныеИзмененияВарианта.Добавить();		
		НоваяСтрока.РазницаСтавок = РазницаСтавок;
		НоваяСтрока.Сумма = Выборка.СуммаВР * (СтавкаНалогаДт - СтавкаНалогаКт);  
		
		Если Выборка.ЭтоАктивныйСчет Тогда
			СтавкаНалогаУменьшалась = СтавкаНалогаДт < СтавкаНалогаКт;
		Иначе
			СтавкаНалогаУменьшалась = СтавкаНалогаДт > СтавкаНалогаКт;
		КонецЕсли;
		
		Если СтавкаНалогаУменьшалась Тогда
			НоваяСтрока.ВариантНалогообложенияИсточник = Выборка.ВариантНалогообложенияПрибылиКт;
			НоваяСтрока.ВариантНалогообложенияПриемник = Выборка.ВариантНалогообложенияПрибылиДт; 
			НоваяСтрока.СуммаИсточник = Выборка.СуммаВР * СтавкаНалогаКт;
			НоваяСтрока.СуммаПриемник = - Выборка.СуммаВР * СтавкаНалогаДт; 
		Иначе	
			НоваяСтрока.ВариантНалогообложенияИсточник = Выборка.ВариантНалогообложенияПрибылиДт;
			НоваяСтрока.ВариантНалогообложенияПриемник = Выборка.ВариантНалогообложенияПрибылиКт; 
			НоваяСтрока.СуммаИсточник = Выборка.СуммаВР * СтавкаНалогаДт;
			НоваяСтрока.СуммаПриемник = - Выборка.СуммаВР * СтавкаНалогаКт; 
		КонецЕсли;
		
	КонецЦикла;
	
	ДанныеИзмененияВарианта.Свернуть("ВариантНалогообложенияИсточник, ВариантНалогообложенияПриемник, РазницаСтавок", 
		"Сумма, СуммаИсточник, СуммаПриемник"); 
	
	ДанныеИзмененияВариантаНалогаВДобавочномКапитале.Свернуть("ВариантНалогообложения, ОбъектВНА, ЕстьИзмененияНалога", 
		"Сумма"); 
	
	ДанныеПроводок = Новый Структура;
	ДанныеПроводок.Вставить("ДанныеИзмененияВарианта", 
		ДанныеИзмененияВарианта);
	ДанныеПроводок.Вставить("ДанныеИзмененияВариантаНалогаВДобавочномКапитале", 
		ДанныеИзмененияВариантаНалогаВДобавочномКапитале); 
		
	Возврат ДанныеПроводок;
	
КонецФункции

Функция СвернутыеДанныеПроводокПриИзмененииВариантаНалогообложенияПрибыли(ДанныеПроводок)
	
	СвернутыеДанныеПроводок = Новый ТаблицаЗначений;
	СвернутыеДанныеПроводок.Колонки.Добавить("ВариантНалогообложения", Новый ОписаниеТипов("СправочникСсылка.ВариантыНалогообложенияПрибыли"));
	СвернутыеДанныеПроводок.Колонки.Добавить("РазницаСтавок", ОбщегоНазначения.ОписаниеТипаЧисло(4, 2));
	СвернутыеДанныеПроводок.Колонки.Добавить("Сумма", ОбщегоНазначенияУТ.ОписаниеТипаДенежногоПоля());

	Для каждого Строка Из ДанныеПроводок Цикл
		
		НоваяСтрока = СвернутыеДанныеПроводок.Добавить();
		НоваяСтрока.ВариантНалогообложения = Строка.ВариантНалогообложенияИсточник;
		НоваяСтрока.РазницаСтавок = Строка.РазницаСтавок;
		НоваяСтрока.Сумма = Строка.СуммаИсточник;
		
		НоваяСтрока = СвернутыеДанныеПроводок.Добавить();
		НоваяСтрока.ВариантНалогообложения = Строка.ВариантНалогообложенияПриемник;
		НоваяСтрока.РазницаСтавок = Строка.РазницаСтавок;
		НоваяСтрока.Сумма = Строка.СуммаПриемник;
				
	КонецЦикла;
	
	СвернутыеДанныеПроводок.Свернуть("ВариантНалогообложения, РазницаСтавок", "Сумма");
	
	Возврат СвернутыеДанныеПроводок;
	
КонецФункции

Функция ПересчетОтложенногоНалогаПриИзмененииВариантаНалогообложенияПрибыли(ДанныеПроводокИзмененияВарианта, 
	Знач ВариантНалогообложенияПрибыли, ДанныеПредыдущегоПересчетаОтложенногоНалогаПриИзмененииВариантаНО)
	
	ПересчетОтложенногоНалога = 0;
	
	ПредыдущийРасчет = ДанныеПредыдущегоПересчетаОтложенногоНалогаПриИзмененииВариантаНО.ДанныеПересчетаОтложенногоНалога.Получить(ВариантНалогообложенияПрибыли);
	
	Если ПредыдущийРасчет <> Неопределено Тогда
		ПересчетОтложенногоНалога = ПересчетОтложенногоНалога + ПредыдущийРасчет;	
	КонецЕсли;
		
	Если ДанныеПроводокИзмененияВарианта.Количество() = 0 Тогда
		Возврат ПересчетОтложенногоНалога;
	КонецЕсли;	

	Отбор = Новый Структура;
	Отбор.Вставить("ВариантНалогообложенияИсточник", ВариантНалогообложенияПрибыли);
	
	СтрокиПоВарианту = ДанныеПроводокИзмененияВарианта.НайтиСтроки(Отбор);
	
	Для каждого Строка Из СтрокиПоВарианту Цикл
		ПересчетОтложенногоНалога = ПересчетОтложенногоНалога + Строка.СуммаИсточник;
	КонецЦикла;

	Отбор = Новый Структура;
	Отбор.Вставить("ВариантНалогообложенияПриемник", ВариантНалогообложенияПрибыли);
	
	СтрокиПоВарианту = ДанныеПроводокИзмененияВарианта.НайтиСтроки(Отбор);
	
	Для каждого Строка Из СтрокиПоВарианту Цикл
		ПересчетОтложенногоНалога = ПересчетОтложенногоНалога + Строка.СуммаПриемник;
	КонецЦикла;
	
	Возврат ПересчетОтложенногоНалога;
	
КонецФункции

Функция ПересчетНалогаОтОперацийКоторыеНеВключаютсяВЧистуюПрибыльПриИзмененииВарианта(Знач ВариантНалогообложенияПрибыли, КонтекстРасчета)
	
	ПересчетНалога = 0;
	
	ДанныеПредыдущегоПересчета = КонтекстРасчета.ДанныеПредыдущегоПересчетаОтложенногоНалогаПриИзмененииВариантаНО;
	ПредыдущийРасчет = ДанныеПредыдущегоПересчета.ДанныеПересчетаОтложенногоНалогаВДобавичномКапитале.Получить(ВариантНалогообложенияПрибыли);	
	
	Если ПредыдущийРасчет <> Неопределено Тогда
		ПересчетНалога = ПересчетНалога + ПредыдущийРасчет;	
	КонецЕсли;
	
	ДанныеПроводокИзмененияВариантаНалогаВДобавочномКапитале = КонтекстРасчета.ДанныеПроводокИзмененияВариантаНалогаВДобавочномКапитале;
	
	Если ДанныеПроводокИзмененияВариантаНалогаВДобавочномКапитале.Количество() = 0 Тогда
		Возврат ПересчетНалога;
	КонецЕсли;	

	Отбор = Новый Структура;
	Отбор.Вставить("ВариантНалогообложения", ВариантНалогообложенияПрибыли);
	Отбор.Вставить("ЕстьИзмененияНалога", Истина);
	
	СтрокиПоВарианту = ДанныеПроводокИзмененияВариантаНалогаВДобавочномКапитале.НайтиСтроки(Отбор);
	
	Для каждого Строка Из СтрокиПоВарианту Цикл
		ПересчетНалога = ПересчетНалога + Строка.Сумма;
	КонецЦикла;
	
	Возврат ПересчетНалога;
	
КонецФункции

Процедура СформироватьПроводкиПриИзмененииВариантаНалогообложенияПрибыли(КонтекстРасчета, Проводки)
	
	ДанныеПроводок = ОбщегоНазначения.СкопироватьРекурсивно(КонтекстРасчета.ДанныеПроводокИзмененияВарианта);

	Если ДанныеПроводок.Количество() > 0
		И НЕ Проводки.Записывать Тогда
		Проводки.Записывать = Истина;
	КонецЕсли; 
	
	СвернутыеДанныеПроводок = СвернутыеДанныеПроводокПриИзмененииВариантаНалогообложенияПрибыли(ДанныеПроводок);   
	
 	Для каждого Строка Из СвернутыеДанныеПроводок Цикл
		
		ДобавитьПроводкуИзмененияВариантаНалогообложенияПрибыли(Проводки, КонтекстРасчета,
			Строка.ВариантНалогообложения, Строка.Сумма, Строка.РазницаСтавок);
			
	КонецЦикла;
	
КонецПроцедуры

Процедура ДобавитьПроводкуИзмененияВариантаНалогообложенияПрибыли(Проводки, КонтекстРасчета, 
	Знач ВариантНалогообложения, Знач Сумма, Знач РазницаСтавок)
	
	ШаблонПроводки = НСтр("ru = 'Пересчет отложенного налога по разнице ставок %1%%'", Метаданные.ОсновнойЯзык.КодЯзыка);
	
	СчетРасчетНалогаНаПрибыль = ПланыСчетов.Хозрасчетный.РасчетНалогаНаПрибыль;
	СчетПрибылиИУбыткиОтПересчетаОНА_ОНО = ПланыСчетов.Хозрасчетный.ПрибылиИУбыткиОтПересчетаОНА_ОНО;
	
	ВидыСубконтоВариантыНалогообложения =
		ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ВариантыНалогообложенияПрибыли;

	Проводка = Проводки.Добавить();
	Проводка.Период      = КонтекстРасчета.КонецПериода;
	Проводка.Организация = КонтекстРасчета.Организация;
	
	Проводка.Сумма       = Сумма;
	Проводка.Содержание  = СтрШаблон(ШаблонПроводки, Окр(РазницаСтавок * 100, 2)); 
	
	Проводка.СчетДт = СчетРасчетНалогаНаПрибыль;
	Проводка.СчетКт = СчетПрибылиИУбыткиОтПересчетаОНА_ОНО;    
	
	БухгалтерскийУчет.УстановитьСубконто(
		Проводка.СчетДт,
		Проводка.СубконтоДт,
		ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ВариантыНалогообложенияПрибыли,
		ВариантНалогообложения);
	
	БухгалтерскийУчет.УстановитьСубконто(
		Проводка.СчетКт,
		Проводка.СубконтоКт,
		ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ВариантыНалогообложенияПрибыли,
		ВариантНалогообложения);
	
КонецПроцедуры

Функция ТаблицаДанныхПроводокИзмененияВарианта() Экспорт

	ДанныеПроводок = Новый ТаблицаЗначений;
	ДанныеПроводок.Колонки.Добавить("ВариантНалогообложенияИсточник", Новый ОписаниеТипов("СправочникСсылка.ВариантыНалогообложенияПрибыли"));
	ДанныеПроводок.Колонки.Добавить("ВариантНалогообложенияПриемник", Новый ОписаниеТипов("СправочникСсылка.ВариантыНалогообложенияПрибыли"));
	ДанныеПроводок.Колонки.Добавить("РазницаСтавок", ОбщегоНазначения.ОписаниеТипаЧисло(4, 2));
	ДанныеПроводок.Колонки.Добавить("Сумма", ОбщегоНазначенияУТ.ОписаниеТипаДенежногоПоля());
	ДанныеПроводок.Колонки.Добавить("СуммаИсточник", ОбщегоНазначенияУТ.ОписаниеТипаДенежногоПоля());
	ДанныеПроводок.Колонки.Добавить("СуммаПриемник", ОбщегоНазначенияУТ.ОписаниеТипаДенежногоПоля());
	
	Возврат ДанныеПроводок;
	
КонецФункции

Функция ТекущиеСтавкиНалогаПоВарианту(ТекущиеСтавкиНалогаПоВариантам, Знач ВариантНалогообложения)

	СтавкаНалога = ТекущиеСтавкиНалогаПоВариантам.Получить(ВариантНалогообложения);		
	
	Если СтавкаНалога = Неопределено Тогда
		СтавкаНалога = 0;
	КонецЕсли;
	
	Возврат СтавкаНалога;
	
КонецФункции 

Функция ТекущиеСтавкиНалогаПоВариантам(ТаблицаРасчета)

	СтавкиНалога = Новый Соответствие;
	
	ВидСтавкиТекущегоНалога = Перечисления.ВидыСтавокОтложенногоНалога.ТекущийНалог;

	Для каждого Строка Из ТаблицаРасчета Цикл
		СтавкаНалога = Строка.РасчетОтложенногоНалога.СтавкиНалога.Получить(ВидСтавкиТекущегоНалога);
		
	    Если СтавкаНалога = Неопределено Тогда
			СтавкаНалога = 0;
		КонецЕсли;

		СтавкиНалога.Вставить(Строка.ВариантНалогообложенияПрибыли, СтавкаНалога); 
	КонецЦикла;
	
    Возврат СтавкиНалога;
	
КонецФункции

Функция ТекстЗапроса_ДанныеПроводокПриИзмененииВариантаНалогообложенияПрибыли(КонтекстРасчета, 
	ЕстьНастройкиПоОбъектамУчета)

	Текст = "ВЫБРАТЬ
	        |	ВЫБОР
	        |		КОГДА Правила.ПозицияСубконтоВариантНалогообложения = 0
	        |			ТОГДА ЕСТЬNULL(НастройкиНалогообложенияДт.ВариантНалогообложенияПрибыли, &ПолеВариантНалогообложенияПоУмолчанию)
	        |		КОГДА Правила.ПозицияСубконтоВариантНалогообложения = 1
	        |				И ДанныеПроводок.СубконтоДт1 <> НЕОПРЕДЕЛЕНО
	        |			ТОГДА ДанныеПроводок.СубконтоДт1
	        |		КОГДА Правила.ПозицияСубконтоВариантНалогообложения = 2
	        |				И ДанныеПроводок.СубконтоДт2 <> НЕОПРЕДЕЛЕНО
	        |			ТОГДА ДанныеПроводок.СубконтоДт2
	        |		КОГДА Правила.ПозицияСубконтоВариантНалогообложения = 3
	        |				И ДанныеПроводок.СубконтоДт3 <> НЕОПРЕДЕЛЕНО
	        |			ТОГДА ДанныеПроводок.СубконтоДт3
	        |		ИНАЧЕ &ПолеВариантНалогообложенияПоУмолчанию
	        |	КОНЕЦ КАК ВариантНалогообложенияПрибылиДт,
	        |	ВЫБОР
	        |		КОГДА Правила.ПозицияСубконтоВариантНалогообложения = 0
	        |			ТОГДА ЕСТЬNULL(НастройкиНалогообложенияКт.ВариантНалогообложенияПрибыли, &ПолеВариантНалогообложенияПоУмолчанию)
	        |		КОГДА Правила.ПозицияСубконтоВариантНалогообложения = 1
	        |				И ДанныеПроводок.СубконтоКт1 <> НЕОПРЕДЕЛЕНО
	        |			ТОГДА ДанныеПроводок.СубконтоКт1
	        |		КОГДА Правила.ПозицияСубконтоВариантНалогообложения = 2
	        |				И ДанныеПроводок.СубконтоКт2 <> НЕОПРЕДЕЛЕНО
	        |			ТОГДА ДанныеПроводок.СубконтоКт2
	        |		КОГДА Правила.ПозицияСубконтоВариантНалогообложения = 3
	        |				И ДанныеПроводок.СубконтоКт3 <> НЕОПРЕДЕЛЕНО
	        |			ТОГДА ДанныеПроводок.СубконтоКт3
	        |		ИНАЧЕ &ПолеВариантНалогообложенияПоУмолчанию
	        |	КОНЕЦ КАК ВариантНалогообложенияПрибылиКт,
	        |	Правила.ВидАктивовОбязательств КАК ВидАктивовОбязательств,
	        |	Правила.СчетГруппировки КАК Счет,
	        |	ДанныеПроводок.Организация КАК Организация,
	        |	ДанныеПроводок.ПодразделениеДт КАК ПодразделениеДт,
	        |	ДанныеПроводок.НаправлениеДеятельностиДт КАК НаправлениеДеятельностиДт,
	        |	ДанныеПроводок.ПодразделениеКт КАК ПодразделениеКт,
	        |	ДанныеПроводок.НаправлениеДеятельностиКт КАК НаправлениеДеятельностиКт,
	        |	ДанныеПроводок.СуммаВР КАК СуммаВР,
	        |	ДанныеПроводок.ОбъектУчета КАК ОбъектУчета,
	        |	ДанныеПроводок.ЭтоДанныеНалогаВДобавочномКапитале КАК ЭтоДанныеНалогаВДобавочномКапитале,
	        |	ВЫБОР
	        |		КОГДА ДанныеПроводок.СчетДт.Вид <> Правила.СчетГруппировки.Вид
	        |			ТОГДА ИСТИНА
	        |		ИНАЧЕ ЛОЖЬ
	        |	КОНЕЦ КАК ЭтоКонтрСчет
	        |ПОМЕСТИТЬ ВТ_ДанныеПроводокПоВариантамНалогообложения
	        |ИЗ
	        |	ВТ_ДанныеПроводок КАК ДанныеПроводок
	        |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ПравилаГруппировки КАК Правила
	        |		ПО ДанныеПроводок.СчетДт = Правила.Счет
	        |		ЛЕВОЕ СОЕДИНЕНИЕ НастройкиНалогообложения КАК НастройкиНалогообложенияДт
	        |		ПО ДанныеПроводок.ПодразделениеДт = НастройкиНалогообложенияДт.Подразделение
	        |			И ДанныеПроводок.НаправлениеДеятельностиДт = НастройкиНалогообложенияДт.НаправлениеДеятельности
	        |			И (&ОтборНастроекПоСубконтоДт)
	        |		ЛЕВОЕ СОЕДИНЕНИЕ НастройкиНалогообложения КАК НастройкиНалогообложенияКт
	        |		ПО ДанныеПроводок.ПодразделениеКт = НастройкиНалогообложенияКт.Подразделение
	        |			И ДанныеПроводок.НаправлениеДеятельностиКт = НастройкиНалогообложенияКт.НаправлениеДеятельности
	        |			И (&ОтборНастроекПоСубконтоКт)
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
	        |	ВЫБОР
	        |		КОГДА ВТ_ДанныеПроводокПоВариантамНалогообложения.ЭтоКонтрСчет
	        |			ТОГДА ВТ_ДанныеПроводокПоВариантамНалогообложения.ВариантНалогообложенияПрибылиКт
	        |		ИНАЧЕ ВТ_ДанныеПроводокПоВариантамНалогообложения.ВариантНалогообложенияПрибылиДт
	        |	КОНЕЦ КАК ВариантНалогообложенияПрибылиДт,
	        |	ВЫБОР
	        |		КОГДА ВТ_ДанныеПроводокПоВариантамНалогообложения.ЭтоКонтрСчет
	        |			ТОГДА ВТ_ДанныеПроводокПоВариантамНалогообложения.ВариантНалогообложенияПрибылиДт
	        |		ИНАЧЕ ВТ_ДанныеПроводокПоВариантамНалогообложения.ВариантНалогообложенияПрибылиКт
	        |	КОНЕЦ КАК ВариантНалогообложенияПрибылиКт,
	        |	ВТ_ДанныеПроводокПоВариантамНалогообложения.ВидАктивовОбязательств КАК ВидАктивовОбязательств,
	        |	ВТ_ДанныеПроводокПоВариантамНалогообложения.Счет КАК Счет,
	        |	ВТ_ДанныеПроводокПоВариантамНалогообложения.ОбъектУчета КАК ОбъектУчета,
	        |	ВТ_ДанныеПроводокПоВариантамНалогообложения.ЭтоДанныеНалогаВДобавочномКапитале КАК ЭтоДанныеНалогаВДобавочномКапитале,
	        |	СУММА(ВЫБОР
	        |			КОГДА ВТ_ДанныеПроводокПоВариантамНалогообложения.ЭтоКонтрСчет
	        |				ТОГДА -ВТ_ДанныеПроводокПоВариантамНалогообложения.СуммаВР
	        |			ИНАЧЕ ВТ_ДанныеПроводокПоВариантамНалогообложения.СуммаВР
	        |		КОНЕЦ) КАК СуммаВР,
	        |	ВЫБОР
	        |		КОГДА ЕСТЬNULL(Хозрасчетный.Вид, ЗНАЧЕНИЕ(ВидСчета.Активный)) В (ЗНАЧЕНИЕ(ВидСчета.Активный), ЗНАЧЕНИЕ(ВидСчета.АктивноПассивный))
	        |			ТОГДА ИСТИНА
	        |		ИНАЧЕ ЛОЖЬ
	        |	КОНЕЦ КАК ЭтоАктивныйСчет
	        |ИЗ
	        |	ВТ_ДанныеПроводокПоВариантамНалогообложения КАК ВТ_ДанныеПроводокПоВариантамНалогообложения
	        |		ЛЕВОЕ СОЕДИНЕНИЕ ПланСчетов.Хозрасчетный КАК Хозрасчетный
	        |		ПО ВТ_ДанныеПроводокПоВариантамНалогообложения.Счет = Хозрасчетный.Ссылка
	        |ГДЕ
	        |	ВТ_ДанныеПроводокПоВариантамНалогообложения.ВариантНалогообложенияПрибылиДт <> ВТ_ДанныеПроводокПоВариантамНалогообложения.ВариантНалогообложенияПрибылиКт
	        |
	        |СГРУППИРОВАТЬ ПО
	        |	ВТ_ДанныеПроводокПоВариантамНалогообложения.Счет,
	        |	ВТ_ДанныеПроводокПоВариантамНалогообложения.ОбъектУчета,
	        |	ВТ_ДанныеПроводокПоВариантамНалогообложения.ЭтоДанныеНалогаВДобавочномКапитале,
	        |	ВТ_ДанныеПроводокПоВариантамНалогообложения.ВидАктивовОбязательств,
	        |	ВЫБОР
	        |		КОГДА ВТ_ДанныеПроводокПоВариантамНалогообложения.ЭтоКонтрСчет
	        |			ТОГДА ВТ_ДанныеПроводокПоВариантамНалогообложения.ВариантНалогообложенияПрибылиКт
	        |		ИНАЧЕ ВТ_ДанныеПроводокПоВариантамНалогообложения.ВариантНалогообложенияПрибылиДт
	        |	КОНЕЦ,
	        |	ВЫБОР
	        |		КОГДА ВТ_ДанныеПроводокПоВариантамНалогообложения.ЭтоКонтрСчет
	        |			ТОГДА ВТ_ДанныеПроводокПоВариантамНалогообложения.ВариантНалогообложенияПрибылиДт
	        |		ИНАЧЕ ВТ_ДанныеПроводокПоВариантамНалогообложения.ВариантНалогообложенияПрибылиКт
	        |	КОНЕЦ,
	        |	Хозрасчетный.Вид";
		
	Если КонтекстРасчета.ИспользуетсяРаздельныйУчет И ЕстьНастройкиПоОбъектамУчета Тогда
		ТекстОтборНастроекПоСубконтоДт = "
		|		ДанныеПроводок.СубконтоДт1 = НастройкиНалогообложенияДт.Субконто1
		|		И  ДанныеПроводок.СубконтоДт2 = НастройкиНалогообложенияДт.Субконто2
		|		И  ДанныеПроводок.СубконтоДт3 = НастройкиНалогообложенияДт.Субконто3";
		ТекстОтборНастроекПоСубконтоКт = "
		|		ДанныеПроводок.СубконтоКт1 = НастройкиНалогообложенияКт.Субконто1
		|		И  ДанныеПроводок.СубконтоКт2 = НастройкиНалогообложенияКт.Субконто2
		|		И  ДанныеПроводок.СубконтоКт3 = НастройкиНалогообложенияКт.Субконто3";
	Иначе
		ТекстОтборНастроекПоСубконтоДт = "ИСТИНА";
		ТекстОтборНастроекПоСубконтоКт = "ИСТИНА";
	КонецЕсли;
	
	Текст = СтрЗаменить(Текст, "&ОтборНастроекПоСубконтоДт", ТекстОтборНастроекПоСубконтоДт);
	Текст = СтрЗаменить(Текст, "&ОтборНастроекПоСубконтоКт", ТекстОтборНастроекПоСубконтоКт);
	
	Возврат Текст;
	
КонецФункции 

Процедура СоздатьТаблицуПроводокКОбработке(МенеджерВременныхТаблиц, КонтекстРасчета)
	
	Запрос = Новый Запрос; 
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("НачалоПериода", КонтекстРасчета.НачалоМесяца);
	Запрос.УстановитьПараметр("КонецПериода", КонтекстРасчета.КонецПериода);
	Запрос.УстановитьПараметр("Организации", КонтекстРасчета.Организации);
	Запрос.УстановитьПараметр("СчетаДобавочныйКапитал", СчетаДобавочныйКапитал(КонтекстРасчета));
	Запрос.УстановитьПараметр("ВидыСубконтоНалогаВДобавочномКапитале", ВидыСубконтоНалогаВДобавочномКапитале(КонтекстРасчета));
	Запрос.Текст = ТекстЗапроса_ТаблицаПроводокКОбработке();
	
    Запрос.Выполнить();
		
КонецПроцедуры

Функция ТекстЗапроса_ТаблицаПроводокКОбработке()

	Текст = "ВЫБРАТЬ
	        |	ХозрасчетныйДвиженияССубконто.Организация КАК Организация,
	        |	ХозрасчетныйДвиженияССубконто.СчетДт КАК СчетДт,
