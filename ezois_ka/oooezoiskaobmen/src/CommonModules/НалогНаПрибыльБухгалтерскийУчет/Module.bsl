// Параметры учета отложенного налога в добавочном капитале.
// 
// Возвращаемое значение:
//  ТаблицаЗначений - Параметры учета отложенного налога в добавочном капитале:
// * Счет - ПланСчетовСсылка.Хозрасчетный - 
// * СчетОтложенногоНалога - ПланСчетовСсылка.Хозрасчетный - 
// * КоррСчетОтложенногоНалога - ПланСчетовСсылка.Хозрасчетный - 
// * ВидАктивовОбязательств - ПеречислениеСсылка.ВидыАктивовИОбязательств - 
// * ВидСубконтоАктивовОбязательств - ПланВидовХарактеристикСсылка.ВидыСубконтоХозрасчетные - 
Функция ПараметрыУчетаОтложенногоНалогаВДобавочномКапитале() Экспорт

	ПараметрыУчета = ТаблицаПараметровУчетаОтложенногоНалогаВДобавочномКапитале();
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса_ПараметрыУчетаОтложенногоНалогаВДобавочномКапитале();
	
	Результат = Запрос.Выполнить();
	
	Если НЕ Результат.Пустой() Тогда
		Выборка = Результат.Выбрать();
		
		Пока Выборка.Следующий() Цикл
			ЗаполнитьЗначенияСвойств(ПараметрыУчета.Добавить(), Выборка);
		КонецЦикла;	
	КонецЕсли;

	Возврат ПараметрыУчета;	
	
КонецФункции

// Возвращает выбывшие ВНА с дооценкой за период.
// 
// Параметры:
//  НачалоПериода     - Дата - начало периода
//  КонецПериода      - Дата - конец периода
//  Организации       - Массив из СправочникСсылка.Организации - Организации
//
// Возвращаемое значение:
//  Соответствие из Булево
//
Функция ВыбывшиеВНАСДооценкой(НачалоПериода, КонецПериода, Организации) Экспорт
	
	ВыбывшиеВНАСДооценкой = Новый Соответствие;
	
	Запрос = Новый Запрос;

	Запрос.Текст = ТекстЗапроса_ВыбывшиеВНАСДооценкой();
	
	Запрос.УстановитьПараметр("ДатаНачала", НачалоПериода);
	Запрос.УстановитьПараметр("ДатаОкончания", КонецПериода);
	Запрос.УстановитьПараметр("Организации", Организации);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		ВыбывшиеВНАСДооценкой.Вставить(Выборка.ОбъектВНА, Истина);
	КонецЦикла;
	
	Возврат ВыбывшиеВНАСДооценкой;
	
КонецФункции

// Возвращает данные предыдущего расчета отложенного налога при изменении варианта налогообложения прибыли.
// 
// Параметры:
//  НачалоНалоговогоПериода     - Дата - начало налогового периода
//  КонецПериода                - Дата - конец периода
//  Организация                 - СправочникСсылка.Организации - организация
//
// Возвращаемое значение:
// 	Структура - Описание:
// * ДанныеПересчетаОтложенногоНалога - Соответствие из СправочникСсылка.ВариантыНалогообложенияПрибыли
// * ДанныеПересчетаОтложенногоНалогаВДобавичномКапитале - Соответствие из СправочникСсылка.ВариантыНалогообложенияПрибыли
//
Функция ДанныеПредыдущегоПересчетаОтложенногоНалогаПриИзмененииВариантаНО(Знач НачалоНалоговогоПериода, Знач КонецПериода, Знач Организация) Экспорт
	
	Данные = ДанныеПредыдущегоПересчетаОтложенногоНалога();
	
	НачалоМесяца = НачалоМесяца(КонецПериода);

	Если Месяц(НачалоМесяца) = 1 Тогда
		Возврат Данные;	
	КонецЕсли;	

	НачалоМесяца = НачалоМесяца(КонецПериода);

	ПредыдущаяОтчетнаяДатаРасчетаОтложенногоНалога = РегистрыСведений.РасчетОтложенногоНалога.ПредыдущаяОтчетнаяДатаРасчета(Организация, 
		НачалоНалоговогоПериода, НачалоМесяца);
		
	ПериодРасчета = РегистрыСведений.РасчетОтложенногоНалога.ПериодРасчета(ПредыдущаяОтчетнаяДатаРасчетаОтложенногоНалога,
		Организация, КонецГода(НачалоНалоговогоПериода));
		
	ПоказательПересчет = Перечисления.ПоказателиОтложенногоНалога.ПересчетОтложенногоНалогаПриИзмененииВариантаНалогообложенияПрибыли;
	
	Показатели = Новый Массив;
	Показатели.Добавить(ПоказательПересчет);
	Показатели.Добавить(Перечисления.ПоказателиОтложенногоНалога.ПересчетНалогаОтОперацийКоторыеНеВключаютсяВЧистуюПрибыльПриИзмененииВарианта);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ПериодРасчета", ПериодРасчета);
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("Показатели", Показатели);

	Запрос.Текст = "ВЫБРАТЬ
	               |	РасчетПоказателейОтложенногоНалога.ВариантНалогообложенияПрибыли КАК ВариантНалогообложенияПрибыли,
	               |	РасчетПоказателейОтложенногоНалога.Сумма КАК Сумма,
	               |	РасчетПоказателейОтложенногоНалога.Показатель КАК Показатель
	               |ИЗ
	               |	РегистрСведений.РасчетПоказателейОтложенногоНалога КАК РасчетПоказателейОтложенногоНалога
	               |ГДЕ
	               |	РасчетПоказателейОтложенногоНалога.ПериодРасчета = &ПериодРасчета
	               |	И РасчетПоказателейОтложенногоНалога.Организация = &Организация
	               |	И РасчетПоказателейОтложенногоНалога.Показатель В (&Показатели)";
	
	Результат = Запрос.Выполнить();
	
	Если НЕ Результат.Пустой() Тогда
		Выборка = Результат.Выбрать();
		
		Пока Выборка.Следующий() Цикл
			Если Выборка.Показатель = ПоказательПересчет Тогда
				Данные.ДанныеПересчетаОтложенногоНалога.Вставить(Выборка.ВариантНалогообложенияПрибыли, Выборка.Сумма);	
			Иначе	
				Данные.ДанныеПересчетаОтложенногоНалогаВДобавичномКапитале.Вставить(Выборка.ВариантНалогообложенияПрибыли, Выборка.Сумма);	
			КонецЕсли;
		КонецЦикла;	
	КонецЕсли;
	
	Возврат Данные;
	
КонецФункции

#Область Правила

// Конструктор правил группировки активов обязательств
// 
// Возвращаемое значение:
//  ТаблицаЗначений - каркас таблицы правил группировки:
//   * ОсновнойСчет - ПланСчетовСсылка.Хозрасчетный -
//   * ВидАктивовОбязательств - ПеречислениеСсылка.ВидыАктивовИОбязательств -
//   * ДополнительныеСчета - Массив Из ПланСчетовСсылка.Хозрасчетный -
//   * ИсключенныеСубконто - Массив Из ПланВидовХарактеристикСсылка.ВидыСубконтоХозрасчетные -
//
Функция НовыйПравилаГруппировкиАктивовОбязательств() Экспорт

	Правила = Новый ТаблицаЗначений;
	Правила.Колонки.Добавить("ОсновнойСчет",              Новый ОписаниеТипов("ПланСчетовСсылка.Хозрасчетный"));
	Правила.Колонки.Добавить("ВидАктивовОбязательств",    Новый ОписаниеТипов("ПеречислениеСсылка.ВидыАктивовИОбязательств"));
	Правила.Колонки.Добавить("ДополнительныеСчета",       Новый ОписаниеТипов("Массив"));
	Правила.Колонки.Добавить("ИсключенныеСубконто",       Новый ОписаниеТипов("Массив"));
	
	Возврат Правила;
	
КонецФункции

// Заполняет правила группировки видов активов и обязательств
//
// Параметры:
//  Правила - см. НовыйПравилаГруппировкиАктивовОбязательств
//
Процедура ЗаполнитьПравилаГруппировкиВидовАктивовИОбязательств(Правила) Экспорт
	
	// В режиме совместимости с редакцией ПБУ 18 2015 года - 
	// см. НалоговыйУчет.ПолучитьТаблицуВидовАктивовИОбязательств()
	
	// ПБУ 18 содержит общее требование о группировке временных разниц и частное.
	//
	// Общее:
	// 3. В аналитическом учете временные разницы учитываются дифференцированно по видам активов и обязательств,
	// в оценке которых возникла временная разница
	//
	// Частное:
	// 19. предоставляется право отражать в бухгалтерском балансе сальдированную (свернутую)
	// сумму отложенного налогового актива и отложенного налогового обязательства, кроме случаев,
	// когда законодательством Российской Федерации о налогах и сборах предусмотрено
	// раздельное формирование налоговой базы.
	//
	// Таким образом, обязательное требование - исключить ситуации, когда отложенный налоговый актив
	// не должен быть признан, несмотря на наличие временных разниц (п. 14, 17 и 19 ПБУ 18).
	//
	// Для этого, организация группирует временные разницы исходя из того, каким образом доходы и расходы,
	// относящиеся к конкретному активу или обязательству (объекту налогового учета),
	// будут участвовать в формировании налоговой базы будущих периодов.
	//
	// Временные разницы должны быть отнесены к разным группам,
	// если относящиеся к ним будущие доходы и расходы будут облагаться налогом на прибыль в разных юрисдикциях
	// или по разным ставкам, либо налоговое законодательство не позволяет взаимозачет прибылей и убытков.
	// См. http://bmcenter.ru/Files/R-KpR-Registr_ucheta_vremennih_raznic
	//
	// В остальном группировка может быть произвольной, в том числе, можно отнести все разницы в одну группу.
	//
	// Поскольку в программе не автоматизировано раздельное формирование налоговой базы,
	// группировка активов и обязательств выполняется с максимальной детализацией,
	// с учетом рациональности (т.е. так, чтобы затраты на детализацию не были чрезмерными).
	
	// Общее правило в отношении субконто:
	// активы и обязательства детализируются до всех разрезов необоротной аналитики (по которым ведется учет разниц).
	
	// Могут быть исключения, распространяющиеся как на все счета, так и на отдельные счета.
	// Общие для всех счетов перечислены в ГлобальныеИсключенияДетализацииАктивовОбязательств,
	// частные - в поле ИсключенныеСубконто правил.
	// Частные исключения могут использоваться при кастомизации.
	
	// Правила, заданные в коллекции позже, имеют больший приоритет, чем заданные раньше.
	// С учетом этого, сначала следует установить правило для счета более высокого уровня, а потом - исключения для подчиненных.
	
	// Раздел I. ВНЕОБОРОТНЫЕ АКТИВЫ
	
	// ОсновныеСредства
	Правило = Правила.Добавить();
	Правило.ОсновнойСчет           = ПланыСчетов.Хозрасчетный.ОсновныеСредства;
