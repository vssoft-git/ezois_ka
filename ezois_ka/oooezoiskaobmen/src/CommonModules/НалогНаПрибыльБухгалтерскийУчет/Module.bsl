Функция ЭтоОтложенныйНалогВДобавочномКапитале(СчетаОтложенныйНалогВДобавочномКапитале, Знач Счет)
		
	ЭтоОтложенныйНалогВДобавочномКапитале = Ложь;
		
	Если ЗначениеЗаполнено(Счет) Тогда
		ЭтоОтложенныйНалогВДобавочномКапитале = СчетаОтложенныйНалогВДобавочномКапитале.Найти(Счет) <> Неопределено;	
	КонецЕсли; 
		
	Возврат ЭтоОтложенныйНалогВДобавочномКапитале;	
	
КонецФункции 

Функция СчетаИКоррСчетаНалогаВДобавочномКапитале(КонтекстРасчета)
	
	СчетаИКоррСчета = Новый Соответствие;
	
	Для каждого Строка Из КонтекстРасчета.ПараметрыУчетаОтложенногоНалогаВДобавочномКапитале Цикл
		СчетаИКоррСчета.Вставить(Строка.СчетОтложенногоНалога, Строка.КоррСчетОтложенногоНалога); 
	КонецЦикла;	
	
	Возврат СчетаИКоррСчета;
	
КонецФункции

Функция ВидыСубконтоВидовАктивовОбязательствВДобавочномКапитале(КонтекстРасчета)

	ВидыСубконто = Новый Соответствие;
	
	Для каждого Строка Из КонтекстРасчета.ПараметрыУчетаОтложенногоНалогаВДобавочномКапитале Цикл
		ВидыСубконто.Вставить(Строка.ВидАктивовОбязательств, Строка.ВидСубконтоАктивовОбязательств);
	КонецЦикла;
	
	Возврат ВидыСубконто;
	
КонецФункции

Функция СчетаПоВидамАктивовОбязательствНалогаВДобавочномКапитале(КонтекстРасчета)
	
	СчетаПоВидамАктивовОбязательств = Новый Соответствие;
	
	Для каждого Строка Из КонтекстРасчета.ПараметрыУчетаОтложенногоНалогаВДобавочномКапитале Цикл
		Счета = СчетаПоВидамАктивовОбязательств.Получить(Строка.ВидАктивовОбязательств);
		
		Если Счета = Неопределено Тогда
			Счета = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Строка.СчетОтложенногоНалога);
			СчетаПоВидамАктивовОбязательств.Вставить(Строка.ВидАктивовОбязательств, Счета);
		Иначе
			Счета.Добавить(Строка.СчетОтложенногоНалога);
		КонецЕсли;
	КонецЦикла;
	
    Возврат СчетаПоВидамАктивовОбязательств;
	
КонецФункции

#КонецОбласти

#Область Расчет

// Заполняет пустую таблицу расчетов данными фин. реза и налогов в разрезе вариантам н/о.
// 
// Параметры:
// 	ТаблицаРасчета  - см. НовыйРасчетПоВариантамНалогообложения
// 	КонтекстРасчета - см. РасчетНалогаНаПрибыль.НовыйКонтекстРасчета
//
Процедура ЗаполнитьДанныеФинРезультатаИНалогов(ТаблицаРасчета, КонтекстРасчета)
	
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	НачисленныйНалог(МенеджерВременныхТаблиц, КонтекстРасчета);
	
	РасчетНалогаНаПрибыль.ПодготовитьВТ_СуммыНалоговойБазыВРазрезеВариантовНалогообложения(
		МенеджерВременныхТаблиц,
		КонтекстРасчета.НачалоНалоговогоПериода,
		КонтекстРасчета.КонецПериода,
		КонтекстРасчета.Организация,
		КонтекстРасчета.ИспользуетсяРаздельныйУчет);
	
	НалогНаПрибыльУбыткиПрошлыхЛет.ПодготовитьВТ_УбытокПеренесенныйНаБудущее(
		МенеджерВременныхТаблиц,
		КонтекстРасчета.НачалоНалоговогоПериода,
		КонтекстРасчета.КонецПериода,
		КонтекстРасчета.Организации,
		КонтекстРасчета.ИспользуетсяРаздельныйУчет);
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ИспользуетсяРаздельныйУчет", КонтекстРасчета.ИспользуетсяРаздельныйУчет);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА НЕ &ИспользуетсяРаздельныйУчет
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.ВариантыНалогообложенияПрибыли.ПустаяСсылка)
	|		ИНАЧЕ
	|			ДанныеБазы.ВариантНалогообложенияПрибыли
	|	КОНЕЦ                                         КАК ВариантНалогообложенияПрибыли,
	|
	|	СУММА(ДанныеБазы.НачисленныйНалог)            КАК НачисленныйНалог,
	|
	|	СУММА(ДанныеБазы.НалоговаяБазаБУ)             КАК НалоговаяБазаБУ,
	|	СУММА(ДанныеБазы.НалоговаяБазаНУ)             КАК НалоговаяБазаНУ,
	|	СУММА(ДанныеБазы.НалоговаяБазаПР)             КАК НалоговаяБазаПР,
	|	СУММА(ДанныеБазы.НалоговаяБазаВР)             КАК НалоговаяБазаВР,
	|
	|	СУММА(ДанныеБазы.УбытокПеренесенныйНаБудущее) КАК УбытокПеренесенныйНаБудущее
	|ИЗ
	|	(ВЫБРАТЬ
	|		НачисленныйНалог.ВариантНалогообложенияПрибыли КАК ВариантНалогообложенияПрибыли,
	|
	|		// Начисленный налог
	|		НачисленныйНалог.Сумма                         КАК НачисленныйНалог,
	|
	|		// Налоговая база
	|		0                                              КАК НалоговаяБазаБУ,
	|		0                                              КАК НалоговаяБазаНУ,
	|		0                                              КАК НалоговаяБазаПР,
	|		0                                              КАК НалоговаяБазаВР,
	|
	|		// Убытки прошлых лет
	|		0                                              КАК УбытокПеренесенныйНаБудущее
	|	ИЗ
	|		НачисленныйНалог КАК НачисленныйНалог
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|
	|	ВЫБРАТЬ
	|		НалоговаяБаза.ВариантНалогообложенияПрибыли,
	|
	|		// Начисленный налог
	|		0,
	|
	|		// Налоговая база
	|		НалоговаяБаза.Сумма,
	|		НалоговаяБаза.СуммаНУ,
	|		НалоговаяБаза.СуммаПР,
	|		НалоговаяБаза.СуммаВР,
	|
	|		// Убытки прошлых лет
	|		0
	|	ИЗ
	|		СуммыНалоговойБазы КАК НалоговаяБаза
	|
	|	ОБЪЕДИНИТЬ ВСЕ
	|
	|	ВЫБРАТЬ
	|		Убытки.ВариантНалогообложенияПрибыли,
	|
	|		// Начисленный налог
	|		0,
	|
	|		// Налоговая база
	|		0,
	|		0,
	|		0,
	|		0,
	|
	|		// Убытки прошлых лет
	|		Убытки.СуммаНУ
	|	ИЗ
	|		УбытокПеренесенныйНаБудущее КАК Убытки
	|	
	|	) КАК ДанныеБазы
	|
	|СГРУППИРОВАТЬ ПО
	|	ВЫБОР
	|		КОГДА НЕ &ИспользуетсяРаздельныйУчет
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.ВариантыНалогообложенияПрибыли.ПустаяСсылка)
	|		ИНАЧЕ
	|			ДанныеБазы.ВариантНалогообложенияПрибыли
	|	КОНЕЦ
	|";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		НоваяСтрока = ДобавитьСтрокуРасчетаПоВариантамНалогообложения(
			ТаблицаРасчета, Выборка.ВариантНалогообложенияПрибыли);
		
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
		
		НоваяСтрока.СуммыНалоговойБазы.Сумма   = Выборка.НалоговаяБазаБУ;
		НоваяСтрока.СуммыНалоговойБазы.СуммаНУ = Выборка.НалоговаяБазаНУ;
		НоваяСтрока.СуммыНалоговойБазы.СуммаПР = Выборка.НалоговаяБазаПР;
		НоваяСтрока.СуммыНалоговойБазы.СуммаВР = Выборка.НалоговаяБазаВР;
		
	КонецЦикла;
	
КонецПроцедуры

// Заполняет расчет отложенного налога в общей таблице расчета
// 
// Параметры:
// 	ТаблицаРасчета - см. НовыйРасчетПоВариантамНалогообложения
// 	КонтекстРасчета - см. РасчетНалогаНаПрибыль.НовыйКонтекстРасчета
//
Процедура РассчитатьОтложенныйНалог(ТаблицаРасчета, КонтекстРасчета)
	
	// ПБУ18.14
	// Изменение величины отложенных налоговых активов в отчетном периоде равняется произведению вычитаемых временных разниц,
	// возникших (погашенных) в отчетном периоде, на ставку налога на прибыль,
	// установленную законодательством Российской Федерации о налогах и сборах и действующую на отчетную дату. 
	//
	// В случае изменения ставок налога на прибыль в соответствии с законодательством
	// Российской Федерации о налогах и сборах величина отложенных налоговых активов подлежит пересчету на дату,
	// предшествующую дате начала применения измененных ставок
	// с отнесением возникшей в результате пересчета разницы на счет учета прибылей и убытков.
	
	// IAS12.60(a) Балансовая стоимость отложенных налоговых активов и обязательств может меняться
	// даже при отсутствии изменений в сумме соответствующих временных разниц ... 
	// в результате изменения в ставках налога или налоговом законодательстве
	
	// IAS12.80(d) Компоненты расхода (дохода) по налогу могут включать сумму расхода (дохода) 
	// по отложенному налогу, относящегося к изменениям в ставках налога или введению новых налогов
	// (c) сумму расхода (дохода) по отложенному налогу, относящегося к возникновению и восстановлению временных разниц;
	// (d) сумму расхода (дохода) по отложенному налогу, относящегося к изменениям в ставках налога или введению новых налогов;
	// (g) расход по отложенному налогу, возникающий в результате списания
	//     или восстановления предыдущего списания отложенного налогового актива в соответствии с пунктом 56
	//     (Балансовая стоимость отложенного налогового актива подлежит повторной оценке по состоянию на конец
	//      каждого отчетного периода...
	//      Любое такое уменьшение должно быть восстановлено в той мере, в которой станет вероятным получение достаточной
	//      налогооблагаемой прибыли.)
	
	// Исходя из этих требований, в программе порядок расчета следующий:
	// 1. Отложенные налоги оцениваем по ставке будущего налога,
	//    которая в частном (и частом) случае равна ставке текущего налога в силу ПБУ 18.
	//    Организация может отклониться от этого требования IAS12.46 и применять другую ставку.
	// 2. В сумме изменения отложенного налога за отчетный период выделяем компоненты
	//    - эффект изменения временных разниц
	//    - эффект изменения ставки налога.
	// 3. Эффект изменения временных разниц оцениваем по ставке текущего налога для выполнения требований ПБУ18.14.
	//    Также это упрощает численную сверку суммы начисленного налога и показателей отложенного налога
	//    (в частности, выполняемую на счете 68.04.2).
	//    Ниже эта ставка обозначена как Rc.
	// 4. Эффект изменения ставки налога численно равен сумме
	//    - произведения временных разниц на начало отчетного периода на разницу между ставками
	//      текущего налога и налога, по которым отложенные налоги оценены в предыдущем отчетном периоде
	//    - произведения временных разниц на конец отчетного периода на разницу между ставками
	//      будущего налога и текущего налога, по которым отложенные налоги оценены в предыдущем отчетном периоде.
	// 5. Эффект изменения временных разниц оцениваем раздельно по увеличению и уменьшению разниц с тем,
	//    чтобы показать в финансовой отчетности раздельно признание и погашение налоговых активов (обязательств).
	// 
	// Корректность расчета в пунктах 3 и 4 обеспечивается следующими равенствами:
	// T1 - T0 = D1*R1 - D0*R0 = (D1-D0)*Rc + D1*(R1-Rc) + D0*(Rc-R0) = 
	//         = {D1*Rc} - {{D0*Rc}} + D1*R1 - {D1*Rc} + {{D0*Rc}} - D0*R0
	// где
	//   T1 - отложенный налог на отчетную дату
	//   T0 - отложенный налог на начало отчетного периода
	//   D1 - временные разницы на отчетную дату 
	//   D0 - временные разницы на начало периода
	//   R1 - ставка налога на отчетную дату
	//   R0 - ставка налога на начало периода
	//   Rc - ставка текущего налога
	//
	// В частном случае, когда все ставки равны, расчет простой:
	// - T1 = D1*R1;
	// - эффект изменения разниц определяется как T1 - T0.
	
	НачальныеДанныеОтчетнаяДата  = КонтекстРасчета.НачалоНалоговогоПериода;
	РегистрыСведений.РасчетОтложенногоНалога.ПривестиПериодРасчета(НачальныеДанныеОтчетнаяДата);
	// При выполнении регламентной операции или при инициализации сведения о примененных ставках записываются всегда,
	// а сведения о суммах отложенного налога - только при наличии временных разниц.
	// Поэтому проверка записей о ставках эффективнее.
	НачальныеДанныеПериодРасчета = РегистрыСведений.ПримененныеСтавкиОтложенногоНалога.ПериодРасчета(
		НачальныеДанныеОтчетнаяДата,
		КонтекстРасчета.Организация,
		КонтекстРасчета.КонецПериода);
	
	ОтчетнаяДата = КонтекстРасчета.КонецПериода + 1;
	
	// Получим данные о временных разницах
	// См. также ИнициализироватьРасчетОтложенногоНалога
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	СоздатьСальдоВременныхРазниц(
		МенеджерВременныхТаблиц,
		ОтчетнаяДата,
		КонтекстРасчета);
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	Запрос.УстановитьПараметр("НачальныеДанныеОтчетнаяДата",  НачальныеДанныеОтчетнаяДата);
	Запрос.УстановитьПараметр("НачальныеДанныеПериодРасчета", НачальныеДанныеПериодРасчета);
	Запрос.УстановитьПараметр("ОтчетнаяДата",                 ОтчетнаяДата);
	Запрос.УстановитьПараметр("Организация",                  КонтекстРасчета.Организация);
	
	// Вычитаемые (deductible) разницы на счетах учета активов имеют отрицательный знак,
	// облагаемые (taxable) - положительный.
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Изменения.ВариантНалогообложенияПрибыли КАК ВариантНалогообложенияПрибыли,
	|	Изменения.СчетОтложенногоНалога КАК СчетОтложенногоНалога,
	|	Изменения.ВидАктивовИОбязательств КАК ВидАктивовИОбязательств,
	|	Изменения.Счет КАК Счет,
	|	Изменения.Филиал КАК Филиал,
	|	Изменения.Подразделение КАК Подразделение,
	|	Изменения.НаправлениеДеятельности КАК НаправлениеДеятельности,
	|	Изменения.Субконто1 КАК Субконто1,
	|	Изменения.Субконто2 КАК Субконто2,
	|	Изменения.Субконто3 КАК Субконто3,
	|	СУММА(Изменения.БалансоваяСтоимость) КАК БалансоваяСтоимость,
	|	СУММА(Изменения.НалоговаяСтоимость) КАК НалоговаяСтоимость,
	|	СУММА(Изменения.ВременнаяРазница) КАК ВременнаяРазница,
	|	СУММА(Изменения.ВременнаяРазницаПредыдущая) КАК ВременнаяРазницаПредыдущая,
	|	СУММА(Изменения.ОтложенныйНалогПредыдущий) КАК ОтложенныйНалогПредыдущий
	|ИЗ
	|	(ВЫБРАТЬ
	|		ТекущиеДанные.ВариантНалогообложенияПрибыли КАК ВариантНалогообложенияПрибыли,
	|		ТекущиеДанные.СчетОтложенногоНалога КАК СчетОтложенногоНалога,
	|		ТекущиеДанные.ВидАктивовОбязательств КАК ВидАктивовИОбязательств,
	|		ТекущиеДанные.Счет КАК Счет,
	|		ТекущиеДанные.Филиал КАК Филиал,
	|		ТекущиеДанные.Подразделение КАК Подразделение,
	|		ТекущиеДанные.НаправлениеДеятельности КАК НаправлениеДеятельности,
	|		ТекущиеДанные.Субконто1 КАК Субконто1,
	|		ТекущиеДанные.Субконто2 КАК Субконто2,
	|		ТекущиеДанные.Субконто3 КАК Субконто3,
	|		ТекущиеДанные.БалансоваяСтоимость КАК БалансоваяСтоимость,
	|		ТекущиеДанные.НалоговаяСтоимость КАК НалоговаяСтоимость,
	|		ТекущиеДанные.ВременнаяРазница КАК ВременнаяРазница,
	|		0 КАК ВременнаяРазницаПредыдущая,
	|		0 КАК ОтложенныйНалогПредыдущий
	|	ИЗ
	|		СальдоВременныхРазниц КАК ТекущиеДанные
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		НачальныеДанные.ВариантНалогообложенияПрибыли,
	|		НачальныеДанные.СчетОтложенногоНалога,
	|		НачальныеДанные.ВидАктивовИОбязательств,
	|		НачальныеДанные.Счет,
	|		НачальныеДанные.Филиал,
	|		НачальныеДанные.Подразделение,
	|		НачальныеДанные.НаправлениеДеятельности,
	|		НачальныеДанные.Субконто1,
	|		НачальныеДанные.Субконто2,
	|		НачальныеДанные.Субконто3,
	|		0,
	|		0,
	|		0,
	|		НачальныеДанные.ВременнаяРазница,
	|		НачальныеДанные.ОтложенныйНалог
	|	ИЗ
	|		РегистрСведений.РасчетОтложенногоНалога КАК НачальныеДанные
	|	ГДЕ
	|		НачальныеДанные.ОтчетнаяДата = &НачальныеДанныеОтчетнаяДата
	|		И НачальныеДанные.Организация = &Организация
	|		И НачальныеДанные.ПериодРасчета = &НачальныеДанныеПериодРасчета
	|		И (НачальныеДанные.ВременнаяРазница <> 0
	|				ИЛИ НачальныеДанные.ОтложенныйНалог <> 0)) КАК Изменения
	|
	|СГРУППИРОВАТЬ ПО
	|	Изменения.ВариантНалогообложенияПрибыли,
	|	Изменения.СчетОтложенногоНалога,
	|	Изменения.ВидАктивовИОбязательств,
	|	Изменения.Счет,
	|	Изменения.Филиал,
	|	Изменения.Подразделение,
	|	Изменения.НаправлениеДеятельности,
	|	Изменения.Субконто1,
	|	Изменения.Субконто2,
	|	Изменения.Субконто3
	|
	|УПОРЯДОЧИТЬ ПО
	|	ВариантНалогообложенияПрибыли,
	|	СчетОтложенногоНалога,
	|	ВидАктивовИОбязательств,
	|	Счет,
	|	Филиал,
	|	Подразделение,
	|	НаправлениеДеятельности,
	|	Субконто1,
	|	Субконто2,
	|	Субконто3
	|ИТОГИ
	|	СУММА(ВременнаяРазница),
	|	СУММА(ВременнаяРазницаПредыдущая),
	|	СУММА(ОтложенныйНалогПредыдущий)
	|ПО
	|	ВариантНалогообложенияПрибыли,
	|	СчетОтложенногоНалога,
	|	ВидАктивовИОбязательств";
	
	
	// Инициализация расчетов отложенного налога по каждому варианту н/о по имеющимся данным
	СоответствиеРасчетов = Новый Соответствие();
	Для Каждого ОбщийРасчет Из ТаблицаРасчета Цикл
		
		Расчет                               = ОбщийРасчет.РасчетОтложенногоНалога;
		Расчет.ВариантНалогообложенияПрибыли = ОбщийРасчет.ВариантНалогообложенияПрибыли;
		Расчет.НачисленныйНалог              = ОбщийРасчет.НачисленныйНалог;
		Расчет.НачальныеДанныеОтчетнаяДата   = НачальныеДанныеОтчетнаяДата;
		Расчет.НачальныеДанныеПериодРасчета  = НачальныеДанныеПериодРасчета;
		
		СоответствиеРасчетов.Вставить(Расчет.ВариантНалогообложенияПрибыли, Расчет);
		
	КонецЦикла;
	
	ВыборкаВариантНалогообложенияПрибыли = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаВариантНалогообложенияПрибыли.Следующий() Цикл
		// Отработаем случай, если по данным активов/пассивов подобрался вариант н/о,
		// отсутствующий в основной таблице расчета.
		Расчет = СоответствиеРасчетов.Получить(
			ВыборкаВариантНалогообложенияПрибыли.ВариантНалогообложенияПрибыли); // см. НовыйРасчетОтложенногоНалога
		
		Если Расчет = Неопределено Тогда
			
			ОбщийРасчет = ДобавитьСтрокуРасчетаПоВариантамНалогообложения(
				ТаблицаРасчета,
				ВыборкаВариантНалогообложенияПрибыли.ВариантНалогообложенияПрибыли);
			
			Расчет                               = ОбщийРасчет.РасчетОтложенногоНалога;
			Расчет.ВариантНалогообложенияПрибыли = ОбщийРасчет.ВариантНалогообложенияПрибыли;
			Расчет.НачальныеДанныеОтчетнаяДата   = НачальныеДанныеОтчетнаяДата;
			Расчет.НачальныеДанныеПериодРасчета  = НачальныеДанныеПериодРасчета;
			
			СоответствиеРасчетов.Вставить(Расчет.ВариантНалогообложенияПрибыли, Расчет);
		КонецЕсли;
	КонецЦикла;
	
	ВыборкаВариантНалогообложенияПрибыли.Сбросить();
	
	// Обработаем полученные данные
	ОпределитьСтавкиНалога(ТаблицаРасчета, КонтекстРасчета);
	
	ОбработатьИзменениеВариантаНалогообложенияПрибыли(
		ТаблицаРасчета,
		КонтекстРасчета);
		
	СчетаОтложенныйНалогВДобавочномКапитале = СчетаОтложенныйНалогВДобавочномКапитале(КонтекстРасчета);
	
	ДанныеОтложенногоНалога = ДанныеОтложенногоНалога();
	ВидыСубконтоВидовАктивовОбязательствВДобавочномКапитале = ВидыСубконтоВидовАктивовОбязательствВДобавочномКапитале(КонтекстРасчета);
	
	ВыбывшиеВНАСДооценкой = КонтекстРасчета.ВыбывшиеВНАСДооценкой;
	
	Пока ВыборкаВариантНалогообложенияПрибыли.Следующий() Цикл
	
		Расчет = СоответствиеРасчетов.Получить(
			ВыборкаВариантНалогообложенияПрибыли.ВариантНалогообложенияПрибыли); // см. НовыйРасчетОтложенногоНалога
		
		СтавкаТекущегоНалога     = Расчет.СтавкиНалога[Перечисления.ВидыСтавокОтложенногоНалога.ТекущийНалог];
		СтавкаПредыдущегоРасчета = Расчет.СтавкиНалога[Перечисления.ВидыСтавокОтложенногоНалога.ПредыдущаяОценка];
		СтавкаБудущегоНалога     = Расчет.СтавкиНалога[Перечисления.ВидыСтавокОтложенногоНалога.БудущийНалог];
		
		Если СтавкаПредыдущегоРасчета = 0 Тогда
			КоэффициентСтавкиТекущегоНалога = Неопределено;
		Иначе
			// Применяется к оценке на начало периода (по ставке предыдущего расчета)
			// Эффект изменения ставки = D0 * (Rc-R0) = T0/R0 * (Rc-R0) = T0 * (Rc-R0)/R0 = T0 * k
			КоэффициентСтавкиТекущегоНалога = (СтавкаТекущегоНалога - СтавкаПредыдущегоРасчета) / СтавкаПредыдущегоРасчета; 
		КонецЕсли;
		
		Если СтавкаБудущегоНалога = 0 Тогда
			КоэффициентСтавкиБудущегоНалога = Неопределено;
		Иначе
			// Применяется к оценке на конец периода (по ставке будущего налога)
			// Эффект изменения ставки = D1*(R1-Rc) = T1/R1 * (R1-Rc) = T1 * (R1-Rc)/R1 = T1 * k
			КоэффициентСтавкиБудущегоНалога  = (СтавкаБудущегоНалога - СтавкаТекущегоНалога) / СтавкаБудущегоНалога;
		КонецЕсли;
		
		ВозможенЭффектИзмененияСтавки = ЗначениеЗаполнено(КоэффициентСтавкиТекущегоНалога)
			Или ЗначениеЗаполнено(КоэффициентСтавкиБудущегоНалога);
		
		ТипСумма = БухгалтерскийУчетКлиентСервер.ТипСумма();
		
		ВыборкаСчетОтложенногоНалога = ВыборкаВариантНалогообложенияПрибыли.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаСчетОтложенногоНалога.Следующий() Цикл
			
			Если Не ЗначениеЗаполнено(ВыборкаСчетОтложенногоНалога.СчетОтложенногоНалога) Тогда
				Продолжить;
			КонецЕсли;
			
			ВыборкаВидАктивовОбязательств = ВыборкаСчетОтложенногоНалога.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаВидАктивовОбязательств.Следующий() Цикл
				
				ЭтоОтложенныйНалогВДобавочномКапитале = ЭтоОтложенныйНалогВДобавочномКапитале(СчетаОтложенныйНалогВДобавочномКапитале,
					ВыборкаСчетОтложенногоНалога.СчетОтложенногоНалога);
				
				Если ЭтоОтложенныйНалогВДобавочномКапитале Тогда
					ЗаписьОтложенныйНалог = ОбщегоНазначения.СкопироватьРекурсивно(ДанныеОтложенногоНалога);
				Иначе					
					ЗаписьОтложенныйНалог = Расчет.ОтложенныйНалог.Добавить(); 	
				КонецЕсли;  
				
				ЗаписьОтложенныйНалог.ВариантНалогообложенияПрибыли = ВыборкаВариантНалогообложенияПрибыли.ВариантНалогообложенияПрибыли;
				ЗаписьОтложенныйНалог.Счет                          = ВыборкаСчетОтложенногоНалога.СчетОтложенногоНалога;
				ЗаписьОтложенныйНалог.ВидАктивовИОбязательств       = ВыборкаВидАктивовОбязательств.ВидАктивовИОбязательств;
				
				// Погрешности округления могут
				// 1. быть в исходных данных - сумме предыдущей оценки отложенного налога
				// 2. образовываться в ходе расчета.
				// При этом в ходе расчета погрешности могут быть двух видов:
				// a. "по горизонтали" - начальное сальдо разниц * ставку + изменения разниц * ставку <> конечное сальдо разниц * ставку
				//    (ПогрешностьОкругленияСальдо)
				// b. "по вертикали"   - суммарное значение разниц по виду умноженное на ставку <> сумме произведений каждой разницы на ставку
				//    (ПогрешностьОкругленияСуммарногоЗначенияНакопленная).
				// Устранение погрешностей одного вида может приводить к появлению погрешностей другого вида.
				// Учитываем все их при расчете.
				//
				// Суть расчета - определение суммы отложенного налогового актива (обязательства) - ранее обозначен T1.
				// Поэтому погрешности в его расчете
				// - учитываем с отрицательным знаком - см. формулу T1 - T0 = eD + eR; T0 - T1 + eD + eR = 0
				// - регистрируем, записываем в ЗаписьОтложенныйНалог.ПогрешностьОкругления
				
				Если Не ВозможенЭффектИзмененияСтавки Тогда
					// В ходе расчета погрешность округления не накапливается, потому что изменения отложенного налога рассчитываются прямым счетом,
					// без умножения на ставку налога.
					ПогрешностьОкругленияСальдо = 0;
				Иначе
					// Вычитаемые (deductible) разницы на счетах учета активов имеют отрицательный знак,
					// облагаемые (taxable) - положительный.
					ОтложенныйНалогПредыдущий   = - ВыборкаВидАктивовОбязательств.ВременнаяРазницаПредыдущая * СтавкаПредыдущегоРасчета;
					ПогрешностьОкругленияСальдо = ВыборкаВидАктивовОбязательств.ОтложенныйНалогПредыдущий - ОтложенныйНалогПредыдущий;
					Если ТипСумма.ПривестиЗначение(ПогрешностьОкругленияСальдо) <> 0 Тогда
						// Слишком большая для погрешности округления
						ПогрешностьОкругленияСальдо = 0;
					КонецЕсли;
				КонецЕсли;
				
				ПогрешностьОкругленияСуммарногоЗначенияНакопленная = 0;// см. выше "погрешность по вертикали"
				
				Выборка = ВыборкаВидАктивовОбязательств.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				Пока Выборка.Следующий() Цикл
					
					// Детальные данные о разницах
					Если Не ЗначениеЗаполнено(Выборка.ВременнаяРазница)
						И Не ЗначениеЗаполнено(Выборка.ВременнаяРазницаПредыдущая) Тогда
						Продолжить;
					КонецЕсли;
						
					ЗаписьВременныеРазницы = Расчет.ВременныеРазницы.Добавить();
					ЗаполнитьЗначенияСвойств(ЗаписьВременныеРазницы, Выборка);
					ЗаписьВременныеРазницы.ОтчетнаяДата = ОтчетнаяДата;
					
					// Сальдо отложенного налога на отчетную дату
					ОтложенныйНалог = - ЗаписьВременныеРазницы.ВременнаяРазница * СтавкаБудущегоНалога;
					
					// Заботимся, чтобы не накапливалась погрешность округления
					// - "по вертикали"
					ПогрешностьОкругленияСуммарногоЗначения = 0;
					ДополнитьОкругленнымЗначением(
						ЗаписьВременныеРазницы.ОтложенныйНалог,
						ОтложенныйНалог,
						ПогрешностьОкругленияСуммарногоЗначения,
						Ложь);
					ПогрешностьОкругленияСуммарногоЗначенияНакопленная = ПогрешностьОкругленияСуммарногоЗначения
						+ ПогрешностьОкругленияСуммарногоЗначенияНакопленная;
						
					УстранениеПогрешностиСуммарногоЗначения = УстранитьПогрешностьОкругления(
						ЗаписьВременныеРазницы.ОтложенныйНалог,
						ПогрешностьОкругленияСуммарногоЗначенияНакопленная);
						
					ЗаписьОтложенныйНалог.ПогрешностьОкругления = ЗаписьОтложенныйНалог.ПогрешностьОкругления + УстранениеПогрешностиСуммарногоЗначения;
					
					// - "по горизонтали"
					Если ВозможенЭффектИзмененияСтавки Тогда
						ПогрешностьОкругленияСальдо = - ПогрешностьОкругленияСуммарногоЗначения
							+ ПогрешностьОкругленияСальдо;
					КонецЕсли;
					
					ЗаписьОтложенныйНалог.ОтложенныйНалог = ЗаписьОтложенныйНалог.ОтложенныйНалог + ЗаписьВременныеРазницы.ОтложенныйНалог;
					
					ИзменениеОтложенногоНалога = ЗаписьВременныеРазницы.ОтложенныйНалог - Выборка.ОтложенныйНалогПредыдущий;
					Если ИзменениеОтложенногоНалога > 0 Тогда
						ЗаписьОтложенныйНалог.УвеличениеОтложенногоНалога = ЗаписьОтложенныйНалог.УвеличениеОтложенногоНалога + ИзменениеОтложенногоНалога;
					Иначе
						ЗаписьОтложенныйНалог.УменьшениеОтложенногоНалога = ЗаписьОтложенныйНалог.УменьшениеОтложенногоНалога + ИзменениеОтложенногоНалога;
					КонецЕсли;
					
					Если Не ВозможенЭффектИзмененияСтавки Тогда
						
						// Все изменения отложенного налога объясняем изменением разниц.
						// Поскольку при вычитании погрешность округления не может измениться, ранее накопленные погрешности не учитываем.
						ЭффектИзмененияВременныхРазниц = ИзменениеОтложенногоНалога;
						
					Иначе
						
						ИзменениеВременнойРазницы = Выборка.ВременнаяРазница - Выборка.ВременнаяРазницаПредыдущая;
						
						ЭффектИзмененияВременныхРазниц = - ИзменениеВременнойРазницы * СтавкаТекущегоНалога; // не округлена
						
						Если ЭффектИзмененияВременныхРазниц <> 0 Тогда
							// При округлении произведения возможна погрешность округления.
							// Поэтому учтем ранее накопленную погрешность.
							ЭффектИзмененияВременныхРазниц = ЭффектИзмененияВременныхРазниц + УстранениеПогрешностиСуммарногоЗначения;
						КонецЕсли;
						
					КонецЕсли;
					
					Если ЭффектИзмененияВременныхРазниц > 0 Тогда
						
						ДополнитьОкругленнымЗначением(
							ЗаписьВременныеРазницы.ЭффектУвеличенияВременныхРазниц,
							ЭффектИзмененияВременныхРазниц,
							ПогрешностьОкругленияСальдо);
							
						ЗаписьОтложенныйНалог.ЭффектУвеличенияВременныхРазниц = ЗаписьВременныеРазницы.ЭффектУвеличенияВременныхРазниц
							+ ЗаписьОтложенныйНалог.ЭффектУвеличенияВременныхРазниц;
							
					ИначеЕсли ЭффектИзмененияВременныхРазниц < 0 Тогда
							
						ДополнитьОкругленнымЗначением(
							ЗаписьВременныеРазницы.ЭффектУменьшенияВременныхРазниц,
							ЭффектИзмененияВременныхРазниц,
							ПогрешностьОкругленияСальдо);
							
						ЗаписьОтложенныйНалог.ЭффектУменьшенияВременныхРазниц = ЗаписьВременныеРазницы.ЭффектУменьшенияВременныхРазниц
							+ ЗаписьОтложенныйНалог.ЭффектУменьшенияВременныхРазниц;
							
					КонецЕсли;
					
					Если ЭтоОтложенныйНалогВДобавочномКапитале Тогда
						АктивОбязательство = АктивОбязательство(ВидыСубконтоВидовАктивовОбязательствВДобавочномКапитале, 
							ЗаписьОтложенныйНалог.ВидАктивовИОбязательств, Выборка);
						
					
						Если ВозможенЭффектИзмененияСтавки Тогда
							ЗаписьВременныеРазницы.ЭффектИзмененияСтавкиТекущегоНалога = 
								Выборка.ОтложенныйНалогПредыдущий * ?(ЗначениеЗаполнено(КоэффициентСтавкиТекущегоНалога), КоэффициентСтавкиТекущегоНалога, 0);
							ЗаписьВременныеРазницы.ЭффектИзмененияСтавкиБудущегоНалога = 
								ЗаписьВременныеРазницы.ОтложенныйНалог * ?(ЗначениеЗаполнено(КоэффициентСтавкиБудущегоНалога), КоэффициентСтавкиБудущегоНалога, 0);
						КонецЕсли;
						
						ЗаполнитьОтложенныйНалогВДобавочномКапитале(Расчет, ЗаписьОтложенныйНалог,
							ЗаписьВременныеРазницы, ИзменениеОтложенногоНалога, АктивОбязательство);
						
						Если ВыбывшиеВНАСДооценкой.Получить(АктивОбязательство) <> Неопределено Тогда
							Расчет.СтрокиРазницНалогаВДобавочномКапиталеПоВыбывшимВНА.Вставить(АктивОбязательство, ЗаписьВременныеРазницы);							
						КонецЕсли;
					КонецЕсли;
							
				КонецЦикла;
				
				Если ВозможенЭффектИзмененияСтавки Тогда
					
					ПогрешностьОкругленияСальдо = - ЗаписьОтложенныйНалог.ПогрешностьОкругления
						+ ПогрешностьОкругленияСальдо;
					
					Если ЗначениеЗаполнено(КоэффициентСтавкиБудущегоНалога) Тогда
						
						ЭффектИзмененияСтавкиБудущегоНалога = ЗаписьОтложенныйНалог.ОтложенныйНалог
							* КоэффициентСтавкиБудущегоНалога;
							
						ДополнитьОкругленнымЗначением(
							ЗаписьОтложенныйНалог.ЭффектИзмененияСтавкиБудущегоНалога,
							ЭффектИзмененияСтавкиБудущегоНалога,
							ПогрешностьОкругленияСальдо);
							
					КонецЕсли;
					
					Если ЗначениеЗаполнено(КоэффициентСтавкиТекущегоНалога) Тогда
				
						ЭффектИзмененияСтавкиТекущегоНалога = ВыборкаВидАктивовОбязательств.ОтложенныйНалогПредыдущий
							* КоэффициентСтавкиТекущегоНалога;
							
						ДополнитьОкругленнымЗначением(
							ЗаписьОтложенныйНалог.ЭффектИзмененияСтавкиТекущегоНалога,
							ЭффектИзмененияСтавкиТекущегоНалога,
							ПогрешностьОкругленияСальдо);
							
					КонецЕсли;
						
					Если (ЗаписьОтложенныйНалог.ЭффектИзмененияСтавкиТекущегоНалога <> 0
						Или ЗаписьОтложенныйНалог.ЭффектИзмененияСтавкиБудущегоНалога <> 0)						
						И НЕ ЭтоОтложенныйНалогВДобавочномКапитале Тогда            
						
						ЗаполнитьЗначенияСвойств(Расчет.ЭффектИзмененияСтавокНалогаНаПрибыль.Добавить(), ЗаписьОтложенныйНалог);
						
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура СоздатьТаблицуПравилГруппировки(ПланГруппировки, МенеджерВременныхТаблиц)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ПланГруппировки", ПланГруппировки);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ПланГруппировки.Счет КАК Счет,
	|	ПланГруппировки.СчетГруппировки КАК СчетГруппировки,
	|	ПланГруппировки.ВидАктивовОбязательств КАК ВидАктивовОбязательств,
	|	ПланГруппировки.ПозицияСубконто1 КАК ПозицияСубконто1,
	|	ПланГруппировки.ПозицияСубконто2 КАК ПозицияСубконто2,
	|	ПланГруппировки.ПозицияСубконто3 КАК ПозицияСубконто3,
	|	ПланГруппировки.НомерВариантаИсключения КАК НомерВариантаИсключения,
	|	ПланГруппировки.ВыбиратьТолькоРазницы КАК ВыбиратьТолькоРазницы,
	|	ПланГруппировки.ПозицияСубконтоВариантНалогообложения КАК ПозицияСубконтоВариантНалогообложения
	|ПОМЕСТИТЬ ВТ_ПравилаГруппировки
	|ИЗ
	|	&ПланГруппировки КАК ПланГруппировки
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Счет";
	Запрос.Выполнить();	

КонецПроцедуры

Процедура ЗаполнитьОтложенныйНалогВДобавочномКапитале(Расчет, ЗаписьОтложенныйНалог, ЗаписьВременныеРазницы, 
	Знач ИзменениеОтложенногоНалога, АктивОбязательство)
	
	СвойстваОтложенногоНалога = "ВариантНалогообложенияПрибыли, ВидАктивовИОбязательств, Счет";
	
	ЗаписьОтложенныйНалогВДобавочномКапитале = Расчет.ОтложенныйНалогВДобавочномКапитале.Добавить();
	ЗаполнитьЗначенияСвойств(ЗаписьОтложенныйНалогВДобавочномКапитале, ЗаписьОтложенныйНалог, СвойстваОтложенногоНалога);
	
	Если ИзменениеОтложенногоНалога > 0 Тогда
		ЗаписьОтложенныйНалогВДобавочномКапитале.УвеличениеОтложенногоНалога = ИзменениеОтложенногоНалога;
	Иначе
		ЗаписьОтложенныйНалогВДобавочномКапитале.УменьшениеОтложенногоНалога = ИзменениеОтложенногоНалога;
	КонецЕсли;  
	
	СвойстваВременныхРазниц = "ЭффектУвеличенияВременныхРазниц, ЭффектУменьшенияВременныхРазниц, 
		|ОтложенныйНалог, ЭффектИзмененияСтавкиТекущегоНалога, ЭффектИзмененияСтавкиБудущегоНалога";
		
	ЗаполнитьЗначенияСвойств(ЗаписьОтложенныйНалогВДобавочномКапитале, ЗаписьВременныеРазницы, СвойстваВременныхРазниц);
			
	ЗаписьОтложенныйНалогВДобавочномКапитале.АктивОбязательство = АктивОбязательство;
	
КонецПроцедуры

Функция АктивОбязательство(ВидыСубконтоВидовАктивовОбязательствВДобавочномКапитале, Знач ВидАктивовИОбязательств, ВыборкаВременныхРазниц)
	
	ВидСубконтоАктива = ВидыСубконтоВидовАктивовОбязательствВДобавочномКапитале.Получить(ВидАктивовИОбязательств);
	МассивТипов = ВидСубконтоАктива.ТипЗначения.Типы();
	
	АктивОбязательство = Неопределено;
	
	Если МассивТипов.Найти(ТипЗнч(ВыборкаВременныхРазниц.Субконто1)) <> Неопределено  Тогда
		АктивОбязательство = ВыборкаВременныхРазниц.Субконто1;
	ИначеЕсли МассивТипов.Найти(ТипЗнч(ВыборкаВременныхРазниц.Субконто2)) <> Неопределено  Тогда
		АктивОбязательство = ВыборкаВременныхРазниц.Субконто2;
	ИначеЕсли МассивТипов.Найти(ТипЗнч(ВыборкаВременныхРазниц.Субконто3)) <> Неопределено  Тогда
		АктивОбязательство = ВыборкаВременныхРазниц.Субконто3;
	КонецЕсли;
	
	Возврат АктивОбязательство;
	
КонецФункции

Функция ПланГруппировки(КонтекстРасчета)

	ПравилаГруппировки = НовыйПравилаГруппировкиАктивовОбязательств();
	
	Если ПолучитьФункциональнуюОпцию("ИспользоватьНастраиваемуюГруппировкуАктивовОбязательств") Тогда
		ПолучитьПравилаГруппировкиВидовАктивовИОбязательств(ПравилаГруппировки);
	Иначе
		ЗаполнитьПравилаГруппировкиВидовАктивовИОбязательств(ПравилаГруппировки);
	КонецЕсли;
	
	ДополнитьПланГруппировкиСчетамиДобавочногоКапитала(ПравилаГруппировки, КонтекстРасчета);
	
	ПланГруппировки = ПланГруппировкиАктивовОбязательств(ПравилаГруппировки);
	
	Возврат ПланГруппировки;

КонецФункции

Процедура ДополнитьПланГруппировкиСчетамиДобавочногоКапитала(ПравилаГруппировки, КонтекстРасчета)

	Для каждого Строка Из КонтекстРасчета.ПараметрыУчетаОтложенногоНалогаВДобавочномКапитале Цикл
		НоваяСтрока = ПравилаГруппировки.Добавить();
		НоваяСтрока.ОсновнойСчет = Строка.Счет; 
		НоваяСтрока.ВидАктивовОбязательств = Строка.ВидАктивовОбязательств;
		НоваяСтрока.ДополнительныеСчета = Новый Массив;
		НоваяСтрока.ИсключенныеСубконто = Новый Массив;
	КонецЦикла;	

КонецПроцедуры

Функция ДанныеОтложенногоНалога()

	ТаблицаОтложенногоНалога = НовыйИзменениеОтложенногоНалога();	
	
	Возврат ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(ТаблицаОтложенногоНалога.Добавить());
	
КонецФункции 

Процедура СоздатьВТ_СчетаОтложенногоНалогаВДобавочномКапитале(КонтекстРасчета, МенеджерВременныхТаблиц)

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст = "ВЫБРАТЬ
	               |	СчетаОтложенногоНалогаВДобавочномКапитале.Счет КАК Счет,
	               |	СчетаОтложенногоНалогаВДобавочномКапитале.СчетОтложенногоНалога КАК СчетОтложенногоНалога
	               |ПОМЕСТИТЬ ВТ_СчетаОтложенногоНалогаВДобавочномКапитале
	               |ИЗ
	               |	&СчетаОтложенногоНалогаВДобавочномКапитале КАК СчетаОтложенногоНалогаВДобавочномКапитале";
	
	Запрос.УстановитьПараметр("СчетаОтложенногоНалогаВДобавочномКапитале", 
		КонтекстРасчета.ПараметрыУчетаОтложенногоНалогаВДобавочномКапитале);
	
	Запрос.Выполнить();	
		
КонецПроцедуры

Процедура СоздатьСальдоВременныхРазниц(МенеджерВременныхТаблиц, ОтчетнаяДата, КонтекстРасчета)
	
	ПланГруппировки = ПланГруппировки(КонтекстРасчета);
	СоздатьТаблицуПравилГруппировки(ПланГруппировки, МенеджерВременныхТаблиц);
	
	// Получаем данные о временных разницах
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ОтчетнаяДата", ОтчетнаяДата);
	Запрос.УстановитьПараметр("Организации",  КонтекстРасчета.Организации);
	
	// Временную таблицу ВТ_БалансовыеДанные не индексируем, потому что она далее используется в качестве ЛЕВОЙ в соединении,
	// и из нее выбираются все данные.
	// Возможные значения NULL в субконто приводим к Неопределено для правильной группировки строк с одинаковыми по сути значениями. 
	
	Запрос.Текст = // Текст будет модифицирован - см. НастроитьРасчетВременнойРазницы(), ОптимизироватьЗапросСальдоДляГруппировки()
	"ВЫБРАТЬ
	|	Остатки.Счет КАК Счет,
	|	Остатки.Организация КАК Филиал,
	|	ЕСТЬNULL(Остатки.Подразделение, ЗНАЧЕНИЕ(Справочник.СтруктураПредприятия.ПустаяСсылка)) КАК Подразделение,
	|	ЕСТЬNULL(Остатки.НаправлениеДеятельности,
	|		ЗНАЧЕНИЕ(Справочник.НаправленияДеятельности.ПустаяСсылка)) КАК НаправлениеДеятельности,
	|	ЕСТЬNULL(Остатки.Субконто1, НЕОПРЕДЕЛЕНО) КАК Субконто1,
	|	ЕСТЬNULL(Остатки.Субконто2, НЕОПРЕДЕЛЕНО) КАК Субконто2,
	|	ЕСТЬNULL(Остатки.Субконто3, НЕОПРЕДЕЛЕНО) КАК Субконто3,
	|	Остатки.СуммаОстаток КАК БалансоваяСтоимость,
	|	ЕСТЬNULL(Остатки.СуммаНУОстаток, 0) КАК НалоговаяСтоимость,
	|	ЕСТЬNULL(Остатки.СуммаВРОстаток, 0) КАК ВременнаяРазница
	|ПОМЕСТИТЬ ВТ_БалансовыеДанные
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.Остатки(
	|			&ОтчетнаяДата,
	|			Счет В
	|				(ВЫБРАТЬ
	|					ПланГруппировки.Счет
	|				ИЗ
	|					ВТ_ПравилаГруппировки КАК ПланГруппировки),
	|			,
	|			Организация В (&Организации)) КАК Остатки";
	НастроитьРасчетВременнойРазницы(Запрос.Текст, КонтекстРасчета.ВариантУчетаОтложенногоНалога);
	ОптимизироватьЗапросСальдоДляГруппировки(Запрос.Текст, ПланГруппировки);
	Запрос.Выполнить();
	
	// Находим данные по варианту налогообложения прибыли
	
	Если КонтекстРасчета.ИспользуетсяРаздельныйУчет Тогда
		ЕстьНастройкиПоОбъектамУчета =
			РаздельныйУчетПоНалогуНаПрибыль.ЕстьНастройкиПоОбъектамУчета(КонтекстРасчета.Организация, ОтчетнаяДата);
	Иначе
		ЕстьНастройкиПоОбъектамУчета = Ложь;
	КонецЕсли;
	
	НастройкиНалогообложенияПрибыли(
		МенеджерВременныхТаблиц,
		ОтчетнаяДата,
		КонтекстРасчета.ИспользуетсяРаздельныйУчет,
		ЕстьНастройкиПоОбъектамУчета);
		
	СоздатьВТ_СчетаОтложенногоНалогаВДобавочномКапитале(КонтекстРасчета, МенеджерВременныхТаблиц);
	
	// Дополняем данными о виде активов и обязательств, группируем по счету, выстраиваем субконто в нужном порядке.
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА Правила.ПозицияСубконтоВариантНалогообложения = 0
	|			ТОГДА ЕСТЬNULL(НастройкиНалогообложения.ВариантНалогообложенияПрибыли,
	|					&ПолеВариантНалогообложенияПоУмолчанию)
	|		КОГДА Правила.ПозицияСубконтоВариантНалогообложения = 1 И БалансовыеДанные.Субконто1 <> НЕОПРЕДЕЛЕНО
	|			ТОГДА БалансовыеДанные.Субконто1
	|		КОГДА Правила.ПозицияСубконтоВариантНалогообложения = 2 И БалансовыеДанные.Субконто2 <> НЕОПРЕДЕЛЕНО
	|			ТОГДА БалансовыеДанные.Субконто2
	|		КОГДА Правила.ПозицияСубконтоВариантНалогообложения = 3 И БалансовыеДанные.Субконто3 <> НЕОПРЕДЕЛЕНО
	|			ТОГДА БалансовыеДанные.Субконто3
	|		ИНАЧЕ &ПолеВариантНалогообложенияПоУмолчанию
	|	КОНЕЦ КАК ВариантНалогообложенияПрибыли,
	|	ВЫБОР
	|		КОГДА ВТ_СчетаОтложенногоНалогаВДобавочномКапитале.СчетОтложенногоНалога ЕСТЬ NULL
	|			ТОГДА ВЫБОР
	|					КОГДА СУММА(БалансовыеДанные.ВременнаяРазница) < 0
	|						ТОГДА ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.ОтложенныеНалоговыеАктивы)
	|					ИНАЧЕ ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.ОтложенныеНалоговыеОбязательства)
	|				КОНЕЦ
	|		ИНАЧЕ ВТ_СчетаОтложенногоНалогаВДобавочномКапитале.СчетОтложенногоНалога
	|	КОНЕЦ КАК СчетОтложенногоНалога,
	|	Правила.ВидАктивовОбязательств КАК ВидАктивовОбязательств,
	|	Правила.СчетГруппировки КАК Счет,
	|	БалансовыеДанные.Филиал КАК Филиал,
	|	БалансовыеДанные.Подразделение КАК Подразделение,
	|	БалансовыеДанные.НаправлениеДеятельности КАК НаправлениеДеятельности,
	|	ВЫБОР
	|		КОГДА Правила.ПозицияСубконто1 = 1
	|			ТОГДА БалансовыеДанные.Субконто1
	|		КОГДА Правила.ПозицияСубконто2 = 1
	|			ТОГДА БалансовыеДанные.Субконто2
	|		КОГДА Правила.ПозицияСубконто3 = 1
	|			ТОГДА БалансовыеДанные.Субконто3
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК Субконто1,
	|	ВЫБОР
	|		КОГДА Правила.ПозицияСубконто1 = 2
	|			ТОГДА БалансовыеДанные.Субконто1
	|		КОГДА Правила.ПозицияСубконто2 = 2
	|			ТОГДА БалансовыеДанные.Субконто2
	|		КОГДА Правила.ПозицияСубконто3 = 2
	|			ТОГДА БалансовыеДанные.Субконто3
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК Субконто2,
	|	ВЫБОР
	|		КОГДА Правила.ПозицияСубконто1 = 3
	|			ТОГДА БалансовыеДанные.Субконто1
	|		КОГДА Правила.ПозицияСубконто2 = 3
	|			ТОГДА БалансовыеДанные.Субконто2
	|		КОГДА Правила.ПозицияСубконто3 = 3
	|			ТОГДА БалансовыеДанные.Субконто3
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК Субконто3,
	|	СУММА(БалансовыеДанные.БалансоваяСтоимость) КАК БалансоваяСтоимость,
	|	СУММА(БалансовыеДанные.НалоговаяСтоимость) КАК НалоговаяСтоимость,
	|	СУММА(БалансовыеДанные.ВременнаяРазница) КАК ВременнаяРазница
	|ПОМЕСТИТЬ СальдоВременныхРазниц
	|ИЗ
	|	ВТ_БалансовыеДанные КАК БалансовыеДанные
	|
	|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ПравилаГруппировки КАК Правила
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_СчетаОтложенногоНалогаВДобавочномКапитале КАК ВТ_СчетаОтложенногоНалогаВДобавочномКапитале
	|			ПО Правила.СчетГруппировки = ВТ_СчетаОтложенногоНалогаВДобавочномКапитале.Счет
	|		ПО БалансовыеДанные.Счет = Правила.Счет
	|
	|	ЛЕВОЕ СОЕДИНЕНИЕ НастройкиНалогообложения КАК НастройкиНалогообложения
	|		ПО БалансовыеДанные.Подразделение           = НастройкиНалогообложения.Подразделение
	|		И  БалансовыеДанные.НаправлениеДеятельности = НастройкиНалогообложения.НаправлениеДеятельности
	|		И  &ОтборНастроекПоСубконто
	|
	|СГРУППИРОВАТЬ ПО
	|	ВЫБОР
	|		КОГДА Правила.ПозицияСубконтоВариантНалогообложения = 0
	|			ТОГДА ЕСТЬNULL(НастройкиНалогообложения.ВариантНалогообложенияПрибыли,
	|					&ПолеВариантНалогообложенияПоУмолчанию)
	|		КОГДА Правила.ПозицияСубконтоВариантНалогообложения = 1 И БалансовыеДанные.Субконто1 <> НЕОПРЕДЕЛЕНО
	|			ТОГДА БалансовыеДанные.Субконто1
	|		КОГДА Правила.ПозицияСубконтоВариантНалогообложения = 2 И БалансовыеДанные.Субконто2 <> НЕОПРЕДЕЛЕНО
	|			ТОГДА БалансовыеДанные.Субконто2
	|		КОГДА Правила.ПозицияСубконтоВариантНалогообложения = 3 И БалансовыеДанные.Субконто3 <> НЕОПРЕДЕЛЕНО
	|			ТОГДА БалансовыеДанные.Субконто3
	|		ИНАЧЕ &ПолеВариантНалогообложенияПоУмолчанию
	|	КОНЕЦ,
	|	Правила.ВидАктивовОбязательств,
	|	Правила.СчетГруппировки,
	|	БалансовыеДанные.Филиал,
	|	БалансовыеДанные.Подразделение,
	|	БалансовыеДанные.НаправлениеДеятельности,
	|	ВЫБОР
	|		КОГДА Правила.ПозицияСубконто1 = 1
	|			ТОГДА БалансовыеДанные.Субконто1
	|		КОГДА Правила.ПозицияСубконто2 = 1
	|			ТОГДА БалансовыеДанные.Субконто2
	|		КОГДА Правила.ПозицияСубконто3 = 1
	|			ТОГДА БалансовыеДанные.Субконто3
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА Правила.ПозицияСубконто1 = 2
	|			ТОГДА БалансовыеДанные.Субконто1
	|		КОГДА Правила.ПозицияСубконто2 = 2
	|			ТОГДА БалансовыеДанные.Субконто2
	|		КОГДА Правила.ПозицияСубконто3 = 2
	|			ТОГДА БалансовыеДанные.Субконто3
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА Правила.ПозицияСубконто1 = 3
	|			ТОГДА БалансовыеДанные.Субконто1
	|		КОГДА Правила.ПозицияСубконто2 = 3
	|			ТОГДА БалансовыеДанные.Субконто2
	|		КОГДА Правила.ПозицияСубконто3 = 3
	|			ТОГДА БалансовыеДанные.Субконто3
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ,
	|	ВТ_СчетаОтложенногоНалогаВДобавочномКапитале.СчетОтложенногоНалога
	|
	|ИМЕЮЩИЕ
	|	СУММА(БалансовыеДанные.ВременнаяРазница) <> 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВТ_БалансовыеДанные
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВТ_СчетаОтложенногоНалогаВДобавочномКапитале
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВТ_ПравилаГруппировки";
	
	Если КонтекстРасчета.ИспользуетсяРаздельныйУчет И ЕстьНастройкиПоОбъектамУчета Тогда
		ТекстОтборНастроекПоСубконто = "
		|		БалансовыеДанные.Субконто1 = НастройкиНалогообложения.Субконто1
		|		И  БалансовыеДанные.Субконто2 = НастройкиНалогообложения.Субконто2
		|		И  БалансовыеДанные.Субконто3 = НастройкиНалогообложения.Субконто3";
	Иначе
		ТекстОтборНастроекПоСубконто = "ИСТИНА";
	КонецЕсли;
	
	Запрос.Текст = СтрЗаменить(ЗАпрос.Текст, "&ОтборНастроекПоСубконто", ТекстОтборНастроекПоСубконто);
	
	РаздельныйУчетПоНалогуНаПрибыль.ОбработатьПолеВариантНалогообложенияПоУмолчаниюВЗапросе(
		Запрос, КонтекстРасчета.ИспользуетсяРаздельныйУчет);
	
	Запрос.Выполнить();
	
КонецПроцедуры

// Создает временную таблицу "НастройкиНалогообложения"
// 
// Содержит колонки:
// 
// // Всегда
// 	* Организация;
// 	* Подразделение;
// 	* НаправлениеДеятельности;
// 	* ВариантНалогообложенияПрибыли
// 
// // Если есть настройки по объектам учета
// 	* ОбъектУчета;
// 	* Субконто1;
// 	* Субконто2;
// 	* Субконто3.
// 
// Параметры:
// 	МенеджерВременныхТаблиц      - МенеджерВременныхТаблиц -
// 	ОтчетнаяДата                 - Дата -
// 	ИспользуетсяРаздельныйУчет   - Булево -
// 	ЕстьНастройкиПоОбъектамУчета - Булево -
//
Процедура НастройкиНалогообложенияПрибыли(МенеджерВременныхТаблиц, ОтчетнаяДата, ИспользуетсяРаздельныйУчет, ЕстьНастройкиПоОбъектамУчета)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	Если НЕ ИспользуетсяРаздельныйУчет Тогда
		
		Запрос.Текст =
		"ВЫБРАТЬ
		|	НЕОПРЕДЕЛЕНО КАК Подразделение,
		|	НЕОПРЕДЕЛЕНО КАК НаправлениеДеятельности,
		|
		|	ЗНАЧЕНИЕ(Справочник.ВариантыНалогообложенияПрибыли.ПустаяСсылка) КАК ВариантНалогообложенияПрибыли
		|
		|ПОМЕСТИТЬ НастройкиНалогообложения
		|";
		
		Запрос.Выполнить();
		
		Возврат;
		
	КонецЕсли;
	
	Если ЕстьНастройкиПоОбъектамУчета Тогда
		
		ТекстЗапроса_ОтборНастроек =
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	БалансовыеДанные.Филиал.ГоловнаяОрганизация КАК Организация,
		|	БалансовыеДанные.Подразделение              КАК Подразделение,
		|	БалансовыеДанные.НаправлениеДеятельности    КАК НаправлениеДеятельности,
		|	ВЫБОР
		|		КОГДА ТИПЗНАЧЕНИЯ(БалансовыеДанные.Субконто1) В (&ТипыОбъектовУчета)
		|			ТОГДА БалансовыеДанные.Субконто1
		|		КОГДА ТИПЗНАЧЕНИЯ(БалансовыеДанные.Субконто2) В (&ТипыОбъектовУчета)
		|			ТОГДА БалансовыеДанные.Субконто2
		|		КОГДА ТИПЗНАЧЕНИЯ(БалансовыеДанные.Субконто3) В (&ТипыОбъектовУчета)
		|			ТОГДА БалансовыеДанные.Субконто3
		|		ИНАЧЕ
		|			&ПустойОбъектУчета
		|	КОНЕЦ                                       КАК ОбъектУчета,
		|
		|	БалансовыеДанные.Субконто1                  КАК Субконто1,
		|	БалансовыеДанные.Субконто2                  КАК Субконто2,
		|	БалансовыеДанные.Субконто3                  КАК Субконто3
		|
		|ПОМЕСТИТЬ ОтборНастроекНалогообложения
		|ИЗ
		|	ВТ_БалансовыеДанные КАК БалансовыеДанные
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Организация,
		|	Подразделение,
		|	ОбъектУчета,
		|	НаправлениеДеятельности
		|";
	
	Иначе
		
		ТекстЗапроса_ОтборНастроек =
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	БалансовыеДанные.Филиал.ГоловнаяОрганизация КАК Организация,
		|	БалансовыеДанные.Подразделение              КАК Подразделение,
		|	БалансовыеДанные.НаправлениеДеятельности    КАК НаправлениеДеятельности,
		|	&ПустойОбъектУчета                          КАК ОбъектУчета
		|
		|ПОМЕСТИТЬ ОтборНастроекНалогообложения
		|ИЗ
		|	ВТ_БалансовыеДанные КАК БалансовыеДанные
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Организация,
		|	Подразделение,
		|	ОбъектУчета,
		|	НаправлениеДеятельности
		|";
		
	КонецЕсли;
	
	ТекстЗапроса_ОтборНастроек =
		СтрЗаменить(ТекстЗапроса_ОтборНастроек,
			"&ПустойОбъектУчета",
			РаздельныйУчетПоНалогуНаПрибыль.ПустойОбъектУчета(Истина));
	
	ПараметрыПолученияНастроек =
		РаздельныйУчетПоНалогуНаПрибыль.НовыйПараметрыПолученияТаблицыНастроекНалогообложенияПрибыли();
	
	ПараметрыПолученияНастроек.ИмяТаблицы                      = "ОтборНастроекНалогообложения";
	ПараметрыПолученияНастроек.ИмяПоля_Организация             = "Организация";
	ПараметрыПолученияНастроек.ИмяПоля_Подразделение           = "Подразделение";
	ПараметрыПолученияНастроек.ИмяПоля_НаправлениеДеятельности = "НаправлениеДеятельности";
	
	Если ЕстьНастройкиПоОбъектамУчета Тогда
		ПараметрыПолученияНастроек.ИмяПоля_ОбъектУчета = "ОбъектУчета";
	КонецЕсли;
	
	ПараметрыПолученияНастроек.Период = ОтчетнаяДата;
	
	ТекстЗапроса_ЗначенияНастроек =
		РаздельныйУчетПоНалогуНаПрибыль.ТекстЗапроса_НастройкиНалогообложенияПрибыли(ПараметрыПолученияНастроек);
	
	Если ЕстьНастройкиПоОбъектамУчета Тогда
		
		ТекстЗапроса_Результат =
		"ВЫБРАТЬ
		|	ОтборНастроек.Подразделение           КАК Подразделение,
		|	ОтборНастроек.НаправлениеДеятельности КАК НаправлениеДеятельности,
		|	ОтборНастроек.ОбъектУчета             КАК ОбъектУчета,
		|
		|	ОтборНастроек.Субконто1               КАК Субконто1,
		|	ОтборНастроек.Субконто2               КАК Субконто2,
		|	ОтборНастроек.Субконто3               КАК Субконто3,
		|
		|	ЗначенияНастроек.ВариантНалогообложенияПрибыли КАК ВариантНалогообложенияПрибыли
		|
		|ПОМЕСТИТЬ НастройкиНалогообложения
		|ИЗ
		|	ОтборНастроекНалогообложения КАК ОтборНастроек
		|	
		|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ
		|		РаздельныйУчет_НастройкиНалогообложенияПрибыли КАК ЗначенияНастроек
		|	ПО
		|		ОтборНастроек.Организация               = ЗначенияНастроек.Организация
		|		И ОтборНастроек.Подразделение           = ЗначенияНастроек.Подразделение
		|		И ОтборНастроек.ОбъектУчета             = ЗначенияНастроек.ОбъектУчета
		|		И ОтборНастроек.НаправлениеДеятельности = ЗначенияНастроек.НаправлениеДеятельности
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Подразделение,
		|	НаправлениеДеятельности,
		|	Субконто1,
		|	Субконто2,
		|	Субконто3
		|;
		|
		|УНИЧТОЖИТЬ ОтборНастроекНалогообложения
		|;
		|
		|УНИЧТОЖИТЬ РаздельныйУчет_НастройкиНалогообложенияПрибыли
		|";
	
	Иначе
		
		ТекстЗапроса_Результат =
		"ВЫБРАТЬ
		|	ОтборНастроек.Подразделение           КАК Подразделение,
		|	ОтборНастроек.НаправлениеДеятельности КАК НаправлениеДеятельности,
		|
		|	ЗначенияНастроек.ВариантНалогообложенияПрибыли КАК ВариантНалогообложенияПрибыли
		|
		|ПОМЕСТИТЬ НастройкиНалогообложения
		|ИЗ
		|	ОтборНастроекНалогообложения КАК ОтборНастроек
		|	
		|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ
		|		РаздельныйУчет_НастройкиНалогообложенияПрибыли КАК ЗначенияНастроек
		|	ПО
		|		ОтборНастроек.Организация               = ЗначенияНастроек.Организация
		|		И ОтборНастроек.Подразделение           = ЗначенияНастроек.Подразделение
		|		И ОтборНастроек.ОбъектУчета             = ЗначенияНастроек.ОбъектУчета
		|		И ОтборНастроек.НаправлениеДеятельности = ЗначенияНастроек.НаправлениеДеятельности
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Подразделение,
		|	НаправлениеДеятельности
		|;
		|
		|УНИЧТОЖИТЬ ОтборНастроекНалогообложения
		|;
		|
		|УНИЧТОЖИТЬ РаздельныйУчет_НастройкиНалогообложенияПрибыли
		|";
		
	КонецЕсли;
	
	Запрос.Текст =
		ТекстЗапроса_ОтборНастроек
		+ ОбщегоНазначения.РазделительПакетаЗапросов()
		+ ТекстЗапроса_ЗначенияНастроек
		+ ОбщегоНазначения.РазделительПакетаЗапросов()
		+ ТекстЗапроса_Результат;
	
	
	Запрос.УстановитьПараметр("Период",            ОтчетнаяДата);
	Запрос.УстановитьПараметр("ТипыОбъектовУчета", РаздельныйУчетПоНалогуНаПрибыль.ТипыОбъектовУчета());
	
	Запрос.Выполнить();
	
КонецПроцедуры

Процедура НастроитьРасчетВременнойРазницы(ТекстЗапроса, ВариантУчетаОтложенногоНалога)
	
	// Запрос включает в себя выборку трех показателей регистра бухгалтерии.
	// Но в зависимости от выбранного варианта учета, нас интересуют
	// - либо данные ресурса с временными разницами
	// - либо данные двух других ресурсов
	
	// Здесь устанавливаем отбор по записям, в которых временная разница фактически есть, чтобы сократить объем выбираемых данных.
	// Однако, такой отбор может приводить к неверным данным о суммах налоговой и бухгалтерской стоимости в случаях,
	// когда данные разных счетов группируются.
	// Поэтому при подготовке текста запроса для группировки отбор может быть удален - см. ОптимизироватьЗапросСальдоДляГруппировки
	
	СхемаЗапроса = Новый СхемаЗапроса;
	СхемаЗапроса.УстановитьТекстЗапроса(ТекстЗапроса);
	
	Для Каждого ОписаниеЗапроса Из СхемаЗапроса.ПакетЗапросов Цикл
		
		Если ТипЗнч(ОписаниеЗапроса) <> Тип("ЗапросВыбораСхемыЗапроса") Тогда
			Продолжить;
		КонецЕсли;
		
		КолонкаВременнаяРазница = ОписаниеЗапроса.Колонки.Найти("ВременнаяРазница");
		Если КолонкаВременнаяРазница = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ИндексКолонкиВременнаяРазница = ОписаниеЗапроса.Колонки.Индекс(КолонкаВременнаяРазница);
		
		Для Каждого ОператорЗапроса Из ОписаниеЗапроса.Операторы Цикл
			
			Если ВариантУчетаОтложенногоНалога <> Перечисления.ВариантыУчетаОтложенногоНалога.БалансовыйМетод Тогда
				
				ВыражениеВременнаяРазница = ВыражениеПоляЗапроса(
					ОписаниеЗапроса,
					ОператорЗапроса,
					"ВременнаяРазница");
					
				ТекстВыраженияВременнаяРазница = Строка(ВыражениеВременнаяРазница);
				
			Иначе
				
				// 1. ВР = БУ - НУ
				
				ВыражениеБалансоваяСтоимость = ВыражениеПоляЗапроса(
					ОписаниеЗапроса,
					ОператорЗапроса,
					"БалансоваяСтоимость");
				
				ВыражениеНалоговаяСтоимость  = ВыражениеПоляЗапроса(
					ОписаниеЗапроса,
					ОператорЗапроса,
					"НалоговаяСтоимость");
					
				ТекстВыраженияВременнаяРазница = СтрШаблон(
					"%1 - %2",
					ВыражениеБалансоваяСтоимость,
					ВыражениеНалоговаяСтоимость);
					
				ВыражениеВременнаяРазница = Новый ВыражениеСхемыЗапроса(ТекстВыраженияВременнаяРазница);
					
				ОператорЗапроса.ВыбираемыеПоля.Установить(ИндексКолонкиВременнаяРазница, ВыражениеВременнаяРазница);
				
			КонецЕсли;
			
			// 2. ВР <> 0
			ТекстУсловия = СтрШаблон("%1 <> 0", ТекстВыраженияВременнаяРазница);
			ОператорЗапроса.Отбор.Добавить(ТекстУсловия);
			
		КонецЦикла;
		
	КонецЦикла;
	
	ТекстЗапроса = СхемаЗапроса.ПолучитьТекстЗапроса();
	
КонецПроцедуры

// Корректирует рассчитываемое значение на округленную величину.
// При этом погрешность округления регистрируется (при последовательных вызовах - суммируется)
// и при превышении порога значимости может быть устранена.
//
// Параметры:
//  Хранилище				 - Число - округленное значение, которое может быть модифицировано.
//                             Должно иметь тип значения с явным ограничением числа знаков в дробной части.
//  ТочноеЗначение			 - Число - слагаемое, которое может иметь точность большую, чем Хранилище.
//  ПогрешностьОкругления	 - Число - накопленная погрешность округления.
//  Устранить				 - Булево - Истина - при превышении накопленной погрешностью округления порога значимости,
//                             значение в Хранилище будет скорректировано так,
//                             чтобы накопленная погрешность округления стала меньше порога значимости.
//
Процедура ДополнитьОкругленнымЗначением(Хранилище, ТочноеЗначение, ПогрешностьОкругления, Устранить = Истина)
	
	ПредыдущееЗначение = Хранилище; // поскольку значение имеет примитивный тип, оно будет скопировано в новую переменную
	
	Хранилище = Хранилище + ТочноеЗначение; // неявное округление
	
	ПогрешностьНовогоОкругления = (Хранилище - ТочноеЗначение - ПредыдущееЗначение);
	
	ПогрешностьОкругления = ПогрешностьОкругления + ПогрешностьНовогоОкругления;
	
	Если Устранить Тогда
		УстранитьПогрешностьОкругления(Хранилище, ПогрешностьОкругления);
	КонецЕсли;
	
КонецПроцедуры

// Применяет накопленную погрешность округления к ранее округленному значению:
// если накопленная погрешность заметна для типа значения округленного значения,
// то это округленное значение будет скорректировано, а абсолютное значение погрешности уменьшится - станет менее порога значимости.
//
// Например, если значение округляется до 2 знаков после запятой, то накопленная погрешность -0.006 - значима (округляется до -0.01).
// Поэтому значение должно быть скорректировано на 0.01, а накопленная погрешность уменьшится - составит 0.004.
//
// Параметры:
//  Хранилище				 - Число - ранее округленное значение, которое может быть модифицировано.
//                             Должно иметь тип значения с явным ограничением числа знаков в дробной части.
//  ПогрешностьОкругления	 - Число - накопленная погрешность округления
// 
// Возвращаемое значение:
//  Число - примененная погрешность.
//
Функция УстранитьПогрешностьОкругления(Хранилище, ПогрешностьОкругления)
	
	ДоПримененияПогрешности = Хранилище; // поскольку значение имеет примитивный тип, оно будет скопировано в новую переменную
	
	Хранилище = Хранилище - ПогрешностьОкругления; // неявное округление
	
	ПримененнаяПогрешность = Хранилище - ДоПримененияПогрешности;
	ПогрешностьОкругления  = ПогрешностьОкругления + ПримененнаяПогрешность;
	
	Возврат ПримененнаяПогрешность;
	
КонецФункции

#КонецОбласти

#Область ИнвестиционныйНалоговыйВычет

Процедура ЗаписатьОтражениеИнвестиционногоВычета(Проводки, КонтекстРасчета)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Организация", КонтекстРасчета.Организация);
	Запрос.УстановитьПараметр("НачалоПериода", КонтекстРасчета.НачалоНалоговогоПериода);
	Запрос.УстановитьПараметр("КонецПериода", Новый Граница(КонтекстРасчета.КонецПериода, ВидГраницы.Включая));
	
	СубконтоХарактеристикиИНВ = Новый Массив;
	СубконтоХарактеристикиИНВ.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ХарактеристикиПримененияИНВ);	
	Запрос.УстановитьПараметр("СубконтоХарактеристикиИНВ", СубконтоХарактеристикиИНВ);

	СубконтоВариантыНОВидыАктивовИОбязательств = Новый Массив;
	СубконтоВариантыНОВидыАктивовИОбязательств.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ВариантыНалогообложенияПрибыли);	
	СубконтоВариантыНОВидыАктивовИОбязательств.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ВидыАктивовИОбязательств);	
	Запрос.УстановитьПараметр("СубконтоВариантыНОВидыАктивовИОбязательств", СубконтоВариантыНОВидыАктивовИОбязательств);

	ВидыАктивовИнвестиционныйВычет = Новый Массив;
	ВидыАктивовИнвестиционныйВычет.Добавить(Перечисления.ВидыАктивовИОбязательств.ФедеральныйИнвестиционныйВычет);	
	ВидыАктивовИнвестиционныйВычет.Добавить(Перечисления.ВидыАктивовИОбязательств.РегиональныйИнвестиционныйВычет);	
	Запрос.УстановитьПараметр("ВидыАктивовИнвестиционныйВычет", ВидыАктивовИнвестиционныйВычет);

	Запрос.Текст = ТекстЗапроса_ДанныеОНАПоИНВПеренесенномуНаБудущее();
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		СодержаниеПризнание  = НСтр("ru = 'Признание отложенного налогового актива'", ОбщегоНазначения.КодОсновногоЯзыка());
		ВидДвиженияПризнание = ВидДвиженияБухгалтерии.Дебет;
		СодержаниеПогашение  = НСтр("ru = 'Погашение отложенного налогового актива'", ОбщегоНазначения.КодОсновногоЯзыка());
		ВидДвиженияПогашение = ВидДвиженияБухгалтерии.Кредит;
		
		СуммаПризнания         = 0;
		СуммаПогашения         = 0;
		КорректировкаПризнания = 0;
		КорректировкаПогашения = 0;
				
		Если Выборка.ВычетОстаток > Выборка.ОтложенныйНалоговыйАктивОстаток Тогда
			
			// Нужно увеличить остаток на счете 09 на разницу между остатком на счете ИНФ и остатком на счете 09,
			// но, может быть, это можно сделать путем уменьшения суммы погашения налогового актива
			// текущего периода (сторнировать проводку Дт 99.02.И Кт 09).
					
			СуммаПризнания = Выборка.ВычетОстаток - Выборка.ОтложенныйНалоговыйАктивОстаток;
			
			Если Выборка.ОтложенныйНалоговыйАктивПогашенВТекущемПериоде > 0 Тогда
				КорректировкаПогашения = Мин(СуммаПризнания, Выборка.ОтложенныйНалоговыйАктивПогашенВТекущемПериоде);
				СуммаПризнания = СуммаПризнания - КорректировкаПогашения;
			КонецЕсли;
		Иначе
			// Нужно уменьшить остаток на счете 09 (сумма должна быть такой же, как на счете ИНВ),
			// но, может быть, это можно сделать путем уменьшения суммы признания налогового актива
			// текущего периода (сторнировать проводку Дт 09 Кт 99.02.И).
			
			СуммаПогашения = Выборка.ОтложенныйНалоговыйАктивОстаток - Выборка.ВычетОстаток;
			
			Если Выборка.ОтложенныйНалоговыйАктивПризнанВТекущемПериоде > 0 Тогда
				КорректировкаПризнания = Мин(СуммаПогашения, Выборка.ОтложенныйНалоговыйАктивПризнанВТекущемПериоде);
				СуммаПогашения = СуммаПогашения - КорректировкаПризнания;
			КонецЕсли;
			
		КонецЕсли;
		
		ПараметрыЗаполнения = ПараметрыЗаполненияПроводокОтложенногоНалога();
		ПараметрыЗаполнения.Проводки = Проводки;
		ПараметрыЗаполнения.Счет = ПланыСчетов.Хозрасчетный.ОтложенныеНалоговыеАктивы; 
		ПараметрыЗаполнения.КорСчет = ПланыСчетов.Хозрасчетный.ИнвестиционныйВычетПоНалогуНаПрибыль; 
		ПараметрыЗаполнения.ВидАктивовИОбязательств = Выборка.ВидАктиваОбязательства;
		ПараметрыЗаполнения.ВариантНалогообложенияПрибыли = Выборка.ВариантНалогообложенияПрибыли;
		ПараметрыЗаполнения.КонтекстРасчета = КонтекстРасчета;
		
		Если СуммаПризнания > 0 Тогда
			ПараметрыЗаполнения.Сумма = СуммаПризнания; 
			ПараметрыЗаполнения.Содержание = СодержаниеПризнание; 
			ПараметрыЗаполнения.ВидДвижения = ВидДвиженияПризнание; 
			ДобавитьПроводкуОтложенныйНалог(ПараметрыЗаполнения);
		КонецЕсли;
			
		Если СуммаПогашения > 0 Тогда
			ПараметрыЗаполнения.Сумма = СуммаПогашения; 
			ПараметрыЗаполнения.Содержание = СодержаниеПогашение; 
			ПараметрыЗаполнения.ВидДвижения = ВидДвиженияПогашение; 
			ДобавитьПроводкуОтложенныйНалог(ПараметрыЗаполнения);
			КонецЕсли;
			
		Если КорректировкаПризнания > 0 Тогда
			ПараметрыЗаполнения.Сумма = -КорректировкаПризнания; 
			ПараметрыЗаполнения.Содержание = СодержаниеПризнание; 
			ПараметрыЗаполнения.ВидДвижения = ВидДвиженияПризнание; 
			ДобавитьПроводкуОтложенныйНалог(ПараметрыЗаполнения);
		КонецЕсли;
			
		Если КорректировкаПогашения > 0 Тогда
			ПараметрыЗаполнения.Сумма = -КорректировкаПогашения; 
			ПараметрыЗаполнения.Содержание = СодержаниеПогашение; 
			ПараметрыЗаполнения.ВидДвижения = ВидДвиженияПогашение; 
			ДобавитьПроводкуОтложенныйНалог(ПараметрыЗаполнения);
		КонецЕсли;
			
	КонецЦикла;
		
КонецПроцедуры

Функция ТекстЗапроса_ДанныеОНАПоИНВПеренесенномуНаБудущее()
	
	Текст = "ВЫБРАТЬ
	|	Остатки.ВариантНалогообложенияПрибыли,
	|	Остатки.ВидАктиваОбязательства,
	|	СУММА(Остатки.ВычетОстаток) КАК ВычетОстаток,
	|	СУММА(Остатки.ОтложенныйНалоговыйАктивОстаток) КАК ОтложенныйНалоговыйАктивОстаток,
	|	СУММА(Остатки.ОтложенныйНалоговыйАктивПризнанВТекущемПериоде) КАК ОтложенныйНалоговыйАктивПризнанВТекущемПериоде,
	|	СУММА(Остатки.ОтложенныйНалоговыйАктивПогашенВТекущемПериоде) КАК ОтложенныйНалоговыйАктивПогашенВТекущемПериоде
	|ИЗ
	|	(ВЫБРАТЬ
	|		ЕСТЬNULL(Субконто1.ВариантНалогообложенияПрибыли,
	|			ЗНАЧЕНИЕ(Справочник.ВариантыНалогообложенияПрибыли.ПустаяСсылка)) КАК ВариантНалогообложенияПрибыли,
	|		ВЫБОР
	|			КОГДА ХозрасчетныйОстатки.Счет = ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.ФедеральныйИнвестиционныйНалоговыйВычет)
	|				ТОГДА ЗНАЧЕНИЕ(Перечисление.ВидыАктивовИОбязательств.ФедеральныйИнвестиционныйВычет)
	|			ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.ВидыАктивовИОбязательств.РегиональныйИнвестиционныйВычет)
	|		КОНЕЦ КАК ВидАктиваОбязательства,
	|		ХозрасчетныйОстатки.СуммаНУОстаток КАК ВычетОстаток,
	|		0 КАК ОтложенныйНалоговыйАктивОстаток,
	|		0 КАК ОтложенныйНалоговыйАктивПризнанВТекущемПериоде,
	|		0 КАК ОтложенныйНалоговыйАктивПогашенВТекущемПериоде
	|	ИЗ
	|		РегистрБухгалтерии.Хозрасчетный.Остатки(&КонецПериода, Счет В ИЕРАРХИИ (ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.ИнвестиционныйНалоговыйВычет)), &СубконтоХарактеристикиИНВ,
	|			Организация = &Организация) КАК ХозрасчетныйОстатки
	|
	|	ОБЪЕДИНИТЬ ВСЕ
	|
	|	ВЫБРАТЬ
	|		Субконто1,
	|		Субконто2,
	|		0,
	|		ХозрасчетныйОстатки.СуммаОстаток,
	|		0,
	|		0
	|	ИЗ
	|		РегистрБухгалтерии.Хозрасчетный.Остатки(&КонецПериода, Счет = ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.ОтложенныеНалоговыеАктивы),
	|			&СубконтоВариантыНОВидыАктивовИОбязательств, Организация = &Организация
	|		И Субконто2 В (&ВидыАктивовИнвестиционныйВычет)) КАК ХозрасчетныйОстатки
	|
	|	ОБЪЕДИНИТЬ ВСЕ
	|
	|	ВЫБРАТЬ
	|		Субконто1,
	|		Субконто2,
	|		0,
	|		0,
	|		ХозрасчетныйОбороты.СуммаОборотДт,
	|		ХозрасчетныйОбороты.СуммаОборотКт
	|	ИЗ
	|		РегистрБухгалтерии.Хозрасчетный.Обороты(&НачалоПериода, &КонецПериода,, Счет = ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.ОтложенныеНалоговыеАктивы),
	|			&СубконтоВариантыНОВидыАктивовИОбязательств, Организация = &Организация
	|		И Субконто2 В (&ВидыАктивовИнвестиционныйВычет),,) КАК ХозрасчетныйОбороты) КАК Остатки
	|СГРУППИРОВАТЬ ПО
	|	Остатки.ВариантНалогообложенияПрибыли,
	|	Остатки.ВидАктиваОбязательства
	|ИМЕЮЩИЕ
	|	СУММА(Остатки.ВычетОстаток) - СУММА(Остатки.ОтложенныйНалоговыйАктивОстаток) <> 0";
	
	Возврат Текст;
	
КонецФункции

Функция ИнвестиционныйНалоговыйВычетЗаПериодПоВариантамНО(КонтекстРасчета)
	
	ИнвестиционныйНалоговыйВычетЗаПериодПоВариантамНО = Новый Соответствие;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Организация", КонтекстРасчета.Организация);
	Запрос.УстановитьПараметр("НачалоПериода", КонтекстРасчета.НачалоНалоговогоПериода);
	Запрос.УстановитьПараметр("КонецПериода", Новый Граница(КонтекстРасчета.КонецПериода, ВидГраницы.Включая));
	
	СубконтоХарактеристикиИНВ = Новый Массив;
	СубконтоХарактеристикиИНВ.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ХарактеристикиПримененияИНВ);	
	Запрос.УстановитьПараметр("СубконтоХарактеристикиИНВ", СубконтоХарактеристикиИНВ);

	Запрос.Текст = ТекстЗапрос_ИнвестиционныйНалоговыйВычетЗаПериод();
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		ДанныеИНВ = ДанныеИнвестиционногоНалоговойВычетаЗаПериод();
		ЗаполнитьЗначенияСвойств(ДанныеИНВ, Выборка);
		ИнвестиционныйНалоговыйВычетЗаПериодПоВариантамНО.Вставить(Выборка.ВариантНалогообложенияПрибыли, ДанныеИНВ);
	КонецЦикла;
	
	Возврат ИнвестиционныйНалоговыйВычетЗаПериодПоВариантамНО;
	
КонецФункции

Функция ДанныеИнвестиционногоНалоговойВычетаЗаПериод()
	
	ДанныеИнвестиционногоНалоговойВычетаЗаПериод = Новый Структура;
	ДанныеИнвестиционногоНалоговойВычетаЗаПериод.Вставить("СуммаУменьшенияНалогаНаПрибыль", 0);
	ДанныеИнвестиционногоНалоговойВычетаЗаПериод.Вставить("СуммаВычетаПеренесенногоНаБудущее", 0);
	
	Возврат ДанныеИнвестиционногоНалоговойВычетаЗаПериод;
	 	
КонецФункции

Функция ТекстЗапрос_ИнвестиционныйНалоговыйВычетЗаПериод()
	
	Текст = "ВЫБРАТЬ
	|	ЕСТЬNULL(Субконто1.ВариантНалогообложенияПрибыли,
	|		ЗНАЧЕНИЕ(Справочник.ВариантыНалогообложенияПрибыли.ПустаяСсылка)) КАК ВариантНалогообложенияПрибыли,
	|	СУММА(ХозрасчетныйОбороты.СуммаНУОборотКт) КАК СуммаУменьшенияНалогаНаПрибыль,
	|	СУММА(ХозрасчетныйОбороты.СуммаНУОборотДт - ХозрасчетныйОбороты.СуммаНУОборотКт) КАК
	|		СуммаВычетаПеренесенногоНаБудущее
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.Обороты(&НачалоПериода, &КонецПериода,, Счет В ИЕРАРХИИ
	|		(ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.ИнвестиционныйНалоговыйВычет)), &СубконтоХарактеристикиИНВ,
	|		Организация = &Организация,,) КАК ХозрасчетныйОбороты
	|СГРУППИРОВАТЬ ПО
	|	ЕСТЬNULL(Субконто1.ВариантНалогообложенияПрибыли, ЗНАЧЕНИЕ(Справочник.ВариантыНалогообложенияПрибыли.ПустаяСсылка))";
	
	Возврат Текст;
	
КонецФункции

#КонецОбласти

#Область Запись

Процедура ЗаписатьИзменениеОтложенногоНалога(Проводки, ТаблицаРасчета, КонтекстРасчета)
	
	ОтдельныеПроводкиИзмененияСтавкиНалога = ОтдельныеПроводкиИзмененияСтавкиНалога(КонтекстРасчета);
	
	Если ОтдельныеПроводкиИзмененияСтавкиНалога Тогда
		
		// Эффект изменения разниц - в корреспонденции со счетом 68.04.2
		// Дт 09      Кт 68.04.2
		// Дт 68.04.2 Кт 09
		// Дт 68.04.2 Кт 77
		// Дт 77      Кт 68.04.2
		СчетРасчетаНалога = ПланыСчетов.Хозрасчетный.РасчетНалогаНаПрибыль;
		
		// Остальные эффекты - в корреспонденции со счетом 99.02.4
		// Дт 09      Кт 99.02.4
		// Дт 99.02.4 Кт 09
		// Дт 99.02.4 Кт 77
		// Дт 77      Кт 99.02.4
		СчетПересчетаОтложенногоНалога = ПланыСчетов.Хозрасчетный.ПрибылиИУбыткиОтПересчетаОНА_ОНО;
		
	Иначе
		// Р-102
		// 5 Сумма отложенного налога на прибыль отражается по дебету или кредиту счета 99 "Прибыли и убытки"
		// (субсчет "Отложенный налог на прибыль") в корреспонденции соответственно с кредитом или дебетом счетов
		// 09 "Отложенные налоговые активы" или 77 "Отложенные налоговые обязательства".
		
		СчетРасчетаНалога              = ПланыСчетов.Хозрасчетный.ОтложенныйНалогНаПрибыль;
		СчетПересчетаОтложенногоНалога = СчетРасчетаНалога; // эффект от изменения ставки на проводках не отражается
		
	КонецЕсли;
	
	ВсеКорректировки =
		КорректировкиОтложенногоНалога(ТаблицаРасчета, КонтекстРасчета, ОтдельныеПроводкиИзмененияСтавкиНалога);
		
	Корректировки = КорректировкиПоОтложенномуНалогуВДобавочномКапитале(КонтекстРасчета, ТаблицаРасчета, ОтдельныеПроводкиИзмененияСтавкиНалога);
	
	ВыделитьПроводкиПоОтложенномуНалогуВДобавочномКапитале(ВсеКорректировки, Корректировки, КонтекстРасчета, ТаблицаРасчета);	
		
	ОтборСтрокКорректировок = Новый Структура("ВариантНалогообложенияПрибыли");
	
	ВидыСубконтоВидовАктивовОбязательствВДобавочномКапитале = ВидыСубконтоВидовАктивовОбязательствВДобавочномКапитале(КонтекстРасчета);
	
	СчетаОтложенныйНалогВДобавочномКапитале = СчетаОтложенныйНалогВДобавочномКапитале(КонтекстРасчета);
	
	Для Каждого ОбщийРасчет Из ТаблицаРасчета Цикл
	
		РасчетОтложенногоНалога = ОбщийРасчет.РасчетОтложенногоНалога;
		
		ОтборСтрокКорректировок.ВариантНалогообложенияПрибыли = ОбщийРасчет.ВариантНалогообложенияПрибыли;
		
		// Учтем ранее сформированные проводки
		Корректировки = ВсеКорректировки.НайтиСтроки(ОтборСтрокКорректировок);
		
		// Представления записываются в ИБ, поэтому локализуются основным языком конфигурации.
		
		Представления = Новый Структура;
		Представления.Вставить("Увеличение", Новый Соответствие);
		Представления.Вставить("Уменьшение", Новый Соответствие);
		Представления.Вставить("Пересчет",   Новый Соответствие);
		
		СтавкаБудущегоНалога = РасчетОтложенногоНалога.СтавкиНалога[Перечисления.ВидыСтавокОтложенногоНалога.БудущийНалог];
		
		Представления.Увеличение.Вставить(
			ВидСчета.Активный,
			НСтр("ru = 'Признание отложенного налогового актива'", Метаданные.ОсновнойЯзык.КодЯзыка));
			
		Представления.Уменьшение.Вставить(
			ВидСчета.Активный,
			НСтр("ru = 'Погашение отложенного налогового актива'", Метаданные.ОсновнойЯзык.КодЯзыка));
			
		Представления.Уменьшение.Вставить(
			ВидСчета.Пассивный,
			НСтр("ru = 'Признание отложенного налогового обязательства'", Метаданные.ОсновнойЯзык.КодЯзыка));
			
		Представления.Увеличение.Вставить(
			ВидСчета.Пассивный,
			НСтр("ru = 'Погашение отложенного налогового обязательства'", Метаданные.ОсновнойЯзык.КодЯзыка));
			
		ШаблонПредставленияПересчетПоСтавке = НСтр(
			"ru = 'Пересчет %1 по ставке %2%%'",
			Метаданные.ОсновнойЯзык.КодЯзыка);
		
		ПредставлениеПересчетПоставке = СтрШаблон(
			ШаблонПредставленияПересчетПоСтавке,
			НСтр("ru = 'отложенного налогового актива'", Метаданные.ОсновнойЯзык.КодЯзыка),
			СтавкаБудущегоНалога * 100);
			
		Представления.Пересчет.Вставить(ВидСчета.Активный, ПредставлениеПересчетПоставке);
			
		ПредставлениеПересчетПоставке = СтрШаблон(
			ШаблонПредставленияПересчетПоСтавке,
			НСтр("ru = 'отложенного налогового обязательства'", Метаданные.ОсновнойЯзык.КодЯзыка),
			СтавкаБудущегоНалога * 100);
			
		Представления.Пересчет.Вставить(ВидСчета.Пассивный, ПредставлениеПересчетПоставке);
		
		// Сформируем проводки на разницу
		СчетаОтложенногоНалога = Новый Соответствие; // Кеш
		
		СодержаниеПроводокИзмененияНалогаВДобавочномКапитале = СодержаниеПроводокИзмененияНалогаВДобавочномКапитале(СтавкаБудущегоНалога);
		
		Для Каждого Корректировка Из Корректировки Цикл
			
			ВидСчетаОтложенногоНалога = СчетаОтложенногоНалога[Корректировка.Счет];
			Если ВидСчетаОтложенногоНалога = Неопределено Тогда
				ВидСчетаОтложенногоНалога = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Корректировка.Счет, "Вид");
				СчетаОтложенногоНалога.Вставить(Корректировка.Счет, ВидСчетаОтложенногоНалога);
			КонецЕсли;
			
			Если Не ЗначениеЗаполнено(ВидСчетаОтложенногоНалога) Тогда
				Продолжить;
			КонецЕсли;
			
			ЭтоОтложенныйНалогВДобавочномКапитале = 
				ЭтоОтложенныйНалогВДобавочномКапитале(СчетаОтложенныйНалогВДобавочномКапитале, Корректировка.Счет) 
				ИЛИ ЭтоОтложенныйНалогВДобавочномКапитале(СчетаОтложенныйНалогВДобавочномКапитале, Корректировка.КорСчет);
			
			ПараметрыЗаполнения = ПараметрыЗаполненияПроводокОтложенногоНалога();
			ПараметрыЗаполнения.Проводки = Проводки;
			ПараметрыЗаполнения.ВариантНалогообложенияПрибыли = ОбщийРасчет.ВариантНалогообложенияПрибыли;
			ПараметрыЗаполнения.Счет = Корректировка.Счет;
			ПараметрыЗаполнения.ВидАктивовИОбязательств = Корректировка.ВидАктивовИОбязательств;
			ПараметрыЗаполнения.КонтекстРасчета = КонтекстРасчета;
			
			ПараметрыЗаполнения.Сумма = Корректировка.УвеличениеОтложенногоНалога;
			
			Если ЭтоОтложенныйНалогВДобавочномКапитале Тогда
				ПараметрыЗаполнения.Содержание = СодержаниеПроводокИзмененияНалогаВДобавочномКапитале.Получить(Корректировка.ВидОперацииРасчетаНалога);
			Иначе
				ПараметрыЗаполнения.Содержание = Представления.Увеличение[ВидСчетаОтложенногоНалога];					
			КонецЕсли;
			
			ПараметрыЗаполнения.ВидДвижения = ВидДвиженияБухгалтерии.Дебет;
			ПараметрыЗаполнения.ВидОперацииРасчетаНалога = Корректировка.ВидОперацииРасчетаНалога;

			Если ЗначениеЗаполнено(Корректировка.КорСчет) Тогда
				ПараметрыЗаполнения.КорСчет = Корректировка.КорСчет;  
				ПараметрыЗаполнения.КорВидАктивовИОбязательств = Корректировка.ВидАктивовИОбязательств;
			Иначе			
				ПараметрыЗаполнения.КорСчет = СчетРасчетаНалога;
			КонецЕсли;
			
			Если ЗначениеЗаполнено(Корректировка.АктивОбязательство) Тогда
				ПараметрыЗаполнения.АктивОбязательство = Корректировка.АктивОбязательство;  
				ПараметрыЗаполнения.ВидСубконтоАктиваОбязательства = ВидыСубконтоВидовАктивовОбязательствВДобавочномКапитале.Получить(Корректировка.ВидАктивовИОбязательств);  
			КонецЕсли;

			ДобавитьПроводкуОтложенныйНалог(ПараметрыЗаполнения);
				
			ПараметрыЗаполнения.Сумма = -Корректировка.УменьшениеОтложенногоНалога;

			Если ЭтоОтложенныйНалогВДобавочномКапитале Тогда
				ПараметрыЗаполнения.Содержание = СодержаниеПроводокИзмененияНалогаВДобавочномКапитале.Получить(Корректировка.ВидОперацииРасчетаНалога);
			Иначе
				ПараметрыЗаполнения.Содержание = Представления.Уменьшение[ВидСчетаОтложенногоНалога];					
			КонецЕсли;

			ПараметрыЗаполнения.ВидДвижения = ВидДвиженияБухгалтерии.Кредит;
			
			ДобавитьПроводкуОтложенныйНалог(ПараметрыЗаполнения);
				
			// Все остальные эффекты, кроме основных проводок, условно относим к изменению ставки налога

			Если ЭтоОтложенныйНалогВДобавочномКапитале Тогда
				ПараметрыЗаполнения.Содержание = СодержаниеПроводокИзмененияНалогаВДобавочномКапитале.Получить(Корректировка.ВидОперацииРасчетаНалога);
			Иначе
				ПараметрыЗаполнения.Содержание = Представления.Пересчет[ВидСчетаОтложенногоНалога];					
			КонецЕсли;
				
			Если Корректировка.Пересчет > 0 Тогда
					
				ПараметрыЗаполнения.Сумма = Корректировка.Пересчет;
				ПараметрыЗаполнения.ВидДвижения = ВидДвиженияБухгалтерии.Дебет;
				
				Если НЕ ЗначениеЗаполнено(Корректировка.КорСчет) Тогда
					ПараметрыЗаполнения.КорСчет = СчетПересчетаОтложенногоНалога;
				КонецЕсли;
				
				ДобавитьПроводкуОтложенныйНалог(ПараметрыЗаполнения);
					
			ИначеЕсли Корректировка.Пересчет < 0 Тогда
					
				ПараметрыЗаполнения.Сумма = -Корректировка.Пересчет;
				ПараметрыЗаполнения.ВидДвижения = ВидДвиженияБухгалтерии.Кредит;

				Если НЕ ЗначениеЗаполнено(Корректировка.КорСчет) Тогда
					ПараметрыЗаполнения.КорСчет = СчетПересчетаОтложенногоНалога;
				КонецЕсли;
						
				ДобавитьПроводкуОтложенныйНалог(ПараметрыЗаполнения);
					
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	СформироватьПроводкиПриИзмененииВариантаНалогообложенияПрибыли(КонтекстРасчета, Проводки);
	
КонецПроцедуры

Функция СодержаниеПроводокИзмененияНалогаВДобавочномКапитале(Знач СтавкаБудущегоНалога)
	
	СодержаниеПроводок = Новый Соответствие;
		
	СодержаниеПроводки = НСтр("ru = 'Изменение налога на прибыль от операций, результат которых не включается в чистую прибыль (убыток)'",
			Метаданные.ОсновнойЯзык.КодЯзыка);			
	СодержаниеПроводок.Вставить(Перечисления.ВидыОперацийРасчетаНалога.Изменение, СодержаниеПроводки);
		
	СодержаниеПроводки = НСтр("ru = 'Списание налога на прибыль от операций, результат которых не включается в чистую прибыль (убыток)'",
			Метаданные.ОсновнойЯзык.КодЯзыка);			
	СодержаниеПроводок.Вставить(Перечисления.ВидыОперацийРасчетаНалога.Списание, СодержаниеПроводки);

	СодержаниеПроводки = НСтр("ru = 'Пересчет налога на прибыль от операций, результат которых не включается в чистую прибыль (убыток) на ставке %1%%'",
			Метаданные.ОсновнойЯзык.КодЯзыка);			
	СодержаниеПроводок.Вставить(Перечисления.ВидыОперацийРасчетаНалога.Пересчет, СтрШаблон(СодержаниеПроводки, СтавкаБудущегоНалога * 100));

	Возврат СодержаниеПроводок;
	
КонецФункции

Функция ОтдельныеПроводкиИзмененияСтавкиНалога(КонтекстРасчета)
	
	// Если текущий налог рассчитывается по данным бухгалтерского учета, то проводки по счету расчета налога
	// важно оценивать по ставке текущего налога.
	// Поэтому в проводках важно различать эффект изменения разниц и эффект изменения ставок.
	// Как следствие, из ранее сформированных проводок важно исключить проводки эффекта изменения ставок.
	
	Возврат (КонтекстРасчета.ВариантУчетаОтложенногоНалога = Перечисления.ВариантыУчетаОтложенногоНалога.БалансовыйМетодПостоянныеРазницы);
	
КонецФункции

Функция КорректировкиПоОтложенномуНалогуВДобавочномКапитале(КонтекстРасчета, ТаблицаРасчета, ОтдельныеПроводкиИзмененияСтавкиНалога)

	Корректировки = НовыйИзменениеОтложенногоНалога();
	                       
	Для Каждого ОбщийРасчет Из ТаблицаРасчета Цикл
 		ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(
			ОбщийРасчет.РасчетОтложенногоНалога.ОтложенныйНалогВДобавочномКапитале,
			Корректировки);
	КонецЦикла;                                                                              
	
	// Отдельно выделяем увеличение или уменьшение отложенного налога за счет эффекта изменения временных разниц
	Корректировки.ЗагрузитьКолонку(
		Корректировки.ВыгрузитьКолонку("ЭффектУвеличенияВременныхРазниц"),
		"УвеличениеОтложенногоНалога");
	Корректировки.ЗагрузитьКолонку(
		Корректировки.ВыгрузитьКолонку("ЭффектУменьшенияВременныхРазниц"),
		"УменьшениеОтложенногоНалога");
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ОтчетнаяДата",           КонтекстРасчета.КонецПериода + 1);
	Запрос.УстановитьПараметр("НачалоПериода",          КонтекстРасчета.НачалоНалоговогоПериода);
	Запрос.УстановитьПараметр("КонецПериода",           КонтекстРасчета.КонецПериода);
	Запрос.УстановитьПараметр("Организации",            КонтекстРасчета.Организации);
	
	СформироватьТекстЗапросаПоОтложенномуНалогуВДобавочномКапитале(Запрос, КонтекстРасчета);
	
	Если НЕ ЗначениеЗаполнено(Запрос.Текст) Тогда
		Возврат Корректировки;		
	КонецЕсли;
	
	КлючевыеПоля = "ВариантНалогообложенияПрибыли, Счет, ВидАктивовИОбязательств, АктивОбязательство";
	
	Корректировки.Индексы.Добавить(КлючевыеПоля);
	Отбор = Новый Структура(КлючевыеПоля);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		ЗаполнитьЗначенияСвойств(Отбор, Выборка);
		
		ЗаписиКорректировка = Корректировки.НайтиСтроки(Отбор);
		
		ИсправлениеОшибкиУчета = Ложь;
		Если ЗначениеЗаполнено(ЗаписиКорректировка) Тогда
			Корректировка = ЗаписиКорректировка[0];
		Иначе
			Корректировка = Корректировки.Добавить();
			ЗаполнитьЗначенияСвойств(Корректировка, Отбор);
			ИсправлениеОшибкиУчета = Истина; // Таких проводок не должно было быть
		КонецЕсли;
		
		Корректировка.ОтложенныйНалог = Корректировка.ОтложенныйНалог - Выборка.ОтложенныйНалог;
		
		Если ИсправлениеОшибкиУчета И Не ОтдельныеПроводкиИзмененияСтавкиНалога  Тогда
			
			Если Корректировка.ОтложенныйНалог > 0 Тогда
				Корректировка.УменьшениеОтложенногоНалога = Корректировка.ОтложенныйНалог;
			Иначе
				Корректировка.УвеличениеОтложенногоНалога = Корректировка.ОтложенныйНалог;
			КонецЕсли;
			
		Иначе
		
			Корректировка.УвеличениеОтложенногоНалога = Корректировка.УвеличениеОтложенногоНалога
				- Выборка.УвеличениеОтложенногоНалога;
			
			Корректировка.УменьшениеОтложенногоНалога = Корректировка.УменьшениеОтложенногоНалога
				- Выборка.УменьшениеОтложенногоНалога;
		
		КонецЕсли;
		
	КонецЦикла;
	
	Для Каждого Корректировка Из Корректировки Цикл
		
		Корректировка.Пересчет =
			  Корректировка.ОтложенныйНалог
			- Корректировка.УвеличениеОтложенногоНалога
			- Корректировка.УменьшениеОтложенногоНалога;
		
	КонецЦикла;
		
	Возврат Корректировки;
	
КонецФункции

Процедура СформироватьТекстЗапросаПоОтложенномуНалогуВДобавочномКапитале(Запрос, КонтекстРасчета)
	
	ТекстОбщегоЗапроса = ТекстЗапросаПоОтложенномуНалогуВДобавочномКапитале_ОбщийЗапрос();
	ТекстПоиска = ТекстЗапросаПоОтложенномуНалогуВДобавочномКапитале_ТекстПоиска(); 
	ШаблонФрагмента = ТекстЗапросаПоОтложенномуНалогуВДобавочномКапитале_ШаблонФрагмента(); 
	
	МассивЗапросов = Новый Массив;
	
	СчетаПоВидамАктивов = СчетаПоВидамАктивовОбязательствНалогаВДобавочномКапитале(КонтекстРасчета); 
	ВидыСубконтоВидовАктивовОбязательств = ВидыСубконтоВидовАктивовОбязательствВДобавочномКапитале(КонтекстРасчета);
	ВидыСубконтоВидОперацииРасчетаНалога = ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ВидыОперацийРасчетаНалога;
	
	ПараметрВидАктиваОбязательства = "ВидАктиваОбязательства";
	ПараметрСчетОтложенныйНалог = "СчетаОтложенныйНалог";
	ПараметрВидСубконто = "ВидыСубконто";
	
	НомерФрагмента = 1;
	
	Если СчетаПоВидамАктивов.Количество() = 0 Тогда
		Возврат;	
	КонецЕсли;
	
	Для каждого Элемент Из СчетаПоВидамАктивов Цикл
		ИмяПараметраВидАктиваОбязательства = ПараметрВидАктиваОбязательства + Строка(НомерФрагмента);  
		ТекстФрагмента = СтрЗаменить(ШаблонФрагмента, ПараметрВидАктиваОбязательства, ИмяПараметраВидАктиваОбязательства);
		
		Запрос.УстановитьПараметр(ИмяПараметраВидАктиваОбязательства, Элемент.Ключ); 
				
		ИмяПараметраСчетОтложенныйНалог = ПараметрСчетОтложенныйНалог + Строка(НомерФрагмента);  
		ТекстФрагмента = СтрЗаменить(ТекстФрагмента, ПараметрСчетОтложенныйНалог, ИмяПараметраСчетОтложенныйНалог);
		
		Запрос.УстановитьПараметр(ИмяПараметраСчетОтложенныйНалог, Элемент.Значение); 
		
		ИмяПараметраВидСубконто = ПараметрВидСубконто + Строка(НомерФрагмента);
		ТекстФрагмента = СтрЗаменить(ТекстФрагмента, ПараметрВидСубконто, ИмяПараметраВидСубконто);  
		
		ВидыСубконто = Новый Массив;                                                           	
		ВидыСубконто.Добавить(ВидыСубконтоВидовАктивовОбязательств.Получить(Элемент.Ключ));
		ВидыСубконто.Добавить(ВидыСубконтоВидОперацииРасчетаНалога);
		
		Запрос.Текст = ТекстФрагмента;
		
		РаздельныйУчетПоНалогуНаПрибыль.ОбработатьПолеВариантаНалогообложенияВЗапросе(
			Запрос,
			КонтекстРасчета.ИспользуетсяРаздельныйУчет,
			"Субконто3",
			ВидыСубконто);          
			
		Запрос.УстановитьПараметр(ИмяПараметраВидСубконто, ВидыСубконто);
		
		МассивЗапросов.Добавить(Запрос.Текст);
		НомерФрагмента = НомерФрагмента + 1;	
	КонецЦикла;	
		
	ТекстЗамены = СтрСоединить(МассивЗапросов, ОбщегоНазначенияУТ.РазделительЗапросовВОбъединении());
	
	Запрос.Текст = СтрЗаменить(ТекстОбщегоЗапроса, ТекстПоиска, ТекстЗамены);
		
КонецПроцедуры

Функция ТекстЗапросаПоОтложенномуНалогуВДобавочномКапитале_ШаблонФрагмента()

    ШаблонФрагмента = 
	"ВЫБРАТЬ
	|		&ПолеВариантНалогообложенияПрибыли КАК ВариантНалогообложенияПрибыли,
	|		&ВидАктиваОбязательства КАК ВидАктивовИОбязательств,
	|		Сальдо.Счет КАК СчетОтложенногоНалога,
	|		Сальдо.Субконто1 КАК АктивОбязательство,
	|		Сальдо.СуммаОстаток КАК ОтложенныйНалог,
	|		0 КАК УвеличениеОтложенногоНалога,
	|		0 КАК УменьшениеОтложенногоНалога
	|	ИЗ
	|		РегистрБухгалтерии.Хозрасчетный.Остатки(
	|				&ОтчетнаяДата,
	|				Счет В (&СчетаОтложенныйНалог),
	|				&ВидыСубконто,
	|				Организация В (&Организации)) КАК Сальдо
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		&ПолеВариантНалогообложенияПрибыли,
	|		&ВидАктиваОбязательства,
	|		Обороты.Счет,
	|		Обороты.Субконто1,
	|		0,
	|		Обороты.СуммаОборотДт,
	|		-Обороты.СуммаОборотКт
	|	ИЗ
	|		РегистрБухгалтерии.Хозрасчетный.Обороты(
	|				&НачалоПериода,
	|				&КонецПериода,
	|				,
	|				Счет В (&СчетаОтложенныйНалог),
	|				&ВидыСубконто,
	|				Организация В (&Организации) И Субконто2 <> ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасчетаНалога.Пересчет),
	|				,
	|				) КАК Обороты";

	Возврат ШаблонФрагмента;

КонецФункции

Функция ТекстЗапросаПоОтложенномуНалогуВДобавочномКапитале_ТекстПоиска()

	ТекстПоиска = 
	"ВЫБРАТЬ
	|		NULL КАК ВариантНалогообложенияПрибыли,
	|		NULL КАК ВидАктивовИОбязательств,
	|		NULL КАК СчетОтложенногоНалога,
	|		NULL КАК АктивОбязательство,
	|		1 КАК ОтложенныйНалог,
	|		1 КАК УвеличениеОтложенногоНалога,
	|		1 КАК УменьшениеОтложенногоНалога";
		
	Возврат ТекстПоиска;
	
КонецФункции 

Функция ТекстЗапросаПоОтложенномуНалогуВДобавочномКапитале_ОбщийЗапрос()

	ТекстОбщегоЗапроса =
	"ВЫБРАТЬ
	|	ОтраженныеДанные.ВариантНалогообложенияПрибыли КАК ВариантНалогообложенияПрибыли,
	|	ОтраженныеДанные.ВидАктивовИОбязательств КАК ВидАктивовИОбязательств,
	|	ОтраженныеДанные.СчетОтложенногоНалога КАК Счет,
	|	ОтраженныеДанные.АктивОбязательство КАК АктивОбязательство,
	|	СУММА(ОтраженныеДанные.ОтложенныйНалог) КАК ОтложенныйНалог,
	|	СУММА(ОтраженныеДанные.УвеличениеОтложенногоНалога) КАК УвеличениеОтложенногоНалога,
	|	СУММА(ОтраженныеДанные.УменьшениеОтложенногоНалога) КАК УменьшениеОтложенногоНалога
	|ИЗ
	|	(ВЫБРАТЬ
	|		NULL КАК ВариантНалогообложенияПрибыли,
	|		NULL КАК ВидАктивовИОбязательств,
	|		NULL КАК СчетОтложенногоНалога,
	|		NULL КАК АктивОбязательство,
	|		1 КАК ОтложенныйНалог,
	|		1 КАК УвеличениеОтложенногоНалога,
	|		1 КАК УменьшениеОтложенногоНалога) КАК ОтраженныеДанные
	|
	|СГРУППИРОВАТЬ ПО
	|	ОтраженныеДанные.ВариантНалогообложенияПрибыли,
	|	ОтраженныеДанные.ВидАктивовИОбязательств,
	|	ОтраженныеДанные.СчетОтложенногоНалога,
	|	ОтраженныеДанные.АктивОбязательство
	|
	|УПОРЯДОЧИТЬ ПО
	|	ОтраженныеДанные.ВариантНалогообложенияПрибыли,
	|	Счет,
	|	АктивОбязательство";   

	Возврат ТекстОбщегоЗапроса; 

КонецФункции

Функция КорректировкиОтложенногоНалога(ТаблицаРасчета, КонтекстРасчета, ОтдельныеПроводкиИзмененияСтавкиНалога)
	
	Корректировки = НовыйИзменениеОтложенногоНалога();
	
	// Заполним таблицу корректировок данными сразу по всем вариантам н/о
	Для Каждого ОбщийРасчет Из ТаблицаРасчета Цикл
		ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(
			ОбщийРасчет.РасчетОтложенногоНалога.ОтложенныйНалог,
			Корректировки);
	КонецЦикла;
	
	ВидыСубконто = Новый Массив;
	ВидыСубконто.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ВидыАктивовИОбязательств);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("СчетаОтложенныйНалог",   СчетаОтложенныйНалог());
	Запрос.УстановитьПараметр("НеиспользованныеАктивы", Перечисления.ВидыАктивовИОбязательств.НеиспользованныеНалоговыеУбыткиВычеты());
	Запрос.УстановитьПараметр("ОтчетнаяДата",           КонтекстРасчета.КонецПериода + 1);
	Запрос.УстановитьПараметр("НачалоПериода",          КонтекстРасчета.НачалоНалоговогоПериода);
	Запрос.УстановитьПараметр("КонецПериода",           КонтекстРасчета.КонецПериода);
	Запрос.УстановитьПараметр("Организации",            КонтекстРасчета.Организации);
	Запрос.УстановитьПараметр("ВидыСубконто",           ВидыСубконто);
	
	Запрос.Текст = // Текст запроса может быть модифицирован - добавляется отбор по кор.счету в запрос ОтраженныеДанные.Обороты
	"ВЫБРАТЬ
	|	ОтраженныеДанные.ВариантНалогообложенияПрибыли КАК ВариантНалогообложенияПрибыли,
	|	ОтраженныеДанные.СчетОтложенногоНалога КАК Счет,
	|	ОтраженныеДанные.ВидАктивовИОбязательств КАК ВидАктивовИОбязательств,
	|	СУММА(ОтраженныеДанные.ОтложенныйНалог) КАК ОтложенныйНалог,
	|	СУММА(ОтраженныеДанные.УвеличениеОтложенногоНалога) КАК УвеличениеОтложенногоНалога,
	|	СУММА(ОтраженныеДанные.УменьшениеОтложенногоНалога) КАК УменьшениеОтложенногоНалога
	|ИЗ
	|	(ВЫБРАТЬ
	|		&ПолеВариантНалогообложенияПрибыли КАК ВариантНалогообложенияПрибыли,
	|		Сальдо.Счет КАК СчетОтложенногоНалога,
	|		Сальдо.Субконто1 КАК ВидАктивовИОбязательств,
	|		Сальдо.СуммаОстаток КАК ОтложенныйНалог,
	|		0 КАК УвеличениеОтложенногоНалога,
	|		0 КАК УменьшениеОтложенногоНалога
	|	ИЗ
	|		РегистрБухгалтерии.Хозрасчетный.Остатки(
	|				&ОтчетнаяДата,
	|				Счет В (&СчетаОтложенныйНалог),
	|				&ВидыСубконто,
	|				Организация В (&Организации)
	|					И НЕ Субконто1 В (&НеиспользованныеАктивы)) КАК Сальдо
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		&ПолеВариантНалогообложенияПрибыли,
	|		Обороты.Счет,
	|		Обороты.Субконто1,
	|		0,
	|		Обороты.СуммаОборотДт,
	|		-Обороты.СуммаОборотКт
	|	ИЗ
	|		РегистрБухгалтерии.Хозрасчетный.Обороты(
	|				&НачалоПериода,
	|				&КонецПериода,
	|				,
	|				Счет В (&СчетаОтложенныйНалог),
	|				&ВидыСубконто,
	|				Организация В (&Организации)
	|					И НЕ Субконто1 В (&НеиспользованныеАктивы),
	|				,
	|				) КАК Обороты) КАК ОтраженныеДанные
	|
	|СГРУППИРОВАТЬ ПО
	|	ОтраженныеДанные.ВариантНалогообложенияПрибыли,
	|	ОтраженныеДанные.СчетОтложенногоНалога,
	|	ОтраженныеДанные.ВидАктивовИОбязательств
	|
	|УПОРЯДОЧИТЬ ПО
	|	ОтраженныеДанные.ВариантНалогообложенияПрибыли,
	|	Счет,
	|	ВидАктивовИОбязательств";
	
	РаздельныйУчетПоНалогуНаПрибыль.ОбработатьПолеВариантаНалогообложенияВЗапросе(
		Запрос,
		КонтекстРасчета.ИспользуетсяРаздельныйУчет,
		"Субконто2",
		ВидыСубконто);
	
	Если ОтдельныеПроводкиИзмененияСтавкиНалога Тогда
		
		// Отдельно выделяем увеличение или уменьшение отложенного налога за счет эффекта изменения временных разниц
		Корректировки.ЗагрузитьКолонку(
			Корректировки.ВыгрузитьКолонку("ЭффектУвеличенияВременныхРазниц"),
			"УвеличениеОтложенногоНалога");
		Корректировки.ЗагрузитьКолонку(
			Корректировки.ВыгрузитьКолонку("ЭффектУменьшенияВременныхРазниц"),
			"УменьшениеОтложенногоНалога");
		
		// Ограничиваем выборку проводок только корреспонденциями со счетом расчета налога
		
		Запрос.УстановитьПараметр("СчетРасчетаНалога", ПланыСчетов.Хозрасчетный.РасчетНалогаНаПрибыль);
		Запрос.УстановитьПараметр("СчетаОтложенныйНалогВДобавочномКапитале", СчетаОтложенныйНалогВДобавочномКапитале(КонтекстРасчета));
		
		СхемаЗапроса = Новый СхемаЗапроса;
		СхемаЗапроса.УстановитьТекстЗапроса(Запрос.Текст);
		Для Каждого ОписаниеЗапроса Из СхемаЗапроса.ПакетЗапросов Цикл
			
			Если ТипЗнч(ОписаниеЗапроса) <> Тип("ЗапросВыбораСхемыЗапроса") Тогда
				Продолжить;
			КонецЕсли;
			
			Для Каждого ОператорГруппировки Из ОписаниеЗапроса.Операторы Цикл
				
				ЗапросГруппировки = ОператорГруппировки.Источники.НайтиПоПсевдониму("ОтраженныеДанные"); // содержит ВложенныйЗапросСхемыЗапроса в Источник
				
				Если ЗапросГруппировки = Неопределено Тогда
					Продолжить;
				КонецЕсли;
				
				Для Каждого ОператорЗапроса Из ЗапросГруппировки.Источник.Запрос.Операторы Цикл
					
					ТаблицаОбороты = ОператорЗапроса.Источники.НайтиПоПсевдониму("Обороты");
					
					Если ТаблицаОбороты = Неопределено Тогда
						Продолжить;
					КонецЕсли;
					
					// Параметры виртуальной таблицы Обороты регистра бухгалтерии:
					// НачалоПериода, КонецПериода, Периодичность, УсловиеСчета, Субконто, Условие, УсловиеКорСчета, КорСубконто
					ИндексПараметраУсловиеКорСчета = 6;
					
					ОтборКорСчет = "КорСчет = &СчетРасчетаНалога ИЛИ КорСчет В (&СчетаОтложенныйНалогВДобавочномКапитале)";
					ТаблицаОбороты.Источник.Параметры[ИндексПараметраУсловиеКорСчета].Выражение = Новый ВыражениеСхемыЗапроса(ОтборКорСчет);
					
				КонецЦикла;
				
			КонецЦикла;
			
		КонецЦикла;
		
		Запрос.Текст = СхемаЗапроса.ПолучитьТекстЗапроса();
		
	КонецЕсли;
	
	КлючевыеПоля = "ВариантНалогообложенияПрибыли, Счет, ВидАктивовИОбязательств";
	
	Корректировки.Индексы.Добавить(КлючевыеПоля);
	Отбор = Новый Структура(КлючевыеПоля);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		ЗаполнитьЗначенияСвойств(Отбор, Выборка);
		
		ЗаписиКорректировка = Корректировки.НайтиСтроки(Отбор);
		
		ИсправлениеОшибкиУчета = Ложь;
		Если ЗначениеЗаполнено(ЗаписиКорректировка) Тогда
			Корректировка = ЗаписиКорректировка[0];
		Иначе
			Корректировка = Корректировки.Добавить();
			ЗаполнитьЗначенияСвойств(Корректировка, Отбор);
			ИсправлениеОшибкиУчета = Истина; // Таких проводок не должно было быть
		КонецЕсли;
		
		Корректировка.ОтложенныйНалог = Корректировка.ОтложенныйНалог - Выборка.ОтложенныйНалог;
		
		Если ИсправлениеОшибкиУчета И Не ОтдельныеПроводкиИзмененияСтавкиНалога Тогда
			
			// Сторнируем ранее сформированные проводки.
			// Если ОтдельныеПроводкиИзмененияСтавкиНалога, то так делать не следует,
			// поскольку эта ошибка могла быть отражена в корреспонденции со счетом пересчета при изменении ставки.
			Если Корректировка.ОтложенныйНалог > 0 Тогда
				Корректировка.УменьшениеОтложенногоНалога = Корректировка.ОтложенныйНалог;
			Иначе
				Корректировка.УвеличениеОтложенногоНалога = Корректировка.ОтложенныйНалог;
			КонецЕсли;
			
		Иначе
		
			Корректировка.УвеличениеОтложенногоНалога = Корректировка.УвеличениеОтложенногоНалога
				- Выборка.УвеличениеОтложенногоНалога;
			
			Корректировка.УменьшениеОтложенногоНалога = Корректировка.УменьшениеОтложенногоНалога
				- Выборка.УменьшениеОтложенногоНалога;
		
		КонецЕсли;
		
	КонецЦикла;
	
	Для Каждого Корректировка Из Корректировки Цикл
		
		Корректировка.Пересчет =
			  Корректировка.ОтложенныйНалог
			- Корректировка.УвеличениеОтложенногоНалога
			- Корректировка.УменьшениеОтложенногоНалога;
		
	КонецЦикла;
	
	Возврат Корректировки;
	
КонецФункции

// Добавляет проводки по отложенному налогу в регистр бухгалтерии Хозрасчетный
//
// Параметры:
//  ПараметрыЗаполнения - Структруа - см.ПараметрыЗаполненияПроводокОтложенногоНалога.
//
Процедура ДобавитьПроводкуОтложенныйНалог(ПараметрыЗаполнения)
	
	Если ПараметрыЗаполнения.Сумма = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Проводки = ПараметрыЗаполнения.Проводки;
	ВидДвижения = ПараметрыЗаполнения.ВидДвижения;
	Счет = ПараметрыЗаполнения.Счет;
	АктивОбязательство = ПараметрыЗаполнения.АктивОбязательство;
	ВидСубконтоАктиваОбязательства = ПараметрыЗаполнения.ВидСубконтоАктиваОбязательства;
	ВидОперацииРасчетаНалога = ПараметрыЗаполнения.ВидОперацииРасчетаНалога;
	КорСчет = ПараметрыЗаполнения.КорСчет;
	КорВидАктивовИОбязательств = ПараметрыЗаполнения.КорВидАктивовИОбязательств;
	КонтекстРасчета = ПараметрыЗаполнения.КонтекстРасчета;
			
	Проводки.Записывать = Истина;
			
	Проводка = Проводки.Добавить();
	Проводка.Период      = КонтекстРасчета.КонецПериода;
	Проводка.Организация = КонтекстРасчета.Организация;
	Проводка.Сумма       = ПараметрыЗаполнения.Сумма;
	Проводка.Содержание  = ПараметрыЗаполнения.Содержание;
	
	СвойстваСчета = БухгалтерскийУчетВызовСервераПовтИсп.ПолучитьСвойстваСчета(Счет);
	
	Если ВидДвижения = ВидДвиженияБухгалтерии.Дебет Тогда
		
		Проводка.СчетДт = Счет;
		Проводка.СчетКт = КорСчет;
		
		БухгалтерскийУчет.УстановитьСубконто(
			Проводка.СчетДт,
			Проводка.СубконтоДт,
			ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ВидыАктивовИОбязательств,
			ПараметрыЗаполнения.ВидАктивовИОбязательств);   
						
		Если ЗначениеЗаполнено(КорВидАктивовИОбязательств) Тогда
			БухгалтерскийУчет.УстановитьСубконто(
				Проводка.СчетКт,
				Проводка.СубконтоКт,
				ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ВидыАктивовИОбязательств,
				КорВидАктивовИОбязательств);   
		КонецЕсли;

		Если СвойстваСчета.Валютный Тогда
			ВалютаРеглУчета = Константы.ВалютаРегламентированногоУчета.Получить();
			Проводка.ВалютаДт = ВалютаРеглУчета;
			Проводка.ВалютнаяСуммаДт = Проводка.Сумма;
		КонецЕсли;
			
	Иначе
		
		Проводка.СчетДт = КорСчет;
		Проводка.СчетКт = Счет;
		
		БухгалтерскийУчет.УстановитьСубконто(
			Проводка.СчетКт,
			Проводка.СубконтоКт,
			ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ВидыАктивовИОбязательств,
			ПараметрыЗаполнения.ВидАктивовИОбязательств);
			
		Если ЗначениеЗаполнено(КорВидАктивовИОбязательств) Тогда
			БухгалтерскийУчет.УстановитьСубконто(
				Проводка.СчетДт,
				Проводка.СубконтоДт,
				ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ВидыАктивовИОбязательств,
				КорВидАктивовИОбязательств);   
		КонецЕсли;
			
		Если СвойстваСчета.Валютный Тогда
			ВалютаРеглУчета = Константы.ВалютаРегламентированногоУчета.Получить();
			Проводка.ВалютаКт = ВалютаРеглУчета;
			Проводка.ВалютнаяСуммаКт = Проводка.Сумма;
		КонецЕсли;
			
	КонецЕсли;
			
	Если ЗначениеЗаполнено(АктивОбязательство) Тогда
		БухгалтерскийУчет.УстановитьСубконто(
			Проводка.СчетДт,
			Проводка.СубконтоДт,
			ВидСубконтоАктиваОбязательства,
			АктивОбязательство);   
		БухгалтерскийУчет.УстановитьСубконто(
			Проводка.СчетКт,
			Проводка.СубконтоКт,
			ВидСубконтоАктиваОбязательства,
			АктивОбязательство);   
	КонецЕсли; 
	
	Если ЗначениеЗаполнено(ВидОперацииРасчетаНалога) Тогда
		БухгалтерскийУчет.УстановитьСубконто(
			Проводка.СчетДт,
			Проводка.СубконтоДт,
			ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ВидыОперацийРасчетаНалога,
			ВидОперацииРасчетаНалога);   
		БухгалтерскийУчет.УстановитьСубконто(
			Проводка.СчетКт,
			Проводка.СубконтоКт,
			ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ВидыОперацийРасчетаНалога,
			ВидОперацииРасчетаНалога);   
	КонецЕсли; 
	
	БухгалтерскийУчет.УстановитьСубконто(
		Проводка.СчетДт,
		Проводка.СубконтоДт,
		ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ВариантыНалогообложенияПрибыли,
		ПараметрыЗаполнения.ВариантНалогообложенияПрибыли);
	
	БухгалтерскийУчет.УстановитьСубконто(
		Проводка.СчетКт,
		Проводка.СубконтоКт,
		ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ВариантыНалогообложенияПрибыли,
		ПараметрыЗаполнения.ВариантНалогообложенияПрибыли);
	
КонецПроцедуры

Функция ТекстЗапроса_ВыбывшиеВНАСДооценкой()

	Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
    |	СтоимостьОС.ОсновноеСредство КАК ОбъектВНА
    |ИЗ
    |	РегистрНакопления.СтоимостьОС КАК СтоимостьОС
    |ГДЕ
    |	СтоимостьОС.Период МЕЖДУ &ДатаНачала И &ДатаОкончания
    |	И СтоимостьОС.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.СписаниеРезерваПереоценкиСтоимостиОС)
	|	И СтоимостьОС.Организация В (&Организации)
    |
    |ОБЪЕДИНИТЬ ВСЕ
    |
    |ВЫБРАТЬ РАЗЛИЧНЫЕ
    |	СтоимостьНМА.НематериальныйАктив
    |ИЗ
    |	РегистрНакопления.СтоимостьНМА КАК СтоимостьНМА
    |ГДЕ
    |	СтоимостьНМА.Период МЕЖДУ &ДатаНачала И &ДатаОкончания
    |	И СтоимостьНМА.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.СписаниеРезерваПереоценкиСтоимостиНМА)
	|	И СтоимостьНМА.Организация В (&Организации)";
	
	Возврат Текст;		
 		
КонецФункции

Процедура ЗаполнитьЭффектВключенияСуммыОперацииВНераспределеннуюПрибыль(СоответствиеРасчетов, ЭффектВключенияСуммыОперацииВНераспределеннуюПрибыльПоВНА,
	Знач АктивОбязательство, Знач ВариантНалогообложенияПрибыли, Знач ЭффектВключенияСуммыОперацииВНераспределеннуюПрибыль)
	
	РасчетОтложенногоНалога = СоответствиеРасчетов.Получить(ВариантНалогообложенияПрибыли);
	
	Если РасчетОтложенногоНалога = Неопределено Тогда
		Возврат;	
	КонецЕсли;
	
	СтрокаВременныхРазниц = РасчетОтложенногоНалога.СтрокиРазницНалогаВДобавочномКапиталеПоВыбывшимВНА.Получить(АктивОбязательство);
	
	Если СтрокаВременныхРазниц = Неопределено Тогда
		Возврат;	
	КонецЕсли;
		
	ЭффектСНачалаПериода = ЭффектВключенияСуммыОперацииВНераспределеннуюПрибыльПоВНА.Получить(АктивОбязательство);
	
	Если ЭффектСНачалаПериода = Неопределено Тогда
		ЭффектСНачалаПериода = 0;	
	КонецЕсли;
	
	ЭффектЗаВесьПериод = ЭффектВключенияСуммыОперацииВНераспределеннуюПрибыль + ЭффектСНачалаПериода;
	
	СтрокаВременныхРазниц.ЭффектВключенияСуммыОперацииВНераспределеннуюПрибыль = ЭффектЗаВесьПериод;
	
	Если СтрокаВременныхРазниц.ЭффектУменьшенияВременныхРазниц > ЭффектЗаВесьПериод Тогда
		СтрокаВременныхРазниц.ЭффектУвеличенияВременныхРазниц = СтрокаВременныхРазниц.ЭффектУвеличенияВременныхРазниц 
			+ (СтрокаВременныхРазниц.ЭффектУменьшенияВременныхРазниц - ЭффектЗаВесьПериод);
		СтрокаВременныхРазниц.ЭффектУменьшенияВременныхРазниц = ЭффектЗаВесьПериод;	
	КонецЕсли;
			
	СтрокаНалогаВДобавочномКапитале = СтрокаНалогаВДобавочномКапитале(РасчетОтложенногоНалога.ОтложенныйНалогВДобавочномКапитале, 
		СтрокаВременныхРазниц, АктивОбязательство);
		
	Если ЗначениеЗаполнено(СтрокаНалогаВДобавочномКапитале) Тогда
		СтрокаНалогаВДобавочномКапитале.ЭффектВключенияСуммыОперацииВНераспределеннуюПрибыль = ЭффектЗаВесьПериод;	
	КонецЕсли;
	
КонецПроцедуры

Функция СтрокаНалогаВДобавочномКапитале(ОтложенныйНалогВДобавочномКапитале, СтрокаВременныхРазниц, АктивОбязательство)
	
	СтрокаНалогаВДобавочномКапитале = Неопределено;
	
	Отбор = Новый Структура;
	Отбор.Вставить("Счет", СтрокаВременныхРазниц.СчетОтложенногоНалога);
	Отбор.Вставить("АктивОбязательство", АктивОбязательство);
	Отбор.Вставить("ВидАктивовИОбязательств", СтрокаВременныхРазниц.ВидАктивовИОбязательств);
	
	Строки = ОтложенныйНалогВДобавочномКапитале.НайтиСтроки(Отбор);
	
	Если Строки.Количество() > 0 Тогда
		СтрокаНалогаВДобавочномКапитале = Строки[0];	
	КонецЕсли;
	
	Возврат СтрокаНалогаВДобавочномКапитале;
	
КонецФункции

Функция ЭффектВключенияСуммыОперацииВНераспределеннуюПрибыльПоВНА(КонтекстРасчета, ТаблицаРасчета)
	
	ДанныеЭффекта = Новый Соответствие;
	
	СтрокиВыбывшихВНА = ЗакрытиеМесяца.НовыйЗаписиВспомогательногоРегистраСведений(Метаданные.РегистрыСведений.РасчетОтложенногоНалога);
	
	ТипыВНА = Новый Массив;
	ТипыВНА.Добавить(Тип("СправочникСсылка.ОбъектыЭксплуатации"));
	ТипыВНА.Добавить(Тип("СправочникСсылка.НематериальныеАктивы"));
	
	СтрокиВыбывшихВНА.Колонки.Добавить("ОбъектВНА", Новый ОписаниеТипов(ТипыВНА));
	
	НачалоМесяца = НачалоМесяца(КонтекстРасчета.КонецПериода);
	НачалоНалоговогоПериода = КонтекстРасчета.НачалоНалоговогоПериода;
	Организация = КонтекстРасчета.Организация;

	Если Месяц(НачалоМесяца) = 1 Тогда
		Возврат ДанныеЭффекта;	
	КонецЕсли;	
	
	Для Каждого ОбщийРасчет Из ТаблицаРасчета Цикл
		Для Каждого ДанныеСтроки Из ОбщийРасчет.РасчетОтложенногоНалога.СтрокиРазницНалогаВДобавочномКапиталеПоВыбывшимВНА Цикл
			НоваяСтрока = СтрокиВыбывшихВНА.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ДанныеСтроки.Значение);
			НоваяСтрока.ОбъектВНА = ДанныеСтроки.Ключ;	
		КонецЦикла;
	КонецЦикла;

	ПредыдущаяОтчетнаяДатаРасчетаОтложенногоНалога = РегистрыСведений.РасчетОтложенногоНалога.ПредыдущаяОтчетнаяДатаРасчета(Организация, 
		НачалоНалоговогоПериода, НачалоМесяца);
	
	ПериодРасчета = РегистрыСведений.РасчетОтложенногоНалога.ПериодРасчета(ПредыдущаяОтчетнаяДатаРасчетаОтложенногоНалога,
		Организация, КонецГода(НачалоНалоговогоПериода));
		
	Если НЕ ЗначениеЗаполнено(ПериодРасчета) Тогда
		Возврат ДанныеЭффекта;	
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса_ЭффектВключенияСуммыОперацииВНераспределеннуюПрибыльПоВНА();
	Запрос.УстановитьПараметр("СтрокиВыбывшихВНА", СтрокиВыбывшихВНА);
	Запрос.УстановитьПараметр("ОтчетнаяДата", ПредыдущаяОтчетнаяДатаРасчетаОтложенногоНалога);
	Запрос.УстановитьПараметр("ПериодРасчета", ПериодРасчета);
	Запрос.УстановитьПараметр("Организация", КонтекстРасчета.Организация);

	Результат = Запрос.Выполнить();
	
	Если Результат.Пустой() Тогда
		Возврат ДанныеЭффекта;	
	КонецЕсли;

	Выборка = Результат.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		ДанныеЭффекта.Вставить(Выборка.ОбъектВНА, Выборка.ЭффектВключенияСуммыОперацииВНераспределеннуюПрибыль);	
	КонецЦикла;
	
	Возврат ДанныеЭффекта;
	
КонецФункции

Функция ТекстЗапроса_ЭффектВключенияСуммыОперацииВНераспределеннуюПрибыльПоВНА()

	Текст = "
	|ВЫБРАТЬ
	|	ВТ_СтрокиВыбывшихВНА.ВариантНалогообложенияПрибыли,
	|	ВТ_СтрокиВыбывшихВНА.ВидАктивовИОбязательств,
	|	ВТ_СтрокиВыбывшихВНА.НаправлениеДеятельности,
	|	ВТ_СтрокиВыбывшихВНА.Подразделение,
	|	ВТ_СтрокиВыбывшихВНА.Субконто1,
	|	ВТ_СтрокиВыбывшихВНА.Субконто2,
	|	ВТ_СтрокиВыбывшихВНА.Субконто3,
	|	ВТ_СтрокиВыбывшихВНА.Счет,
	|	ВТ_СтрокиВыбывшихВНА.СчетОтложенногоНалога,
	|	ВТ_СтрокиВыбывшихВНА.Филиал,
	|	ВТ_СтрокиВыбывшихВНА.ОбъектВНА
	|ПОМЕСТИТЬ ВТ
	|ИЗ
	|	&СтрокиВыбывшихВНА КАК ВТ_СтрокиВыбывшихВНА
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РасчетОтложенногоНалога.ВариантНалогообложенияПрибыли,
	|	РасчетОтложенногоНалога.СчетОтложенногоНалога,
	|	РасчетОтложенногоНалога.ВидАктивовИОбязательств,
	|	РасчетОтложенногоНалога.Счет,
	|	РасчетОтложенногоНалога.Филиал,
	|	РасчетОтложенногоНалога.Подразделение,
	|	РасчетОтложенногоНалога.НаправлениеДеятельности,
	|	РасчетОтложенногоНалога.Субконто1,
	|	РасчетОтложенногоНалога.Субконто2,
	|	РасчетОтложенногоНалога.Субконто3,
	|	РасчетОтложенногоНалога.ЭффектВключенияСуммыОперацииВНераспределеннуюПрибыль
	|ПОМЕСТИТЬ ВТ_ЭффектВключенияСуммыОперацииВНераспределеннуюПрибыль
	|ИЗ
	|	РегистрСведений.РасчетОтложенногоНалога КАК РасчетОтложенногоНалога
	|ГДЕ
	|	РасчетОтложенногоНалога.ОтчетнаяДата = &ОтчетнаяДата
	|	И РасчетОтложенногоНалога.Организация = &Организация
	|	И РасчетОтложенногоНалога.ПериодРасчета = &ПериодРасчета
	|	И (РасчетОтложенногоНалога.ВариантНалогообложенияПрибыли, РасчетОтложенногоНалога.СчетОтложенногоНалога,
	|		РасчетОтложенногоНалога.ВидАктивовИОбязательств, РасчетОтложенногоНалога.Счет, РасчетОтложенногоНалога.Филиал,
	|		РасчетОтложенногоНалога.Подразделение, РасчетОтложенногоНалога.НаправлениеДеятельности,
	|		РасчетОтложенногоНалога.Субконто1, РасчетОтложенногоНалога.Субконто2, РасчетОтложенногоНалога.Субконто3) В
	|		(ВЫБРАТЬ
	|			ВариантНалогообложенияПрибыли,
	|			СчетОтложенногоНалога,
	|			ВидАктивовИОбязательств,
	|			Счет,
	|			Филиал,
	|			Подразделение,
	|			НаправлениеДеятельности,
	|			Субконто1,
	|			Субконто2,
	|			Субконто3
	|		ИЗ
	|			ВТ)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ.ОбъектВНА,
	|	ЕСТЬNULL(ВТ_ЭффектВключенияСуммыОперацииВНераспределеннуюПрибыль.ЭффектВключенияСуммыОперацииВНераспределеннуюПрибыль,
	|		0) КАК ЭффектВключенияСуммыОперацииВНераспределеннуюПрибыль
	|ИЗ
	|	ВТ КАК ВТ
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ЭффектВключенияСуммыОперацииВНераспределеннуюПрибыль КАК
	|			ВТ_ЭффектВключенияСуммыОперацииВНераспределеннуюПрибыль
	|		ПО ВТ.ВариантНалогообложенияПрибыли = ВТ_ЭффектВключенияСуммыОперацииВНераспределеннуюПрибыль.ВариантНалогообложенияПрибыли
	|		И ВТ.ВидАктивовИОбязательств = ВТ_ЭффектВключенияСуммыОперацииВНераспределеннуюПрибыль.ВидАктивовИОбязательств
	|		И ВТ.НаправлениеДеятельности = ВТ_ЭффектВключенияСуммыОперацииВНераспределеннуюПрибыль.НаправлениеДеятельности
	|		И ВТ.Подразделение = ВТ_ЭффектВключенияСуммыОперацииВНераспределеннуюПрибыль.Подразделение
	|		И ВТ.Субконто1 = ВТ_ЭффектВключенияСуммыОперацииВНераспределеннуюПрибыль.Субконто1
	|		И ВТ.Субконто2 = ВТ_ЭффектВключенияСуммыОперацииВНераспределеннуюПрибыль.Субконто2
	|		И ВТ.Субконто3 = ВТ_ЭффектВключенияСуммыОперацииВНераспределеннуюПрибыль.Субконто3
	|		И ВТ.Счет = ВТ_ЭффектВключенияСуммыОперацииВНераспределеннуюПрибыль.Счет
	|		И ВТ.СчетОтложенногоНалога = ВТ_ЭффектВключенияСуммыОперацииВНераспределеннуюПрибыль.СчетОтложенногоНалога
	|		И ВТ.Филиал = ВТ_ЭффектВключенияСуммыОперацииВНераспределеннуюПрибыль.Филиал";
	
	Возврат Текст;
		
КонецФункции

Функция НакопленныйНалогДооценкиПоВыбывшимВНА(КонтекстРасчета, ТаблицаРасчета)
	
	НакопленныйНалогДооценкиПоВыбывшимВНА = Новый Соответствие;
	
	Если КонтекстРасчета.ВыбывшиеВНАСДооценкой.Количество() = 0 
		ИЛИ КонтекстРасчета.ПараметрыУчетаОтложенногоНалогаВДобавочномКапитале.Количество() = 0 Тогда
		Возврат НакопленныйНалогДооценкиПоВыбывшимВНА;
	КонецЕсли;	
	
	СтавкиТекущегоНалога = СтавкиТекущегоНалогаПоВариантамНалогообложенияПрибыли(ТаблицаРасчета);
	
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;  
	
	СоздатьВТОстатокНакопленнойДооценки(МенеджерВременныхТаблиц, КонтекстРасчета);

	НастройкиНалогообложенияПрибыли(
		МенеджерВременныхТаблиц,
		КонтекстРасчета.НачалоНалоговогоПериода,
		КонтекстРасчета.ИспользуетсяРаздельныйУчет,
		Ложь);
	
	Запрос = Новый Запрос; 
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст = ТекстЗапроса_НакопленныйНалогДооценкиПоВыбывшимВНА();
			
	РаздельныйУчетПоНалогуНаПрибыль.ОбработатьПолеВариантНалогообложенияПоУмолчаниюВЗапросе(
		Запрос, КонтекстРасчета.ИспользуетсяРаздельныйУчет);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
	 	СтавкаНалога = СтавкиТекущегоНалога.Получить(Выборка.ВариантНалогообложенияПрибыли);
		
		Если СтавкаНалога = Неопределено Тогда
			Продолжить;
		КонецЕсли;	
		
		Налог = Окр(Выборка.СуммаВР * СтавкаНалога, 2);
		
		НакопленныйНалогДооценкиПоВыбывшимВНА.Вставить(Выборка.ОбъектВНА, Налог);	
	КонецЦикла;

	Возврат НакопленныйНалогДооценкиПоВыбывшимВНА;
	
КонецФункции

Функция СтавкиТекущегоНалогаПоВариантамНалогообложенияПрибыли(ТаблицаРасчета)

	 СтавкиТекущегоНалога = Новый Соответствие;
	 
	 Для каждого ОбщийРасчет Из ТаблицаРасчета Цикл
		 Расчет = ОбщийРасчет.РасчетОтложенногоНалога;
		 СтавкиТекущегоНалога.Вставить(Расчет.ВариантНалогообложенияПрибыли, Расчет.СтавкиНалога[Перечисления.ВидыСтавокОтложенногоНалога.ТекущийНалог]);
	 КонецЦикла;
	 
	 Возврат СтавкиТекущегоНалога;
	 
КонецФункции

Функция ТекстЗапроса_НакопленныйНалогДооценкиПоВыбывшимВНА()
	
	Текст = 
	"ВЫБРАТЬ
	|	ЕСТЬNULL(НастройкиНалогообложения.ВариантНалогообложенияПрибыли, &ПолеВариантНалогообложенияПоУмолчанию) КАК ВариантНалогообложенияПрибыли,
	|	БалансовыеДанные.ОбъектВНА КАК ОбъектВНА,
	|	БалансовыеДанные.СуммаВР КАК СуммаВР
	|ИЗ
	|	ВТ_БалансовыеДанные КАК БалансовыеДанные
	|		ЛЕВОЕ СОЕДИНЕНИЕ НастройкиНалогообложения КАК НастройкиНалогообложения
	|		ПО БалансовыеДанные.Подразделение = НастройкиНалогообложения.Подразделение
	|			И БалансовыеДанные.НаправлениеДеятельности = НастройкиНалогообложения.НаправлениеДеятельности";
		
	Возврат Текст;
	
КонецФункции

Процедура СоздатьВТОстатокНакопленнойДооценки(МенеджерВременныхТаблиц, КонтекстРасчета)

	Запрос = Новый Запрос;	
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст = ТекстЗапроса_СоздатьВТОстатокНакопленнойДооценки();
	
	ВидСубконтоОС = ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ОсновныеСредства;
	ВидСубконтоНМА = ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.НематериальныеАктивы;
	
	ВидыСубконтоОС = Новый Массив;
	ВидыСубконтоОС.Добавить(ВидСубконтоОС);
	ВидыСубконтоНМА = Новый Массив;
	ВидыСубконтоНМА.Добавить(ВидСубконтоНМА);	
	
	СчетаОС = Новый Массив;
	СчетаНМА = Новый Массив;
	
	Для каждого Строка Из КонтекстРасчета.ПараметрыУчетаОтложенногоНалогаВДобавочномКапитале Цикл
		Если Строка.ВидСубконтоАктивовОбязательств = ВидСубконтоОС Тогда
			СчетаОС.Добавить(Строка.Счет);	
		ИначеЕсли Строка.ВидСубконтоАктивовОбязательств = ВидСубконтоНМА Тогда
			СчетаНМА.Добавить(Строка.Счет);	
		КонецЕсли;	
	КонецЦикла;  
	
	ВыбывшиеОС = Новый Массив;
	ВыбывшиеНМА = Новый Массив;
	
	Для каждого Элемент Из КонтекстРасчета.ВыбывшиеВНАСДооценкой Цикл
		ОбъектВНА = Элемент.Ключ;
		
		Если ТипЗнч(ОбъектВНА) = Тип("СправочникСсылка.ОбъектыЭксплуатации") Тогда
			ВыбывшиеОС.Добавить(ОбъектВНА);
		Иначе
			ВыбывшиеНМА.Добавить(ОбъектВНА);
		КонецЕсли;
	КонецЦикла;  
	
	Запрос.УстановитьПараметр("Организации", КонтекстРасчета.Организации);
	Запрос.УстановитьПараметр("ЭтоБалансовыйСПРВР", КонтекстРасчета.ВариантУчетаОтложенногоНалога <> Перечисления.ВариантыУчетаОтложенногоНалога.БалансовыйМетод);
	Запрос.УстановитьПараметр("Период", НачалоМесяца(КонтекстРасчета.КонецПериода));
	Запрос.УстановитьПараметр("СчетаОС", СчетаОС);
	Запрос.УстановитьПараметр("СчетаНМА", СчетаНМА);
	Запрос.УстановитьПараметр("ВидыСубконтоОС", ВидыСубконтоОС);
	Запрос.УстановитьПараметр("ВидыСубконтоНМА", ВидыСубконтоНМА);
	Запрос.УстановитьПараметр("ВыбывшиеОС", ВыбывшиеОС);
	Запрос.УстановитьПараметр("ВыбывшиеНМА", ВыбывшиеНМА); 
	
	Запрос.Выполнить();
	
КонецПроцедуры

Функция ТекстЗапроса_СоздатьВТОстатокНакопленнойДооценки()

	Текст = 
	"ВЫБРАТЬ
	|	ХозрасчетныйОстатки.Организация КАК Филиал,
	|	ХозрасчетныйОстатки.Подразделение КАК Подразделение,
	|	ХозрасчетныйОстатки.НаправлениеДеятельности КАК НаправлениеДеятельности,
	|	ВЫБОР
	|		КОГДА &ЭтоБалансовыйСПРВР
	|			ТОГДА ХозрасчетныйОстатки.СуммаВРОстаток
	|		ИНАЧЕ ХозрасчетныйОстатки.СуммаОстаток - ХозрасчетныйОстатки.СуммаНУОстаток
	|	КОНЕЦ КАК СуммаВР,
	|	ХозрасчетныйОстатки.Субконто1 КАК ОбъектВНА
	|ПОМЕСТИТЬ ВТ_БалансовыеДанные
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.Остатки(&Период, Счет В (&СчетаОС), &ВидыСубконтоОС, Субконто1 В (&ВыбывшиеОС)
	|	И Организация В (&Организации)) КАК ХозрасчетныйОстатки
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ХозрасчетныйОстатки.Организация,
	|	ХозрасчетныйОстатки.Подразделение,
	|	ХозрасчетныйОстатки.НаправлениеДеятельности,
	|	ВЫБОР
	|		КОГДА &ЭтоБалансовыйСПРВР
	|			ТОГДА ХозрасчетныйОстатки.СуммаВРОстаток
	|		ИНАЧЕ ХозрасчетныйОстатки.СуммаОстаток - ХозрасчетныйОстатки.СуммаНУОстаток
	|	КОНЕЦ,
	|	ХозрасчетныйОстатки.Субконто1
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.Остатки(&Период, Счет В (&СчетаНМА), &ВидыСубконтоНМА, Субконто1 В (&ВыбывшиеНМА)
	|	И Организация В (&Организации)) КАК ХозрасчетныйОстатки";	

	Возврат Текст;
	
КонецФункции

Процедура ВыделитьПроводкиПоОтложенномуНалогуВДобавочномКапитале(ВсеКорректировки, Корректировки, КонтекстРасчета, ТаблицаРасчета)
	
	Отбор = Новый Структура;
	Отбор.Вставить("Счет");
	Отбор.Вставить("ВидАктивовИОбязательств");
	Отбор.Вставить("ВариантНалогообложенияПрибыли");
	Отбор.Вставить("КорСчет");
	
	Счет84 = ПланыСчетов.Хозрасчетный.ПрибыльПодлежащаяРаспределению; 
	
	ВыбывшиеВНАСДооценкой = КонтекстРасчета.ВыбывшиеВНАСДооценкой; 
	НакопленныйНалогДооценкиПоВыбывшимВНА = НакопленныйНалогДооценкиПоВыбывшимВНА(КонтекстРасчета, ТаблицаРасчета);

	ЭффектВключенияСуммыОперацииВНераспределеннуюПрибыльПоВНА = ЭффектВключенияСуммыОперацииВНераспределеннуюПрибыльПоВНА(КонтекстРасчета, ТаблицаРасчета);
	
	СчетаИКоррСчетаНалогаВДобавочномКапитале = СчетаИКоррСчетаНалогаВДобавочномКапитале(КонтекстРасчета);
	
	СоответствиеРасчетов = Новый Соответствие;
	
	Для Каждого ОбщийРасчет Из ТаблицаРасчета Цикл
		ОбщийРасчет.РасчетОтложенногоНалога.ОтложенныйНалогВДобавочномКапитале.Индексы.Добавить("Счет, АктивОбязательство, ВидАктивовИОбязательств");
		СоответствиеРасчетов.Вставить(ОбщийРасчет.ВариантНалогообложенияПрибыли, ОбщийРасчет.РасчетОтложенногоНалога);
	КонецЦикла;	
	
	ЕстьДанныеИзмененияВариантаНалогообложения = КонтекстРасчета.ДанныеПроводокИзмененияВариантаНалогаВДобавочномКапитале.Количество() <> 0;
	
	Для каждого Строка Из Корректировки Цикл    		
		КоррСчетОтложенногоНалога = СчетаИКоррСчетаНалогаВДобавочномКапитале.Получить(Строка.Счет);
		
		Если КоррСчетОтложенногоНалога = Неопределено Тогда
			Продолжить;
		КонецЕсли;	
		
		НалогНеИзменился = Строка.УвеличениеОтложенногоНалога = 0 И Строка.УменьшениеОтложенногоНалога = 0 И Строка.Пересчет = 0;
		ОбъектВНАВыбылВОтчетномПериоде = ВыбывшиеВНАСДооценкой.Получить(Строка.АктивОбязательство) <> Неопределено; 
		
		Если НалогНеИзменился И ОбъектВНАВыбылВОтчетномПериоде Тогда
			ЗаполнитьЭффектВключенияСуммыОперацииВНераспределеннуюПрибыль(СоответствиеРасчетов, ЭффектВключенияСуммыОперацииВНераспределеннуюПрибыльПоВНА,
				Строка.АктивОбязательство, Строка.ВариантНалогообложенияПрибыли, 0);
		КонецЕсли;	 
		
		Если НалогНеИзменился Тогда
			Продолжить;
		КонецЕсли;	
		
		Если Строка.Пересчет <> 0 Тогда
			НоваяСтрока = ВсеКорректировки.Добавить();	
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Строка, 
				"Счет, АктивОбязательство, ВариантНалогообложенияПрибыли, ВидАктивовИОбязательств, Пересчет");
			НоваяСтрока.КорСчет = Счет84; 
			НоваяСтрока.ВидОперацииРасчетаНалога = Перечисления.ВидыОперацийРасчетаНалога.Пересчет;
		
			Строка.Пересчет = 0;
		
		КонецЕсли;
		
		Если ОбъектВНАВыбылВОтчетномПериоде Тогда
			НоваяСтрока = ВсеКорректировки.Добавить();	
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Строка);
			НоваяСтрока.КорСчет = Счет84; 
			НоваяСтрока.ВидОперацииРасчетаНалога = Перечисления.ВидыОперацийРасчетаНалога.Списание;
			
			Если НоваяСтрока.УвеличениеОтложенногоНалога > 0 Тогда
				НоваяСтрока.УменьшениеОтложенногоНалога = НоваяСтрока.УменьшениеОтложенногоНалога - НоваяСтрока.УвеличениеОтложенногоНалога;				
			Иначе
				НоваяСтрока.УменьшениеОтложенногоНалога = НоваяСтрока.УменьшениеОтложенногоНалога + НоваяСтрока.УвеличениеОтложенногоНалога;				
			КонецЕсли;
			
			НоваяСтрока.УвеличениеОтложенногоНалога = 0;

			НакопленныйНалогДооценки = НакопленныйНалогДооценкиПоВыбывшимВНА.Получить(Строка.АктивОбязательство);
			
			ИзмениласьСтавкаТекущегоНалога = НакопленныйНалогДооценки <> Неопределено 
				И НакопленныйНалогДооценки <> НоваяСтрока.УменьшениеОтложенногоНалога;
			
			Если ИзмениласьСтавкаТекущегоНалога Тогда
				Строка.УвеличениеОтложенногоНалога = - (НакопленныйНалогДооценки - НоваяСтрока.УменьшениеОтложенногоНалога);		
				Строка.УменьшениеОтложенногоНалога = 0;
				НоваяСтрока.УменьшениеОтложенногоНалога = НакопленныйНалогДооценки; 			
			КонецЕсли;
				
			ЗаполнитьЭффектВключенияСуммыОперацииВНераспределеннуюПрибыль(СоответствиеРасчетов, ЭффектВключенияСуммыОперацииВНераспределеннуюПрибыльПоВНА,
				НоваяСтрока.АктивОбязательство, НоваяСтрока.ВариантНалогообложенияПрибыли, НоваяСтрока.УменьшениеОтложенногоНалога);
			
			Если НЕ ИзмениласьСтавкаТекущегоНалога Тогда
				Продолжить;
			КонецЕсли;
		КонецЕсли;
		
		Если ЕстьДанныеИзмененияВариантаНалогообложения Тогда
			СформироватьПроводкуИзмененияВариантаНалогообложенияВДобавочномКапитале(ВсеКорректировки, Строка, КонтекстРасчета, Счет84);
		КонецЕсли;
		
		Если Строка.УвеличениеОтложенногоНалога = 0 И Строка.УменьшениеОтложенногоНалога = 0 Тогда
			Продолжить;
		КонецЕсли;  
		
		ЗаполнитьЗначенияСвойств(Отбор, Строка);
		Отбор.Счет = КоррСчетОтложенногоНалога;
		
		НайденныеСтроки = ВсеКорректировки.НайтиСтроки(Отбор);
		
		Если НайденныеСтроки.Количество() <> 1 Тогда
			НоваяСтрока = ВсеКорректировки.Добавить();	
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Строка, 
				"Счет, АктивОбязательство, ВариантНалогообложенияПрибыли, ВидАктивовИОбязательств");
			НоваяСтрока.КорСчет = Счет84; 
			НоваяСтрока.ВидОперацииРасчетаНалога = Перечисления.ВидыОперацийРасчетаНалога.Изменение;
			НоваяСтрока.Пересчет = Строка.УвеличениеОтложенногоНалога - Строка.УменьшениеОтложенногоНалога;
			
			Продолжить;	
		КонецЕсли;	                          
		
		СтрокаКорСчет = НайденныеСтроки[0];
		
		ОстатокОтложенногоНалогаУменьшение = Строка.УвеличениеОтложенногоНалога + СтрокаКорСчет.УменьшениеОтложенногоНалога;
		ОстатокОтложенногоНалогаУвеличение = Строка.УменьшениеОтложенногоНалога + СтрокаКорСчет.УвеличениеОтложенногоНалога; 		
		
		Если ОстатокОтложенногоНалогаУменьшение <> 0 
			ИЛИ ОстатокОтложенногоНалогаУвеличение <> 0 
			ИЛИ СтрокаКорСчет.Пересчет <> 0 Тогда
		
			НоваяСтрока = ВсеКорректировки.Добавить();	
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаКорСчет);
			НоваяСтрока.УменьшениеОтложенногоНалога = ОстатокОтложенногоНалогаУменьшение; 
			НоваяСтрока.УвеличениеОтложенногоНалога = ОстатокОтложенногоНалогаУвеличение;      
					
		КонецЕсли;    

		СтрокаКорСчет.КорСчет = Строка.Счет; 
		СтрокаКорСчет.АктивОбязательство = Строка.АктивОбязательство;
		СтрокаКорСчет.УменьшениеОтложенногоНалога = СтрокаКорСчет.УменьшениеОтложенногоНалога - ОстатокОтложенногоНалогаУменьшение;
		СтрокаКорСчет.УвеличениеОтложенногоНалога = СтрокаКорСчет.УвеличениеОтложенногоНалога - ОстатокОтложенногоНалогаУвеличение;
		СтрокаКорСчет.Пересчет = 0;
		СтрокаКорСчет.ВидОперацииРасчетаНалога = Перечисления.ВидыОперацийРасчетаНалога.Изменение;
				
	КонецЦикла;
		
КонецПроцедуры

Процедура СформироватьПроводкуИзмененияВариантаНалогообложенияВДобавочномКапитале(ВсеКорректировки, Строка, КонтекстРасчета, Знач Счет84)

	ДанныеПроводок = КонтекстРасчета.ДанныеПроводокИзмененияВариантаНалогаВДобавочномКапитале;
	
	Отбор = Новый Структура;
	Отбор.Вставить("ВариантНалогообложения", Строка.ВариантНалогообложенияПрибыли);
	Отбор.Вставить("ОбъектВНА", Строка.АктивОбязательство);
	
	ДанныеПоОбъектуВНА = ДанныеПроводок.НайтиСтроки(Отбор);
	
	Если ДанныеПоОбъектуВНА.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	СтрокаДанных = ДанныеПоОбъектуВНА[0];
	СтрокаДанных.ЕстьИзмененияНалога = Истина;
	
	Строка.УвеличениеОтложенногоНалога = Строка.УвеличениеОтложенногоНалога - СтрокаДанных.Сумма; 	
	
	НоваяСтрока = ВсеКорректировки.Добавить();	
	ЗаполнитьЗначенияСвойств(НоваяСтрока, Строка);
	НоваяСтрока.КорСчет = Счет84; 
	НоваяСтрока.ВидОперацииРасчетаНалога = Перечисления.ВидыОперацийРасчетаНалога.Изменение;
	НоваяСтрока.УвеличениеОтложенногоНалога = СтрокаДанных.Сумма;				
	НоваяСтрока.УменьшениеОтложенногоНалога = 0;
	
КонецПроцедуры

#КонецОбласти

#Область ВыборкаГруппировкаВременныхРазниц

// Технологические процедуры выборки и группировки сальдо временных разниц

Функция БалансовыеСчетаВременныхРазниц()
	
	ОписаниеСчетов = Новый Структура;
	ОписаниеСчетов.Вставить("ГлобальныеИсключения", ГлобальныеИсключенияДетализацииАктивовОбязательств());
	ОписаниеСчетов.Вставить("ПланСчетов",           Новый ТаблицаЗначений);
	ОписаниеСчетов.ПланСчетов.Колонки.Добавить("Счет",      Новый ОписаниеТипов("ПланСчетовСсылка.Хозрасчетный"));
	ОписаниеСчетов.ПланСчетов.Колонки.Добавить("Родитель",  Новый ОписаниеТипов("ПланСчетовСсылка.Хозрасчетный"));
	ОписаниеСчетов.ПланСчетов.Колонки.Добавить("Субконто1", Новый ОписаниеТипов("ПланВидовХарактеристикСсылка.ВидыСубконтоХозрасчетные"));
	ОписаниеСчетов.ПланСчетов.Колонки.Добавить("Субконто2", Новый ОписаниеТипов("ПланВидовХарактеристикСсылка.ВидыСубконтоХозрасчетные"));
	ОписаниеСчетов.ПланСчетов.Колонки.Добавить("Субконто3", Новый ОписаниеТипов("ПланВидовХарактеристикСсылка.ВидыСубконтоХозрасчетные"));
	ОписаниеСчетов.ПланСчетов.Колонки.Добавить("СчетСПредопределеннымВариантомНалогообложения",
		Новый ОписаниеТипов("Булево"));
	// После заполнения будут добавлены индексы
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("СчетаДоходовРасходов",       СчетаДоходовРасходов());
	Запрос.УстановитьПараметр("СчетаБезНалоговойСтоимости", СчетаБезНалоговойСтоимости());
	Запрос.УстановитьПараметр("СчетаСПредопределеннымВариантомНалогообложения",
		СчетаСПредопределеннымВариантомНалогообложения());
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Счета.Ссылка КАК Счет,
	|	Счета.Родитель КАК Родитель,
	|	ВидыСубконто1.ВидСубконто КАК Субконто1,
	|	ВидыСубконто2.ВидСубконто КАК Субконто2,
	|	ВидыСубконто3.ВидСубконто КАК Субконто3,
	|	ВЫБОР
	|		КОГДА Счета.Ссылка В (&СчетаСПредопределеннымВариантомНалогообложения)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ
	|			ЛОЖЬ
	|	КОНЕЦ КАК СчетСПредопределеннымВариантомНалогообложения
	|ИЗ
	|	ПланСчетов.Хозрасчетный КАК Счета
	|		ЛЕВОЕ СОЕДИНЕНИЕ ПланСчетов.Хозрасчетный.ВидыСубконто КАК ВидыСубконто1
	|		ПО Счета.Ссылка = ВидыСубконто1.Ссылка
	|			И (ВидыСубконто1.НомерСтроки = 1)
	|			И (НЕ ВидыСубконто1.ТолькоОбороты)
	|			И (ВидыСубконто1.Суммовой)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ПланСчетов.Хозрасчетный.ВидыСубконто КАК ВидыСубконто2
	|		ПО Счета.Ссылка = ВидыСубконто2.Ссылка
	|			И (ВидыСубконто2.НомерСтроки = 2)
	|			И (НЕ ВидыСубконто2.ТолькоОбороты)
	|			И (ВидыСубконто2.Суммовой)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ПланСчетов.Хозрасчетный.ВидыСубконто КАК ВидыСубконто3
	|		ПО Счета.Ссылка = ВидыСубконто3.Ссылка
	|			И (ВидыСубконто3.НомерСтроки = 3)
	|			И (НЕ ВидыСубконто3.ТолькоОбороты)
	|			И (ВидыСубконто3.Суммовой)
	|ГДЕ
	|	НЕ Счета.Ссылка В ИЕРАРХИИ (&СчетаДоходовРасходов)
	|	И НЕ Счета.Забалансовый
	|	И (Счета.НалоговыйУчет
	|			ИЛИ Счета.Ссылка В ИЕРАРХИИ (&СчетаБезНалоговойСтоимости))";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(ОписаниеСчетов.ПланСчетов.Добавить(), Выборка);
	КонецЦикла;
	
	ОписаниеСчетов.ПланСчетов.Индексы.Добавить("Счет");
	ОписаниеСчетов.ПланСчетов.Индексы.Добавить("Родитель");
	
	Возврат ОписаниеСчетов;
	
КонецФункции

Процедура СоставитьПланВыполненияПравила(ПланГруппировки, Правило, ОписаниеСчетов, Знач ОписаниеСчета, СубконтоСчетаГруппировки)
	
	Если ТипЗнч(ОписаниеСчета) = Тип("ПланСчетовСсылка.Хозрасчетный") Тогда
		ОписаниеСчета = ОписаниеСчетов.ПланСчетов.Найти(ОписаниеСчета, "Счет");
		Если ОписаниеСчета = Неопределено Тогда
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	ДобавитьЗаписьПланаВыполненияПравила(ПланГруппировки, Правило, ОписаниеСчетов, ОписаниеСчета, СубконтоСчетаГруппировки);
	
	ПодчиненныеСчета = ОписаниеСчетов.ПланСчетов.НайтиСтроки(Новый Структура("Родитель", ОписаниеСчета.Счет));
	
	Если Не ЗначениеЗаполнено(ПодчиненныеСчета) Тогда
		ДобавитьЗаписьПланаВыполненияПравила(ПланГруппировки, Правило, ОписаниеСчетов, ОписаниеСчета, СубконтоСчетаГруппировки);
	Иначе
		Для Каждого ОписаниеПодчиненногоСчета Из ПодчиненныеСчета Цикл
			СоставитьПланВыполненияПравила(ПланГруппировки, Правило, ОписаниеСчетов, ОписаниеПодчиненногоСчета, СубконтоСчетаГруппировки);
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

Процедура ДобавитьЗаписьПланаВыполненияПравила(ПланГруппировки, Правило, ОписаниеСчетов, ОписаниеСчета, СубконтоСчетаГруппировки)
	
	Запись = ПланГруппировки.Найти(ОписаниеСчета.Счет, "Счет");
	Если Запись <> Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Правило = Неопределено Тогда
		Если ОписаниеСчета.Счет = ПланыСчетов.Хозрасчетный.ПриростСтоимостиИмуществаПоПереоценке 
			ИЛИ ОписаниеСчета.Счет = ПланыСчетов.Хозрасчетный.ПриростСтоимостиНМАПоПереоценке Тогда
				Возврат;
		КонецЕсли;
		ВидАктивовОбязательств = Перечисления.ВидыАктивовИОбязательств.ВидПрочие();
		СчетГруппировки        = ОписаниеСчета.Счет;
		ИсключенныеСубконто    = Новый Массив;
	Иначе
		ВидАктивовОбязательств = Правило.ВидАктивовОбязательств;
		СчетГруппировки        = Правило.ОсновнойСчет;
		ИсключенныеСубконто    = Правило.ИсключенныеСубконто
	КонецЕсли;
		
	Запись = ПланГруппировки.Добавить();
	Запись.Счет = ОписаниеСчета.Счет;
	Запись.ВидАктивовОбязательств = ВидАктивовОбязательств;
	
	Если СубконтоСчетаГруппировки = Неопределено Тогда
		Запись.СчетГруппировки = ОписаниеСчета.Счет;
	Иначе
		Запись.СчетГруппировки = СчетГруппировки;
	КонецЕсли;
		
	Запись.ВыбиратьТолькоРазницы = (Запись.Счет = Запись.СчетГруппировки);
	Запись.НомерВариантаИсключения = 0;
	
	Для НомерСубконто = 1 По 3 Цикл
		
		ВидСубконто = ОписаниеСчета["Субконто" + НомерСубконто];
		
		ПозицияСубконто = НомерСубконто;
		Если СубконтоСчетаГруппировки = Неопределено Тогда
			Если Не МожноИспользоватьСубконтоДляГруппировки(ВидСубконто, ОписаниеСчетов, ИсключенныеСубконто) Тогда
				ПозицияСубконто = 0;
			КонецЕсли;
		Иначе
			ПозицияСубконто = СубконтоСчетаГруппировки[ВидСубконто];
			Если ПозицияСубконто = Неопределено Тогда
				ПозицияСубконто = 0;
			КонецЕсли;
		КонецЕсли;
		
		Запись["ПозицияСубконто" + НомерСубконто] = ПозицияСубконто;
		
		Если ПозицияСубконто = 0 Тогда
			Запись.НомерВариантаИсключения = Запись.НомерВариантаИсключения + Pow(2, НомерСубконто - 1);
		КонецЕсли;
		
		// Определение позиции субконто по варианту н/о
		Если ОписаниеСчета.СчетСПредопределеннымВариантомНалогообложения
			И ВидСубконто = ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ВариантыНалогообложенияПрибыли Тогда
			
			Запись.ПозицияСубконтоВариантНалогообложения = НомерСубконто;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Функция МожноИспользоватьСубконтоДляГруппировки(ВидСубконто, ОписаниеСчетов, ИсключенныеСубконто)
	Возврат ЗначениеЗаполнено(ВидСубконто) 
		И ОписаниеСчетов.ГлобальныеИсключения.Найти(ВидСубконто) = Неопределено
		И ИсключенныеСубконто.Найти(ВидСубконто) = Неопределено;
КонецФункции

Процедура ОптимизироватьЗапросСальдоДляГруппировки(ТекстЗапроса, ПланГруппировки)
	
	// Выделим в отдельные запросы получение данных по счетам, где требуется исключить какие-либо субконто.
	// Это позволит сократить выборку детальных данных, которые впоследствии все равно будут сгруппированы.
	
	// На каждую комбинацию исключаемых полей делаем свой запрос, ограниченный счетами, где необходима такая комбинация.
	// Каждый из таких запросов получит указание, какие субконто заведомо не нужны.
	
	// Исходный запрос ограничим счетами, по которым исключения не требуются.
	// В таком запросе будет описано получение всех трех субконто.
	// Исходный запрос важно оставить, даже если окажется, что фактически счетов без исключений нет.
	// Потому что по наличию субконто в пути к полю платформа определяет тип поля запроса.
	// Если ни в одном не будет, то колонка запроса получит тип Неопределено, который не может быть выбран в запросе.
	
	// Комбинации заранее получили номера.
	// Конкретное значение (семантика) номера в этой процедуре не важно: главное, чтобы 
	// - номер однозначно идентифицировал набор исключаемых полей
	// - при последовательных выполнениях одна и так же комбинация получала один и тот же номер
	//   (это важно для кеширования платформой текстов запросов).
	
	// Кроме исключения субконто, выделим запросы, в которых возможно заранее наложить отбор на записи, содержащие разницы.
	
	КомбинацииИсключаемыхПолей = ПланГруппировки.Скопировать();
	Для НомерСубконто = 1 По 3 Цикл
		КомбинацииИсключаемыхПолей.Колонки.Добавить("ИсключитьСубконто" + НомерСубконто, Новый ОписаниеТипов("Булево"));
	КонецЦикла;
	Для Каждого Запись Из КомбинацииИсключаемыхПолей Цикл
		Для НомерСубконто = 1 По 3 Цикл
			Запись["ИсключитьСубконто" + НомерСубконто] = (Запись["ПозицияСубконто" + НомерСубконто] = 0);
		КонецЦикла;
	КонецЦикла;
	КомбинацииИсключаемыхПолей.Свернуть("ИсключитьСубконто1, ИсключитьСубконто2, ИсключитьСубконто3, НомерВариантаИсключения, ВыбиратьТолькоРазницы");
	
	Если КомбинацииИсключаемыхПолей.Количество() = 1
		И КомбинацииИсключаемыхПолей[0].ВыбиратьТолькоРазницы
		И ТривиальнаяКомбинацияИсключаемыхПолей(КомбинацииИсключаемыхПолей[0]) Тогда
		// Оптимизация невозможна.
		Возврат;
	КонецЕсли;
	
	СхемаЗапроса = Новый СхемаЗапроса;
	СхемаЗапроса.УстановитьТекстЗапроса(ТекстЗапроса);
	ОписаниеЗапроса  = СхемаЗапроса.ПакетЗапросов[0];
	ОператорыЗапроса = ОписаниеЗапроса.Операторы;
	
	ПоляЗапросаСубконто = Новый Соответствие; // Ключ - номер субконто; значение - индекс поля.
	Для НомерСубконто = 1 По 3 Цикл
		Колонка = ОписаниеЗапроса.Колонки.Найти("Субконто" + НомерСубконто);
		Если Колонка = Неопределено Тогда
			Возврат;
		КонецЕсли;
		ПоляЗапросаСубконто.Вставить(НомерСубконто, ОписаниеЗапроса.Колонки.Индекс(Колонка));
	КонецЦикла;
	
	// Работаем с первым запросом в пакете. Исходный запрос содержит один оператор с обращением к виртуальной таблице Остатки.
	
	ШаблонУсловиеСчета = "Счет В(%1)";
	ШаблонЗапросаУсловиеСчета = 
	"ВЫБРАТЬ
	|	ПланГруппировки.Счет КАК Счет
	|ИЗ
	|	ВТ_ПравилаГруппировки КАК ПланГруппировки
	|ГДЕ
	|	ПланГруппировки.НомерВариантаИсключения = &НомерВариантаИсключения
	|	И ПланГруппировки.ВыбиратьТолькоРазницы = &ВыбиратьТолькоРазницы";
	// Значения параметров будут позже заменены на константы
	ШаблонУсловиеСчета = СтрШаблон(ШаблонУсловиеСчета, ШаблонЗапросаУсловиеСчета);
	ШаблонУсловиеСчета = СтрЗаменить(ШаблонУсловиеСчета, "&НомерВариантаИсключения", "%1");
	ШаблонУсловиеСчета = СтрЗаменить(ШаблонУсловиеСчета, "&ВыбиратьТолькоРазницы",   "%2");
	
	Для Каждого Комбинация Из КомбинацииИсключаемыхПолей Цикл
		
		Если ТривиальнаяКомбинацияИсключаемыхПолей(Комбинация)
			И Комбинация.ВыбиратьТолькоРазницы Тогда
			Оператор = ОператорыЗапроса[0];
		Иначе
			
			Оператор = ОператорыЗапроса.Добавить(ОператорыЗапроса[0]);
			
			// Исключим субконто
			Для НомерСубконто = 1 По 3 Цикл
				Если Не Комбинация["ИсключитьСубконто" + НомерСубконто] Тогда
					Продолжить;
				КонецЕсли;
				ИндексПоля = ПоляЗапросаСубконто[НомерСубконто];
				Оператор.ВыбираемыеПоля[ИндексПоля] = Новый ВыражениеСхемыЗапроса("Неопределено");
			КонецЦикла;
			
			// Уберем отбор
			Если Не Комбинация.ВыбиратьТолькоРазницы Тогда
				Оператор.Отбор.Очистить();
			КонецЕсли;
			
		КонецЕсли;
		
		// Укажем отбор по счетам, соответствующим комбинации.
		Источник = Оператор.Источники.НайтиПоИмени("РегистрБухгалтерии.Хозрасчетный.Остатки");
		Если Источник = Неопределено Тогда
			Возврат;
		КонецЕсли;
		
		ТекстУсловиеСчета = СтрШаблон(
			ШаблонУсловиеСчета,
			XMLСтрока(Комбинация.НомерВариантаИсключения),
			XMLСтрока(Комбинация.ВыбиратьТолькоРазницы));
		
		ПараметрУсловиеСчета = Источник.Источник.Параметры[ИндексПараметраУсловиеСчета()];
		ПараметрУсловиеСчета.Выражение = Новый ВыражениеСхемыЗапроса(ТекстУсловиеСчета);
		
	КонецЦикла;
	
	ТекстЗапроса = СхемаЗапроса.ПолучитьТекстЗапроса();
	
КонецПроцедуры

Функция ИндексПараметраУсловиеСчета()
	Возврат 1; // В виртуальной таблице Остатки регистра бухгалтерии: Остатки(Период, УсловиеСчета, Субконто, Условие)
КонецФункции

Функция ТривиальнаяКомбинацияИсключаемыхПолей(Комбинация)
	
	Для НомерСубконто = 1 По 3 Цикл
		Если Комбинация["ИсключитьСубконто" + НомерСубконто] Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

