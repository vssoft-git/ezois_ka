// Возвращает QR-код на ссылку для проверки возраста в мессенжере Макс
//
// Параметры:
//  Ширина - Число
//  Высота - Число
//
// Возвращаемое значение:
//  Картинка
// 
Функция QRКодСслыкаНаПроверкуВозраста(Ширина = 100, Высота = 100) Экспорт
	
	ПараметрыШтрихкода = ГенерацияШтрихкода.ПараметрыГенерацииШтрихкода();
	ПараметрыШтрихкода.Ширина = Ширина;
	ПараметрыШтрихкода.Высота = Высота;
	ПараметрыШтрихкода.ТипКода = 16;
	НастройкиСоединенияпроверкиВозраста = МенеджерОборудованияКлиентСервер.НастройкиСоединенияпроверкиВозраста();
	ПараметрыШтрихкода.Штрихкод = НастройкиСоединенияпроверкиВозраста.СсылкаПолученияЦифровогоID;
	ПараметрыШтрихкода.ПрозрачныйФон = Истина;
	ПараметрыШтрихкода.УровеньКоррекцииQR = 3;
	ПараметрыШтрихкода.ЛоготипКартинка = Base64Строка(БиблиотекаКартинок.ЛоготипМаксБПО.ПолучитьДвоичныеДанные());
	ПараметрыШтрихкода.ЛоготипРазмерПроцентОтШК = 30;
	
	СгенерированныйШтрихкод = ГенерацияШтрихкода.ИзображениеШтрихкода(ПараметрыШтрихкода);
	Если СгенерированныйШтрихкод.Результат Тогда
		Возврат СгенерированныйШтрихкод.Картинка;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

