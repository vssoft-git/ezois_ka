	|	НЕОПРЕДЕЛЕНО КАК МестоУчетаДт,
	|	
	|	ЗНАЧЕНИЕ(Справочник.Валюты.ПустаяСсылка) КАК ВалютаДт,
	|	Строки.Подразделение КАК ПодразделениеДт,
	|	Строки.НаправлениеДеятельности КАК НаправлениеДеятельностиДт,
	|	
	|	ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.РегиональныйИнвестиционныйНалоговыйВычетФедеральнаяЧасть) КАК СчетДт,
	|	
	|	Строки.ОсновноеСредство КАК СубконтоДт1,
	|	ПервоначальныеСведенияОС.ДокументВводаВЭксплуатациюНУ КАК СубконтоДт2,
	|	ЗНАЧЕНИЕ(Перечисление.ВидыРасходовПоИнвестиционномуВычету.ПервоначальнаяСтоимостьОС) КАК СубконтоДт3,
	|	
	|	0 КАК ВалютнаяСуммаДт,
	|	0 КАК КоличествоДт,
	|
	|	Вт_ПрименениеРИНВ.ДоляРасходовИНВ_ФБ * Строки.СуммаРасходовНУПриИНВ КАК СуммаНУДт,
	|	0 КАК СуммаПРДт,
	|	0 КАК СуммаВРДт,
	|	
	|	// Кт ///////////////////////////////////////////////////////////////////////////////////////////
	|	
	|	НЕОПРЕДЕЛЕНО КАК ВидСчетаКт,
	|	НЕОПРЕДЕЛЕНО КАК АналитикаУчетаКт,
	|	НЕОПРЕДЕЛЕНО КАК МестоУчетаКт,
	|	
	|	НЕОПРЕДЕЛЕНО КАК ВалютаКт,
	|	НЕОПРЕДЕЛЕНО КАК ПодразделениеКт,
	|	НЕОПРЕДЕЛЕНО КАК НаправлениеДеятельностиКт,
	|	
	|	ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.ПустаяСсылка) КАК СчетКт,
	|	
	|	НЕОПРЕДЕЛЕНО КАК СубконтоКт1,
	|	НЕОПРЕДЕЛЕНО КАК СубконтоКт2,
	|	НЕОПРЕДЕЛЕНО КАК СубконтоКт3,
	|	
	|	0 КАК ВалютнаяСуммаКт,
	|	0 КАК КоличествоКт,
	|
	|	Вт_ПрименениеРИНВ.ДоляРасходовИНВ_ФБ * Строки.СуммаРасходовНУПриИНВ КАК СуммаНУКт,
	|	0 КАК СуммаПРКт,
	|	0 КАК СуммаВРКт,
	|
	|	""Применение инвестиционного налогового вычета"" КАК Содержание
	|ИЗ
	|	РазрезыКОтражению КАК ДокументыКОтражению
	|
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.СтоимостьОС КАК Строки
	|		ПО Строки.Регистратор = ДокументыКОтражению.Ссылка
	|			И Строки.Организация = ДокументыКОтражению.Организация
	|
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.КорректировкаСтоимостиИАмортизацииОС КАК ДанныеДокумента
	|		ПО ДанныеДокумента.Ссылка = ДокументыКОтражению.Ссылка
	|
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.КорректировкаСтоимостиИАмортизацииОС.ОС КАК ТаблицаОС
	|		ПО ТаблицаОС.Ссылка = Строки.Регистратор
	|			И ТаблицаОС.ОсновноеСредство = Строки.ОсновноеСредство
	|
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПервоначальныеСведенияОС КАК ПервоначальныеСведенияОС
	|		ПО ПервоначальныеСведенияОС.Ссылка = Строки.Регистратор
	|			И ПервоначальныеСведенияОС.ОсновноеСредство = Строки.ОсновноеСредство
	|
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПорядокУчетаОСБУ КАК ПорядокУчетаОСБУ
	|		ПО ПорядокУчетаОСБУ.Ссылка = Строки.Регистратор
	|			И ПорядокУчетаОСБУ.ОсновноеСредство = Строки.ОсновноеСредство
	|
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Вт_ПрименениеРегиональныхИНВ КАК Вт_ПрименениеРИНВ
	|		ПО ДокументыКОтражению.ГоловнаяОрганизация = Вт_ПрименениеРИНВ.Организация
	|			И ДанныеДокумента.Подразделение = Вт_ПрименениеРИНВ.Подразделение
	|			И ДанныеДокумента.Дата = Вт_ПрименениеРИНВ.Дата
	|
	|ГДЕ
	|	Строки.СуммаРасходовНУПриИНВ <> 0
	|	И ПорядокУчетаОСБУ.ИнвестиционныйНалоговыйВычет = ЗНАЧЕНИЕ(Перечисление.ВариантыПримененияИНВ.Региональный)
	|	И Вт_ПрименениеРИНВ.ПрименяетсяФедеральныйИНВ = ИСТИНА
	|";
	
	ТекстыЗапроса.Добавить(ТекстЗапроса);
	
	#КонецОбласти

	ТекстЗапроса = СтрСоединить(ТекстыЗапроса, ОбщегоНазначенияУТ.РазделительЗапросовВОбъединении());
	
	//-- Локализация
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ТекстЗапросаВТОтраженияВРеглУчете() Экспорт
	
	ТекстЗапроса = "";

	//++ Локализация

	СписокЗапросов = Новый Массив;

	#Область ТаблицыДляОтраженияИНВ
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	ТаблицаДокумента.Ссылка КАК Ссылка,
	|	ТаблицаДокумента.Дата КАК Дата,
	|	ТаблицаДокумента.Организация КАК Организация,
	|	ТабличнаяЧасть.ОсновноеСредство КАК ОсновноеСредство
	|
	|ПОМЕСТИТЬ ТаблицаОС
	|
	|ИЗ
	|	ДокументыКОтражению КАК ДокументыКОтражению
	|
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.КорректировкаСтоимостиИАмортизацииОС КАК ТаблицаДокумента
	|		ПО ТаблицаДокумента.Ссылка = ДокументыКОтражению.Ссылка
	|
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.КорректировкаСтоимостиИАмортизацииОС.ОС КАК ТабличнаяЧасть
	|		ПО ТабличнаяЧасть.Ссылка = ТаблицаДокумента.Ссылка
	|
	|ГДЕ
	|	ТаблицаДокумента.КорректировкаСуммыРасходовНУПриИНВ
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Дата,
	|	ОсновноеСредство,
	|	Организация
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СрезРегистратор.Ссылка КАК Ссылка,
	|	СрезРегистратор.ОсновноеСредство КАК ОсновноеСредство,
	|	ДанныеРегистра.ДокументВводаВЭксплуатациюНУ КАК ДокументВводаВЭксплуатациюНУ
	|
	|ПОМЕСТИТЬ ПервоначальныеСведенияОС
	|
	|ИЗ
	|	(ВЫБРАТЬ
	|		СрезПериод.Ссылка КАК Ссылка,
	|		СрезПериод.Организация КАК Организация,
	|		СрезПериод.ОсновноеСредство КАК ОсновноеСредство,
	|		СрезПериод.ДанныеРегистраПериод КАК ДанныеРегистраПериод,
	|		МАКСИМУМ(ДанныеРегистра.Регистратор) КАК ДанныеРегистраРегистратор
	|	ИЗ
	|		(ВЫБРАТЬ
	|			ТаблицаОС.Ссылка КАК Ссылка,
	|			ТаблицаОС.Организация КАК Организация,
	|			ТаблицаОС.ОсновноеСредство КАК ОсновноеСредство,
