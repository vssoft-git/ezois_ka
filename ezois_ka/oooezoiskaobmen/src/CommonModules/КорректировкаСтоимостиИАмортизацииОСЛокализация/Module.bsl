	|		СрезПериод.Ссылка КАК Ссылка,
	|		СрезПериод.Организация КАК Организация,
	|		СрезПериод.ОсновноеСредство КАК ОсновноеСредство,
	|		СрезПериод.ДанныеРегистраПериод КАК ДанныеРегистраПериод,
	|		МАКСИМУМ(ДанныеРегистра.Регистратор) КАК ДанныеРегистраРегистратор
	|	ИЗ
	|		(ВЫБРАТЬ
	|			ТаблицаОС.Ссылка КАК Ссылка,
	|			ТаблицаОС.Организация КАК Организация,
	|			ТаблицаОС.ОсновноеСредство КАК ОсновноеСредство,
	|			МАКСИМУМ(ДанныеРегистра.Период) КАК ДанныеРегистраПериод
	|		ИЗ
	|			ТаблицаОС КАК ТаблицаОС
	|
	|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ПорядокУчетаОСБУ КАК ДанныеРегистра
	|				ПО ДанныеРегистра.Период <= ТаблицаОС.Дата
	|					И ДанныеРегистра.Организация = ТаблицаОС.Организация
	|					И ДанныеРегистра.ОсновноеСредство = ТаблицаОС.ОсновноеСредство
	|					И ДанныеРегистра.Регистратор <> ТаблицаОС.Ссылка
	|					И ДанныеРегистра.Активность
	|
	|		СГРУППИРОВАТЬ ПО
	|			ТаблицаОС.Ссылка,
	|			ТаблицаОС.Организация,
	|			ТаблицаОС.ОсновноеСредство
	|
	|		) КАК СрезПериод
	|		
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ПорядокУчетаОСБУ КАК ДанныеРегистра
	|			ПО ДанныеРегистра.Период = СрезПериод.ДанныеРегистраПериод
	|				И ДанныеРегистра.Организация = СрезПериод.Организация
	|				И ДанныеРегистра.ОсновноеСредство = СрезПериод.ОсновноеСредство
	|				И ДанныеРегистра.Регистратор <> СрезПериод.Ссылка
	|				И ДанныеРегистра.Активность
	|
	|	СГРУППИРОВАТЬ ПО
	|		СрезПериод.Ссылка,
	|		СрезПериод.Организация,
	|		СрезПериод.ОсновноеСредство,
	|		СрезПериод.ДанныеРегистраПериод
	|
	|	) КАК СрезРегистратор
	|
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ПорядокУчетаОСБУ КАК ДанныеРегистра
	|		ПО ДанныеРегистра.Период = СрезРегистратор.ДанныеРегистраПериод
	|			И ДанныеРегистра.Регистратор = СрезРегистратор.ДанныеРегистраРегистратор
	|			И ДанныеРегистра.Организация = СрезРегистратор.Организация
	|			И ДанныеРегистра.ОсновноеСредство = СрезРегистратор.ОсновноеСредство
	|			И ДанныеРегистра.Активность
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Ссылка,
	|	ОсновноеСредство
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ
	|	ТаблицаОС
	|";
	СписокЗапросов.Добавить(ТекстЗапроса);
	
	#КонецОбласти

	#Область ПрименениеИНВ

	ТекстЗапроса =
	"ВЫБРАТЬ
	|	ТаблицаДокумента.Организация КАК Организация,
	|	ТаблицаДокумента.Подразделение КАК Подразделение,
	|	ТаблицаДокумента.Дата КАК Период,
	|	ТаблицаДокумента.Организация.ГоловнаяОрганизация КАК ГоловнаяОрганизация
	|
	|ПОМЕСТИТЬ ДанныеДокументов
	|
	|ИЗ
	|	ДокументыКОтражению КАК ДокументыКОтражению
	|
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.КорректировкаСтоимостиИАмортизацииОС КАК ТаблицаДокумента
	|		ПО ТаблицаДокумента.Ссылка = ДокументыКОтражению.Ссылка
	|
	|ГДЕ
	|	ТаблицаДокумента.КорректировкаСуммыРасходовНУПриИНВ
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация,
	|	Подразделение,
	|	Период";
	СписокЗапросов.Добавить(ТекстЗапроса);
	
	РегистрыСведений.ПрименениеРегиональныхИНВ.ТекстЗапросаПараметровПримененияРегиональныхИНВ(СписокЗапросов);
	
	#КонецОбласти
	
	СписокЗапросов.Добавить(Символы.ПС);
	
	ТекстЗапроса = СтрСоединить(СписокЗапросов, ОбщегоНазначения.РазделительПакетаЗапросов());

	//-- Локализация
	
	Возврат ТекстЗапроса;
	
КонецФункции

#КонецОбласти

#Область ФормаДокумента

Процедура ПриВыполненииКоманды(ИмяКоманды, Форма) Экспорт
	
	//++ Локализация
	
	Объект = Форма.Объект; // ДокументОбъект.КорректировкаСтоимостиИАмортизацииОС
	
	Если ИмяКоманды = Форма.Команды.ЗаполнитьПараметрыНУ.Имя Тогда
		
		Документы.КорректировкаСтоимостиИАмортизацииОС.ЗаполнитьПараметрыЗаПериод(Форма.Объект, "НУ");
		НачатьРасчетАмортизацииПоЗаданнымПараметрам(Объект, "НУ");
	
	ИначеЕсли ИмяКоманды = Форма.Команды.РассчитатьАмортизациюНУ.Имя Тогда
		
		НачатьРасчетАмортизацииПоЗаданнымПараметрам(Объект, "НУ");
	
	КонецЕсли; 
	
	//-- Локализация
	
КонецПроцедуры

Процедура ЗаполнитьПараметрыПоУмолчанию(Объект, ПараметрыРасчета, ПараметрыДляРасчета) Экспорт
	
	//++ Локализация
	
	Если НЕ Объект.РежимИсправленияСПрошлойДаты
		ИЛИ Объект.НачалоПериода = '000101010000' Тогда
		Возврат;
	КонецЕсли;
	
	Если ПараметрыРасчета.ЗаполнитьБУ Тогда
		Объект.АмортизацияПРНаНачалоПериода = ПараметрыДляРасчета.АмортизацияПРНаНачалоПериода;
		Объект.АмортизацияЦФНаНачалоПериода = ПараметрыДляРасчета.АмортизацияЦФНаНачалоПериода;
		Объект.АмортизацияПРЦФНаНачалоПериода = ПараметрыДляРасчета.АмортизацияПРЦФНаНачалоПериода;
	КонецЕсли;

	Если ПараметрыРасчета.ЗаполнитьНУ Тогда
		Объект.ПараметрыЗаПериодНУ.Очистить();
		ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ПараметрыДляРасчета.ПараметрыЗаПериодНУ, Объект.ПараметрыЗаПериодНУ);
	КонецЕсли;
	
	//-- Локализация
	
КонецПроцедуры

Процедура НачатьРасчетАмортизацииПоЗаданнымПараметрам(Объект, РазделУчета) Экспорт
	
	//++ Локализация

	ТаблицыРасчета = Новый Структура;

	Если РазделУчета <> Неопределено Тогда
		
		СписокРазделовУчета = СтрРазделить(РазделУчета, ",");
	
	Иначе
		
		СписокРазделовУчета = Новый Массив;
		СписокРазделовУчета.Добавить("НУ");
		
	КонецЕсли;

	Если СписокРазделовУчета.Найти("НУ") <> Неопределено Тогда
		ТаблицыРасчета.Вставить("ПараметрыЗаПериодНУ", Объект.ПараметрыЗаПериодНУ.Выгрузить());
	КонецЕсли;
	
	ОсновноеСредство = ВнеоборотныеАктивыСлужебный.ПервоеЗаполненноеЗначениеВТаблице(
		Объект.ОС, "ОсновноеСредство", Справочники.ОбъектыЭксплуатации.ПустаяСсылка());
	
	ПараметрыРасчета = Новый Структура;
	ПараметрыРасчета.Вставить("Организация", Объект.Организация);
	ПараметрыРасчета.Вставить("ОсновноеСредство", ОсновноеСредство);
	ПараметрыРасчета.Вставить("ДатаВводаВЭксплуатациюНУ", Объект.ДатаВводаВЭксплуатациюНУ);
	ПараметрыРасчета.Вставить("АмортизацияНУНаНачалоПериода", Объект.АмортизацияНУНаНачалоПериода);
	ПараметрыРасчета.Вставить("АмортизацияДо2009", Объект.АмортизацияДо2009);
	ПараметрыРасчета.Вставить("ФактическийСрокИспользованияДо2009", Объект.ФактическийСрокИспользованияДо2009);
	
	РезультатРасчета = Документы.АмортизацияОС2_4.РассчитатьАмортизациюПоТаблице(ТаблицыРасчета, ПараметрыРасчета);
	
	Если РезультатРасчета.Свойство("РезультатРасчетаНУ") Тогда
		
		Для Каждого СтрокаПараметры Из Объект.ПараметрыЗаПериодНУ Цикл
			
			СтрокаАмортизация = РезультатРасчета.РезультатРасчетаНУ.Найти(СтрокаПараметры.Дата, "Период");
			
			Если СтрокаАмортизация <> Неопределено Тогда
				СтрокаПараметры.АмортизацияНУ = СтрокаАмортизация.АмортизацияНУ;
			Иначе
				СтрокаПараметры.АмортизацияНУ = 0;
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	//-- Локализация
	
КонецПроцедуры

#КонецОбласти

//++ Локализация

#Область Локализация

Процедура ЗаполнитьНаОснованииПоступленияАрендованныхОС(Объект, Основание, СтандартнаяОбработка)

	СтандартнаяОбработка = Ложь;
	
	Объект.ДокументОснование = Основание;
	Объект.ВидИмущества = Перечисления.ВидыИмущества.Арендованное;
	Объект.ОтражатьВУпрУчете = Ложь;
	Объект.ОтражатьВРеглУчете = Истина;
	Объект.ОтражатьВБУ = Истина;
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	ТабличнаяЧасть.ОсновноеСредство КАК ОсновноеСредство
	|ИЗ
	|	Документ.ПоступлениеАрендованныхОС.ОС КАК ТабличнаяЧасть
	|ГДЕ
	|	ТабличнаяЧасть.Ссылка = &Основание
	|
	|УПОРЯДОЧИТЬ ПО
	|	ТабличнаяЧасть.НомерСтроки";
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("Основание", Основание);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если Не РезультатЗапроса.Пустой() Тогда
		
		Объект.ОС.Загрузить(РезультатЗапроса.Выгрузить());
		
		ПервоначальныеСведения = Справочники.ОбъектыЭксплуатации.ПервоначальныеСведения(Объект.ОС[0].ОсновноеСредство);
		Объект.Организация = ПервоначальныеСведения.Организация;
		Объект.Подразделение = ПервоначальныеСведения.Местонахождение;
		
		Документы.КорректировкаСтоимостиИАмортизацииОС.ЗаполнитьПоДаннымУчета(Объект);
		
	КонецЕсли; 
	
КонецПроцедуры

Функция ЗаполнитьДляПримененияИНВ(Объект, Основание)
	
	Если НЕ ЗначениеЗаполнено(Основание) Тогда
		Возврат Истина;
	КонецЕсли;
	
	// Заполнение документа для сценария с применением инвестиционного налогового вычета.
	// Выполняется когда ранее вычет не применялся и требуется скорректировать стоимость и амортизацию.
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	ТабличнаяЧасть.Ссылка.Дата КАК Дата,
	|	ТабличнаяЧасть.ОсновноеСредство КАК ОсновноеСредство
	|
	|ПОМЕСТИТЬ ТаблицаОС
	|
	|ИЗ
	|	Документ.ИзменениеПараметровОС2_4.ОС КАК ТабличнаяЧасть
	|
	|ГДЕ
	|	ТабличнаяЧасть.Ссылка = &Основание
	|	И ТабличнаяЧасть.Ссылка.ОтражатьВНУ
	|	И ТабличнаяЧасть.Ссылка.ИнвестиционныйНалоговыйВычетФлаг
	|	И ТабличнаяЧасть.Ссылка.ИнвестиционныйНалоговыйВычет В (
	|		ЗНАЧЕНИЕ(Перечисление.ВариантыПримененияИНВ.Региональный),
	|		ЗНАЧЕНИЕ(Перечисление.ВариантыПримененияИНВ.Федеральный))
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Дата,
	|	ОсновноеСредство
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СрезРегистратор.ОсновноеСредство КАК ОсновноеСредство,
	|	ДанныеРегистра.ИнвестиционныйНалоговыйВычет КАК ИнвестиционныйНалоговыйВычет
	|
	|ПОМЕСТИТЬ ПорядокУчетаОСБУ
	|
	|ИЗ
	|	(ВЫБРАТЬ
	|		СрезПериод.ОсновноеСредство КАК ОсновноеСредство,
	|		СрезПериод.ДанныеРегистраПериод КАК ДанныеРегистраПериод,
	|		МАКСИМУМ(ДанныеРегистра.Регистратор) КАК ДанныеРегистраРегистратор
	|	ИЗ
	|		(ВЫБРАТЬ
	|			ТаблицаОС.ОсновноеСредство КАК ОсновноеСредство,
	|			МАКСИМУМ(ДанныеРегистра.Период) КАК ДанныеРегистраПериод
	|		ИЗ
	|			ТаблицаОС КАК ТаблицаОС
	|
	|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ПорядокУчетаОСБУ КАК ДанныеРегистра
	|				ПО ДанныеРегистра.Период < ТаблицаОС.Дата
	|					И ДанныеРегистра.ОсновноеСредство = ТаблицаОС.ОсновноеСредство
	|					И ДанныеРегистра.Регистратор <> &Основание
	|					И ДанныеРегистра.Активность
	|
	|		СГРУППИРОВАТЬ ПО
	|			ТаблицаОС.ОсновноеСредство
	|
	|		) КАК СрезПериод
	|		
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ПорядокУчетаОСБУ КАК ДанныеРегистра
	|			ПО ДанныеРегистра.Период = СрезПериод.ДанныеРегистраПериод
	|				И ДанныеРегистра.ОсновноеСредство = СрезПериод.ОсновноеСредство
	|				И ДанныеРегистра.Регистратор <> &Основание
	|				И ДанныеРегистра.Активность
	|
	|	СГРУППИРОВАТЬ ПО
	|		СрезПериод.ОсновноеСредство,
	|		СрезПериод.ДанныеРегистраПериод
	|
	|	) КАК СрезРегистратор
	|
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ПорядокУчетаОСБУ КАК ДанныеРегистра
	|		ПО ДанныеРегистра.Период = СрезРегистратор.ДанныеРегистраПериод
	|			И ДанныеРегистра.Регистратор = СрезРегистратор.ДанныеРегистраРегистратор
	|			И ДанныеРегистра.ОсновноеСредство = СрезРегистратор.ОсновноеСредство
	|			И ДанныеРегистра.Активность
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВложенныйЗапрос.ОсновноеСредство КАК ОсновноеСредство,
	|	СУММА(ВложенныйЗапрос.СуммаАмортизационнойПремииКВ) КАК СуммаАмортизационнойПремииКВ,
	|	СУММА(ВложенныйЗапрос.СуммаАмортизационнойПремииВключеннойВРасходы) КАК СуммаАмортизационнойПремииВключеннойВРасходы
	|ИЗ
	|	(ВЫБРАТЬ
	|		СтоимостьОСОбороты.ОсновноеСредство КАК ОсновноеСредство,
	|		СтоимостьОСОбороты.АмортизационнаяПремияПриход КАК СуммаАмортизационнойПремииКВ,
	|		СтоимостьОСОбороты.АмортизационнаяПремияРасход КАК СуммаАмортизационнойПремииВключеннойВРасходы
	|	ИЗ
	|		РегистрНакопления.СтоимостьОС.Обороты(
	|				,
	|				&КонецПериода,
	|				,
	|				ОсновноеСредство В
	|					(ВЫБРАТЬ
	|						ТаблицаОС.ОсновноеСредство
	|					ИЗ
	|						ТаблицаОС КАК ТаблицаОС)) КАК СтоимостьОСОбороты
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		СтоимостьОС.ОсновноеСредство КАК ОсновноеСредство,
	|		0 КАК СуммаАмортизационнойПремииКВ,
	|
	|		ВЫБОР
	|			КОГДА СтоимостьОС.НастройкаХозяйственнойОперации = ЗНАЧЕНИЕ(Справочник.НастройкиХозяйственныхОпераций.ВключениеАмортизационнойПремииВРасходы)
	|				ТОГДА СтоимостьОС.СтоимостьНУ
	|			ИНАЧЕ -СтоимостьОС.СтоимостьНУ
	|		КОНЕЦ КАК СуммаАмортизационнойПремииВключеннойВРасходы
	|	ИЗ
	|		РегистрНакопления.СтоимостьОС КАК СтоимостьОС
	|
	|	ГДЕ
	|		СтоимостьОС.Период <= &КонецПериода
	|		И СтоимостьОС.Регистратор <> &Ссылка
	|		И СтоимостьОС.Регистратор ССЫЛКА Документ.КорректировкаСтоимостиИАмортизацииОС
	|		И СтоимостьОС.Активность
	|
	|		И СтоимостьОС.НастройкаХозяйственнойОперации В (
	|			ЗНАЧЕНИЕ(Справочник.НастройкиХозяйственныхОпераций.ВключениеАмортизационнойПремииВРасходы),
	|			ЗНАЧЕНИЕ(Справочник.НастройкиХозяйственныхОпераций.УменьшениеАмортизационнойПремии))
	|
	|		И СтоимостьОС.ОсновноеСредство В
	|					(ВЫБРАТЬ
	|						ТаблицаОС.ОсновноеСредство
	|					ИЗ
	|						ТаблицаОС КАК ТаблицаОС)
	|
	|	) КАК ВложенныйЗапрос
	|
	|СГРУППИРОВАТЬ ПО
	|	ВложенныйЗапрос.ОсновноеСредство
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеДокумента.Ссылка КАК ДокументОснование,
	|	ДанныеДокумента.Дата КАК Дата,
	|	ДанныеДокумента.СобытиеОС КАК СобытиеОС,
	|	ДанныеДокумента.ИнвестиционныйНалоговыйВычет КАК ИнвестиционныйНалоговыйВычет,
	|	ЛОЖЬ КАК ОтражатьВУпрУчете,
	|	ИСТИНА КАК ОтражатьВРеглУчете,
	|	ИСТИНА КАК ОтражатьВБУ,
	|	ИСТИНА КАК ОтражатьВНУ
	|
	|ИЗ
	|	Документ.ИзменениеПараметровОС2_4 КАК ДанныеДокумента
	|
	|ГДЕ
	|	ДанныеДокумента.Ссылка = &Основание
	|	И ДанныеДокумента.ИнвестиционныйНалоговыйВычетФлаг
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТабличнаяЧасть.ОсновноеСредство КАК ОсновноеСредство
	|ИЗ
	|	Документ.ИзменениеПараметровОС2_4.ОС КАК ТабличнаяЧасть
	|
	|		ЛЕВОЕ СОЕДИНЕНИЕ ПорядокУчетаОСБУ КАК ПорядокУчетаОСБУ
	|		ПО ПорядокУчетаОСБУ.ОсновноеСредство = ТабличнаяЧасть.ОсновноеСредство
	|
	|ГДЕ
	|	ТабличнаяЧасть.Ссылка = &Основание
	|	И ПорядокУчетаОСБУ.ИнвестиционныйНалоговыйВычет В (
	|		ЗНАЧЕНИЕ(Перечисление.ВариантыПримененияИНВ.НеПрименяется),
	|		ЗНАЧЕНИЕ(Перечисление.ВариантыПримененияИНВ.ПустаяСсылка))
	|
	|УПОРЯДОЧИТЬ ПО
	|	ТабличнаяЧасть.НомерСтроки
	|";
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("Основание", Основание);
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	Запрос.УстановитьПараметр("КонецПериода", НачалоМесяца(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Основание, "Дата"))-1);
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	Если РезультатЗапроса[РезультатЗапроса.ВГраница()].Пустой() Тогда
		Возврат Истина;
	КонецЕсли;
	
	Объект.ОС.Загрузить(РезультатЗапроса[РезультатЗапроса.ВГраница()].Выгрузить());

	ПервоначальныеСведения = Справочники.ОбъектыЭксплуатации.ПервоначальныеСведения(Объект.ОС[0].ОсновноеСредство);
	
	Если НЕ ЗначениеЗаполнено(ПервоначальныеСведения.ДатаВводаВЭксплуатациюНУ) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	АмортизационнаяПремия = РезультатЗапроса[РезультатЗапроса.ВГраница()-2].Выгрузить();
	СуммаАмортизационнойПремииВключеннойВРасходы = 
		?(АмортизационнаяПремия.Количество() <> 0, АмортизационнаяПремия[0].СуммаАмортизационнойПремииВключеннойВРасходы, 0);
	
	СуммаАмортизационнойПремииКВ = 
		?(АмортизационнаяПремия.Количество() <> 0, АмортизационнаяПремия[0].СуммаАмортизационнойПремииКВ, 0);
	
	Объект.ВидИмущества = Перечисления.ВидыИмущества.Собственное;
	
	ВыборкаРеквизиты = РезультатЗапроса[РезультатЗапроса.ВГраница()-1].Выбрать();
	ВыборкаРеквизиты.Следующий();
	ЗаполнитьЗначенияСвойств(Объект, ВыборкаРеквизиты);

	Объект.Дата = Мин(ВыборкаРеквизиты.Дата + 1, КонецДня(ВыборкаРеквизиты.Дата));
	Объект.Организация = ПервоначальныеСведения.Организация;
	Объект.Подразделение = ПервоначальныеСведения.Местонахождение;

	Объект.РежимИсправленияСПрошлойДаты = Истина;
	Объект.НачалоПериода = НачалоМесяца(ПервоначальныеСведения.ДатаВводаВЭксплуатациюНУ);
	
	Документы.КорректировкаСтоимостиИАмортизацииОС.ЗаполнитьПоДаннымУчета(Объект);
	
	КорректировкаВСледующемМесяце = НачалоМесяца(ПервоначальныеСведения.ДатаВводаВЭксплуатациюНУ) = ДобавитьМесяц(НачалоМесяца(Объект.Дата), -1);

	СтоимостьОтличается = Ложь;
	АмортизацияОтличается = Ложь;
	ТребуетсяКорректировкаАмортизационнойПремии = Ложь;
	
	ИсходныеЗначения = Новый Структура("ПервоначальнаяСтоимостьНУ,СтоимостьНУ,СтоимостьПР,АмортизацияНУ,АмортизацияПР");
	
	#Область ЗаполнениеПараметровКорректировки
	
	Объект.КорректировкаПервоначальнойСтоимости = Ложь;
	Объект.КорректировкаСтоимости = Истина;
	Объект.ОтражениеУвеличенияСтоимости = Ложь;
	Объект.ОтражениеУменьшенияСтоимости = Истина;
	Объект.ОтражениеИзмененияСтоимостиНУЗаСчетПР = Истина;
	Объект.КорректировкаАмортизации = Истина;
	Объект.ОтражениеУвеличенияАмортизации = Истина;
	Объект.ОтражениеУменьшенияАмортизации = Истина;
	Объект.ОтражениеУменьшенияАмортизацииСторно = Истина;
	Объект.РаздельнаяКорректировкаТекущегоИПрошлогоПериодов = Истина;
	Объект.ПараметрыРасходовСовпадаютСДаннымиУчетаУменьшениеСтоимости = Истина;
	Объект.ПараметрыРасходовСовпадаютСДаннымиУчетаУвеличениеАмортизации = Истина;
	Объект.ПараметрыРасходовСовпадаютСДаннымиУчетаУменьшениеАмортизации = Истина;
	Объект.ПараметрыРасходовСовпадаютСДаннымиУчетаУменьшениеАмортизацииТекущегоГода = Истина;
	Объект.ПараметрыРасходовСовпадаютСДаннымиУчетаУменьшениеДоходовЦФ = Истина;
	Объект.ВключаетАмортизациюТекущегоМесяца = Истина;
	Объект.КорректировкаАмортизационнойПремии = Истина;
	Объект.ОтражениеУменьшенияАмортизационнойПремии = Истина;
	Объект.ОтражениеУменьшенияАмортизационнойПремииСторно = Истина;
	Объект.ПараметрыРасходовСовпадаютСДаннымиУчетаАмортизационнаяПремия = Истина;
	Объект.ПараметрыРасходовСовпадаютСДаннымиУчетаУменьшениеАмортизационнойПремии = Истина;
	Объект.КорректировкаСуммыРасходовНУПриИНВ = Истина;
	Объект.КорректировкаПараметровРасчетаАмортизации = Ложь;
	Объект.ПрименениеЦелевогоФинансирования = ПервоначальныеСведения.ПрименениеЦелевогоФинансирования;

	#КонецОбласти

	#Область ЗаполнениеДокументаЕслиПрименяетсяФИНВ
	
	Если ВыборкаРеквизиты.ИнвестиционныйНалоговыйВычет = Перечисления.ВариантыПримененияИНВ.Федеральный Тогда
	
		//- Сумма расходов по ФИНВ равна стоимости в НУ
		//- Стоимость в НУ нужно уменьшить на сумму расходов по ФИНВ * доля расходов ИНВ %
		//- ПР в стоимости нужно увеличить на сумму расходов по ФИНВ * доля расходов ИНВ %
		//- Амортизация в НУ пересчитывается с даты принятия к учету, исходя из новой стоимости 
		//- ПР в амортизации нужно увеличить по правилам его расчета при начислении амортизации в БУ

		// Нужно рассчитать амортизацию за период исходя из стоимости НУ с учетом ФИНВ
		// Для расчета ПР в амортизации выполняется расчет амортизации в БУ исходя из суммы ПР с учетом ФИНВ
		
		Документы.КорректировкаСтоимостиИАмортизацииОС.ЗаполнитьПараметрыЗаПериод(Объект, "БУ,НУ");
		
		НастройкиУчетаНалогаНаПрибыль = НастройкиНалоговУчетныхПолитикПовтИсп.ДействующиеПараметрыНалоговУчетныхПолитик(
			"НастройкиУчетаНалогаНаПрибыль", Объект.Организация, Объект.Дата);
			
		Если НастройкиУчетаНалогаНаПрибыль <> Неопределено Тогда
			ДоляРасходовИНВ = НастройкиУчетаНалогаНаПрибыль.ДоляРасходовИНВ;
		Иначе
			ДоляРасходовИНВ = 0;
		КонецЕсли;
		
		Для Сч = 1 По Объект.ПараметрыЗаПериодБУ.Количество() Цикл
			
			ДанныеСтроки = Объект.ПараметрыЗаПериодБУ[Сч-1];
			
			Если Сч < 3 Тогда
				
				Если Объект.ПараметрыЗаПериодНУ.Количество() > 1 Тогда
					СтоимостьНУ = Объект.ПараметрыЗаПериодНУ[1].СтоимостьНУ;
					КорректировкаСтоимостиИНВ = Окр(СтоимостьНУ * ДоляРасходовИНВ / 100, 2);
					ДанныеСтроки.СтоимостьПР = ДанныеСтроки.СтоимостьПР + КорректировкаСтоимостиИНВ;
				КонецЕсли;
				
			Иначе	
				
				СтрокаНУ = Объект.ПараметрыЗаПериодНУ.Найти(НачалоДня(КонецМесяца(ДанныеСтроки.Дата)), "Дата");
				Если СтрокаНУ <> Неопределено Тогда
					СтоимостьНУ = СтрокаНУ.СтоимостьНУ + СуммаАмортизационнойПремииВключеннойВРасходы;
					КорректировкаСтоимостиИНВ = Окр(СтоимостьНУ * ДоляРасходовИНВ / 100, 2);
					ДанныеСтроки.СтоимостьПР = ДанныеСтроки.СтоимостьПР + КорректировкаСтоимостиИНВ;
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;

		Для Сч = 1 По Объект.ПараметрыЗаПериодНУ.Количество() Цикл
			
			ДанныеСтроки = Объект.ПараметрыЗаПериодНУ[Сч-1];
			
			Если ДанныеСтроки.СтоимостьНУ = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			Если Сч < 3 Тогда
				СтоимостьНУ = ДанныеСтроки.СтоимостьНУ;
			Иначе
				СтоимостьНУ = ДанныеСтроки.СтоимостьНУ + СуммаАмортизационнойПремииВключеннойВРасходы;
			КонецЕсли;
			
			КорректировкаСтоимостиИНВ = Окр(СтоимостьНУ * ДоляРасходовИНВ / 100, 2);
			ДанныеСтроки.СтоимостьНУ = ДанныеСтроки.СтоимостьНУ - КорректировкаСтоимостиИНВ;
			
		КонецЦикла;
		
		Если КорректировкаВСледующемМесяце
			И СуммаАмортизационнойПремииКВ <> 0
			И Объект.ПараметрыЗаПериодНУ.Количество() > 2 Тогда
			
			СтрокаНУ = Объект.ПараметрыЗаПериодНУ[1];
			СтрокаНУ.СтоимостьНУ = СтрокаНУ.СтоимостьНУ - СуммаАмортизационнойПремииКВ; 
		КонецЕсли;

		Документы.КорректировкаСтоимостиИАмортизацииОС.НачатьРасчетАмортизацииПоЗаданнымПараметрам(Объект,, "БУ,НУ");
	
		АмортизацияНУ = 0;
		АмортизацияНаНачалоГодаНУ = 0;
		Для Каждого Элемент Из Объект.ПараметрыЗаПериодНУ Цикл
			Если Элемент.Дата < НачалоГода(Объект.Дата) Тогда
				АмортизацияНаНачалоГодаНУ = АмортизацияНаНачалоГодаНУ + Элемент.АмортизацияНУ;
			Иначе
				АмортизацияНУ = АмортизацияНУ + Элемент.АмортизацияНУ;
			КонецЕсли;
		КонецЦикла;
	
		АмортизацияПР = 0;
		АмортизацияНаНачалоГодаПР = 0;
		Для Каждого Элемент Из Объект.ПараметрыЗаПериодБУ Цикл
			Если Элемент.Дата < НачалоГода(Объект.Дата) Тогда
				АмортизацияНаНачалоГодаПР = АмортизацияНаНачалоГодаПР + Элемент.АмортизацияПР;
			Иначе
				АмортизацияПР = АмортизацияПР + Элемент.АмортизацияПР;
			КонецЕсли;
		КонецЦикла;
		
		Для Каждого ДанныеСтроки Из Объект.ОС Цикл
			
			ЗаполнитьЗначенияСвойств(ИсходныеЗначения, ДанныеСтроки);
			
			СтоимостьНУ = ДанныеСтроки.СтоимостьНУ + СуммаАмортизационнойПремииВключеннойВРасходы;
			
			КорректировкаСтоимостиИНВ = Окр(СтоимостьНУ * ДоляРасходовИНВ / 100, 2);
			
			ДанныеСтроки.СтоимостьНУ = ДанныеСтроки.СтоимостьНУ - КорректировкаСтоимостиИНВ;
			ДанныеСтроки.СтоимостьПР = ДанныеСтроки.СтоимостьПР + КорректировкаСтоимостиИНВ;
			ДанныеСтроки.СуммаРасходовНУПриИНВ = СтоимостьНУ;
			
			Если КорректировкаВСледующемМесяце
				И СуммаАмортизационнойПремииКВ <> 0 Тогда
				ДанныеСтроки.СтоимостьНУ = ДанныеСтроки.СтоимостьНУ - СуммаАмортизационнойПремииКВ;
			КонецЕсли;
			
			ДанныеСтроки.АмортизацияНУ = АмортизацияНУ;
			ДанныеСтроки.АмортизацияНаНачалоГодаНУ = АмортизацияНаНачалоГодаНУ;
			
			ДанныеСтроки.АмортизацияПР = АмортизацияПР;
			ДанныеСтроки.АмортизацияНаНачалоГодаПР = АмортизацияНаНачалоГодаПР;
						
			Если ДанныеСтроки.СтоимостьНУ <> ИсходныеЗначения.СтоимостьНУ
				ИЛИ ДанныеСтроки.СтоимостьПР <> ИсходныеЗначения.СтоимостьПР Тогда
				
				СтоимостьОтличается = Истина;
			КонецЕсли;
			
			Если ДанныеСтроки.АмортизацияНУ <> ИсходныеЗначения.АмортизацияНУ
				ИЛИ ДанныеСтроки.АмортизацияПР <> ИсходныеЗначения.АмортизацияПР
				ИЛИ КорректировкаВСледующемМесяце Тогда
				
				АмортизацияОтличается = Истина;
			КонецЕсли;
			
		КонецЦикла;
	
	КонецЕсли;
	
	#КонецОбласти
	
	#Область ЗаполнениеДокументаЕслиПрименяетсяРИНВ
	
	Если ВыборкаРеквизиты.ИнвестиционныйНалоговыйВычет = Перечисления.ВариантыПримененияИНВ.Региональный Тогда
	
		//- Сумма расходов по РИНВ должна равняться исходной стоимости
		//- Стоимость и амортизация НУ должны быть нулевыми
		//- ПР в стоимости должен увеличиться на текущую стоимость в НУ
		//- ПР в амортизации нужно увеличить по правилам его расчета при начислении амортизации в БУ
		
		Документы.КорректировкаСтоимостиИАмортизацииОС.ЗаполнитьПараметрыЗаПериод(Объект, "БУ,НУ");
		
		Для Сч = 1 По Объект.ПараметрыЗаПериодБУ.Количество() Цикл
			
			ДанныеСтроки = Объект.ПараметрыЗаПериодБУ[Сч-1];
			
			Если Сч < 3 Тогда
				
				Если Объект.ПараметрыЗаПериодНУ.Количество() > 1 Тогда
					СтрокаНУ = Объект.ПараметрыЗаПериодНУ[1];
					КорректировкаСтоимостиИНВ = СтрокаНУ.СтоимостьНУ;
					ДанныеСтроки.СтоимостьПР = ДанныеСтроки.СтоимостьПР + КорректировкаСтоимостиИНВ;
				КонецЕсли;
				
			Иначе	
				
				СтрокаНУ = Объект.ПараметрыЗаПериодНУ.Найти(НачалоДня(КонецМесяца(ДанныеСтроки.Дата)), "Дата");
				Если СтрокаНУ <> Неопределено Тогда
					КорректировкаСтоимостиИНВ = СтрокаНУ.СтоимостьНУ + СуммаАмортизационнойПремииВключеннойВРасходы;
					ДанныеСтроки.СтоимостьПР = ДанныеСтроки.СтоимостьПР + КорректировкаСтоимостиИНВ;
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;
	
		Документы.КорректировкаСтоимостиИАмортизацииОС.НачатьРасчетАмортизацииПоЗаданнымПараметрам(Объект,, "БУ");
		
		АмортизацияПР = 0;
		АмортизацияНаНачалоГодаПР = 0;
		Для Каждого ДанныеСтроки Из Объект.ПараметрыЗаПериодБУ Цикл
			Если ДанныеСтроки.Дата < НачалоГода(Объект.Дата) Тогда
				АмортизацияНаНачалоГодаПР = АмортизацияНаНачалоГодаПР + ДанныеСтроки.АмортизацияПР;
			Иначе
				АмортизацияПР = АмортизацияПР + ДанныеСтроки.АмортизацияПР;
			КонецЕсли;
		КонецЦикла;
		
		Для Каждого ДанныеСтроки Из Объект.ОС Цикл
			
			ЗаполнитьЗначенияСвойств(ИсходныеЗначения, ДанныеСтроки);

			КорректировкаСтоимостиИНВ = ДанныеСтроки.СтоимостьНУ + СуммаАмортизационнойПремииВключеннойВРасходы;

			ДанныеСтроки.СтоимостьНУ = 0;
			ДанныеСтроки.СтоимостьПР = ДанныеСтроки.СтоимостьПР + КорректировкаСтоимостиИНВ;
			ДанныеСтроки.СуммаРасходовНУПриИНВ = КорректировкаСтоимостиИНВ;
			
			ДанныеСтроки.АмортизацияНУ = 0;
			ДанныеСтроки.АмортизацияНаНачалоГодаНУ = 0;
			
			ДанныеСтроки.АмортизацияПР = АмортизацияПР;
			ДанныеСтроки.АмортизацияНаНачалоГодаПР = АмортизацияНаНачалоГодаПР;
			
			Если СуммаАмортизационнойПремииВключеннойВРасходы <> 0 Тогда
				
				ДанныеСтроки.АмортизационнаяПремия = СуммаАмортизационнойПремииВключеннойВРасходы;
				ТребуетсяКорректировкаАмортизационнойПремии = Истина;
				
			ИначеЕсли КорректировкаВСледующемМесяце 
				И СуммаАмортизационнойПремииКВ <> 0 Тогда
					
				ДанныеСтроки.АмортизационнаяПремия = СуммаАмортизационнойПремииКВ;
				ТребуетсяКорректировкаАмортизационнойПремии = Истина;

			КонецЕсли;
			
			Если ДанныеСтроки.СтоимостьНУ <> ИсходныеЗначения.СтоимостьНУ
				ИЛИ ДанныеСтроки.СтоимостьПР <> ИсходныеЗначения.СтоимостьПР Тогда
				
				СтоимостьОтличается = Истина;
			КонецЕсли;
			
			Если ДанныеСтроки.АмортизацияНУ <> ИсходныеЗначения.АмортизацияНУ
				ИЛИ ДанныеСтроки.АмортизацияПР <> ИсходныеЗначения.АмортизацияПР
				ИЛИ КорректировкаВСледующемМесяце
					И СуммаАмортизационнойПремииКВ <> 0 Тогда
				
				АмортизацияОтличается = Истина;
			КонецЕсли;
			
		КонецЦикла;
	
		Объект.РежимИсправленияСПрошлойДаты = Ложь;
		Объект.НачалоПериода = '00010101';
	
	КонецЕсли;
	
	#КонецОбласти
		
	Объект.ОтражатьВБУ = Ложь;
	Объект.ОтражатьВНУ = Истина;
	Объект.ОтражатьВРеглУчете = Истина;
	Объект.ОтражатьВУпрУчете = Ложь;
	
	Объект.ПараметрыЗаПериод.Очистить();
	Объект.ПараметрыЗаПериодБУ.Очистить();
	
	Если КорректировкаВСледующемМесяце
		И СуммаАмортизационнойПремииКВ <> 0 Тогда
		// Чтобы отразилось включение ам. премии в расходы при начислении амортизации 
		Объект.ВключаетАмортизациюТекущегоМесяца = Ложь;
	КонецЕсли;
	
	// Сброс параметров, которые не изменились
	Если НЕ СтоимостьОтличается Тогда
		Объект.КорректировкаСтоимости = Ложь;
	КонецЕсли;
	
	Если НЕ АмортизацияОтличается Тогда
		Объект.КорректировкаАмортизации = Ложь;
	КонецЕсли;

	Если НЕ ТребуетсяКорректировкаАмортизационнойПремии Тогда
		Объект.КорректировкаАмортизационнойПремии = Ложь;
	КонецЕсли;

	Если ПервоначальныеСведения.ДатаВводаВЭксплуатациюНУ >= НачалоГода(Объект.Дата) Тогда
		Объект.РаздельнаяКорректировкаТекущегоИПрошлогоПериодов = Ложь;
	КонецЕсли;

	// Очистка зависимых реквизитов
	ПараметрыРеквизитовОбъекта = ВнеоборотныеАктивыКлиентСервер.ЗначенияСвойствЗависимыхРеквизитов_КорректировкаСтоимостиИАмортизацииОС(
		Объект, Документы.КорректировкаСтоимостиИАмортизацииОС.ВспомогательныеРеквизиты(Объект));
	
	ОбщегоНазначенияУТКлиентСервер.ОчиститьНеиспользуемыеРеквизиты(
		Объект, ПараметрыРеквизитовОбъекта, "ОС,ПараметрыЗаПериод,ПараметрыЗаПериодБУ,ПараметрыЗаПериодНУ");

	Возврат Ложь;
	
КонецФункции

#КонецОбласти

//-- Локализация

#КонецОбласти
