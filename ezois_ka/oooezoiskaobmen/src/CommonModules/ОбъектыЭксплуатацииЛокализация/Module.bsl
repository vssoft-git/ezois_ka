		Строка.СуммаПР = ЗначенияПоУмолчанию.СтоимостьПР-ЗначенияПоУмолчанию.АмортизацияПР;
		Строка.СуммаВР = ЗначенияПоУмолчанию.СтоимостьВР-ЗначенияПоУмолчанию.АмортизацияВР;
		Сведения2_2.Добавить(Строка);
		
	КонецЕсли;
	
	//-- Локализация
	
	Возврат Сведения2_2;
	
