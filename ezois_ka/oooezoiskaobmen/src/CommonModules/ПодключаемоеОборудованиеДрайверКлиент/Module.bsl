// Подключить встроенное ТС ПИоТ
// 
// Возвращаемое значение:
//   См. ВнешниеКомпонентыБПОКлиент.РезультатПодключения
//
Асинх Функция ПодключитьТСПИоТАсинх(ПараметрыПодключения) 
	
	ОписаниеКомпонентыПодключения = ПараметрыПодключенияТСПИоТ();
	ИмяОбъекта = ОписаниеКомпонентыПодключения.ИмяОбъекта;
	ПолноеИмяМакета = ОписаниеКомпонентыПодключения.ПолноеИмяМакета;
	
	Результат = ВнешниеКомпонентыБПОКлиент.РезультатПодключения();
	
	ОбъектКомпоненты = МенеджерОборудованияКлиент.ПодключенныйЭкземплярПИоТ(ПараметрыПодключения.ИдентификаторУстройства);
	Если ОбъектКомпоненты <> Неопределено Тогда   
		Результат.Подключено = Истина;
		Результат.ПодключаемыйМодуль = ОбъектКомпоненты;   
		Возврат Результат;
	КонецЕсли;         
	
	// На каждый экземпляр ПИоТ создаем в памяти свой уникальный объект внешней компоненты
	ПараметрыПодключенияВК = ВнешниеКомпонентыБПОКлиент.ПараметрыПодключения();
	ПараметрыПодключенияВК.Кэшировать = Ложь;
	
	// Пробуем подключиться через БСП загруженную ВК из справочника "Внешние компоненты"
	Если Не ОбщегоНазначенияБПОКлиентСервер.ЭтоМобильныйКлиент() И ОбщегоНазначенияБПОКлиент.ИспользуетсяБСП() Тогда
		РезультатПодключения = Ждать ВнешниеКомпонентыБПОКлиент.ПодключитьКомпонентуАсинх(ИмяОбъекта ,Неопределено, ПараметрыПодключенияВК);
	Иначе
		РезультатПодключения = Ждать ВнешниеКомпонентыБПОКлиент.ПодключитьКомпонентуИзМакетаАсинх(ИмяОбъекта ,Неопределено, ПараметрыПодключенияВК);
	КонецЕсли;     
	
	Если НЕ РезультатПодключения.Подключено Тогда
		
		// Загрузка и установка из макета БПО
		РезультатПодключения = Ждать ВнешниеКомпонентыБПОКлиент.ПодключитьКомпонентуИзМакетаАсинх(ИмяОбъекта, ПолноеИмяМакета, ПараметрыПодключенияВК);
		Если Не РезультатПодключения.Подключено Тогда
			
			РезультатУстановки = Ждать ВнешниеКомпонентыБПОКлиент.УстановитьКомпонентуИзМакетаАсинх(ПолноеИмяМакета); // Структура
			Если Не РезультатУстановки.Установлено Тогда
				Результат.Подключено = Ложь;
				Результат.ОписаниеОшибки = НСтр("ru = 'Ошибка установки ""1С:ТС ПИоТ""'");
				Возврат Результат;
			КонецЕсли;
		
			РезультатПодключения = Ждать ВнешниеКомпонентыБПОКлиент.ПодключитьКомпонентуИзМакетаАсинх(ИмяОбъекта, ПолноеИмяМакета, ПараметрыПодключенияВК);
			Если Не РезультатПодключения.Подключено Тогда
				Результат.Подключено = Ложь;
				Результат.ОписаниеОшибки = НСтр("ru = 'Ошибка подключения ""1С:ТС ПИоТ""'");
				Возврат Результат;
			КонецЕсли;
		КонецЕсли;                                     
		
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(Результат, РезультатПодключения);
	
	Попытка  
		ИДПИоТ = "";  
		ОбъектДрайвера = РезультатПодключения.ПодключаемыйМодуль;
		РезультатВызова = Ждать ОбъектДрайвера.ПодключитьПИоТАсинх(ИДПИоТ, ПараметрыПодключения.ТСПИоТПараметрыXML); // Структура       
		Если РезультатВызова.Значение Тогда
			МенеджерОборудованияКлиент.ДобавитьПодключенныйЭкземплярПИоТ(ПараметрыПодключения.ИдентификаторУстройства, ОбъектДрайвера);  
		Иначе
			РезультатВыполнения = Ждать ПолучитьОшибкуПИоТ(ОбъектДрайвера);  
			РезультатВыполнения.Вставить("Подключено", Ложь);
			Возврат РезультатВыполнения;
		КонецЕсли;     
		
	Исключение             
		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ОписаниеОшибки = ОписаниеОшибки = НСтр("ru='Ошибка инцицилизации ПИоТ'") + Символы.НПП + ТекстОшибки;
		Возврат ОшибкаВызоваДрайвера("Инициализация", ОписаниеОшибки);
	КонецПопытки;                     
	
	Возврат Результат; 
	
КонецФункции

