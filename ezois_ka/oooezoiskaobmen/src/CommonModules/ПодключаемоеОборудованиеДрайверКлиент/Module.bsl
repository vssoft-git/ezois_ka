Функция ПараметрыПодключенияТСПИоТ()
	
	ПараметрыПодключения = Новый Структура();
	ПараметрыПодключения.Вставить("ИмяОбъекта", "PIoT1C");
	ПараметрыПодключения.Вставить("ПолноеИмяМакета", "ОбщийМакет.Драйвер1СТСПИоТ");
