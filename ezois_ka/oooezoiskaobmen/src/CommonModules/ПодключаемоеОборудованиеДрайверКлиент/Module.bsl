		РезультатВыполнения = РезультатОперацииНаОборудовании(Ложь, ОписаниеОшибки); 
		Возврат РезультатВыполнения;
	КонецЕсли;
	
	ПроверкаАутентификацияПИоТ = МенеджерОборудованияКлиент.ПроверкаАутентификацияПИоТПройдена(ПараметрыПодключения.ИдентификаторУстройства);
	Если НЕ ПроверкаАутентификацияПИоТ Тогда      
		ВремРезультатВыполнения = Ждать НачатьРаботуПИоТ(ОбъектДрайвера, ПараметрыПодключения, ДанныеОперации);
		Если Не ВремРезультатВыполнения.Результат Тогда
			Возврат ВремРезультатВыполнения;
		КонецЕсли;
	КонецЕсли;
	
	Попытка                                
		РезультатПроверки = "";     
		РезультатПараметрыXML = ""; 
		СтатусСостоянияXML = "";   
		ЗаписьЛога = НачатьЗаписьЛогаОперации(ПараметрыПодключения, "PiotCheckKM", ВМассив(, ДанныеОперации.ЗапросJSON, РезультатПроверки, РезультатПараметрыXML, СтатусСостоянияXML));
		РезультатВызова = Ждать ОбъектДрайвера.ПроверкаКМПИоТАсинх(ПараметрыПодключения.ИДУстройства, ДанныеОперации.ЗапросJSON, РезультатПроверки, РезультатПараметрыXML, СтатусСостоянияXML); 
		ЗавершитьЗаписьЛогаОперации(ЗаписьЛога, РезультатВызова);
	Исключение
		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ЗавершитьЗаписьЛогаИсключением(ЗаписьЛога, ТекстОшибки);
		РезультатВыполнения = ОшибкаВызоваДрайвера("ПроверкаКМПИоТ", ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке())); 
		Возврат РезультатВыполнения;
	КонецПопытки;
	
	Если РезультатВызова.Значение Тогда              
		РезультатВыполнения = РезультатОперацииНаОборудовании(Истина);     
	Иначе
		ТекстОшибки = НСтр("ru = 'Проверка КМ в ТС ПИоТ не пройдена.'");
		РезультатВыполнения = Ждать ПолучитьОшибкуПИоТ(ОбъектДрайвера, ЗаписьЛога, ТекстОшибки);
	КонецЕсли;                                  
	РезультатПараметрыXML = РезультатВызова.Параметры[3];  
	СтатусСостоянияXML = РезультатВызова.Параметры[4];
	РезультатВыполнения.Вставить("РезультатПроверки"    , РезультатВызова.Параметры[2]);     
	РезультатВыполнения.Вставить("РезультатПараметрыXML", РезультатПараметрыXML);     
	РезультатВыполнения.Вставить("СтатусСостоянияXML"   , СтатусСостоянияXML);   
	РезультатВыполнения.Вставить("ЗапросПроверки"       , ДанныеОперации.ЗапросJSON);  
	
	Возврат РезультатВыполнения;
	
КонецФункции       

// Статус КМ ПИоТ
//
Асинх Функция СтатусПИоТ(ОбъектДрайвера, ПараметрыПодключения, ДанныеОперации);
	
	Если НЕ ПараметрыПодключения.ТипыОборудования.ККТ Или ПараметрыПодключения.РевизияИнтерфейса < 4005 Тогда
		ОписаниеОшибки = НСтр("ru='Драйвер не поддерживает операцию.'");
		ЗаписатьОшибкуВЛог(ПараметрыПодключения, "PiotStatus", ОписаниеОшибки);
		РезультатВыполнения = РезультатОперацииНаОборудовании(Ложь, ОписаниеОшибки);
		Возврат РезультатВыполнения;
	КонецЕсли;   
	
	ИспользоватьТСПИоТ = ПараметрыПодключения.Свойство("ИспользоватьТСПИоТ") И ПараметрыПодключения.ИспользоватьТСПИоТ;
	Если НЕ ИспользоватьТСПИоТ Тогда
		ОписаниеОшибки = НСтр("ru='Данная команда доступна только при использовании ""1С:ПИОТ""'");
		ЗаписатьОшибкуВЛог(ПараметрыПодключения, "PiotStatus", ОписаниеОшибки);
		РезультатВыполнения = РезультатОперацииНаОборудовании(Ложь, ОписаниеОшибки);
		Возврат РезультатВыполнения;
	КонецЕсли;
	
	ПроверкаАутентификацияПИоТ = МенеджерОборудованияКлиент.ПроверкаАутентификацияПИоТПройдена(ПараметрыПодключения.ИдентификаторУстройства);
	Если НЕ ПроверкаАутентификацияПИоТ Тогда      
		ОписаниеОшибки = НСтр("ru='Процедура аутентификация ""1С:ПИОТ"" ранее не была запущена.'");
		ЗаписатьОшибкуВЛог(ПараметрыПодключения, "PiotStatus", ОписаниеОшибки);
		РезультатВыполнения = РезультатОперацииНаОборудовании(Ложь, ОписаниеОшибки);
		Возврат РезультатВыполнения;
	КонецЕсли;

	Попытка                                
		СтатусСостояния = "";   
		ЗаписьЛога = НачатьЗаписьЛогаОперации(ПараметрыПодключения, "PiotStatus", ВМассив(, СтатусСостояния));
		РезультатВызова = Ждать ОбъектДрайвера.СтатусПИоТАсинх(ПараметрыПодключения.ИДУстройства, СтатусСостояния); 
		ЗавершитьЗаписьЛогаОперации(ЗаписьЛога, РезультатВызова);
	Исключение
		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ЗавершитьЗаписьЛогаИсключением(ЗаписьЛога, ТекстОшибки);
		РезультатВыполнения = ОшибкаВызоваДрайвера("PiotStatus", ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке())); 
		Возврат РезультатВыполнения;
	КонецПопытки;
	
	Если РезультатВызова.Значение Тогда              
		РезультатВыполнения = РезультатОперацииНаОборудовании(Истина);     
	Иначе
		ТекстОшибки = НСтр("ru = 'Ошибка определения состояния ТС ПИоТ'");
		РезультатВыполнения = Ждать ПолучитьОшибкуПИоТ(ОбъектДрайвера, ЗаписьЛога, ТекстОшибки);
	КонецЕсли;    
	РезультатВыполнения.Вставить("СтатусСостоянияXML", РезультатВызова.Параметры[1]); 
	
	Возврат РезультатВыполнения;
	
КонецФункции       

// Получить ошибку ПИоТ
//
Асинх Функция ПолучитьОшибкуПИоТ(ОбъектДрайвера, ЗаписьЛога = Неопределено, ОписаниеОшибки = Неопределено) 
	
	РезультатВызова = Ждать ОбъектДрайвера.ПолучитьОшибкуПИоТАсинх(""); // Структура    
	ТекстОшибки = РезультатВызова.Параметры[0];                               
	Если НЕ ПустаяСтрока(ОписаниеОшибки) Тогда
		ТекстОшибки = ОписаниеОшибки + Символы.ПС + ТекстОшибки;
	КонецЕсли;
	РезультатВыполнения = РезультатОперацииНаОборудовании(Ложь, ТекстОшибки);
	
	Если ЗаписьЛога <> Неопределено Тогда
		ЗаписатьОшибкуДрайвераВЛогОперации(ЗаписьЛога, РезультатВызова);
	КонецЕсли;
	
	Возврат РезультатВыполнения;
	
КонецФункции

// Возвращает cлужебную информацию ТС ПИоТ 
// 
// Параметры:
//  ОбъектДрайвера - ОбъектВнешнейКомпоненты 
//  ОписаниеДрайвера - Структура
//  ПараметрыПодключения - Структура
// 
// Возвращаемое значение:
//  Булево      
//
Асинх Функция СлужебнаяИнформацияПИоТ(ОбъектДрайвера, ПараметрыПодключения, ДанныеОперации) Экспорт
	
	Если НЕ ПараметрыПодключения.ТипыОборудования.ККТ Или ПараметрыПодключения.РевизияИнтерфейса < 4005 Тогда
		ОписаниеОшибки = НСтр("ru='Драйвер не поддерживает операцию.'");
		ЗаписатьОшибкуВЛог(ПараметрыПодключения, "СлужебнаяИнформацияПИоТ", ОписаниеОшибки);
		РезультатВыполнения = РезультатОперацииНаОборудовании(Ложь, ОписаниеОшибки);
		Возврат РезультатВыполнения;
	КонецЕсли;   
	
	ИспользоватьТСПИоТ = ПараметрыПодключения.Свойство("ИспользоватьТСПИоТ") И ПараметрыПодключения.ИспользоватьТСПИоТ;
	Если НЕ ИспользоватьТСПИоТ Тогда
		ОписаниеОшибки = НСтр("ru='Данная команда доступна только при использовании ""1С:ПИОТ""'");
		ЗаписатьОшибкуВЛог(ПараметрыПодключения, "PiotStatus", ОписаниеОшибки);
		РезультатВыполнения = РезультатОперацииНаОборудовании(Ложь, ОписаниеОшибки);
		Возврат РезультатВыполнения;
	КонецЕсли;

	Попытка
		СлужебнаяИнформация = "";   
		ЗаписьЛога = НачатьЗаписьЛогаОперации(ПараметрыПодключения, "СлужебнаяИнформацияПИоТ", ВМассив(, СлужебнаяИнформация));
		РезультатВызова = Ждать ОбъектДрайвера.СлужебнаяИнформацияПИоТАсинх(ПараметрыПодключения.ИДУстройства, СлужебнаяИнформация); 
		ЗавершитьЗаписьЛогаОперации(ЗаписьЛога, РезультатВызова);
	Исключение
		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ЗавершитьЗаписьЛогаИсключением(ЗаписьЛога, ТекстОшибки);
		ОписаниеОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		Возврат Ложь;
	КонецПопытки;
	
	Если РезультатВызова.Значение Тогда              
		РезультатВыполнения = РезультатОперацииНаОборудовании(Истина);     
		РезультатВыполнения.Вставить("СлужебнаяИнформацияXML", РезультатВызова.Параметры[1]);
	Иначе
		ТекстОшибки = НСтр("ru = 'Служебная информация ПИоТ не получена.'");
		РезультатВыполнения = Ждать ПолучитьОшибкуПИоТ(ОбъектДрайвера, ЗаписьЛога, ТекстОшибки);
	КонецЕсли;    
	
	Возврат РезультатВыполнения;
	
КонецФункции   

// Снять экземпляр ПИоТ с регистрации 
//
Асинх Функция СнятьЭкземплярСРегистрацииПИоТ(ОбъектДрайвера, ПараметрыПодключения, ДанныеОперации);
	
	Если НЕ ПараметрыПодключения.ТипыОборудования.ККТ Или ПараметрыПодключения.РевизияИнтерфейса < 4005 Тогда
		ОписаниеОшибки = НСтр("ru='Драйвер не поддерживает операцию.'");
		ЗаписатьОшибкуВЛог(ПараметрыПодключения, "PiotUnregister", ОписаниеОшибки);
		РезультатВыполнения = РезультатОперацииНаОборудовании(Ложь, ОписаниеОшибки);
		Возврат РезультатВыполнения;
	КонецЕсли;  
	
	ИспользоватьТСПИоТ = ПараметрыПодключения.Свойство("ИспользоватьТСПИоТ") И ПараметрыПодключения.ИспользоватьТСПИоТ;
	Если НЕ ИспользоватьТСПИоТ Тогда
		ОписаниеОшибки = НСтр("ru='Данная команда доступна только при использовании ""1С:ТС ПИоТ""'");
		ЗаписатьОшибкуВЛог(ПараметрыПодключения, "PiotUnregister", ОписаниеОшибки);
		РезультатВыполнения = РезультатОперацииНаОборудовании(Ложь, ОписаниеОшибки);
		Возврат РезультатВыполнения;
	КонецЕсли;
	
	Попытка                                
		ЗаписьЛога = НачатьЗаписьЛогаОперации(ПараметрыПодключения, "PiotUnregister", ВМассив(,));
		РезультатВызова = Ждать ОбъектДрайвера.СнятьЭкземплярСРегистрацииПИоТАсинх(ПараметрыПодключения.ИДУстройства); 
		ЗавершитьЗаписьЛогаОперации(ЗаписьЛога, РезультатВызова);
	Исключение
		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()); 
		ЗавершитьЗаписьЛогаИсключением(ЗаписьЛога, ТекстОшибки);
		РезультатВыполнения = ОшибкаВызоваДрайвера("СнятьЭкземплярСРегистрацииПИоТ", ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке())); 
		Возврат РезультатВыполнения;
	КонецПопытки;
	
	Если РезультатВызова.Значение Тогда              
		РезультатВыполнения = РезультатОперацииНаОборудовании(Истина);         
	Иначе                                                       
		РезультатВыполнения = Ждать ПолучитьОшибкуПИоТ(ОбъектДрайвера, ЗаписьЛога);
	КонецЕсли;
	
	Возврат РезультатВыполнения;
	
КонецФункции 

