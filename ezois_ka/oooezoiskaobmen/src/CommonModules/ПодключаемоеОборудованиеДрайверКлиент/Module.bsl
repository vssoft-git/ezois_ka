				ЗавершитьЗаписьЛогаОперации(ЗаписьЛога, РезультатВызова);
				
			ИначеЕсли Команда = "AuthorizeVoid" Тогда
				
				ЗаписьЛога = НачатьЗаписьЛогаОперации(ПараметрыПодключения, "CancelPaymentByPaymentCard", 
