Процедура ДобавитьСтрокиДерева(Комплектации, ДЗ, НоменклатураСборки, ХарактеристикаСборки, Родитель, Комплектация = Неопределено, ИД = "",НомерСтроки=0, КоличествоРодителя = 1)
    
    
    //если это не автосборка Если НоменклатураСборки.... тогда Возврат КонецЕсли;
    Если Комплектация = Неопределено тогда
        Комплектация = Комплектации.НайтиСтроки(новый Структура("НоменклатураОсн, ХарактеристикаОсн",НоменклатураСборки, ХарактеристикаСборки));
    КонецЕсли;
    Порядок = 0;
    Для Каждого стр из Комплектация цикл
        
        мКомплектация = Комплектации.найтистроки(новый Структура("НоменклатураОсн, ХарактеристикаОсн",стр.Номенклатура,стр.Характеристика));
        Если ВариантФормирования = "Иерархия"  или  
            ВариантФормирования <> "Иерархия"  и  мКомплектация.количество() = 0 тогда
            Порядок = Порядок + 1;
            нСтр1 = Родитель.Строки.Добавить();
            Если ВариантФормирования = "Иерархия" тогда 
                Родитель.Комплектация = стр.Ссылка; 
            иначе
                нСтр1.Комплектация = стр.Ссылка; 
            КонецЕсли;
            нСтр1.Номенклатура = стр.Номенклатура; 
			нСтр1.Характеристика = стр.Характеристика;
            нСтр1.Количество = стр.Количество * КоличествоРодителя / стр.ссылка.Количество ;
            нСтр1.Количество2 = стр.Количество  ;
            нСтр1.Цена = стр.Цена ;
            нСтр1.Ид_ = ?(ВариантФормирования = "Иерархия", ИД + ?(ИД <> "", ".","") + формат(Порядок,"ЧГ = 0"),НомерСтроки);
            нСтр1.РодительИД = ?(ВариантФормирования = "Иерархия",Родитель.ИД,0);
            НомерСтроки = НомерСтроки + 1;
            нСтр1.ИД = НомерСтроки;
            
            нСтр1.КоличествоМатериалов =  0;
            нСтр1.Сумма =  0;           
            Если мКомплектация.количество() тогда 
                //если есть комплектация, то добавим в дерево и заполним материалы для нее в рекурсии
                ДобавитьСтрокиДерева(Комплектации, ДЗ, стр.Номенклатура, стр.Характеристика, нСтр1, мКомплектация, нСтр1.Ид_ ,НомерСтроки,нСтр1.Количество);
                для Каждого стр1 из  нСтр1.Строки цикл
                    нСтр1.КоличествоМатериалов = нСтр1.КоличествоМатериалов + стр1.КоличествоМатериалов;
                    нСтр1.Сумма =  нСтр1.Сумма + стр1.Сумма; ;
                КонецЦикла;
            Иначе 
                нСтр1.КоличествоМатериалов =  нСтр1.Количество  ;
                нСтр1.Сумма =  нСтр1.Количество * нСтр1.Цена;
            КонецЕсли;
            стр2 = Материалы.Добавить();
            стр2.Номенклатура 	=  нСтр1.Номенклатура;
			стр2.Характеристика =  нСтр1.Характеристика;
            стр2.Количество 	=  нСтр1.Количество;

		Иначе
			
            ДобавитьСтрокиДерева(Комплектации, ДЗ, стр.Номенклатура, стр.Характеристика, Родитель, мКомплектация,"" ,НомерСтроки,стр.Количество * КоличествоРодителя / стр.ссылка.Количество);
            
        КонецЕсли;
        
        
    КонецЦикла;
    
    
КонецПроцедуры

Процедура СформироватьТабличныйДокументНаСервере(ДанныеДерева,ТабДокумент,ДанныеРасшифровки)
    
    //ТабДокумент = Новый ТабличныйДокумент;
    
    
    ИсточникиДанных = Новый Структура("ДанныеДерева", ДанныеДерева);
    СхемаКомпоновки = ПолучитьМакет("ОсновнаяСхемаКомпоновкиДанных");
    
    КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
    МакетКомпоновки = КомпоновщикМакета.Выполнить(СхемаКомпоновки, КомпоновщикНастроек.ПолучитьНастройки(),ДанныеРасшифровки);
    
    ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;	
    ПроцессорКомпоновки.Инициализировать(МакетКомпоновки, ИсточникиДанных,ДанныеРасшифровки);
    
    ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВТабличныйДокумент;
    ПроцессорВывода.УстановитьДокумент(ТабДокумент);
    ПроцессорВывода.Вывести(ПроцессорКомпоновки);
    
КонецПроцедуры

Функция СведенияОВнешнейОбработке() Экспорт
    
    ПараметрыРегистрации = ДополнительныеОтчетыИОбработки.СведенияОВнешнейОбработке("2.1.1.10");
    ПараметрыРегистрации.Вид = ДополнительныеОтчетыИОбработкиКлиентСервер.ВидОбработкиДополнительныйОтчет();
    ПараметрыРегистрации.Версия = "1.0";
    ПараметрыРегистрации.БезопасныйРежим = Ложь;
    НоваяКоманда = ПараметрыРегистрации.Команды.Добавить();
    НоваяКоманда.Представление = НСтр("ru = 'Структура узлов'");
    НоваяКоманда.Идентификатор = "СтруктураУзлов";
    НоваяКоманда.Использование = ДополнительныеОтчетыИОбработкиКлиентСервер.ТипКомандыВызовСерверногоМетода();
    НоваяКоманда.ПоказыватьОповещение = Истина;
    
    Возврат ПараметрыРегистрации;
    
КонецФункции

