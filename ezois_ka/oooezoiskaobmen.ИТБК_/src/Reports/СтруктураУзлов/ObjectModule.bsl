
Процедура ПриКомпоновкеРезультата(ДокументРезультат, ДанныеРасшифровки, СтандартнаяОбработка)
    ВариантКомплектации = КомпоновщикНастроек.ПолучитьНастройки().ПараметрыДанных.Элементы.Найти("ВариантКомплектации").Значение;
    ВариантФормирования = КомпоновщикНастроек.ПолучитьНастройки().ПараметрыДанных.Элементы.Найти("ВариантФормирования").Значение;
    СтандартнаяОбработка = Ложь;
    ДЗ = новый ДеревоЗначений;
    Дз.Колонки.Добавить("Номенклатура", новый ОписаниеТипов("СправочникСсылка.Номенклатура"),"Номенклатура");
    Дз.Колонки.Добавить("Характеристика", новый ОписаниеТипов("СправочникСсылка.ХарактеристикиНоменклатуры"),"Характеристика");
    Дз.Колонки.Добавить("ИД_",новый ОписаниеТипов("строка"),"ИД");
    Дз.Колонки.Добавить("РодительИД", новый ОписаниеТипов("Число"),"РодительИД");
    Дз.Колонки.Добавить("ИД",новый ОписаниеТипов("Число"),"ИД");
    Дз.Колонки.Добавить("Комплектация",новый ОписаниеТипов("СправочникСсылка.ВариантыКомплектацииНоменклатуры"),"Комплектация");
    Дз.Колонки.Добавить("Количество",новый ОписаниеТипов("Число"),"Количество");
    Дз.Колонки.Добавить("Количество2",новый ОписаниеТипов("Число"),"Количество");
    Дз.Колонки.Добавить("Всего",новый ОписаниеТипов("Число"),"Количество");
    Дз.Колонки.Добавить("КоличествоМатериалов",новый ОписаниеТипов("Число"),"Количество");
    Дз.Колонки.Добавить("Цена",новый ОписаниеТипов("Число"),"Количество");
    Дз.Колонки.Добавить("Сумма",новый ОписаниеТипов("Число"),"Количество");
    Материалы.Очистить();
    ЗаполнитьДерево(ДЗ);
    Материалы.Свернуть("Номенклатура","Количество");
    
    Если ВариантФормирования = "Иерархия"  Тогда   
        ЗаполнитьВсего(ДЗ);
    КонецЕсли;
    
    СформироватьТабличныйДокументНаСервере(ДЗ,ДокументРезультат,ДанныеРасшифровки);
    
КонецПроцедуры

Процедура ЗаполнитьВсего(Род)
    
    для Каждого стр из Род.Строки цикл
        ЗаполнитьВсего(стр);
        стр.Всего = Материалы.Найти(стр.номенклатура).Количество; 
    КонецЦикла;
    
КонецПроцедуры	

Процедура ЗаполнитьДерево(ДЗ)
    
    ЗаполнитьДеревоСервер(ДЗ);
    
КонецПроцедуры	

