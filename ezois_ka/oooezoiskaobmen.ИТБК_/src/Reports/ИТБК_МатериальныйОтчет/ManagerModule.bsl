Функция ПолучитьВыпускПродукции(ДатаНачала, ДатаОкончания, ГотоваяПродукция, СборкаИзКомплектующих) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ТоварыОрганизаций.Номенклатура КАК Номенклатура,
	|	ТоварыОрганизаций.Регистратор КАК ДокументСборки,
	|	СУММА(ТоварыОрганизаций.Количество) КАК Количество
	|ИЗ
	|	РегистрНакопления.ТоварыОрганизаций КАК ТоварыОрганизаций
	|ГДЕ
	|	ТоварыОрганизаций.Активность
	|	И ТоварыОрганизаций.Период МЕЖДУ &ДатаНачала И &ДатаОкончания
	|	И ТоварыОрганизаций.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|	И ТоварыОрганизаций.АналитикаУчетаНоменклатуры.Номенклатура.Родитель = &ГотоваяПродукция
	|	И ТоварыОрганизаций.ХозяйственнаяОперация = &СборкаИзКомплектующих
	|
	|СГРУППИРОВАТЬ ПО
	|	ТоварыОрганизаций.Номенклатура,
	|	ТоварыОрганизаций.Регистратор");
	
	Запрос.УстановитьПараметр("ДатаНачала"           , ДатаНачала);
	Запрос.УстановитьПараметр("ДатаОкончания"        , ДатаОкончания);
	Запрос.УстановитьПараметр("ГотоваяПродукция"     , ГотоваяПродукция);
	Запрос.УстановитьПараметр("СборкаИзКомплектующих", СборкаИзКомплектующих);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции // ПолучитьВыпускПродукции()

Функция ТекстЗапросаРазблюдовкаПоСпецификациям()
	
	Возврат "ВЫБРАТЬ
	        |	ВариантыКомплектацииНоменклатурыТовары.Ссылка.Владелец КАК Номенклатура,
	        |	ВариантыКомплектацииНоменклатурыТовары.Ссылка.Количество КАК Количество,
	        |	ВариантыКомплектацииНоменклатурыТовары.Номенклатура КАК Комплектующее,
	        |	ВариантыКомплектацииНоменклатурыТовары.Количество КАК КоличествоКомплектующих,
	        |	ЕСТЬNULL(ВариантыКомплектацииНоменклатуры.Ссылка, ЗНАЧЕНИЕ(Справочник.ВариантыКомплектацииНоменклатуры.ПустаяСсылка)) КАК ВариантКомплектации,
	        |	ВЫБОР
	        |		КОГДА ЕСТЬNULL(ВариантыКомплектацииНоменклатуры.Ссылка, ЗНАЧЕНИЕ(Справочник.ВариантыКомплектацииНоменклатуры.ПустаяСсылка)) = ЗНАЧЕНИЕ(Справочник.ВариантыКомплектацииНоменклатуры.ПустаяСсылка)
	        |			ТОГДА ЛОЖЬ
	        |		ИНАЧЕ ИСТИНА
	        |	КОНЕЦ КАК ВариантКомплектацииУказан
	        |ИЗ
	        |	Справочник.ВариантыКомплектацииНоменклатуры.Товары КАК ВариантыКомплектацииНоменклатурыТовары
	        |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВариантыКомплектацииНоменклатуры КАК ВариантыКомплектацииНоменклатуры
	        |		ПО ВариантыКомплектацииНоменклатурыТовары.Номенклатура = ВариантыКомплектацииНоменклатуры.Владелец
	        |			И (ВариантыКомплектацииНоменклатуры.Основной)
	        |			И (НЕ ВариантыКомплектацииНоменклатуры.ПометкаУдаления)
	        |ГДЕ
	        |	ВариантыКомплектацииНоменклатурыТовары.Ссылка В(&ВариантыКомплектации)";	
	
КонецФункции // ТекстЗапросаРазблюдовкаПоСпецификациям()

Функция ТекстЗапросаРазблюдовкаПоСериям()
	
	Возврат "ВЫБРАТЬ
	        |	ТЗСерииНоменклатуры.Номенклатура КАК Номенклатура,
	        |	ТЗСерииНоменклатуры.Серия КАК Серия
	        |ПОМЕСТИТЬ ВТСерииНоменклатуры
	        |ИЗ
	        |	&ТЗСерииНоменклатуры КАК ТЗСерииНоменклатуры
	        |
	        |ИНДЕКСИРОВАТЬ ПО
	        |	Номенклатура,
	        |	Серия
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
	        |	ТоварыНаСкладах.Регистратор КАК Регистратор,
	        |	ТоварыНаСкладах.Номенклатура КАК Номенклатура,
	        |	ТоварыНаСкладах.Серия КАК Серия,
	        |	СУММА(ТоварыНаСкладах.ВНаличии) КАК Количество
	        |ПОМЕСТИТЬ ВТТоварыНаСкладах
	        |ИЗ
	        |	РегистрНакопления.ТоварыНаСкладах КАК ТоварыНаСкладах
	        |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТСерииНоменклатуры КАК ВТСерииНоменклатуры
	        |		ПО (ТоварыНаСкладах.Активность)
	        |			И (ТоварыНаСкладах.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход))
	        |			И ТоварыНаСкладах.Номенклатура = ВТСерииНоменклатуры.Номенклатура
	        |			И ТоварыНаСкладах.Серия = ВТСерииНоменклатуры.Серия
	        |			И (ТоварыНаСкладах.Регистратор ССЫЛКА Документ.СборкаТоваров)
	        |
	        |СГРУППИРОВАТЬ ПО
	        |	ТоварыНаСкладах.Номенклатура,
	        |	ТоварыНаСкладах.Серия,
	        |	ТоварыНаСкладах.Регистратор
	        |
	        |ИНДЕКСИРОВАТЬ ПО
	        |	Регистратор
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
	        |	ВТТоварыНаСкладах.Номенклатура КАК Номенклатура,
	        |	ВТТоварыНаСкладах.Серия КАК Серия,
	        |	СУММА(ВТТоварыНаСкладах.Количество) КАК Количество,
	        |	ТоварыНаСкладах.Номенклатура КАК Комплектующее,
	        |	ТоварыНаСкладах.Серия КАК СерияКомплектующего,
	        |	ВЫБОР
	        |		КОГДА ТоварыНаСкладах.Серия = ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка)
	        |			ТОГДА ЛОЖЬ
	        |		ИНАЧЕ ИСТИНА
	        |	КОНЕЦ КАК СерияУказана,
	        |	ЕСТЬNULL(ВариантыКомплектацииНоменклатуры.Ссылка, ЗНАЧЕНИЕ(Справочник.ВариантыКомплектацииНоменклатуры.ПустаяСсылка)) КАК ВариантКомплектации,
	        |	ВЫБОР
	        |		КОГДА ЕСТЬNULL(ВариантыКомплектацииНоменклатуры.Ссылка, ЗНАЧЕНИЕ(Справочник.ВариантыКомплектацииНоменклатуры.ПустаяСсылка)) = ЗНАЧЕНИЕ(Справочник.ВариантыКомплектацииНоменклатуры.ПустаяСсылка)
	        |			ТОГДА ЛОЖЬ
	        |		ИНАЧЕ ИСТИНА
	        |	КОНЕЦ КАК ВариантКомплектацииУказан,
	        |	СУММА(ТоварыНаСкладах.ВНаличии) КАК КоличествоКомплектующих
	        |ИЗ
	        |	ВТТоварыНаСкладах КАК ВТТоварыНаСкладах
	        |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыНаСкладах КАК ТоварыНаСкладах
	        |			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВариантыКомплектацииНоменклатуры КАК ВариантыКомплектацииНоменклатуры
	        |			ПО ТоварыНаСкладах.Номенклатура = ВариантыКомплектацииНоменклатуры.Владелец
	        |				И (ВариантыКомплектацииНоменклатуры.Основной)
	        |				И (НЕ ВариантыКомплектацииНоменклатуры.ПометкаУдаления)
	        |		ПО (ТоварыНаСкладах.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход))
	        |			И ВТТоварыНаСкладах.Регистратор = ТоварыНаСкладах.Регистратор
	        |
	        |СГРУППИРОВАТЬ ПО
	        |	ВТТоварыНаСкладах.Номенклатура,
	        |	ВТТоварыНаСкладах.Серия,
	        |	ТоварыНаСкладах.Номенклатура,
	        |	ТоварыНаСкладах.Серия,
	        |	ВЫБОР
	        |		КОГДА ТоварыНаСкладах.Серия = ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка)
	        |			ТОГДА ЛОЖЬ
	        |		ИНАЧЕ ИСТИНА
	        |	КОНЕЦ,
	        |	ЕСТЬNULL(ВариантыКомплектацииНоменклатуры.Ссылка, ЗНАЧЕНИЕ(Справочник.ВариантыКомплектацииНоменклатуры.ПустаяСсылка)),
	        |	ВЫБОР
	        |		КОГДА ЕСТЬNULL(ВариантыКомплектацииНоменклатуры.Ссылка, ЗНАЧЕНИЕ(Справочник.ВариантыКомплектацииНоменклатуры.ПустаяСсылка)) = ЗНАЧЕНИЕ(Справочник.ВариантыКомплектацииНоменклатуры.ПустаяСсылка)
	        |			ТОГДА ЛОЖЬ
	        |		ИНАЧЕ ИСТИНА
	        |	КОНЕЦ";
 
	
КонецФункции // ТекстЗапросаРазблюдовкаПоСериям()

Функция ПолучитьЗатратыНаСборку(ДатаНачала, ДатаОкончания, ГотоваяПродукция, СтатьяРасходов) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ТоварыОрганизаций.Регистратор КАК Регистратор,
	|	ТоварыОрганизаций.АналитикаУчетаНоменклатуры.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ ВТТоварыОрганизаций
	|ИЗ
	|	РегистрНакопления.ТоварыОрганизаций КАК ТоварыОрганизаций
	|ГДЕ
	|	ТоварыОрганизаций.Активность
	|	И ТоварыОрганизаций.Период МЕЖДУ &ДатаНачала И &ДатаОкончания
	|	И ТоварыОрганизаций.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
	|	И ТоварыОрганизаций.ХозяйственнаяОперация <> ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ПеремещениеТоваров)
	|	И ТоварыОрганизаций.АналитикаРасходов.Родитель = &ГотоваяПродукция
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	ТоварыОрганизаций.Регистратор,
	|	ТоварыОрганизаций.АналитикаУчетаНоменклатуры.Номенклатура
	|ИЗ
	|	РегистрНакопления.ТоварыОрганизаций КАК ТоварыОрганизаций
	|ГДЕ
	|	ТоварыОрганизаций.Активность
	|	И ТоварыОрганизаций.Период МЕЖДУ &ДатаНачала И &ДатаОкончания
	|	И ТоварыОрганизаций.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
	|	И ТоварыОрганизаций.ХозяйственнаяОперация <> ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ПеремещениеТоваров)
	|	И ТоварыОрганизаций.КорАналитикаУчетаНоменклатуры.Номенклатура.Родитель = &ГотоваяПродукция
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	ТоварыОрганизаций.Регистратор,
	|	ТоварыОрганизаций.АналитикаУчетаНоменклатуры.Номенклатура
	|ИЗ
	|	РегистрНакопления.ТоварыОрганизаций КАК ТоварыОрганизаций
	|ГДЕ
	|	ТоварыОрганизаций.Активность
	|	И ТоварыОрганизаций.Период МЕЖДУ &ДатаНачала И &ДатаОкончания
	|	И ТоварыОрганизаций.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
	|	И ТоварыОрганизаций.ХозяйственнаяОперация <> ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ПеремещениеТоваров)
	|	И ТоварыОрганизаций.СтатьяРасходов = &СтатьяРасходов
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТоварыНаСкладахОбороты.Номенклатура КАК Номенклатура,
	|	ТоварыНаСкладахОбороты.Склад КАК Склад,
	|	ТоварыНаСкладахОбороты.Серия КАК Серия,
	|	ВЫБОР
	|		КОГДА ТоварыНаСкладахОбороты.Серия = ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяССылка)
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ КАК СерияУказана,
	|	ЕСТЬNULL(ВариантыКомплектацииНоменклатуры.Ссылка, ЗНАЧЕНИЕ(Справочник.ВариантыКомплектацииНоменклатуры.ПустаяСсылка)) КАК ВариантКомплектации,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(ВариантыКомплектацииНоменклатуры.Ссылка, ЗНАЧЕНИЕ(Справочник.ВариантыКомплектацииНоменклатуры.ПустаяСсылка)) = ЗНАЧЕНИЕ(Справочник.ВариантыКомплектацииНоменклатуры.ПустаяСсылка)
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ КАК ВариантКомплектацииУказан,
	|	ТоварыНаСкладахОбороты.Регистратор КАК ДокументСборки,
	|	ВЫБОР
	|		КОГДА ТоварыНаСкладахОбороты.Номенклатура.Родитель = &ГотоваяПродукция
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ЭтоГотоваяПродукция,
	|	СУММА(ТоварыНаСкладахОбороты.ВНаличииРасход) КАК Количество
	|ИЗ
	|	РегистрНакопления.ТоварыНаСкладах.Обороты(
	|			&ДатаНачала,
	|			&ДатаОкончания,
	|			Регистратор,
	|			Номенклатура В
	|				(ВЫБРАТЬ
	|					ВТТоварыОрганизаций.Номенклатура КАК Номенклатура
	|				ИЗ
	|					ВТТоварыОрганизаций КАК ВТТоварыОрганизаций)) КАК ТоварыНаСкладахОбороты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТТоварыОрганизаций КАК ВТТоварыОрганизаций
	|		ПО ТоварыНаСкладахОбороты.Номенклатура = ВТТоварыОрганизаций.Номенклатура
	|			И ТоварыНаСкладахОбороты.Регистратор = ВТТоварыОрганизаций.Регистратор
	|			И (ТоварыНаСкладахОбороты.ВНаличииРасход <> 0)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВариантыКомплектацииНоменклатуры КАК ВариантыКомплектацииНоменклатуры
	|		ПО ТоварыНаСкладахОбороты.Номенклатура = ВариантыКомплектацииНоменклатуры.Владелец
	|			И (ВариантыКомплектацииНоменклатуры.Основной)
	|			И (НЕ ВариантыКомплектацииНоменклатуры.ПометкаУдаления)
	|
	|СГРУППИРОВАТЬ ПО
	|	ТоварыНаСкладахОбороты.Номенклатура,
	|	ТоварыНаСкладахОбороты.Серия,
	|	ТоварыНаСкладахОбороты.Склад,
	|	ЕСТЬNULL(ВариантыКомплектацииНоменклатуры.Ссылка, ЗНАЧЕНИЕ(Справочник.ВариантыКомплектацииНоменклатуры.ПустаяСсылка)),
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(ВариантыКомплектацииНоменклатуры.Ссылка, ЗНАЧЕНИЕ(Справочник.ВариантыКомплектацииНоменклатуры.ПустаяСсылка)) = ЗНАЧЕНИЕ(Справочник.ВариантыКомплектацииНоменклатуры.ПустаяСсылка)
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА ТоварыНаСкладахОбороты.Серия = ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяССылка)
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ,
	|	ТоварыНаСкладахОбороты.Регистратор,
	|	ВЫБОР
	|		КОГДА ТоварыНаСкладахОбороты.Номенклатура.Родитель = &ГотоваяПродукция
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ");
	
	Запрос.УстановитьПараметр("ДатаНачала"      , ДатаНачала);
	Запрос.УстановитьПараметр("ДатаОкончания"   , ДатаОкончания);
	Запрос.УстановитьПараметр("ГотоваяПродукция", ГотоваяПродукция);
	Запрос.УстановитьПараметр("СтатьяРасходов"  , СтатьяРасходов);
	
	ТабЗатратыНаСборку = Запрос.Выполнить().Выгрузить();
	
	ЕстьУзлы = Истина;
	
	Пока ЕстьУзлы Цикл
		ЕстьУзлы = Ложь;
		
		///////////////////////////////
		// разблюдовка по спецификациям
		Запрос.Текст = ТекстЗапросаРазблюдовкаПоСпецификациям();
		
		ТабЗатратыДляРазблюдовки = ТабЗатратыНаСборку.НайтиСтроки(Новый Структура("СерияУказана,ВариантКомплектацииУказан,ЭтоГотоваяПродукция", Ложь, Истина, Ложь));
		
		// Номенклатура,Склад,Серия,СерияУказана,ВариантКомплектации,ВариантКомплектацииУказан,ДокументСборки,ЭтоГотоваяПродукция,Количество
		Пока ТабЗатратыДляРазблюдовки.Количество() > 0 Цикл
			ВариантыКомплектации = ТабЗатратыНаСборку.ВыгрузитьКолонку("ВариантКомплектации");
			
			// запрос в цикле детектед, а куда деваться?
			Запрос.УстановитьПараметр("ВариантыКомплектации", ВариантыКомплектации);
			ТабСпецификацииНаСборку = Запрос.Выполнить().Выгрузить();
			
			Для Каждого СтрЗатратыДляРазблюдовки Из ТабЗатратыДляРазблюдовки Цикл
				ТекущаяСпецификация = ТабСпецификацииНаСборку.НайтиСтроки(Новый Структура("Номенклатура", СтрЗатратыДляРазблюдовки.Номенклатура));
				
				// добавляем разблюдовку узла в затраты и исключаем узел
				Для Каждого СтрТекущаяСпецификация Из ТекущаяСпецификация Цикл
					СтрЗатратыНаСборку = ТабЗатратыНаСборку.Добавить();
					СтрЗатратыНаСборку.Номенклатура              = СтрТекущаяСпецификация.Комплектующее;
					СтрЗатратыНаСборку.Склад                     = СтрЗатратыДляРазблюдовки.Склад;
					СтрЗатратыНаСборку.Серия                     = Справочники.СерииНоменклатуры.ПустаяСсылка();
					СтрЗатратыНаСборку.СерияУказана              = Ложь;
					СтрЗатратыНаСборку.ВариантКомплектации       = СтрТекущаяСпецификация.ВариантКомплектации;
					СтрЗатратыНаСборку.ВариантКомплектацииУказан = СтрТекущаяСпецификация.ВариантКомплектацииУказан;
					СтрЗатратыНаСборку.ДокументСборки            = СтрЗатратыДляРазблюдовки.ДокументСборки;
					СтрЗатратыНаСборку.ЭтоГотоваяПродукция       = Ложь;
					СтрЗатратыНаСборку.Количество                = СтрЗатратыДляРазблюдовки.Количество * СтрТекущаяСпецификация.КоличествоКомплектующих / СтрТекущаяСпецификация.Количество;
					
					ЕстьУзлы = Истина;
				КонецЦикла;
				
				ТабЗатратыНаСборку.Удалить(СтрЗатратыДляРазблюдовки);
			КонецЦикла;
			
			// разблюдовываем глубже
			ТабЗатратыДляРазблюдовки = ТабЗатратыНаСборку.НайтиСтроки(Новый Структура("СерияУказана,ВариантКомплектацииУказан,ЭтоГотоваяПродукция", Ложь, Истина, Ложь));
		КонецЦикла;
		
		////////////////////////
		// разблюдовка по сериям
		Запрос.Текст = ТекстЗапросаРазблюдовкаПоСериям();
		
		ТабЗатратыДляРазблюдовки = ТабЗатратыНаСборку.НайтиСтроки(Новый Структура("СерияУказана,ЭтоГотоваяПродукция", Истина, Ложь));
		
		// Номенклатура,Склад,Серия,СерияУказана,ВариантКомплектации,ВариантКомплектацииУказан,ДокументСборки,ЭтоГотоваяПродукция,Количество
		Пока ТабЗатратыДляРазблюдовки.Количество() > 0 Цикл
			ТабСерииНоменклатуры = ТабЗатратыНаСборку.Скопировать(Новый Структура("СерияУказана,ЭтоГотоваяПродукция", Истина, Ложь), "Номенклатура,Серия");
			
			// эх...
			Запрос.УстановитьПараметр("ТЗСерииНоменклатуры", ТабСерииНоменклатуры);
			ТабСпецификацииНаСборку = Запрос.Выполнить().Выгрузить();
			
			Для Каждого СтрЗатратыДляРазблюдовки Из ТабЗатратыДляРазблюдовки Цикл
				ТекущаяСпецификация = ТабСпецификацииНаСборку.НайтиСтроки(Новый Структура("Номенклатура,Серия", СтрЗатратыДляРазблюдовки.Номенклатура, СтрЗатратыДляРазблюдовки.Серия));
				
				// добавляем разблюдовку узла в затраты и исключаем узел
				Для Каждого СтрТекущаяСпецификация Из ТекущаяСпецификация Цикл
					СтрЗатратыНаСборку = ТабЗатратыНаСборку.Добавить();
					СтрЗатратыНаСборку.Номенклатура              = СтрТекущаяСпецификация.Комплектующее;
					СтрЗатратыНаСборку.Склад                     = СтрЗатратыДляРазблюдовки.Склад;
					СтрЗатратыНаСборку.Серия                     = СтрТекущаяСпецификация.СерияКомплектующего;
					СтрЗатратыНаСборку.СерияУказана              = СтрТекущаяСпецификация.СерияУказана;
					СтрЗатратыНаСборку.ВариантКомплектации       = СтрТекущаяСпецификация.ВариантКомплектации;
					СтрЗатратыНаСборку.ВариантКомплектацииУказан = СтрТекущаяСпецификация.ВариантКомплектацииУказан;
					СтрЗатратыНаСборку.ДокументСборки            = СтрЗатратыДляРазблюдовки.ДокументСборки;
					СтрЗатратыНаСборку.ЭтоГотоваяПродукция       = Ложь;
					СтрЗатратыНаСборку.Количество                = СтрЗатратыДляРазблюдовки.Количество * СтрТекущаяСпецификация.КоличествоКомплектующих / СтрТекущаяСпецификация.Количество;
					
					ЕстьУзлы = Истина;
				КонецЦикла;
				
				ТабЗатратыНаСборку.Удалить(СтрЗатратыДляРазблюдовки);
			КонецЦикла;
			
			// разблюдовываем глубже
			ТабЗатратыДляРазблюдовки = ТабЗатратыНаСборку.НайтиСтроки(Новый Структура("СерияУказана,ЭтоГотоваяПродукция", Истина, Ложь));
		КонецЦикла;
	КонецЦикла; // Пока ЕстьУзлы Цикл
	
	ТабЗатратыНаСборку.Свернуть("Номенклатура,Склад, ДокументСборки", "Количество");
	
	Возврат ТабЗатратыНаСборку;
	
КонецФункции // ПолучитьЗатратыНаСборку()

Функция ПолучитьДокументПередачи(ДатаПередачи, ДатаФормирования, Организация, Склад, СкладЦеха, ТабТовары)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ДвижениеПродукцииИМатериалов.Ссылка КАК Ссылка,
	|	ЕСТЬNULL(ДопРеквизиты.Значение, ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)) КАК ДатаЗаполнения
	|ИЗ
	|	Документ.ДвижениеПродукцииИМатериалов КАК ДвижениеПродукцииИМатериалов
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ДвижениеПродукцииИМатериалов.ДополнительныеРеквизиты КАК ДопРеквизиты
	|		ПО ДвижениеПродукцииИМатериалов.Ссылка = ДопРеквизиты.Ссылка
	|			И (ДопРеквизиты.Свойство = &РекДатаЗаполнения)
	|ГДЕ
	|	ДвижениеПродукцииИМатериалов.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ПередачаМатериаловВКладовую)
	|	И ДвижениеПродукцииИМатериалов.Организация = &Организация
	|	И ДвижениеПродукцииИМатериалов.Отправитель = &Склад
	|	И ДвижениеПродукцииИМатериалов.Получатель = &СкладЦеха
	|	И НЕ ДвижениеПродукцииИМатериалов.ПометкаУдаления
	|	И НЕ ДвижениеПродукцииИМатериалов.Проведен
	|	И ДвижениеПродукцииИМатериалов.Дата = &ДатаПередачи
	|	И ДвижениеПродукцииИМатериалов.ИТБК_ТехническийДокумент
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДатаЗаполнения УБЫВ");
	
	РекДатаЗаполнения = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоРеквизиту("Имя", "ПередачаВКладовую_ДатаЗаполненияМатОтчета");
	
	Запрос.УстановитьПараметр("ДатаПередачи"     , ДатаПередачи);
	Запрос.УстановитьПараметр("Склад"            , Склад);
	Запрос.УстановитьПараметр("СкладЦеха"        , СкладЦеха);
	Запрос.УстановитьПараметр("Организация"      , Организация);
	Запрос.УстановитьПараметр("РекДатаЗаполнения", РекДатаЗаполнения);
	
	Результат = Запрос.Выполнить();
	
	Если Результат.Пустой() Тогда
		ДокНайден = Ложь;
		
	Иначе
		Выборка = Результат.Выбрать();
		Выборка.Следующий();
		
		ДокПередачи = Выборка.Ссылка.ПолучитьОбъект();
		
		// Сравниваем состав документа с отчетом
		СтараяТабТовары = ДокПередачи.Товары.Выгрузить(, "Номенклатура,Количество");
		СтараяТабТовары.Свернуть("Номенклатура", "Количество");
		СтараяТабТовары.Сортировать("Номенклатура", Новый СравнениеЗначений);
		
		НоваяТабТовары = ТабТовары.Скопировать();
		НоваяТабТовары.Свернуть("Номенклатура" , "Количество");
		НоваяТабТовары.Сортировать("Номенклатура" , Новый СравнениеЗначений);
		
		ЕстьРазница      = Ложь;
		СтарыйМаксИндекс = СтараяТабТовары.Количество() - 1;
		НовыйМаксИндекс  = НоваяТабТовары.Количество()  - 1;
		МаксИндекс       = Макс(СтарыйМаксИндекс, НовыйМаксИндекс);
				
		Для Индекс = 1 По МаксИндекс Цикл
			СтрСтарая = ?(Индекс > СтарыйМаксИндекс, Неопределено, СтараяТабТовары[Индекс]);
			СтрНовая  = ?(Индекс > НовыйМаксИндекс , Неопределено, НоваяТабТовары[Индекс]);
			
			Если СтрСтарая = Неопределено Или СтрНовая = Неопределено Или СтрСтарая.Номенклатура <> СтрНовая.Номенклатура Или СтрСтарая.Количество <> СтрНовая.Количество Тогда
				ЕстьРазница = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		ДокНайден = Не ЕстьРазница;
	КонецЕсли;
	
	Если Не ДокНайден Тогда
		ДокПередачи = Документы.ДвижениеПродукцииИМатериалов.СоздатьДокумент();
		ДокПередачи.ХозяйственнаяОперация    = Перечисления.ХозяйственныеОперации.ПередачаМатериаловВКладовую;
		ДокПередачи.Организация              = Организация;
		ДокПередачи.Отправитель              = Склад;
		ДокПередачи.Получатель               = СкладЦеха;
		ДокПередачи.Дата                     = ДатаПередачи;
		ДокПередачи.ИТБК_ТехническийДокумент = Истина;
		ДокПередачи.ВариантПриемкиТоваров    = Перечисления.ВариантыПриемкиТоваров.РазделенаПоЗаказамИНакладным;
		ДокПередачи.Комментарий              = "Интгерация мат.отчета в 1С Бух";
		ДокПередачи.Ответственный = ПараметрыСеанса.ТекущийПользователь;
		
		Для Каждого СтрТовары Из ТабТовары Цикл
			НоваяСтрока = ДокПередачи.Товары.Добавить();
			НоваяСтрока.Номенклатура       = СтрТовары.Номенклатура;
			НоваяСтрока.Количество         = СтрТовары.Количество;
			НоваяСтрока.КоличествоУпаковок = СтрТовары.Количество;
		КонецЦикла;
		
		Если Не РекДатаЗаполнения.Пустая() Тогда
			СтрРеквизита = ДокПередачи.ДополнительныеРеквизиты.Найти(РекДатаЗаполнения, "Свойство");

			Если СтрРеквизита = Неопределено Тогда
				СтрРеквизита = ДокПередачи.ДополнительныеРеквизиты.Добавить();
				СтрРеквизита.Свойство = РекДатаЗаполнения;
			КонецЕсли;
			
			СтрРеквизита.Значение = ДатаФормирования;
		КонецЕсли;
	КонецЕсли;
	
	Возврат ДокПередачи;
	
КонецФункции // ПолучитьДокументПередачи() 

Функция СформироватьДокументыПередачи(ДатаПередачи, Организация, СкладЦеха, ДеревоДанных, АдресФайлаОтчета) Экспорт
	
	ДатаФормирования = ТекущаяДатаСеанса(); 
	
  	ПараметрыФайлаОтчета = Новый Структура("Автор,ВладелецФайлов,ИмяБезРасширения,РасширениеБезТочки,ВремяИзмененияУниверсальное");
    ПараметрыФайлаОтчета.Автор              = ПараметрыСеанса.ТекущийПользователь;
	ПараметрыФайлаОтчета.ИмяБезРасширения   = "Материальный отчет " + Формат(ДатаФормирования, "ДФ=yyyy-MM-dd_HH-mm-ss");
	ПараметрыФайлаОтчета.РасширениеБезТочки = "mxl";
	
	ТабТовары = Новый ТаблицаЗначений;
	ТабТовары.Колонки.Добавить("Номенклатура");
	ТабТовары.Колонки.Добавить("Количество");
	
	ДокументыПередачи = Новый Массив;
	
	Для Каждого УзелСклад Из ДеревоДанных.Строки Цикл
		ТабТовары.Очистить();
		
		Для Каждого УзелНоменклатура Из УзелСклад.Строки Цикл
			СтрТовары = ТабТовары.Добавить();
			СтрТовары.Номенклатура = УзелНоменклатура.Номенклатура;
			СтрТовары.Количество   = УзелНоменклатура.Количество;
		КонецЦикла;
		
		ДокПередачи = ПолучитьДокументПередачи(ДатаПередачи, ДатаФормирования, Организация, УзелСклад.Склад, СкладЦеха, ТабТовары);
		
		// Согласованно сохраняем документ и прикрепляем файл отчета
		НачатьТранзакцию();
		
		Если ПустаяСтрока(ДокПередачи.Номер) Тогда
			ДокПередачи.УстановитьНовыйНомер();
		КонецЕсли;
		
		ДокПередачи.ДополнительныеСвойства.Вставить("ИТБК_ЗаполнениеМатОтчета", Истина);
		ДокПередачи.Записать(РежимЗаписиДокумента.Запись);
		
		ПараметрыФайлаОтчета.ВладелецФайлов = ДокПередачи.Ссылка;
		РаботаСФайлами.ДобавитьФайл(ПараметрыФайлаОтчета, АдресФайлаОтчета);
		
		ЗафиксироватьТранзакцию();
		
		СтрСообщения = СтрШаблон("Создан (обновлен) документ %1", ДокПередачи);
		ОбщегоНазначения.СообщитьПользователю(СтрСообщения, ДокПередачи.Ссылка);
		
		ДокументыПередачи.Добавить(ДокПередачи.Ссылка);
	КонецЦикла;
	
	Возврат ДокументыПередачи;
	
КонецФункции // СформироватьДокументыПередачи()