&НаКлиенте
Процедура ИТБК_ДоизготовлениеПередНачаломИзменения(Элемент, Отказ)
	Если ЗначениеЗаполнено(Элемент.ТекущиеДанные.Серия) 
		и Элемент.ТекущийЭлемент.Имя = "ИТБК_ДоизготовлениеДоизготовление" Тогда
		Элемент.ТекущиеДанные.Количество = Мин(Элемент.ТекущиеДанные.Количество,1); 
	ИначеЕсли ЗначениеЗаполнено(Элемент.ТекущиеДанные.Серия) 
		и Элемент.ТекущийЭлемент.Имя = "ИТБК_ДоизготовлениеОтказ" Тогда
		Элемент.ТекущиеДанные.Отказ = Мин(Элемент.ТекущиеДанные.Отказ,1);
	КонецЕсли;
