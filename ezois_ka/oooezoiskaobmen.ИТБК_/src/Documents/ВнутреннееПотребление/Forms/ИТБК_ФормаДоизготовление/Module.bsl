&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
    отказ = истина; возврат;
    Если Параметры.Свойство("АвтоТест") Тогда // Возврат при получении формы для анализа.
        Возврат;
    КонецЕсли;
    
    ОбновлениеИнформационнойБазы.ПроверитьОбъектОбработан(Объект, ЭтотОбъект);
    
    
    // СтандартныеПодсистемы.ВерсионированиеОбъектов
    ВерсионированиеОбъектов.ПриСозданииНаСервере(ЭтаФорма);
    // Конец СтандартныеПодсистемы.ВерсионированиеОбъектов
    
	ПриЧтенииСозданииНаСервере();   // fix Designer09.09.2021 4:40:58
    
    Если Элементы.ХозяйственнаяОперация.СписокВыбора.Количество() = 1 Тогда
        Элементы.ХозяйственнаяОперация.Видимость = Ложь;
    КонецЕсли;
    
    // СтандартныеПодсистемы.ПодключаемыеКоманды
    ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект);
    // Конец СтандартныеПодсистемы.ПодключаемыеКоманды
    
    // ИнтеграцияС1СДокументооборотом
    ИнтеграцияС1СДокументооборот.ПриСозданииНаСервере(ЭтаФорма);
    // Конец ИнтеграцияС1СДокументооборотом
    
	// Выбор статей и аналитик.
	//ПараметрыВыбораСтатейИАналитик = Документы.ВнутреннееПотребление.ПараметрыВыбораСтатейИАналитик(Объект.ХозяйственнаяОперация);
	//ДоходыИРасходыСервер.ПриСозданииНаСервере(ЭтотОбъект, ПараметрыВыбораСтатейИАналитик);
	// Выбор статей и аналитик.
	ПараметрыВыбораСтатейИАналитик = Документы.ВнутреннееПотребление.ПараметрыВыбораСтатейИАналитик_ИТБК_Доизготовление(Объект.ХозяйственнаяОперация);
	//ПараметрыВыбораСтатейИАналитик = Документы.ВнутреннееПотребление.ПараметрыВыбораСтатейИАналитик_vs_Доизготовление(Объект.ХозяйственнаяОперация);
	ДоходыИРасходыСервер.ПриСозданииНаСервере(ЭтотОбъект, ПараметрыВыбораСтатейИАналитик);
	
    ВнутреннееПотреблениеЛокализация.ПриСозданииНаСервере(ЭтаФорма, Отказ, СтандартнаяОбработка);
    
    СобытияФорм.ПриСозданииНаСервере(ЭтаФорма, Отказ, СтандартнаяОбработка);
	
	Если Параметры.Свойство("ПараметрКоманды") тогда
		объект.ИТБК_АктИзготовления = Параметры.ПараметрКоманды;
		объект.vs_АктИзготовления = Параметры.ПараметрКоманды;  //????????????????????????????????????????
		объект.Склад = объект.ИТБК_АктИзготовления.Склад;
		объект.Организация = объект.ИТБК_АктИзготовления.Организация;
		объект.Подразделение = объект.ИТБК_АктИзготовления.Подразделение;
		ИТБК_АктИзготовленияПриИзмененииНаСервере();
	КонецЕсли;
	
	
КонецПроцедуры

