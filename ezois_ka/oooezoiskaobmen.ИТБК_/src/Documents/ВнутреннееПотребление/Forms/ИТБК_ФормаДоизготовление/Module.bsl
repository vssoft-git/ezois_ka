Процедура ИТБК_ДоизготовлениеНоменклатураПриИзмененииНаСервере(ИД)
	строка = объект.ИТБК_Доизготовление.НайтиПоИдентификатору(ИД);
	Если не ЗначениеЗаполнено(строка.СтатьяРасходов) тогда
		строка.СтатьяРасходов = Константы.ИТБК_СтатьяДоизготовления.Получить();
		строка.АналитикаРасходов =  ?(объект.ИТБК_АктИзготовления <> Неопределено, объект.ИТБК_АктИзготовления.Номенклатура,Неопределено);
	КонецЕсли;
КонецПроцедуры

