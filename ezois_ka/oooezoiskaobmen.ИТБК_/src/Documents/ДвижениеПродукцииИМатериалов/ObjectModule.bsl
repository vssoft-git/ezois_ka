
&Перед("ПередЗаписью")
Процедура ИТБК_ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	Если ИТБК_ТехническийДокумент И Не ДополнительныеСвойства.Свойство("ИТБК_ЗаполнениеМатОтчета") Тогда
		ОбщегоНазначения.СообщитьПользователю("Изменение технического документа запрещено!", Ссылка,,, Отказ);
	КонецЕсли;
	
КонецПроцедуры // ИТБК_ПередЗаписью()
