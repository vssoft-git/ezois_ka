&НаСервере
Процедура ЗаказНаСборкуПриИзмененииНаСервере()
	
	Сборка = Неопределено;
	
	Элементы.Материалы_ТаблицаГруппаДоизгтовление.ТолькоПросмотр = не ИспользуютсяСерии(объект.ЗаказНаСборку.Номенклатура);
	объект.Материалы.Очистить();
	объект.Серии.Очистить();
	Если  объект.ЗаказНаСборку.Пустая() тогда возврат КонецЕсли;
	ПараметрыУказанияСерий = Новый ФиксированнаяСтруктура(НоменклатураСервер.ПараметрыУказанияСерий(Документы.СборкаТоваров.ПустаяСсылка(),Документы.СборкаТоваров));
	
	
	Отказ = Ложь;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|   СборкаТоваров.Ссылка КАК Ссылка
	|ИЗ
	|   Документ.СборкаТоваров КАК СборкаТоваров
	|ГДЕ
	|   СборкаТоваров.ЗаказНаСборку = &ЗаказНаСборку
	|   И СборкаТоваров.ПометкаУдаления = &ПометкаУдаления";
	
	Запрос.УстановитьПараметр("ЗаказНаСборку",объект.ЗаказНаСборку);
	Запрос.УстановитьПараметр("ПометкаУдаления", Ложь);
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	
	Если  РезультатЗапроса.Количество()  тогда
		Сборка = РезультатЗапроса[0].ссылка;
		ОбщегоНазначения.СообщитьПользователю("Данный заказ был изготовлен ",РезультатЗапроса[0].Ссылка,"ЗаказНаСборку","Объект.ЗаказНаСборку",Отказ);
	КонецЕсли;
	Элементы.СоздатьСборки.Доступность = не Отказ;
	Элементы.Материалы_Таблица.ТолькоПросмотр =  Отказ;
	Элементы.Созданасборка.Видимость = не  Элементы.СоздатьСборки.Доступность;
	Элементы.ОстаткиМатериалов.Видимость = не Отказ;
	
	
	Изделие = Объект.ЗаказНаСборку.Номенклатура;
	
КонецПроцедуры

