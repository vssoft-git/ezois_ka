&НаКлиенте
Процедура МатериалыПриИзменении(Элемент)
	
	
	ТС = Элементы.Материалы_Таблица.ТекущиеДанные;
	Если тс = Неопределено тогда Возврат КонецЕсли;;
	
	Если ТС.Норма + Тс.Дополнительно < ТС.Исключить тогда 
		ПоказатьПредупреждение(,"Количество  комплектующих в столбце ""Исключить""  
		|не может  превышать  сумму  количества  комплектующих  в  столбцах  ""Норма"" и ""Дополнительно"", 
		|уменьшите  количество до  значения, не превышающего названную сумму  в столбце Исключить!");
	КонецЕсли;
	
	ТС.Исключить = Мин(ТС.Норма + Тс.Дополнительно, ТС.Исключить);
	Тс.Количество =   ТС.Норма + Тс.Дополнительно - ТС.Исключить;
	
	//пересчитаем остатки с учетом изменений
	ПересчитатьОстатки();
	
	
КонецПроцедуры

&НаСервере
Функция  ВернутьИДВыделенной(СтрокиДерева,ИД)
	
	
	// пробежимся по всем Строкам (по всем Строкам одного уровня, которые были переданы!)
	Для каждого Строка из СтрокиДерева.ПолучитьЭлементы() Цикл
		
		// Вот наше условие, 
		Если " "+ СокрЛП( Строка.ИД) = " "+ СокрЛП(ИД) Тогда
			// Если условие сработало, возвращаем строку
			Возврат Строка.ПолучитьИдентификатор();
		КонецЕсли;
	КонецЦикла;
	
	// Если не нашли строку, смотрим под-строки каждой строки
	Для каждого Строка из СтрокиДерева.ПолучитьЭлементы()  Цикл
		
		// Здесь осуществляется рекурсивный вызов
		НайденнаяСтрока = ВернутьИДВыделенной(Строка,ИД);
		Если НайденнаяСтрока <> неопределено Тогда
			// Если нашли, возвращается Строка
			Возврат НайденнаяСтрока;
		КонецЕсли;
		
	КонецЦикла;
	
	// Не нашли строку по условию, возвращаем неопределено
	Возврат неопределено;
	
КонецФункции


