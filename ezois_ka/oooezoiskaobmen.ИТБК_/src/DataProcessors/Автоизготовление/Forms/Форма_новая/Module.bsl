&НаКлиенте
Процедура СоздатьСборки(Команда)
	
	Отказ = ПересчитатьОстатки();
	Если  Объект.Материалы.Итог("количество") = 0 тогда
		
		ПоказатьПредупреждение(,"Изготовление данного Заказа и проведение документа Сборка невозможны, так как количество комплектующих  всех строк равно нулю ");
		
	ИначеЕсли не Отказ тогда
		
		Если ОбщегоНазначенияУТВызовСервера.ЗначениеРеквизитаОбъекта(
			ОбщегоНазначенияУТВызовСервера.ЗначениеРеквизитаОбъекта(Изделие,"ВидНоменклатуры")
			,"ИспользоватьСерии")  тогда
			Если не объект.Серии.Количество() тогда
				для м = 1 по   ОбщегоНазначенияУТВызовСервера.ЗначениеРеквизитаОбъекта(
					объект.ЗаказНаСборку,"Количество") цикл
					объект.Серии.Добавить();
				КонецЦикла;
			КонецЕсли;
			Форма = ОткрытьФорму("Обработка.Автоизготовление.Форма.СозданиеСерий",,ЭтаФорма,,,,новый ОписаниеОповещения("СоздатьСборкиЗавершение",ЭтаФорма),РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
			//Форма = ОткрытьФорму("ВнешняяОбработка.Автоизготовление.Форма.ФормаРедактированияОстатков",новый Структура("Родитель,ключ", Родитель.ИД,объект),ЭтаФорма);
			КопироватьДанныеФормы(Объект,Форма.Объект);
		иначе          
			
			СоздатьДокументыРекурсивно();
			ЗаказНаСборкуПриИзменении(Неопределено);
			
		КонецЕсли;
		
	Иначе 
		
		ПоказатьПредупреждение(,"не хватает остатков ");
		
	КонецЕсли;
	
КонецПроцедуры


