&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если  Параметры.Свойство("ПараметрКоманды",объект.ЗаказНаСборку) тогда
		Если  объект.ЗаказНаСборку.Статус <> Перечисления.СтатусыВнутреннихЗаказов.КВыполнению или не объект.ЗаказНаСборку.Проведен тогда
			отказ = Истина;
			Сообщить("Изготовление выполняется только на проведенные заказы в статусе "" к выполнению """);
		КонецЕсли;
	КонецЕсли;
	
	Свойство = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоРеквизиту("Имя","Автоизготовление_feccce2b4e25489e8cd74e9e3fdba306");
	Значение = объект.ЗаказНаСборку.Номенклатура.ДополнительныеРеквизиты.Найти(Свойство);
	Если Значение <>  Неопределено 
		и Значение.Значение = Истина тогда
		отказ = Истина;
		Сообщить("Номенклатура является автоизготавливаемой, изготовление невозможно");
		Возврат;
	КонецЕсли;
	

	НовыйМассивПараметр = Новый Массив();
	
	НовыйМассив = Новый Массив();
	НовыйМассив.Добавить(Перечисления.СтатусыВнутреннихЗаказов.КВыполнению);
	НовыеЗначения = Новый ФиксированныйМассив(НовыйМассив);
	
	НовыйПараметр = Новый ПараметрВыбора("Отбор.Статус", НовыеЗначения);
	
	НовыйМассивПараметр.Добавить(НовыйПараметр);
	
	НовыйМассив = Новый Массив();
	НовыйМассив.Добавить(Истина);
	НовыеЗначения = Новый ФиксированныйМассив(НовыйМассив);
	
	НовыйПараметр = Новый ПараметрВыбора("Отбор.Проведен", НовыеЗначения);
	
	НовыйМассивПараметр.Добавить(НовыйПараметр);
	// begin fix Designer17.02.2022 10:24:55
	//Объект.ДатаСборки = Объект.ЗаказНаСборку.ОкончаниеСборкиРазборки;
	//
	//ПересчетЗначения = Ложь;    
	ПересчетЗначения = Истина;
	Объект.ДатаСборки = КонецДня(Объект.ЗаказНаСборку.НачалоСборкиРазборки);
	Если ЗначениеЗаполнено(Объект.ЗаказНаСборку) Тогда
		ЗаказНаСборкуПриИзмененииНаСервере();
		Если Не Изделие.Пустая() Тогда 
			ЗаполнитьДеревоСервер();
			Объект.Материалы.Сортировать("Номенклатура");
			ПересчетЗначения = Истина;
			ПересчитатьОстатки();
		КонецЕсли;
	КонецЕсли;
	// end fix Designer17.02.2022 10:24:49
	НовыеПараметры = Новый ФиксированныйМассив(НовыйМассивПараметр);
	Элементы.ЗаказНаСборку.ПараметрыВыбора = НовыеПараметры;
	
	 УстановитьУсловноеОформление();
	
	
 КонецПроцедуры
 
&НаСервере
Процедура УстановитьУсловноеОформление()
	
	
	Элемент = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных("Материалы_ТаблицаГруппа3");
	
	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект.Номенклатура.ВидНоменклатуры.ИспользоватьСерии");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	ОтборЭлемента.ПравоеЗначение = Ложь;
	
	Элемент.Оформление.УстановитьЗначениеПараметра("Доступность", Ложь);

КонецПроцедуры
