#Область ЗаполнениеДерева

&НаКлиенте
Процедура ЗаполнитьДерево()
	
	Если Изделие.Пустая() тогда Возврат; КонецЕсли;
	
	ЗаполнитьДеревоСервер();
	
	объект.Материалы.Сортировать("Номенклатура");
	
КонецПроцедуры	

&НаСервере
Процедура ЗаполнитьДеревоСервер()
	
	Объект.Материалы.Очистить();
	объект.Серии.Очистить();
	
	Если  объект.ЗаказНаСборку.Пустая() тогда возврат КонецЕсли;
	
	МатериалыКомплектации = РегистрыСведений.ИТБК_ДанныеАвтоизготовления.СоздатьНаборЗаписей();
	//МатериалыКомплектации = РегистрыСведений.vs_ДанныеАвтоизготовления.СоздатьНаборЗаписей();
	МатериалыКомплектации.Отбор.ЗаказНаСборку.Установить(Объект.ЗаказНаСборку);
	МатериалыКомплектации.Прочитать();
	
	ЕстьСохраненныеДанные = Ложь;
	
	Если МатериалыКомплектации.Количество() = 0 тогда    
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|   НоменклатураДополнительныеРеквизиты.Ссылка КАК Ссылка
		|ПОМЕСТИТЬ НоменклатураАвтоИзготовления
		|ИЗ
		|   Справочник.Номенклатура.ДополнительныеРеквизиты КАК НоменклатураДополнительныеРеквизиты
		|ГДЕ
		|   НоменклатураДополнительныеРеквизиты.Свойство.Имя = ""Автоизготовление_feccce2b4e25489e8cd74e9e3fdba306""
		|   И НоменклатураДополнительныеРеквизиты.Значение = ИСТИНА
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|   ВариантыКомплектацииНоменклатурыТовары.Номенклатура КАК Номенклатура,
		|   СУММА(ВариантыКомплектацииНоменклатурыТовары.Количество) КАК Количество,
		|   ВариантыКомплектацииНоменклатурыТовары.Ссылка.Владелец КАК НоменклатураОсн,
		|   ВариантыКомплектацииНоменклатурыТовары.Ссылка КАК Ссылка,
		|   ВариантыКомплектацииНоменклатурыТовары.Номенклатура В
		|       (ВЫБРАТЬ
		|           т.Ссылка
		|       ИЗ
		|           номенклатураавтоизготовления КАК т) КАК Автоизготовление
		|ИЗ
		|   Справочник.ВариантыКомплектацииНоменклатуры.Товары КАК ВариантыКомплектацииНоменклатурыТовары
		|ГДЕ
		|   (ВариантыКомплектацииНоменклатурыТовары.Ссылка.Основной
		|               И НЕ ВариантыКомплектацииНоменклатурыТовары.Ссылка.ПометкаУдаления 
		|				И НЕ ВариантыКомплектацииНоменклатурыТовары.Ссылка.Владелец = &Владелец
		|               И ВариантыКомплектацииНоменклатурыТовары.Ссылка.Владелец В
		|                       (ВЫБРАТЬ
		|                           т.Ссылка
		|                       ИЗ
		|                           номенклатураавтоизготовления КАК т)
		|           ИЛИ ВариантыКомплектацииНоменклатурыТовары.Ссылка = &ВариантКомплектации)
		|
		|СГРУППИРОВАТЬ ПО
		|   ВариантыКомплектацииНоменклатурыТовары.Ссылка.Владелец,
		|   ВариантыКомплектацииНоменклатурыТовары.Номенклатура,
		|   ВариантыКомплектацииНоменклатурыТовары.Ссылка
		|
		|УПОРЯДОЧИТЬ ПО
		|   Автоизготовление";
		Запрос.УстановитьПараметр("Изделие", Изделие);
		Запрос.УстановитьПараметр("ВариантКомплектации", объект.ЗаказНаСборку.ВариантКомплектации);
		Запрос.УстановитьПараметр("Владелец", объект.ЗаказНаСборку.ВариантКомплектации.Владелец);
		Комплектации = Запрос.Выполнить().Выгрузить();
		
	иначе
		Объект.Материалы.Загрузить(МатериалыКомплектации.Выгрузить());
		для Каждого стр из Объект.Материалы цикл
			стр.ИспользуютсяСерии = ИспользуютсяСерии(стр.Номенклатура)
		КонецЦикла;
		ЕстьСохраненныеДанные = Истина;
		
	КонецЕсли;
	
	ДобавитьСтрокиДереваРодителя(Комплектации,  Изделие,,объект.ЗаказНаСборку.Количество);
	
	
	Если МатериалыКомплектации.Количество() = 0 тогда    
		Мат = объект.Материалы.Выгрузить();
		Мат.Свернуть("Номенклатура,ИспользуютсяСерии","Норма,Дополнительно,Исключить,Количество,Доизготовление,Серия");
		объект.Материалы.Загрузить(Мат);
		//если это первое заполнение разделим серийные товары по 1
		РазделитьСерийныеТоварыПо1();
	КонецЕсли;
	
	ПересчитатьОстатки();
	
КонецПроцедуры


&НаСервере
Процедура ДобавитьСтрокиДереваРодителя(Комплектации,  НоменклатураСборки,  Комплектация = Неопределено, Количество = 1)
	
	
	Если не ЕстьСохраненныеДанные тогда
		
		//если это не автосборка Если НоменклатураСборки.... тогда Возврат КонецЕсли;
		Если Комплектация = Неопределено тогда
			Комплектация = Комплектации.найтистроки(новый Структура("НоменклатураОсн",НоменклатураСборки));
		КонецЕсли;
		Порядок = 0;
		Для Каждого стр из Комплектация цикл
			мКомплектация = Комплектации.найтистроки(новый Структура("НоменклатураОсн",стр.Номенклатура));
			Если мКомплектация.количество() тогда 
				//если есть комплектация, то добавим в дерево и заполним материалы для нее в рекурсии
				ДобавитьСтрокиДерева(Комплектации,  стр.Номенклатура, мКомплектация, стр.Количество, Количество);
			иначе
				//иначе это материал
				
				СтрМатериалы = объект.Материалы.Добавить();
				СтрМатериалы.Номенклатура = стр.Номенклатура;
				СтрМатериалы.Норма = стр.Количество * Количество / стр.ссылка.Количество;
				СтрМатериалы.Количество = стр.Количество * Количество / стр.ссылка.Количество;
				СтрМатериалы.ИспользуютсяСерии = ИспользуютсяСерии(СтрМатериалы.Номенклатура)
				
			КонецЕсли;
			
		КонецЦикла;
	КонецЕсли;
	
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьСтрокиДерева(Комплектации,  НоменклатураСборки,  Комплектация = Неопределено, Количество = 1, КолРодителя)
	
	
	Если не ЕстьСохраненныеДанные тогда
		
		//если это не автосборка Если НоменклатураСборки.... тогда Возврат КонецЕсли;
		Если Комплектация = Неопределено тогда
			Комплектация = Комплектации.найтистроки(новый Структура("НоменклатураОсн",НоменклатураСборки));
		КонецЕсли;
		Порядок = 0;
		Для Каждого стр из Комплектация цикл
			мКомплектация = Комплектации.найтистроки(новый Структура("НоменклатураОсн",стр.Номенклатура));
			Если мКомплектация.количество() тогда 
				//если есть комплектация, то добавим в дерево и заполним материалы для нее в рекурсии
				ДобавитьСтрокиДерева(Комплектации,  стр.Номенклатура, мКомплектация, стр.Количество*Количество,КолРодителя);
			иначе
				//иначе это материал
				СтрМатериалы = объект.Материалы.Добавить();
				СтрМатериалы.Номенклатура = стр.Номенклатура;
				СтрМатериалы.Норма = (стр.Количество * Количество / стр.ссылка.Количество)*КолРодителя;
				СтрМатериалы.Количество = (стр.Количество * Количество / стр.ссылка.Количество)*КолРодителя;
				СтрМатериалы.ИспользуютсяСерии = ИспользуютсяСерии(СтрМатериалы.Номенклатура)
				
			КонецЕсли;
			
		КонецЦикла;
	КонецЕсли;
	
	
КонецПроцедуры

Процедура РазделитьСерийныеТоварыПо1()
	
	материалы = объект.Материалы.Выгрузить();
	объект.Материалы.Очистить();
	для  Каждого стр из  материалы цикл
		НовСтр = объект.Материалы.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтр,стр);
		Если ИспользуютсяСерии(стр.Номенклатура) тогда
			Количество = НовСтр.Количество;
			НовСтр.Норма = 1;   
			НовСтр.Количество = 1;
			
			для м = 1 по Количество-1 Цикл 
				ЗаполнитьЗначенияСвойств(объект.Материалы.Добавить(),НовСтр);
			КонецЦикла;
			
		КонецЕсли;
	КонецЦикла;
	
	
КонецПроцедуры




#КонецОбласти


