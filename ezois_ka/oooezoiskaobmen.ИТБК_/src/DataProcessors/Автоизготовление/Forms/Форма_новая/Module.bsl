&НаСервере
Функция ПересчитатьОстатки() Экспорт
	
	Если Элементы.Материалы_Таблица.ТолькоПросмотр тогда возврат Неопределено КонецЕсли;
	
	Отказ = Ложь;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТоварыНаСкладахОстатки.Номенклатура КАК Номенклатура,
	|	ТоварыНаСкладахОстатки.Серия КАК Серия,
	|	9999999 КАК Порядок,
	|	ТоварыНаСкладахОстатки.ВНаличииОстаток КАК ВНаличииОстаток,
	|	ТоварыНаСкладахОстатки.ВНаличииОстаток КАК ВНаличииОстатокСвободный
	|ИЗ
	|	РегистрНакопления.ТоварыНаСкладах.Остатки(
	|			&Дата,
	|			Номенклатура В (&Номенклатура)
	|				И Склад = &Склад) КАК ТоварыНаСкладахОстатки";
	
	Запрос.УстановитьПараметр("Номенклатура", Объект.Материалы.Выгрузить().ВыгрузитьКолонку("Номенклатура"));
	Запрос.УстановитьПараметр("Склад", Объект.ЗаказНаСборку.Склад);
	Запрос.УстановитьПараметр("Дата", ?(ПересчетЗначения,Объект.ДатаСборки,ТекущаяДата()));
	
	Остатки.Загрузить(Запрос.Выполнить().Выгрузить());
	
	Запрос = Новый Запрос;
	Запрос.Текст = " 
	|ВЫБРАТЬ
	|	Т.Номенклатура 		КАК Номенклатура,
	|	Т.ВНаличииОстаток 	КАК ВНаличииОстаток,
	|	АУН.Ссылка			КАК КлючАналитики
	|ПОМЕСТИТЬ вт
	|ИЗ
	|	РегистрНакопления.ТоварыНаСкладах.Остатки(
	|			&Дата,
	|			Номенклатура В (&Номенклатура)
	|				И Склад = &Склад) КАК Т
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КлючиАналитикиУчетаНоменклатуры КАК АУН
	|			ПО Т.Номенклатура = АУН.Номенклатура  
	|			И Т.Характеристика = АУН.Характеристика   
	|			И Т.Серия = АУН.Серия 
	|			И Т.Назначение = АУН.Назначение 
	|			И Т.Склад = АУН.СкладскаяТерритория
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	//|ВЫБРАТЬ
	//|	СвободныеОстаткиОстатки.Номенклатура КАК Номенклатура,
	//|	вт.ВНаличииОстаток КАК ВНаличииОстаток,
	//|	СвободныеОстаткиОстатки.ВНаличииОстаток КАК ВНаличииОстатокСвободный,
	//|	вт.ВНаличииОстаток - СвободныеОстаткиОстатки.ВНаличииОстаток КАК ВРезерве
	//|ИЗ
	//|	РегистрНакопления.СвободныеОстатки.Остатки(
	//|			&Дата,
	//|			Номенклатура В (&Номенклатура)
	//|				И Склад = &Склад) КАК СвободныеОстаткиОстатки
	//|		ЛЕВОЕ СОЕДИНЕНИЕ вт КАК вт
	//|		ПО СвободныеОстаткиОстатки.Номенклатура = вт.Номенклатура" ;
	|ВЫБРАТЬ
	|	вт.Номенклатура 								КАК Номенклатура,
	|	ЕСТЬNULL(СУММА(вт.ВНаличииОстаток),0) 			КАК ВНаличииОстаток,
	|	ЕСТЬNULL(СУММА(вт.ВНаличииОстаток),0) 
	|		- ЕСТЬNULL(СУММА(РТ.КоличествоОстаток),0) 	КАК ВНаличииОстатокСвободный,
	|	ЕСТЬNULL(СУММА(РТ.КоличествоОстаток),0) 		КАК ВРезерве
	|ИЗ
	|	 вт КАК вт
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТоваровОрганизаций.Остатки(
	|			&Дата,) КАК РТ
	|		ПО вт.КлючАналитики = РТ.АналитикаУчетаНоменклатуры
	|СГРУППИРОВАТЬ ПО вт.Номенклатура
	|
	|";
	Запрос.УстановитьПараметр("Номенклатура", Объект.Материалы.Выгрузить().ВыгрузитьКолонку("Номенклатура"));
	Запрос.УстановитьПараметр("Склад", Объект.ЗаказНаСборку.Склад);
	Запрос.УстановитьПараметр("Дата", ?(ПересчетЗначения,Объект.ДатаСборки,ТекущаяДата()));
	ОстаткиСвободные = Запрос.Выполнить().Выгрузить();
	
	//заполняем обычными остатками на складах 
	Для Каждого СтрМатериалы из объект.Материалы цикл
		// остаток по данной серии
		Остаток = Остатки.НайтиСтроки(новый Структура("Номенклатура,Серия",СтрМатериалы.Номенклатура,СтрМатериалы.Серия));
		Если не Остаток.Количество() = 0 тогда
			//поставим приоритет списания больше тем, , кто есть в 	таблице материалов
			СтрМатериалы.НаСкладеВсего = Остаток[0].ВНаличииОстаток;
			Остаток[0].Порядок = СтрМатериалы.НомерСтроки;
		КонецЕсли;
		
		//РЕЗЕРВ БЕЗ УЧЕТА СЕРИЙ 
		Резерв = ОстаткиСвободные.НайтиСтроки(новый Структура("Номенклатура",СтрМатериалы.Номенклатура));
		Если не Резерв.Количество() = 0 тогда
			СтрМатериалы.ВРезерве = Резерв[0].ВРезерве
		КонецЕсли;
		
	КонецЦикла;    
	
	Остатки.Сортировать("Номенклатура,Порядок");
	
	
	// распределим свободный остаток по остаткам с сериями.
	// в первую очередь уйдут как раз серии с меньшим порядком( те что есть в материалах)
	Для Каждого СтрМатериалы из ОстаткиСвободные цикл
		//ищем строки остатка
		Остаток = Остатки.НайтиСтроки(новый Структура("Номенклатура",СтрМатериалы.Номенклатура));
		Всего = 0;
		//в цикле смотрим сколько всего остатка и когда он превысит максимально возможное ( свободный остаток ) 
		//оставим только то, что можно оставить 
		Для Каждого мОстаток из Остаток цикл
			Всего = Всего + мОстаток.ВНаличииОстатокСвободный;
			Если  всего > СтрМатериалы.ВНаличииОстатокСвободный тогда
				мОстаток.ВНаличииОстатокСвободный = мОстаток.ВНаличииОстатокСвободный - (всего - СтрМатериалы.ВНаличииОстатокСвободный);
			КонецЕсли;
		КонецЦикла; 		
		Остаток = объект.Материалы.НайтиСтроки(новый Структура("Номенклатура",СтрМатериалы.Номенклатура));
		Для Каждого мОстаток из Остаток цикл
			мОстаток.НаСкладеБезСерий = СтрМатериалы.ВНаличииОстаток;
		КонецЦикла; 		
		
	КонецЦикла;    
	//
	//
	
	
	//пойдем по материалам и распредеим остатки. если чего-то не хватает - раскрасим строку дерева родителя
	Для Каждого СтрМатериалы из объект.Материалы цикл
		
		СтрМатериалы.НаСкладе = 0 ;
		Остаток = Остатки.НайтиСтроки(новый Структура("Номенклатура,Серия",СтрМатериалы.Номенклатура,СтрМатериалы.Серия));
		
		Если Остаток.Количество() = 0  и СтрМатериалы.Количество <> 0 тогда
			
			Отказ = Истина;
			Продолжить;
			
		ИначеЕсли не Остаток.Количество() = 0 и Остаток[0].ВНаличииОстатокСвободный < СтрМатериалы.Количество тогда 
			
			Отказ = Истина;
			
		ИначеЕсли Остаток.Количество() = 0 тогда
			
			Продолжить;
			
		КонецЕсли;
		
		ВНаличии = ?(Остаток[0].ВНаличииОстатокСвободный - СтрМатериалы.Количество < 0 , Остаток[0].ВНаличииОстатокСвободный , СтрМатериалы.Количество) ;
		СтрМатериалы.НаСкладе = ?(Остаток[0].ВНаличииОстатокСвободный < 0, 0, ВНаличии); 
		
		//уменьшим остаток для дальнейшего распределения
		Остаток[0].ВНаличииОстаток = Остаток[0].ВНаличииОстаток - СтрМатериалы.Количество;
		Остаток[0].ВНаличииОстатокСвободный = Остаток[0].ВНаличииОстатокСвободный - СтрМатериалы.Количество;
		
	КонецЦикла;
	
	
	//для разработки и просмотра на форме остатка после распределения
	
	СохранитьДанные();
	
	//всг+(
	Если НЕ Константы.КонтролироватьОстаткиТоваровОрганизаций.Получить() Тогда
		Отказ = ЛОЖЬ;
	КонецЕсли;
	//всг)
	
	
	Возврат Отказ;
	
КонецФункции

&НаСервере
Процедура СохранитьДанные()
	
	Набор = РегистрыСведений.ИТБК_ДанныеАвтоизготовления.СоздатьНаборЗаписей();
	Набор.Отбор.ЗаказНаСборку.Установить(Объект.ЗаказНаСборку);
	набор.Очистить();
	для Каждого СтрокаНабора из объект.Материалы цикл
		НСТР = НАБОР.Добавить();
		ЗаполнитьЗначенияСвойств(НСТР,СтрокаНабора);
		НСТР.НомерСтроки_ = СтрокаНабора.НомерСтроки;
	КонецЦикла;  
	для Каждого СтрокаНабора из Набор цикл
		СтрокаНабора.ЗаказНаСборку      = объект.ЗаказНаСборку;
	КонецЦикла;
	Набор.Записать();
	
	Набор = РегистрыСведений.vs_ДанныеАвтоизготовления.СоздатьНаборЗаписей();
	Набор.Отбор.ЗаказНаСборку.Установить(Объект.ЗаказНаСборку);
	набор.Очистить();
	для Каждого СтрокаНабора из объект.Материалы цикл
		НСТР = НАБОР.Добавить();
		ЗаполнитьЗначенияСвойств(НСТР,СтрокаНабора);
		НСТР.НомерСтроки_ = СтрокаНабора.НомерСтроки;
	КонецЦикла;  
	для Каждого СтрокаНабора из Набор цикл
		СтрокаНабора.ЗаказНаСборку      = объект.ЗаказНаСборку;
	КонецЦикла;
	Набор.Записать();
	
КонецПроцедуры

