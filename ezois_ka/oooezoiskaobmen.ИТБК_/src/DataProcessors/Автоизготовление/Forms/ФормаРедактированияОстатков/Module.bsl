
&НаКлиенте
Процедура МатериалыПриИзменении(Элемент)
    
    ТС = Элементы.Материалы.ТекущиеДанные;
    Если тс = Неопределено тогда Возврат КонецЕсли;;
    
    Тс.Количество = ТС.Норма + Тс.Дополнительно - ТС.Исключить ;
    
    //заполним таблицу владельца по нашей    
    КопироватьДанныеФормы(Объект,ВладелецФормы.Объект);
    
    //пересчитаем остатки с учетом изменений
    ВладелецФормы.ПересчитатьОстатки();
    ВладелецФормы.РазвернемДерево();
    
    //обновим данные нашей формы с новыми остатками
    КопироватьДанныеФормы(ВладелецФормы.Объект,Объект);
    
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
    
    Элементы.Материалы.ОтборСтрок = Новый ФиксированнаяСтруктура("ИДРодителя", Параметры.Родитель) ;
    
КонецПроцедуры

&НаКлиенте
Процедура МатериалыПриАктивизацииЯчейки(Элемент)
    
    Элементы.Материалы.ВыделенныеСтроки.Очистить();
    
КонецПроцедуры

&НаКлиенте
Процедура МатериалыПередУдалением(Элемент, Отказ)
    
    Отказ = Истина;
    
КонецПроцедуры

&НаКлиенте
Процедура МатериалыПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
    
    Отказ = Истина;
    
КонецПроцедуры
