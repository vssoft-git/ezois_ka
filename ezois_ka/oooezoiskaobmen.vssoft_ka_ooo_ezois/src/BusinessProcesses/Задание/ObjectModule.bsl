
&После("ОбработкаЗаполнения")
Процедура vs_ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)

	Если ДанныеЗаполнения <> Неопределено И ТипЗнч(ДанныеЗаполнения) = Тип("ДокументОбъект.КоммерческоеПредложениеКлиенту") Тогда
		Сделка = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеЗаполнения, "Сделка");
	КонецЕсли;

КонецПроцедуры
