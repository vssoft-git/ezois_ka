&НаКлиенте
Процедура Ок(Команда)
    
    ОчиститьСообщения();
    
    Если не ОкНаСервере() тогда
        ОповеститьОВыборе("Ок")
    КонецЕсли;
    
КонецПроцедуры

&НаСервере
Функция  ОкНаСервере()
    отказ = Ложь;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТоварыНаСкладахОстатки.Серия КАК Серия,
		|	ТоварыНаСкладахОстатки.ВНаличииОстаток КАК ВНаличииОстаток,
		|	ТоварыНаСкладахОстатки.Серия.Наименование КАК СерияНаименование
		|ИЗ
		|	РегистрНакопления.ТоварыНаСкладах.Остатки(, Серия.Наименование В (&Серия)) КАК ТоварыНаСкладахОстатки";
	
	Запрос.УстановитьПараметр("Серия",  объект.Серии.Выгрузить().ВыгрузитьКолонку("Серия"));
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();

    для Каждого  стр из объект.Серии цикл
        стр.серия = СокрЛП(стр.серия);
		Если //не Справочники.СерииНоменклатуры.НайтиПоНаименованию(СокрЛП(стр.Серия),Истина).Пустая() 
			РезультатЗапроса.Найти(стр.Серия,"СерияНаименование") <> Неопределено тогда
            ОбщегоНазначения.СообщитьПользователю("Данная серия уже есть на остатках " + стр.серия,,,,Отказ);
        иначеЕсли стр.Серия = "" тогда
            ОбщегоНазначения.СообщитьПользователю("Не заполнена серия " + стр.номерстроки,,,,Отказ);
        иначеЕсли объект.Серии.найтиСтроки(новый Структура("серия",стр.серия)).количество() > 1 тогда
            ОбщегоНазначения.СообщитьПользователю("Одна серия введена 2 раза " + стр.серия,,,,Отказ);
        КонецЕсли;
    КонецЦикла;
    
    возврат отказ;
    
КонецФункции
