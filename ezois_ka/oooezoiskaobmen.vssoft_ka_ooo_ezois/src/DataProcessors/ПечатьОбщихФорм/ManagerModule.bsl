	ПараметрыШапки.Вставить("ДатаИсправления",
		?(ДанныеПечати.Исправление, Формат(ДанныеПечати.ДатаИсправления, "ДЛФ=ДД"), "--"));
		
	Если ОпцииПечати.ДействующиеПостановления.Постановление2026 Тогда 
