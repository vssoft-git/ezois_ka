Процедура ОбработатьСтрокиД(СтрокиД)
	СтрокиИ=СтрокиД.НайтиСтроки(Новый Структура("Сумма",0));
	Если СтрокиИ.Количество() Тогда
		Для каждого СтрокаД Из СтрокиИ Цикл
			//Если СтрокаД.Сумма=0 Тогда
			ОбработатьСтрокиД(СтрокаД.Строки);
			СтрокаД.Сумма = СтрокаД.Строки.Итог("Сумма");
		    СтрокаД.Цена = СтрокаД.Сумма / ?(СтрокаД.Израсходовано=0,1,СтрокаД.Израсходовано);
			//КонецЕсли;	
		КонецЦикла;
	КонецЕсли;
