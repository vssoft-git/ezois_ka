Процедура ПриКомпоновкеРезультата(ДокументРезультат, ДанныеРасшифровки, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ДокументРезультат.Очистить();
	
	// Применяем пользовательские настройки
	КомпоновщикНастроек.ЗагрузитьНастройки(КомпоновщикНастроек.ПолучитьНастройки());
	
	НастройкиКД = КомпоновщикНастроек.Настройки;
	ПараметрыДанных = КомпоновщикНастроек.Настройки.ПараметрыДанных;
	
	// Читаем параметры отчета
	ПериодОтчета  = ПараметрыДанных.НайтиЗначениеПараметра(Новый ПараметрКомпоновкиДанных("Период")).Значение;
	ДатаНачала    = ПериодОтчета.ДатаНачала;
	ДатаОкончания = ПериодОтчета.ДатаОкончания;
	
	
	
		
	ПараметрДанных = КомпоновщикНастроек.Настройки.ПараметрыДанных.Элементы.Найти("Склад1");
	ПараметрДанных.Значение = Справочники.Склады.НайтиПоНаименованию("Цех № 1", Истина);
	ПараметрДанных.Использование=Истина;
	
	
	
	ГотоваяПродукция      = ПараметрыДанных.НайтиЗначениеПараметра(Новый ПараметрКомпоновкиДанных("ГотоваяПродукция")).Значение;
	ГотоваяПродукция      = ?(ЗначениеЗаполнено(ГотоваяПродукция), ГотоваяПродукция, Справочники.Номенклатура.НайтиПоНаименованию("ГП", Истина));
	
	СтатьяРасходов	      = ПараметрыДанных.НайтиЗначениеПараметра(Новый ПараметрКомпоновкиДанных("СтатьяРасходов")).Значение;
	СтатьяРасходов        = ?(ЗначениеЗаполнено(СтатьяРасходов), СтатьяРасходов, ПланыВидовХарактеристик.СтатьиРасходов.НайтиПоНаименованию("!!! Списание на расходы", Истина));
	
	СборкаИзКомплектующих = ПараметрыДанных.НайтиЗначениеПараметра(Новый ПараметрКомпоновкиДанных("СборкаИзКомплектующих")).Значение;
	СборкаИзКомплектующих = ?(ЗначениеЗаполнено(СборкаИзКомплектующих), СборкаИзКомплектующих, Перечисления.ХозяйственныеОперации.СборкаТоваров);
	
	Запрос = Новый Запрос();
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ДатаНачала"           , Новый Граница(ДатаНачала, Видграницы.Включая));
	Запрос.УстановитьПараметр("ДатаОкончания"        , Новый Граница(ДатаОкончания, Видграницы.Включая));
	Запрос.УстановитьПараметр("ГотоваяПродукция"     , ГотоваяПродукция);
	Запрос.УстановитьПараметр("СборкаИзКомплектующих", СборкаИзКомплектующих);
	Запрос.УстановитьПараметр("Наименование", "%(АИ)%");
	ДопизготовлениеПроизводство = Новый Массив();
	ДопизготовлениеПроизводство.Добавить(Новый ПланВидовХарактеристикСсылка.СтатьиРасходов(Новый УникальныйИдентификатор("4e86c433-5bf1-11eb-ab3f-00155d439817")));
	ДопизготовлениеПроизводство.Добавить(Новый ПланВидовХарактеристикСсылка.СтатьиРасходов(Новый УникальныйИдентификатор("fc8bf825-6139-11eb-ab40-00155d439817")));
	Запрос.УстановитьПараметр("ДопизготовлениеПроизводство", ДопизготовлениеПроизводство);
		
	// Читаем данные
	//ТабВыпускПродукции = Отчеты.ИТБК_МатериальныйОтчет.ПолучитьВыпускПродукции(ДатаНачала, ДатаОкончания, ГотоваяПродукция, СборкаИзКомплектующих); 
	//ТабВыпускПродукции = ПолучитьВыпускПродукции(Запрос, ДатаНачала, ДатаОкончания, ГотоваяПродукция, СборкаИзКомплектующих);	//всг+
	//ТабЗатратыНаСборку = Отчеты.ИТБК_МатериальныйОтчет.ПолучитьЗатратыНаСборку(ДатаНачала, ДатаОкончания, ГотоваяПродукция, СтатьяРасходов);
	//ТабЗатратыНаСборку = ПолучитьЗатратыНаСборку(Запрос, ДатаНачала, ДатаОкончания, ГотоваяПродукция, СтатьяРасходов);   //всг+
	
	Запрос.Текст = ПолучитьТекстВыпускПродукцииЗатратыНаСборку();
	Пакет = Запрос.ВыполнитьПакетСПромежуточнымиДанными();
	ТабВыпускПродукции 		= Пакет[0].Выгрузить();
	ТабВыпускПродукции.Колонки.Добавить("ВидОперации");
	ТабВыпускПродукции.ЗаполнитьЗначения("Сборка", "ВидОперации");

	МассивУзловАИ      		= Пакет[1].Выгрузить().ВыгрузитьКолонку("Ссылка");
	
	ТаблицаПродукцииРазбор 	= Пакет[3].Выгрузить();
	ТаблицаПродукцииРазбор.Колонки.Добавить("ЭтоЭлемент", Новый ОписаниеТипов("Булево"));
	ТаблицаПродукцииРазбор.Колонки.Добавить("Обработано", Новый ОписаниеТипов("Булево"));
	ТаблицаПродукцииРазбор.Колонки.Добавить("ЭтоАИ", Новый ОписаниеТипов("Булево"));
	ТаблицаПродукцииРазбор.Колонки.Добавить("СкладАИ", Новый ОписаниеТипов("СправочникСсылка.Склады"));

	ТаблицаПродукцииТЗРазобрано = Новый ТаблицаЗначений;
	ТаблицаПродукцииТЗРазобрано.Колонки.Добавить("Номенклатура", 	Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ТаблицаПродукцииТЗРазобрано.Колонки.Добавить("Характеристика", 	Новый ОписаниеТипов("СправочникСсылка.ХарактеристикиНоменклатуры"));
	ТаблицаПродукцииТЗРазобрано.Колонки.Добавить("Серия", 			Новый ОписаниеТипов("СправочникСсылка.СерииНоменклатуры"));
	ТаблицаПродукцииТЗРазобрано.Колонки.Добавить("Склад", 			Новый ОписаниеТипов("СправочникСсылка.Склады"));
	ТаблицаПродукцииТЗРазобрано.Колонки.Добавить("Назначение", 		Новый ОписаниеТипов("СправочникСсылка.Назначения"));
	ТаблицаПродукцииТЗРазобрано.Колонки.Добавить("Количество", 		Новый ОписаниеТипов("Число"));
	ТаблицаПродукцииТЗРазобрано.Колонки.Добавить("ЭтоЭлемент", 		Новый ОписаниеТипов("Булево"));
	ТаблицаПродукцииТЗРазобрано.Колонки.Добавить("Обработано", 		Новый ОписаниеТипов("Булево"));
	ТаблицаПродукцииТЗРазобрано.Колонки.Добавить("ЭтоАИ", 			Новый ОписаниеТипов("Булево"));
	ТаблицаПродукцииТЗРазобрано.Колонки.Добавить("ДокументСборки");


	ТабЗатратыНаСборку = Новый ТаблицаЗначений;
	ТабЗатратыНаСборку.Колонки.Добавить("Номенклатура", 			Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ТабЗатратыНаСборку.Колонки.Добавить("Характеристика", 			Новый ОписаниеТипов("СправочникСсылка.ХарактеристикиНоменклатуры"));
	ТабЗатратыНаСборку.Колонки.Добавить("Серия", 					Новый ОписаниеТипов("СправочникСсылка.СерииНоменклатуры"));
	ТабЗатратыНаСборку.Колонки.Добавить("Назначение", 				Новый ОписаниеТипов("СправочникСсылка.Назначения"));
	ТабЗатратыНаСборку.Колонки.Добавить("ДокументСборки");
	ТабЗатратыНаСборку.Колонки.Добавить("Склад", 					Новый ОписаниеТипов("СправочникСсылка.Склады"));
	ТабЗатратыНаСборку.Колонки.Добавить("Количество", 				Новый ОписаниеТипов("Число"));


	МассивУдаляемых = Новый Массив;
	ОграничениеЦикла = 0;
	ОсталосьНеразобранныхТекущихКомплектов = ТаблицаПродукцииРазбор.Количество(); 
	Пока ОсталосьНеразобранныхТекущихКомплектов > 0 Цикл
		
		  РазобратьТекущийНабор(ТаблицаПродукцииРазбор, ДатаНачала, ДатаОкончания, МассивУзловАИ);
		
		  МассивУдаляемых.Очистить();
		  Для Каждого СтрокаРазбор Из ТаблицаПродукцииРазбор Цикл
			  Если СтрокаРазбор.Обработано Тогда
				  МассивУдаляемых.Добавить(СтрокаРазбор);
			  КонецЕсли;	
			  Если СтрокаРазбор.ЭтоЭлемент Тогда
				   НоваяСтрокаТП = ТаблицаПродукцииТЗРазобрано.Добавить();
				   ЗаполнитьЗначенияСвойств(НоваяСтрокаТП, СтрокаРазбор);
				   МассивУдаляемых.Добавить(СтрокаРазбор);
			  КонецЕсли;	
		  КонецЦикла;
		  Для Каждого УдаляемыйЭлемент Из МассивУдаляемых Цикл
			  ТаблицаПродукцииРазбор.Удалить(УдаляемыйЭлемент);
		  КонецЦикла;	
		
		
		 ОграничениеЦикла = ОграничениеЦикла + 1;
		 ОсталосьНеразобранныхТекущихКомплектов = ТаблицаПродукцииРазбор.Количество();
		 Если ОграничениеЦикла > 100 Тогда
			  ОсталосьНеразобранныхТекущихКомплектов = 0;
		 КонецЕсли;
		
	КонецЦикла;


	Для Каждого СтрокаРазбор Из ТаблицаПродукцииТЗРазобрано Цикл
		НоваяСтрокаТаблицыРазбор = ТабЗатратыНаСборку.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрокаТаблицыРазбор, СтрокаРазбор);				
	КонецЦикла;
	/////////////////////////////////////////////////////////////////////////////////

	ТабЗатратыНаСборку.Колонки.Добавить("ВидОперации");
	ТабЗатратыНаСборку.ЗаполнитьЗначения("СписаниеЗатрат", "ВидОперации"); 
	
	
	ВнешниеНаборыДанных = Новый Структура;
	ВнешниеНаборыДанных.Вставить("Изготовлено", ТабВыпускПродукции);
	ВнешниеНаборыДанных.Вставить("Потреблено" , ТабЗатратыНаСборку);
	
	// Выводим отчет
	СхемаКД	= ПолучитьМакет("ОсновнаяСхемаКомпоновкиДанных");
	
	ДанныеРасшифровки   = Новый ДанныеРасшифровкиКомпоновкиДанных;
    КомпоновщикМакетаКД	= Новый КомпоновщикМакетаКомпоновкиДанных;
    МакетКД		        = КомпоновщикМакетаКД.Выполнить(СхемаКД, НастройкиКД, ДанныеРасшифровки);

    ПроцессорКД	= Новый ПроцессорКомпоновкиДанных;                                    
    ПроцессорКД.Инициализировать(МакетКД, ВнешниеНаборыДанных, ДанныеРасшифровки);

    ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВТабличныйДокумент;
    ПроцессорВывода.УстановитьДокумент(ДокументРезультат);
    ПроцессорВывода.Вывести(ПроцессорКД);
	
	// Формируем документы
	Если ФормироватьДокументы Тогда
		ДеревоДанных = Новый ДеревоЗначений;
		
		ВнешниеНаборыДанных.Вставить("Изготовлено", Новый ТаблицаЗначений); // для заполнения документов нужна только таблица списаний
		
		МакетКД = КомпоновщикМакетаКД.Выполнить(СхемаКД, НастройкиКД,,, Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));

		ПроцессорКД = Новый ПроцессорКомпоновкиДанных;
		ПроцессорКД.Инициализировать(МакетКД, ВнешниеНаборыДанных);

		ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
		ПроцессорВывода.УстановитьОбъект(ДеревоДанных);
		ПроцессорВывода.Вывести(ПроцессорКД);
		
		ИмяФайлаОтчета    = ПолучитьИмяВременногоФайла("mxl");
		ДокументРезультат.Записать(ИмяФайлаОтчета);
		ДанныеФайлаОтчета = Новый ДвоичныеДанные(ИмяФайлаОтчета);
		АдресФайлаОтчета  = ПоместитьВоВременноеХранилище(ДанныеФайлаОтчета);
		
		Отчеты.vs_МатериальныйОтчет_2023.СформироватьДокументыПередачи(ДатаОкончания, Организация, СкладЦеха, ДеревоДанных, АдресФайлаОтчета);
	КонецЕсли;
	
	// Формируем документы
	//Если ФормироватьДокументы Тогда
	//	ДеревоДанных = Новый ДеревоЗначений;
	//	
	//	ВнешниеНаборыДанных.Вставить("Изготовлено", Новый ТаблицаЗначений); // для заполнения документов нужна только таблица списаний
	//	
	//	МакетКД = КомпоновщикМакетаКД.Выполнить(СхемаКД, НастройкиКД,,, Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));

	//	ПроцессорКД = Новый ПроцессорКомпоновкиДанных;
	//	ПроцессорКД.Инициализировать(МакетКД, ВнешниеНаборыДанных);

	//	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
	//	ПроцессорВывода.УстановитьОбъект(ДеревоДанных);
	//	ПроцессорВывода.Вывести(ПроцессорКД);
	//	
	//	ИмяФайлаОтчета    = ПолучитьИмяВременногоФайла("mxl");
	//	ДокументРезультат.Записать(ИмяФайлаОтчета);
	//	ДанныеФайлаОтчета = Новый ДвоичныеДанные(ИмяФайлаОтчета);
	//	АдресФайлаОтчета  = ПоместитьВоВременноеХранилище(ДанныеФайлаОтчета);
	//	
	//	Отчеты.ИТБК_МатериальныйОтчет.СформироватьДокументыПередачи(ДатаОкончания, Организация, СкладЦеха, ДеревоДанных, АдресФайлаОтчета);
	//КонецЕсли;
	
КонецПроцедуры // ПриКомпоновкеРезультата() 

