		    |ИЗ
		    |	РегистрНакопления.ТоварыНаСкладах.Обороты(&ДатаНачала, &ДатаОкончания, Регистратор, ) КАК Товары
		    |ГДЕ
		    |	Товары.Регистратор = &Регистратор
		    |
		    |СГРУППИРОВАТЬ ПО
		    |	Товары.Назначение,
		    |	Товары.Характеристика,
		    |	Товары.Серия,
		    |	Товары.Помещение,
		    |	Товары.Склад,
		    |	Товары.Регистратор,
		    |	Товары.Номенклатура
		    |
		    |ИМЕЮЩИЕ
		    |	ЕСТЬNULL(СУММА(&КоличествоКомплектов * Товары.ВНаличииРасход / &КоличествоКомплектовИсходное),0) > 0");
			
			ЗапросРазборКомплекта.УстановитьПараметр("Регистратор"     				, ТаблицаЗапросЭтоЭлемент[0].ДокументСборки);
			ЗапросРазборКомплекта.УстановитьПараметр("ДатаНачала"					, Новый Граница(НачалоДня(ТаблицаЗапросЭтоЭлемент[0].ДокументСборки.Дата)));
			ЗапросРазборКомплекта.УстановитьПараметр("ДатаОкончания"				, Новый Граница(КонецДня(ТаблицаЗапросЭтоЭлемент[0].ДокументСборки.Дата)));
			ЗапросРазборКомплекта.УстановитьПараметр("КоличествоКомплектовИсходное"	, ТаблицаЗапросЭтоЭлемент[0].ДокументСборки.Количество);
			ЗапросРазборКомплекта.УстановитьПараметр("КоличествоКомплектовИсходное"	, 
				?(ЗапросРазборКомплекта.Параметры.КоличествоКомплектовИсходное = 0, 1, ЗапросРазборКомплекта.Параметры.КоличествоКомплектовИсходное));
			ЗапросРазборКомплекта.УстановитьПараметр("КоличествоКомплектов"     	, СтрокаТ.Количество);

			ТаблицаРазборКомплекта = ЗапросРазборКомплекта.Выполнить().Выгрузить();
			
			Для Каждого СтрокаЗапроса2Р Из ТаблицаРазборКомплекта Цикл
				НоваяСтрокаТаблицыРазбор = ТаблицаПродукцииРазбор.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрокаТаблицыРазбор, СтрокаЗапроса2Р);
				ИндексМ = МассивУзловАИ.Найти(СтрокаТ.Номенклатура.ВидНоменклатуры);
				Если ИндексМ <> Неопределено Тогда
				    НоваяСтрокаТаблицыРазбор.ЭтоАИ = ИСТИНА;
					НоваяСтрокаТаблицыРазбор.СкладАИ = СтрокаТ.Склад;
				КонецЕсли;
				Если СтрокаТ.ЭтоАИ Тогда
				    НоваяСтрокаТаблицыРазбор.ЭтоАИ = ИСТИНА;
					НоваяСтрокаТаблицыРазбор.СкладАИ = СтрокаТ.СкладАИ;
				КонецЕсли;
			
			КонецЦикла;
			СтрокаТ.Обработано = ИСТИНА;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры




