					И ЕСТЬNULL(ЦеныНоменклатурыСрезПоследних.Упаковка.Знаменатель, 0) &lt;&gt; 0
				ТОГДА ВЫРАЗИТЬ(ЦеныНоменклатурыСрезПоследних.Упаковка.Числитель / ЦеныНоменклатурыСрезПоследних.Упаковка.Знаменатель КАК ЧИСЛО(17, 7))
			КОГДА ЦеныНоменклатурыСрезПоследних.Упаковка.ТипИзмеряемойВеличины = ЗНАЧЕНИЕ(Перечисление.ТипыИзмеряемыхВеличин.КоличествоШтук)
				ТОГДА 1
			ИНАЧЕ NULL
		КОНЕЦ, 1) * ЕСТЬNULL(ВЫБОР
			КОГДА Таблица.НоменклатураКДоизготовлению.ЕдиницаИзмерения.ТипИзмеряемойВеличины = ЗНАЧЕНИЕ(Перечисление.ТипыИзмеряемыхВеличин.Вес)
					И Таблица.НоменклатураКДоизготовлению.ВесИспользовать
					И ЕСТЬNULL(Таблица.НоменклатураКДоизготовлению.ЕдиницаИзмерения.Знаменатель, 0) &lt;&gt; 0
					И ЕСТЬNULL(Таблица.НоменклатураКДоизготовлению.ВесЕдиницаИзмерения.Числитель, 0) &lt;&gt; 0
					И ЕСТЬNULL(Таблица.НоменклатураКДоизготовлению.ВесЕдиницаИзмерения.Знаменатель, 0) &lt;&gt; 0
					И ЕСТЬNULL(Таблица.НоменклатураКДоизготовлению.ВесЧислитель, 0) &lt;&gt; 0
					И ЕСТЬNULL(Таблица.НоменклатураКДоизготовлению.ВесЗнаменатель, 0) &lt;&gt; 0
				ТОГДА ВЫРАЗИТЬ((ВЫРАЗИТЬ((ВЫРАЗИТЬ(Таблица.НоменклатураКДоизготовлению.ЕдиницаИзмерения.Числитель / Таблица.НоменклатураКДоизготовлению.ЕдиницаИзмерения.Знаменатель КАК ЧИСЛО(17, 7))) / (ВЫРАЗИТЬ(Таблица.НоменклатураКДоизготовлению.ВесЕдиницаИзмерения.Числитель / Таблица.НоменклатураКДоизготовлению.ВесЕдиницаИзмерения.Знаменатель КАК ЧИСЛО(17, 7))) КАК ЧИСЛО(17, 7))) / (ВЫРАЗИТЬ(Таблица.НоменклатураКДоизготовлению.ВесЧислитель / Таблица.НоменклатураКДоизготовлению.ВесЗнаменатель КАК ЧИСЛО(17, 7))) КАК ЧИСЛО(17, 7))
			КОГДА Таблица.НоменклатураКДоизготовлению.ЕдиницаИзмерения.ТипИзмеряемойВеличины = ЗНАЧЕНИЕ(Перечисление.ТипыИзмеряемыхВеличин.Объем)
					И Таблица.НоменклатураКДоизготовлению.ОбъемИспользовать
					И ЕСТЬNULL(Таблица.НоменклатураКДоизготовлению.ЕдиницаИзмерения.Знаменатель, 0) &lt;&gt; 0
					И ЕСТЬNULL(Таблица.НоменклатураКДоизготовлению.ОбъемЕдиницаИзмерения.Числитель, 0) &lt;&gt; 0
					И ЕСТЬNULL(Таблица.НоменклатураКДоизготовлению.ОбъемЕдиницаИзмерения.Знаменатель, 0) &lt;&gt; 0
					И ЕСТЬNULL(Таблица.НоменклатураКДоизготовлению.ОбъемЧислитель, 0) &lt;&gt; 0
					И ЕСТЬNULL(Таблица.НоменклатураКДоизготовлению.ОбъемЗнаменатель, 0) &lt;&gt; 0
				ТОГДА ВЫРАЗИТЬ((ВЫРАЗИТЬ((ВЫРАЗИТЬ(Таблица.НоменклатураКДоизготовлению.ЕдиницаИзмерения.Числитель / Таблица.НоменклатураКДоизготовлению.ЕдиницаИзмерения.Знаменатель КАК ЧИСЛО(17, 7))) / (ВЫРАЗИТЬ(Таблица.НоменклатураКДоизготовлению.ОбъемЕдиницаИзмерения.Числитель / Таблица.НоменклатураКДоизготовлению.ОбъемЕдиницаИзмерения.Знаменатель КАК ЧИСЛО(17, 7))) КАК ЧИСЛО(17, 7))) / (ВЫРАЗИТЬ(Таблица.НоменклатураКДоизготовлению.ОбъемЧислитель / Таблица.НоменклатураКДоизготовлению.ОбъемЗнаменатель КАК ЧИСЛО(17, 7))) КАК ЧИСЛО(17, 7))
			КОГДА Таблица.НоменклатураКДоизготовлению.ЕдиницаИзмерения.ТипИзмеряемойВеличины = ЗНАЧЕНИЕ(Перечисление.ТипыИзмеряемыхВеличин.Площадь)
					И Таблица.НоменклатураКДоизготовлению.ПлощадьИспользовать
					И ЕСТЬNULL(Таблица.НоменклатураКДоизготовлению.ЕдиницаИзмерения.Знаменатель, 0) &lt;&gt; 0
					И ЕСТЬNULL(Таблица.НоменклатураКДоизготовлению.ПлощадьЕдиницаИзмерения.Числитель, 0) &lt;&gt; 0
					И ЕСТЬNULL(Таблица.НоменклатураКДоизготовлению.ПлощадьЕдиницаИзмерения.Знаменатель, 0) &lt;&gt; 0
					И ЕСТЬNULL(Таблица.НоменклатураКДоизготовлению.ПлощадьЧислитель, 0) &lt;&gt; 0
					И ЕСТЬNULL(Таблица.НоменклатураКДоизготовлению.ПлощадьЗнаменатель, 0) &lt;&gt; 0
				ТОГДА ВЫРАЗИТЬ((ВЫРАЗИТЬ((ВЫРАЗИТЬ(Таблица.НоменклатураКДоизготовлению.ЕдиницаИзмерения.Числитель / Таблица.НоменклатураКДоизготовлению.ЕдиницаИзмерения.Знаменатель КАК ЧИСЛО(17, 7))) / (ВЫРАЗИТЬ(Таблица.НоменклатураКДоизготовлению.ПлощадьЕдиницаИзмерения.Числитель / Таблица.НоменклатураКДоизготовлению.ПлощадьЕдиницаИзмерения.Знаменатель КАК ЧИСЛО(17, 7))) КАК ЧИСЛО(17, 7))) / (ВЫРАЗИТЬ(Таблица.НоменклатураКДоизготовлению.ПлощадьЧислитель / Таблица.НоменклатураКДоизготовлению.ПлощадьЗнаменатель КАК ЧИСЛО(17, 7))) КАК ЧИСЛО(17, 7))
			КОГДА Таблица.НоменклатураКДоизготовлению.ЕдиницаИзмерения.ТипИзмеряемойВеличины = ЗНАЧЕНИЕ(Перечисление.ТипыИзмеряемыхВеличин.Длина)
					И Таблица.НоменклатураКДоизготовлению.ДлинаИспользовать
					И ЕСТЬNULL(Таблица.НоменклатураКДоизготовлению.ЕдиницаИзмерения.Знаменатель, 0) &lt;&gt; 0
					И ЕСТЬNULL(Таблица.НоменклатураКДоизготовлению.ДлинаЕдиницаИзмерения.Числитель, 0) &lt;&gt; 0
					И ЕСТЬNULL(Таблица.НоменклатураКДоизготовлению.ДлинаЕдиницаИзмерения.Знаменатель, 0) &lt;&gt; 0
					И ЕСТЬNULL(Таблица.НоменклатураКДоизготовлению.ДлинаЧислитель, 0) &lt;&gt; 0
					И ЕСТЬNULL(Таблица.НоменклатураКДоизготовлению.ДлинаЗнаменатель, 0) &lt;&gt; 0
				ТОГДА ВЫРАЗИТЬ((ВЫРАЗИТЬ((ВЫРАЗИТЬ(Таблица.НоменклатураКДоизготовлению.ЕдиницаИзмерения.Числитель / Таблица.НоменклатураКДоизготовлению.ЕдиницаИзмерения.Знаменатель КАК ЧИСЛО(17, 7))) / (ВЫРАЗИТЬ(Таблица.НоменклатураКДоизготовлению.ДлинаЕдиницаИзмерения.Числитель / Таблица.НоменклатураКДоизготовлению.ДлинаЕдиницаИзмерения.Знаменатель КАК ЧИСЛО(17, 7))) КАК ЧИСЛО(17, 7))) / (ВЫРАЗИТЬ(Таблица.НоменклатураКДоизготовлению.ДлинаЧислитель / Таблица.НоменклатураКДоизготовлению.ДлинаЗнаменатель КАК ЧИСЛО(17, 7))) КАК ЧИСЛО(17, 7))
			КОГДА (Таблица.НоменклатураКДоизготовлению.ЕдиницаИзмерения.ТипИзмеряемойВеличины = ЗНАЧЕНИЕ(Перечисление.ТипыИзмеряемыхВеличин.Мощность)
					ИЛИ Таблица.НоменклатураКДоизготовлению.ЕдиницаИзмерения.ТипИзмеряемойВеличины = ЗНАЧЕНИЕ(Перечисление.ТипыИзмеряемыхВеличин.Энергия)
					ИЛИ Таблица.НоменклатураКДоизготовлению.ЕдиницаИзмерения.ТипИзмеряемойВеличины = ЗНАЧЕНИЕ(Перечисление.ТипыИзмеряемыхВеличин.ЭлектрическийЗаряд)
					ИЛИ Таблица.НоменклатураКДоизготовлению.ЕдиницаИзмерения.ТипИзмеряемойВеличины = ЗНАЧЕНИЕ(Перечисление.ТипыИзмеряемыхВеличин.Время))
					И Таблица.НоменклатураКДоизготовлению.ЕдиницаИзмерения.ТипИзмеряемойВеличины = Таблица.НоменклатураКДоизготовлению.ЕдиницаИзмерения.ТипИзмеряемойВеличины
					И ЕСТЬNULL(Таблица.НоменклатураКДоизготовлению.ЕдиницаИзмерения.Знаменатель, 0) &lt;&gt; 0
				ТОГДА ВЫРАЗИТЬ((ВЫРАЗИТЬ(Таблица.НоменклатураКДоизготовлению.ЕдиницаИзмерения.Числитель / Таблица.НоменклатураКДоизготовлению.ЕдиницаИзмерения.Знаменатель КАК ЧИСЛО(17, 7))) / (ВЫРАЗИТЬ(Таблица.НоменклатураКДоизготовлению.ЕдиницаИзмерения.Числитель / Таблица.НоменклатураКДоизготовлению.ЕдиницаИзмерения.Знаменатель КАК ЧИСЛО(17, 7))) КАК ЧИСЛО(17, 7))
			КОГДА Таблица.НоменклатураКДоизготовлению.ЕдиницаИзмерения.ТипИзмеряемойВеличины = ЗНАЧЕНИЕ(Перечисление.ТипыИзмеряемыхВеличин.Упаковка)
					И ЕСТЬNULL(Таблица.НоменклатураКДоизготовлению.ЕдиницаИзмерения.Знаменатель, 0) &lt;&gt; 0
				ТОГДА ВЫРАЗИТЬ(Таблица.НоменклатураКДоизготовлению.ЕдиницаИзмерения.Числитель / Таблица.НоменклатураКДоизготовлению.ЕдиницаИзмерения.Знаменатель КАК ЧИСЛО(17, 7))
			КОГДА Таблица.НоменклатураКДоизготовлению.ЕдиницаИзмерения.ТипИзмеряемойВеличины = ЗНАЧЕНИЕ(Перечисление.ТипыИзмеряемыхВеличин.КоличествоШтук)
				ТОГДА 1
			ИНАЧЕ NULL
		КОНЕЦ, 1) * ВЫБОР
		КОГДА &amp;Валюта &lt;&gt; ЦеныНоменклатурыСрезПоследних.Валюта
			ТОГДА ВЫБОР
					КОГДА ЕСТЬNULL(КурсыВалютыЦены.КурсЗнаменатель, 0) &gt; 0
							И ЕСТЬNULL(КурсыВалютыЦены.КурсЧислитель, 0) &gt; 0
							И ЕСТЬNULL(КурсыВалюты.КурсЗнаменатель, 0) &gt; 0
							И ЕСТЬNULL(КурсыВалюты.КурсЧислитель, 0) &gt; 0
						ТОГДА КурсыВалютыЦены.КурсЧислитель * КурсыВалюты.КурсЗнаменатель / (КурсыВалюты.КурсЧислитель * КурсыВалютыЦены.КурсЗнаменатель)
					ИНАЧЕ 0
				КОНЕЦ
		ИНАЧЕ 1
	КОНЕЦ КАК Цена
{ВЫБРАТЬ
	ЗаказНаСборку.*,
	НоменклатураКДоизготовлению.*,
	ПериодСекунда,
	ПериодМинута,
	ПериодЧас,
	ПериодДень,
	ПериодНеделя,
	ПериодДекада,
	ПериодМесяц,
	ПериодКвартал,
	ПериодПолугодие,
	ПериодГод,
	Регистратор.*,
	НомерСтроки,
	ДоизготовитьНачальныйОстаток,
	ДоизготовитьОборот,
	ДоизготовитьПриход,
	ДоизготовитьРасход,
	ДоизготовитьКонечныйОстаток,
	АдресОбъекта.*,
	ЗаводскойНомер.*,
	ИзготовленнаяПродукция.*,
	ИзготовленнаяПродукцияКод,
	ИзготовленнаяХарактеристика.*,
	НоменклатураКДоизготовлениюКод,
	ХарактеристикаКДоизготовлению.*,
	Цена}
ИЗ
	Таблица КАК Таблица
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(&amp;КонецПериода {(&amp;КонецПериода)}, ВидЦены = &amp;ВидЦены {(Номенклатура).* КАК НоменклатураКДоизготовлению, (Характеристика).* КАК ХарактеристикаКДоизготовлению}) КАК ЦеныНоменклатурыСрезПоследних
		ПО Таблица.НоменклатураКДоизготовлению = ЦеныНоменклатурыСрезПоследних.Номенклатура
			И Таблица.ХарактеристикаКДоизготовлению = ЦеныНоменклатурыСрезПоследних.Характеристика
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ОтносительныеКурсыВалют.СрезПоследних(&amp;КонецПериода {(&amp;КонецПериода)}, БазоваяВалюта = &amp;БазоваяВалюта) КАК КурсыВалютыЦены
		ПО (ЦеныНоменклатурыСрезПоследних.Валюта = КурсыВалютыЦены.Валюта)
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ОтносительныеКурсыВалют.СрезПоследних(
				&amp;КонецПериода {(&amp;КонецПериода)},
				Валюта = &amp;Валюта
					И БазоваяВалюта = &amp;БазоваяВалюта) КАК КурсыВалюты
		ПО (ИСТИНА)
{ГДЕ
	Таблица.ЗаказНаСборку.*,
	Таблица.НоменклатураКДоизготовлению.*,
	Таблица.ИзготовленнаяПродукция.*}</query>
	</dataSet>
	<calculatedField>
		<dataPath>КоличествоПодчиненныхЗаписей</dataPath>
		<expression>1</expression>
		<title xsi:type="xs:string">Количество записей</title>
