		<expression>Сумма(ВычислитьВыражениеСГруппировкойМассив("Сумма(ФактическаяСтоимость) + Сумма(ФактическаяСтоимостьДоизготовления) + Сумма(ФСДоизготовления)", "Номенклатура"))</expression>
		<group>Номенклатура</group>
		<group>Склад</group>
		<group>ОбщийИтог</group>
	</totalField>
	<totalField>
		<dataPath>ИтогоПлан_Факт</dataPath>
		<expression>Сумма(ВычислитьВыражениеСГруппировкойМассив("Сумма(ПлановаяСтоимость) - (Сумма(ФактическаяСтоимость) + Сумма(ФактическаяСтоимостьДоизготовления) + Сумма(ФСДоизготовления))", "Номенклатура"))</expression>
		<group>Номенклатура</group>
		<group>Склад</group>
		<group>ОбщийИтог</group>
	</totalField>
	<totalField>
		<dataPath>ФактическаяСтоимостьДоизготовления</dataPath>
		<expression>Сумма(ВычислитьВыражениеСГруппировкойМассив("Сумма(ФактическаяСтоимостьДоизготовления)+Сумма(ФСДоизготовления)", "Материал"))</expression>
		<group>ДокументСборки</group>
		<group>Материал</group>
		<group>Номенклатура</group>
		<group>Серия</group>
		<group>СерияУзла</group>
		<group>Склад</group>
		<group>Узел</group>
		<group>ОбщийИтог</group>
	</totalField>
