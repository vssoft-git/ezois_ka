
&ИзменениеИКонтроль("ПриСозданииНаСервереРеквизитыПечатиРеализации")
Процедура vs_ПриСозданииНаСервереРеквизитыПечатиРеализации(Форма, Отказ, СтандартнаяОбработка)

	//++ Локализация
	Параметры = Форма.Параметры;
	Элементы = Форма.Элементы;

	ОбъектМетаданных = Метаданные.Документы.Найти(Параметры.ТипОбъекта);
	Элементы.ПредставлениеКодаСпециальныхОбстоятельств.Видимость = ОбъектМетаданных <> Неопределено
	И ОбщегоНазначения.ЕстьРеквизитОбъекта("КодСпециальныхОбстоятельств", ОбъектМетаданных);
	Элементы.ПредставлениеКодаСпециальныхОбстоятельств.ТолькоПросмотр = Параметры.ТипОбъекта = "КорректировкаРеализации";
	Форма.ПредставлениеКодаСпециальныхОбстоятельств = ОбменСКонтрагентамиУТ.ПредставлениеКодаСпециальныхОбстоятельств(
	Форма.КодСпециальныхОбстоятельств);
	//-- Локализация

#Удаление
	Возврат;
#КонецУдаления
#Вставка
	Если Форма.ТипОбъекта = "РеализацияТоваровУслуг" Тогда
		ПараметрыСтроки = Новый КвалификаторыСтроки(50,ДопустимаяДлина.Переменная);
		ОписаниеТиповДляРеквизита = Новый ОписаниеТипов("Строка",,ПараметрыСтроки);
		
		//Элементы.ДоверенностьНомер.ОграничениеТипа = НашеОписание;
		////Параметры.ДоверенностьНомер = Элементы.ДоверенностьНомер.ОграничениеТипа.ПривестиЗначение(Параметры.ДоверенностьНомер);
		//Параметры.ДоверенностьНомер = НашеОписание.ПривестиЗначение(Параметры.ДоверенностьНомер);
		////Форма.ДоверенностьНомер = Элементы.ДоверенностьНомер.ОграничениеТипа.ПривестиЗначение(Форма.ДоверенностьНомер);
		//Форма.ДоверенностьНомер = НашеОписание.ПривестиЗначение(Форма.ДоверенностьНомер);
		////Параметры.ДоверенностьНомер.ОграничениеТипа = Новый ОписаниеТипов(ТипСтр);
		
		// Добавить реквизит с типом "Строка"
		ДобавляемыеРеквизиты = Новый Массив;
		НовыйРеквизит = Новый РеквизитФормы("vs_ДоверенностьНомер", ОписаниеТиповДляРеквизита, , "Номер", Истина);
		ДобавляемыеРеквизиты.Добавить(НовыйРеквизит);
		Форма.ИзменитьРеквизиты(ДобавляемыеРеквизиты);
		
		Элементы.ДоверенностьНомер.Видимость = Ложь;
		
		НовыйЭлемент = Элементы.Вставить("vs_ДоверенностьНомер", Тип("ПолеФормы"), Элементы.ГруппаДоверенностьНомерДата, Элементы.ДоверенностьДата);
		НовыйЭлемент.Заголовок 				= "Номер (vssoft)";
		НовыйЭлемент.Вид 					= ВидПоляФормы.ПолеВвода;
		НовыйЭлемент.ПутьКДанным 			= "vs_ДоверенностьНомер";
	КонецЕсли;
	
	Возврат;

#КонецВставки

КонецПроцедуры
