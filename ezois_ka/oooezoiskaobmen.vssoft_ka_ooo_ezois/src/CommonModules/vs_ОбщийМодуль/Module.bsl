		СтрТВП.НоменклатураУзел = СтруктураСерии.ВыгрузитьКолонку("НоменклатураУзел");
	КонецЦикла;
	
	Т = Новый ТабличныйДокумент();
	ТаблицаРезультата = Новый ТаблицаЗначений();
	
	О = Отчеты.vs_НевыполненныеОбязательстваПоЗаказуНаСборку.Создать();
	Настройки1 = О.КомпоновщикНастроек.ПолучитьНастройки();
	
