			СтрокаД.Сумма = СтрокаД.Строки.Итог("Сумма");
		    СтрокаД.Цена = СтрокаД.Сумма / ?(СтрокаД.Израсходовано=0,1,СтрокаД.Израсходовано);
			//КонецЕсли;	
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

Функция ЗаполнитьСтрокиРекурсивно(СтруктураСерииДерево, ТЗ)

	Для каждого СтрокаДерева Из СтруктураСерииДерево.Строки Цикл
		Если Не ЗначениеЗаполнено(СтрокаДерева.НоменклатураУзел) Тогда
			СтрТЗ = ТЗ.Добавить();
			ЗаполнитьЗначенияСвойств(СтрТЗ, СтрокаДерева);
			Если ЗначениеЗаполнено(СтрокаДерева.Родитель)
				и ЗначениеЗаполнено(СтрокаДерева.Родитель.НоменклатураУзел) Тогда
				СтрТЗ.НоменклатураУзел = СтрокаДерева.Родитель.НоменклатураУзел;
			КонецЕсли;
		КонецЕсли;
		
		ЗаполнитьСтрокиРекурсивно(СтрокаДерева, ТЗ);
		
	КонецЦикла; 
	Возврат(ТЗ);	
КонецФункции

