        мКомплектация = Комплектации.найтистроки(новый Структура("НоменклатураОсн, ХарактеристикаОсн",стр.Номенклатура,стр.Характеристика));
        Если ВариантФормирования = "Иерархия"  или  
            ВариантФормирования <> "Иерархия"  и  мКомплектация.количество() = 0 тогда
            Порядок = Порядок + 1;
            нСтр1 = Родитель.Строки.Добавить();
            Если ВариантФормирования = "Иерархия" тогда 
                Родитель.Комплектация = стр.ВариантКомплектации; 
            иначе
                нСтр1.Комплектация = стр.ВариантКомплектации; 
            КонецЕсли;
            нСтр1.Номенклатура = стр.Номенклатура; 
			нСтр1.Характеристика = стр.Характеристика;
            нСтр1.Количество = стр.Количество * КоличествоРодителя / стр.ВариантКомплектации.Количество ;
            нСтр1.Количество2 = стр.Количество  ;
            нСтр1.Цена = стр.Цена ;
            нСтр1.Ид_ = ?(ВариантФормирования = "Иерархия", ИД + ?(ИД <> "", ".","") + формат(Порядок,"ЧГ = 0"),НомерСтроки);
            нСтр1.РодительИД = ?(ВариантФормирования = "Иерархия",Родитель.ИД,0);
            НомерСтроки = НомерСтроки + 1;
            нСтр1.ИД = НомерСтроки;
            
            нСтр1.КоличествоМатериалов =  0;
            нСтр1.Сумма =  0;           
            Если мКомплектация.количество() тогда 
                //если есть комплектация, то добавим в дерево и заполним материалы для нее в рекурсии
                vs_АнализПлановогоИФактическогоПотребленияМатериалов_МО_ПриКомпоновкеРезультата_ДобавитьСтрокиДерева(Комплектации, ДЗ, стр.Номенклатура, стр.Характеристика, нСтр1, мКомплектация, нСтр1.Ид_ ,НомерСтроки,нСтр1.Количество,ВариантФормирования,Материалы);
                для Каждого стр1 из  нСтр1.Строки цикл
                    нСтр1.КоличествоМатериалов = нСтр1.КоличествоМатериалов + стр1.КоличествоМатериалов;
                    нСтр1.Сумма =  нСтр1.Сумма + стр1.Сумма; ;
                КонецЦикла;
            Иначе 
                нСтр1.КоличествоМатериалов =  нСтр1.Количество  ;
                нСтр1.Сумма =  нСтр1.Количество * нСтр1.Цена;
            КонецЕсли;
            стр2 = Материалы.Добавить();
            стр2.Номенклатура 	=  нСтр1.Номенклатура;
			стр2.Характеристика =  нСтр1.Характеристика;
            стр2.Количество 	=  нСтр1.Количество;

		Иначе
			
            vs_АнализПлановогоИФактическогоПотребленияМатериалов_МО_ПриКомпоновкеРезультата_ДобавитьСтрокиДерева(Комплектации, ДЗ, стр.Номенклатура, стр.Характеристика, Родитель, мКомплектация,"" ,НомерСтроки,стр.Количество * КоличествоРодителя / стр.ВариантКомплектации.Количество,ВариантФормирования,Материалы);
            
        КонецЕсли;
        
    КонецЦикла;
    
КонецПроцедуры

Процедура vs_АнализПлановогоИФактическогоПотребленияМатериалов_МО_ПриКомпоновкеРезультата_ЗаполнитьТекущиеЗатратыНаИзделие(ТабВыпускПродукции,
					ПараметрыОтчета, ПревышенЛимитСтрок, ИсключеннаяНоменклатура, ПользовательскиеНастройки, Знач ИспользоватьАктуальныеЦены, 
					Знач ДатаЦены, Знач ТабЗатратыНаСборку, Знач ТабВыпускПродукцииОбщийИНеГПКопия, ПотребленоУзлов = Неопределено)
					
	//ВидЦены = КомпоновкаДанныхКлиентСервер.ПолучитьПараметр(ПараметрыОтчета, "ВидЗакупочнойЦены").Значение;
	ВидЦены = КомпоновкаДанныхКлиентСервер.ПолучитьПараметр(ПараметрыОтчета, "ВидЦены").Значение;
	
	Для Каждого СтрТВП Из ТабВыпускПродукции Цикл

		СтруктураСерииНоменклатурыДерево = Новый ДеревоЗначений;
