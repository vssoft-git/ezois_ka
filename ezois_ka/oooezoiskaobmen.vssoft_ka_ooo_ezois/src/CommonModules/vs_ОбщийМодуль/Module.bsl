	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(НоменклатураДоизготовления, ТабЗатратыНаСборку.ВыгрузитьКолонку("Номенклатура"), Истина);
	Для Каждого СтрТВП Из ТабВыпускПродукции Цикл
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(НоменклатураДоизготовления, СтрТВП.НоменклатураУзел, Истина);	
	КонецЦикла;
	
	//КомпоновкаДанныхКлиентСервер.ДобавитьОтбор(Настройки1.Отбор, "АктИзготовления", АктыИзготовления, ВидСравненияКомпоновкиДанных.ВСписке);
	КомпоновкаДанныхКлиентСервер.ДобавитьОтбор(Настройки1.Отбор, "ИзготовленнаяПродукция", НоменклатураДоизготовления, ВидСравненияКомпоновкиДанных.ВСписке);
	
	//ВидЗакупочнойЦены = КомпоновкаДанныхКлиентСервер.ПолучитьПараметр(ПараметрыОтчета, "ВидЗакупочнойЦены").Значение;
	//КомпоновкаДанныхКлиентСервер.УстановитьПараметр(Настройки1, "ВидЦены",ВидЗакупочнойЦены); 
	КомпоновкаДанныхКлиентСервер.УстановитьПараметр(Настройки1, "ВидЦены", ВидЦены);
	О.КомпоновщикНастроек.ЗагрузитьНастройки(Настройки1);

	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	МакетКомпоновкиДанных = КомпоновщикМакета.Выполнить(О.СхемаКомпоновкиДанных,
   		Настройки1, , , Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));

	ПроцессорКомпоновкиДанных = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновкиДанных.Инициализировать(МакетКомпоновкиДанных);

	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
	ПроцессорВывода.УстановитьОбъект(ТаблицаРезультата);
	ПроцессорВывода.Вывести(ПроцессорКомпоновкиДанных);
	
	Для Каждого СтрТВП Из ТабВыпускПродукции Цикл
		СтруктураОтбора = Новый Структура("ИзготовленнаяПродукция, НоменклатураКДоизготовлению",СтрТВП.Номенклатура, Неопределено);	// Потом Добавить Характеристики
		ИскомыеСтроки = ТаблицаРезультата.НайтиСтроки(СтруктураОтбора);
		ЗаписьЖурналаРегистрации(СтрШаблон("ИзготовленнаяПродукция.%1", СтрТВП.Номенклатура), УровеньЖурналаРегистрации.Информация,, СтрТВП.Номенклатура);
		Для Каждого СтрИС Из ИскомыеСтроки Цикл
			//Если СтрИС.НоменклатураКДоизготовлению = Неопределено Тогда Прервать; КонецЕсли;
			
			ФактическаяСтоимостьДоизготовления = ?(ТипЗнч(СтрИС.СтоимостьКонечныйОстаток)=Тип("Число"),СтрИС.СтоимостьКонечныйОстаток,0);
			Если ФактическаяСтоимостьДоизготовления = 0 Тогда Продолжить; КонецЕсли;
			Если ПотребленоУзлов = Неопределено Тогда
				СтрТВП.ФактическаяСтоимостьДоизготовления = СтрТВП.ФактическаяСтоимостьДоизготовления + ФактическаяСтоимостьДоизготовления;
			Иначе
				СтрПУ = ПотребленоУзлов.Добавить();
				СтрПУ.Номенклатура 				= СтрТВП.Номенклатура;
				СтрПУ.Характеристика 			= СтрТВП.Характеристика;
				СтрПУ.Серия 					= СтрТВП.Серия;  
				СтрПУ.ДокументСборки           	= СтрТВП.ДокументСборки;
				СтрПУ.Материал 					= СтрИС.НоменклатураКДоизготовлению;
				//СтрПУ.ХарактеристикаМатериала = СтрИС.Характеристика;
				//СтрПУ.СерияМатериала			= СтрИС.Серия;
				СтрПУ.КоличествоДоизготовление	= СтрИС.ДоизготовитьКонечныйОстаток;
