Функция ЕстьДоизготовления(vs_АктИзготовления) Экспорт 

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ первые 1 
		|	ВнутреннееПотребление.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ВнутреннееПотребление КАК ВнутреннееПотребление
		|ГДЕ
		|	ВнутреннееПотребление.vs_ЭтоДоизготовление
		|	И ВнутреннееПотребление.vs_АктИзготовления = &vs_АктИзготовления
		|	И не ВнутреннееПотребление.ПометкаУдаления ";
	
	Запрос.УстановитьПараметр("vs_АктИзготовления", vs_АктИзготовления);
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	ЕстьДоизготовления = ВыборкаДетальныеЗаписи.Следующий();
	
	Если ЕстьДоизготовления тогда 
		Сообщить("По " + vs_АктИзготовления + " есть доизготовления");
	КонецЕсли;
	
	Возврат  ЕстьДоизготовления;

КонецФункции // ЕстьДоизготовления()   

