							СтруктураДанныеДоговора.ВнешнийИдентификатор 	= СтруктураДанныеДоговора.Наименование;
							СтруктураДанныеДоговора.Номер					= Выборка.НомерДоговора;
							СтруктураДанныеДоговора.Дата					= Выборка.ДатаДоговора;	
