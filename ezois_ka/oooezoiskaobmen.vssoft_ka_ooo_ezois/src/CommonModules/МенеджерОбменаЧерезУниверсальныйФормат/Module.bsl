		ИдентификаторыИзВидовЗапасов = Истина;
		ПолучитьСведенияОПрослеживаемости(ИмяТаблицы, ДанныеИБ, ДанныеXDTO, КомпонентыОбмена, ИдентификаторыИзВидовЗапасов); 
	КонецЕсли;  
	//-- Локализация
КонецПроцедуры

