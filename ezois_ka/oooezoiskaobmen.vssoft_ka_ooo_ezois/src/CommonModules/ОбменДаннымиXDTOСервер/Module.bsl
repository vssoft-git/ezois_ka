								КомментарийСумма					= 0; 
								КомпонентыОбмена.Вставить("КомментарийСумма", 0);
								КомпонентыОбмена.Вставить("УникальныйИД", "");
							ИначеЕсли КомпонентыОбмена.Свойство("КомментарийОплаты")
								и ЗначениеЗаполнено(КомпонентыОбмена.КомментарийОплаты)
								и СвойствоТипЗначения.Имя = "string" Тогда
								//ЗначениеСвойства 					= СтрШаблон("%1 %2",ЗначениеСвойства,КомпонентыОбмена.КомментарийОплаты);
							    //Тип("ТипЗначенияXDTO")
							   	// Приемник["AdditionalInfo"] = ФабрикаXDTO.Создать(СвойствоТипЗначения, КомпонентыОбмена.КомментарийОплаты);
								КомментарийОплаты  					= "";
