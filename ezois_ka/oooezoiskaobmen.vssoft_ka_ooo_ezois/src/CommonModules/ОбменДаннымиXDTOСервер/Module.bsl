//&ИзменениеИКонтроль("ЗаполнитьТаблицуИзменений")
Функция vs_ЗаполнитьТаблицуИзменений(УзелДляОбмена, НомерСообщения, КоличествоОбъектовКВыгрузке)

	ИмяПланаОбмена = ОбменДаннымиПовтИсп.ПолучитьИмяПланаОбмена(УзелДляОбмена);

//#Удаление
//	// Получаем выборку измененных данных.
//	ВыборкаИзменений = ПланыОбмена.ВыбратьИзменения(УзелДляОбмена, НомерСообщения);
//#КонецУдаления
//#Вставка
	// Получаем выборку измененных данных.
	Если ТипЗнч(КоличествоОбъектовКВыгрузке) = Тип("Структура") Тогда
		КомпонентыОбмена = КоличествоОбъектовКВыгрузке;
		vs_НачалоПериодаСинхронизации = Неопределено;
		vs_КонецПериодаСинхронизации = Неопределено;
		vs_СписокДокументовСинхронизации = Неопределено;
		КомпонентыОбмена.Свойство("vs_НачалоПериодаСинхронизации", vs_НачалоПериодаСинхронизации);
		КомпонентыОбмена.Свойство("vs_КонецПериодаСинхронизации", vs_КонецПериодаСинхронизации);
		КомпонентыОбмена.Свойство("vs_СписокДокументовСинхронизации", vs_СписокДокументовСинхронизации);
		Если ЗначениеЗаполнено(vs_СписокДокументовСинхронизации) Тогда
			ЗаписьЖурналаРегистрации("COM-Соединение.vs_НачалоСинхронизации",УровеньЖурналаРегистрации.Предупреждение,,vs_СписокДокументовСинхронизации.ВГраница());
		КонецЕсли;
		
		Если (ЗначениеЗаполнено(vs_НачалоПериодаСинхронизации)
			или ЗначениеЗаполнено(vs_КонецПериодаСинхронизации)
			или ЗначениеЗаполнено(vs_СписокДокументовСинхронизации)) Тогда
			ЗаписьЖурналаРегистрации("COM-Соединение.vs_НачалоПериодаСинхронизации",УровеньЖурналаРегистрации.Предупреждение,,vs_НачалоПериодаСинхронизации);
			ЗаписьЖурналаРегистрации("COM-Соединение.vs_КонецПериодаСинхронизации",УровеньЖурналаРегистрации.Предупреждение,,vs_КонецПериодаСинхронизации);
			ЗаписьЖурналаРегистрации("COM-Соединение.vs_СписокДокументовСинхронизации",УровеньЖурналаРегистрации.Предупреждение,,ТипЗнч(vs_СписокДокументовСинхронизации));
			ЗаписьЖурналаРегистрации("COM-Соединение.vs_СписокДокументовСинхронизации",УровеньЖурналаРегистрации.Предупреждение,,vs_СписокДокументовСинхронизации.ВГраница(),"ВГраница()");
			ТекстЗапроса = "";
			НаибольшийИндекс = vs_СписокДокументовСинхронизации.ВГраница();
			Для Каждого ЭлМ Из vs_СписокДокументовСинхронизации Цикл
				ТекстЗапроса = СтрШаблон("%1%2", ТекстЗапроса, СтрШаблон("
				|ВЫБРАТЬ
				|	Док.Ссылка КАК Ссылка
				|ИЗ
				|	Документ.%1.Изменения КАК Док
				|ГДЕ
				|	Док.Узел = &Узел
				|	И Док.НомерСообщения ЕСТЬ NULL
				|	%2
				|	%3
				|%4
				|%5
				|", 
				ЭлМ, 
				?(ЗначениеЗаполнено(vs_НачалоПериодаСинхронизации), "И НЕ Док.Ссылка.Дата < &ДатаНач", ""),
				?(ЗначениеЗаполнено(vs_НачалоПериодаСинхронизации), "И НЕ Док.Ссылка.Дата > &ДатаКон", ""),
				?(ЭлМ = "СписаниеБезналичныхДенежныхСредств",		
