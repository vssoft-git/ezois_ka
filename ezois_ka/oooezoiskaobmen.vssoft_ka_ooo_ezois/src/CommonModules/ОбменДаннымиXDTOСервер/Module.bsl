Процедура vs_ПолучитьСуммуКомментарийЭтапаОплаты(ЗначениеСвойства, НомерСтрокиЭтапа, КомментарийСумма, КомментарийОплаты)
	Если Не ТипЗнч(ЗначениеСвойства) = Тип("ДокументСсылка.ЗаказПоставщику") 
		и Не ТипЗнч(ЗначениеСвойства) = Тип("ДокументОбъект.ЗаказПоставщику") Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Переданное значение не документ Заказ поставщику!'"));
		Возврат;
	КонецЕсли;
	КоличествоЭтапов = ЗначениеСвойства.ЭтапыГрафикаОплаты.Количество();
	Если КоличествоЭтапов > НомерСтрокиЭтапа Тогда
		Этап = ЗначениеСвойства.ЭтапыГрафикаОплаты[НомерСтрокиЭтапа];
		КомментарийСумма = Этап.СуммаПлатежа;
		КомментарийОплаты = СтрШаблон("%1 %2%3",Этап.ВариантОплаты,Этап.ПроцентПлатежа,"%");
	Иначе
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрШаблон("%1 номер строки этапа: %2 Документ: %3",НСтр("ru = 'Переданный номер строки этапа больше количества этапов документа Заказ поставщику!'"),НомерСтрокиЭтапа,ЗначениеСвойства));
		КомментарийСумма = 0;
		КомментарийОплаты = "";
	КонецЕсли;
КонецПроцедуры

