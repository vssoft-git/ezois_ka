	|					(РасшифровкаПлатежа.СтавкаНДС.Ставка / 100) / ((РасшифровкаПлатежа.СтавкаНДС.Ставка / 100) + 1))
	|	ИНАЧЕ
	|		СУММА(РасшифровкаПлатежа.СуммаНДС) * КурсВалюты.КурсЧислитель * КурсВалютыПересчета.КурсЗнаменатель 
	|				/ (КурсВалюты.КурсЗнаменатель * КурсВалютыПересчета.КурсЧислитель)
	|	КОНЕЦ КАК СуммаНДС,
	|	РасшифровкаПлатежа.ЗаявкаНаРасходованиеДенежныхСредств,
	|	СУММА(ВЫБОР
	|			КОГДА РасшифровкаПлатежа.ПланированиеСуммы = ЗНАЧЕНИЕ(Перечисление.СпособыПланированияОплатыЗаявок.ВВалютеВзаиморасчетов) 
	|				ТОГДА РасшифровкаПлатежа.СуммаВзаиморасчетов
	|			ИНАЧЕ РасшифровкаПлатежа.Сумма
	|	КОНЕЦ) КАК СуммаПлатежа,
	|	КурсВалюты.КурсЧислитель * КурсВалютыПересчета.КурсЗнаменатель 
	|		/ (КурсВалюты.КурсЗнаменатель * КурсВалютыПересчета.КурсЧислитель) КАК КоэффициентПересчета,
	|	РасшифровкаПлатежа.ДатаПогашения КАК ДатаПогашения
	|
	|ИЗ ВтРасшифровкаПлатежа КАК РасшифровкаПлатежа
	|		
	|		ЛЕВОЕ СОЕДИНЕНИЕ
	|			КурсыВалют КАК КурсВалюты
	|		ПО
	|			РасшифровкаПлатежа.Валюта = КурсВалюты.Валюта
	|			И РасшифровкаПлатежа.ОбъектРасчетов = КурсВалюты.ОбъектРасчетов 
	|
	|		ЛЕВОЕ СОЕДИНЕНИЕ
	|			КурсыВалют КАК КурсВалютыПересчета
	|		ПО
	|			&Валюта = КурсВалютыПересчета.Валюта
	|			И РасшифровкаПлатежа.ОбъектРасчетов = КурсВалютыПересчета.ОбъектРасчетов 
	|
	|СГРУППИРОВАТЬ ПО
	|	РасшифровкаПлатежа.Партнер,
	|	РасшифровкаПлатежа.Контрагент,
	|	РасшифровкаПлатежа.ОбъектРасчетов,
	|	РасшифровкаПлатежа.ВалютаВзаиморасчетов,
#Вставка
	|	ВЫРАЗИТЬ(РасшифровкаПлатежа.Комментарий КАК СТРОКА(100)),
#КонецВставки
	|	РасшифровкаПлатежа.СтатьяРасходов,
	|	РасшифровкаПлатежа.АналитикаРасходов,
	|	РасшифровкаПлатежа.АналитикаАктивовПассивов,
	|	РасшифровкаПлатежа.СтатьяДвиженияДенежныхСредств,
	//++ НЕ УТ
	|	РасшифровкаПлатежа.СтатьяЦелевыхСредств,
	//-- НЕ УТ
	|	РасшифровкаПлатежа.ДоговорКредитаДепозита,
	|	РасшифровкаПлатежа.ТипСуммыКредитаДепозита,
	|	РасшифровкаПлатежа.ДоговорАренды,
	|	РасшифровкаПлатежа.ТипПлатежаПоАренде,
	|	РасшифровкаПлатежа.ДоговорЗаймаСотруднику,
	|	РасшифровкаПлатежа.Подразделение,
	|	РасшифровкаПлатежа.НаправлениеДеятельности,
	|	РасшифровкаПлатежа.Ведомость,
	//++ НЕ УТ
	|	&ГруппировкаСубконто,
	//-- НЕ УТ
	|	РасшифровкаПлатежа.СтавкаНДС,
	|	РасшифровкаПлатежа.ЗаявкаНаРасходованиеДенежныхСредств,
	|	РасшифровкаПлатежа.ПланированиеСуммы,
	|	КурсВалюты.КурсЧислитель,
	|	КурсВалюты.КурсЗнаменатель,
	|	КурсВалютыПересчета.КурсЗнаменатель,
	|	КурсВалютыПересчета.КурсЧислитель,
	|	РасшифровкаПлатежа.ДатаПогашения
	|
	|ИМЕЮЩИЕ
	|	ВЫБОР
	|		КОГДА РасшифровкаПлатежа.ПланированиеСуммы = ЗНАЧЕНИЕ(Перечисление.СпособыПланированияОплатыЗаявок.ВВалютеВзаиморасчетов)
	|			ТОГДА СУММА(РасшифровкаПлатежа.СуммаВзаиморасчетов) * КурсВалюты.КурсЧислитель * КурсВалютыПересчета.КурсЗнаменатель 
	|				/ (КурсВалюты.КурсЗнаменатель * КурсВалютыПересчета.КурсЧислитель)
	|		ИНАЧЕ СУММА(РасшифровкаПлатежа.Сумма)
	|	КОНЕЦ > 0
	|	
	|УПОРЯДОЧИТЬ ПО
	|	РасшифровкаПлатежа.ЗаявкаНаРасходованиеДенежныхСредств
	|";
	
	//++ НЕ УТ
	Если ДанныеЗаполнения.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ПеречислениеВБюджет
		И РеглУчетСервер.ВидыНалоговСНастройкойСчетов().Найти(ДанныеЗаполнения.ТипНалога) <> Неопределено
		Или ДанныеЗаполнения.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ПрочаяВыдачаДенежныхСредств Тогда
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ГруппировкаСубконто",
		"	РасшифровкаПлатежа.НастройкаСчетовУчета");
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ДанныеСубконто",
		"	РасшифровкаПлатежа.НастройкаСчетовУчета КАК НастройкаСчетовУчета");
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ГруппировкаСубконто", "ЛОЖЬ");
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ДанныеСубконто",
		"	МИНИМУМ(РасшифровкаПлатежа.НастройкаСчетовУчета) КАК НастройкаСчетовУчета");
	КонецЕсли;
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ПоляСубконто",
		"РасшифровкаДокумента.НастройкаСчетовУчета КАК НастройкаСчетовУчета");
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ПоляНеопределено", "НЕОПРЕДЕЛЕНО КАК НастройкаСчетовУчета");
	//-- НЕ УТ
	
	Запрос.УстановитьПараметр("Валюта", ДанныеЗаполнения.Валюта);
	Запрос.УстановитьПараметр("ВалютаУпр", ЗначениеНастроекПовтИсп.ВалютаУправленческогоУчета());
	Запрос.УстановитьПараметр("МассивСсылок", МассивСсылок);
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("БазоваяВалюта", ЗначениеНастроекПовтИсп.ВалютаРегламентированногоУчетаОрганизации(ДанныеЗаполнения.Организация));
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	ТабличнаяЧасть.Очистить();
	
	// Сумма в валюте заявки пересчитывается в сумму в валюте документа
	// с учетом возможных разных курсов на дату отгрузки или курсов договора
	СуммаПлатежаСтрокРасшифровки = 0;
	СуммаДокумента = 0;
	Пока Выборка.Следующий() Цикл
		Если (СуммаПлатежаСтрокРасшифровки + Выборка.СуммаПлатежа) > ДанныеЗаполнения.СуммаДокумента Тогда
			СуммаДокумента = СуммаДокумента + (ДанныеЗаполнения.СуммаДокумента - СуммаПлатежаСтрокРасшифровки) * Выборка.КоэффициентПересчета;
			Прервать;
		КонецЕсли;
		СуммаПлатежаСтрокРасшифровки = СуммаПлатежаСтрокРасшифровки + Выборка.СуммаПлатежа;
		СуммаДокумента = СуммаДокумента + Выборка.Сумма;
	КонецЦикла;
	
	ОбрабатываемыеСтроки = Новый Массив;
	
	Выборка.Сбросить();
	Пока Выборка.Следующий() Цикл
		Если СуммыКОплате <> Неопределено Тогда
			СуммаЗаявки = СуммыКОплате.Получить(Выборка.ЗаявкаНаРасходованиеДенежныхСредств)
				* Выборка.КоэффициентПересчета;
			Сумма = Мин(Выборка.Сумма, СуммаЗаявки, СуммаДокумента);
		Иначе
			Сумма = Мин(Выборка.Сумма, СуммаДокумента);
		КонецЕсли;
		ПересчитатьНДС = (Сумма <> Выборка.Сумма);
		СуммаДокумента = СуммаДокумента - Сумма;
		Если Сумма > 0 Тогда
			НоваяСтрока = ТабличнаяЧасть.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
			НоваяСтрока.Сумма = Сумма;
			
			Если ПересчитатьНДС Тогда
				ОбрабатываемыеСтроки.Добавить(НоваяСтрока);
			КонецЕсли;
			
			//++ НЕ УТ
			Если ЗначениеЗаполнено(Выборка.НастройкаСчетовУчета) Тогда
				НоваяСтрока.НастройкаСчетовУчета = НастройкаСчетовУчетаСервер.КопияНастройкиСчетовУчета(Выборка.НастройкаСчетовУчета);
			КонецЕсли;
			
			Если Константы.ИспользоватьНачислениеЗарплаты.Получить()
				И ДанныеЗаполнения.Свойство("ХозяйственнаяОперация")
				И ДанныеЗаполнения.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВыплатаЗарплатыЧерезКассу Тогда
				
				Если ТабличнаяЧасть.Количество() Тогда
					ДанныеЗаполнения.Вставить("Ведомость", Выборка.Ведомость);
				КонецЕсли;
			КонецЕсли;
			//-- НЕ УТ
			
		КонецЕсли;
	КонецЦикла;
	
	КэшированныеЗначения = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения();
	
	ПараметрыПересчетаНДС = Новый Структура("ЦенаВключаетНДС", Истина);
	СтруктураДействий = Новый Структура;
	СтруктураДействий.Вставить("ПересчитатьСуммуНДС", ПараметрыПересчетаНДС);
	
	ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокиТЧ(
		ОбрабатываемыеСтроки,
		СтруктураДействий,
		ТабличнаяЧасть,
		КэшированныеЗначения);
	
	Если ДанныеЗаполнения.СуммаДокумента <> ТабличнаяЧасть.Итог("СуммаВзаиморасчетов") Тогда
		Для каждого СтрокаТЧ Из ТабличнаяЧасть Цикл
			СтрокаТЧ.СуммаВзаиморасчетов = 0;
		КонецЦикла;
	КонецЕсли;
	
	Если ТабличнаяЧасть.Количество() Тогда
		ДанныеЗаполнения.Вставить("СуммаДокумента", ТабличнаяЧасть.Итог("Сумма"));
	КонецЕсли;
	
	Если ДанныеЗаполнения.СписокКонтрагентов Тогда
	
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	БанковскиеСчетаКонтрагентов.Контрагент КАК Контрагент,
			|	БанковскиеСчетаКонтрагентов.БанковскийСчетКонтрагента КАК БанковскийСчетКонтрагента
			|ИЗ
			|	Документ.ЗаявкаНаРасходованиеДенежныхСредств КАК ЗаявкаНаРасходованиеДенежныхСредств
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаявкаНаРасходованиеДенежныхСредств.БанковскиеСчетаСпискаКонтрагентов КАК БанковскиеСчетаКонтрагентов
			|		ПО ЗаявкаНаРасходованиеДенежныхСредств.Ссылка = БанковскиеСчетаКонтрагентов.Ссылка
			|ГДЕ
			|	ЗаявкаНаРасходованиеДенежныхСредств.Ссылка В(&МассивСсылок)";
		
		Запрос.УстановитьПараметр("МассивСсылок", МассивСсылок);
		
		ДанныеЗаполнения.Вставить("БанковскиеСчетаСпискаКонтрагентов", Запрос.Выполнить().Выгрузить());
		
	КонецЕсли;
	
КонецПроцедуры
