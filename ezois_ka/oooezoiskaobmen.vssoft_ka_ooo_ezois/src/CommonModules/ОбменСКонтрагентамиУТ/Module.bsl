		ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(
			ДеревоДанных, "ИныеСведенияОбОтгрузке", ДанныеШапки.СопроводительныеДокументы);
	КонецЕсли;

	Путь = "СведенияОСчетеФактуре.ИнформационноеПолеФХЖ.ТекстоваяИнформация";
	ДопДанныеСчетаФактуры = ЭлектронноеВзаимодействие.ДанныеЭлементаДереваЭлектронногоДокумента(ДеревоДанных, Путь);
	
	Если ТипЗнч(ДокументОтгрузки) = Тип("ДокументСсылка.КорректировкаРеализации")
		И ТипЗнч(ДокументОтгрузки.ДокументОснование) = Тип("ДокументСсылка.ПервичныйДокумент") Тогда

		ДопДанные = ДопДанныеСчетаФактуры.Добавить();
		ДопДанные.Идентификатор = "ДокументОснованиеПервичныйДокумент";
		ДопДанные.Значение = Истина;

