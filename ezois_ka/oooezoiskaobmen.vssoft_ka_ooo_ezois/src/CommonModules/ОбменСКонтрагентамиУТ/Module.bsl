	ТаблицаТоваров.Колонки.Добавить("СуммаНалога");
	ТаблицаТоваров.Колонки.Добавить("НалоговаяСтавка");
	ТаблицаТоваров.Колонки.Добавить("СуммаАкциза");
	ТаблицаТоваров.Колонки.Добавить("СведенияОДекларации");
	ТаблицаТоваров.Колонки.Добавить("Номенклатура");
	ТаблицаТоваров.Колонки.Добавить("ЕдиницаИзмерения");
	ТаблицаТоваров.Колонки.Добавить("НаименованиеНавигационнаяСсылка");
	ТаблицаТоваров.Колонки.Добавить("ОснованиеОсвобожденияОтНДС");
	ТаблицаТоваров.Колонки.Добавить("Сопоставление");
	ТаблицаТоваров.Колонки.Добавить("Признак", Новый ОписаниеТипов("Строка",, Новый КвалификаторыСтроки(1)));
	ТаблицаТоваров.Колонки.Добавить("Код", Новый ОписаниеТипов("Строка",, Новый КвалификаторыСтроки(100)));
	ТаблицаТоваров.Колонки.Добавить("КодВидаТовара", Новый ОписаниеТипов("Строка",, Новый КвалификаторыСтроки(10)));
	ТаблицаТоваров.Колонки.Добавить("СведенияОМаркировке");
	ТаблицаТоваров.Колонки.Добавить("ГТИН", Новый ОписаниеТипов("Строка",, Новый КвалификаторыСтроки(255)));
	ТаблицаТоваров.Колонки.Добавить("СведенияОПрослеживаемости");
	Если ФорматУПД = ПоддерживаемыеФорматы.УПД_5_02.ИнформацияПродавца Тогда
		СтраныПроисхождения = Новый ТаблицаЗначений;
		ТаблицаТоваров.Колонки.Добавить("СтранаПроисхождения", Новый ОписаниеТипов("Строка",, Новый КвалификаторыСтроки(255)));
		ТаблицаТоваров.Колонки.Добавить("КодПоОКДП2", Новый ОписаниеТипов("Строка",, Новый КвалификаторыСтроки(12)));
	Иначе
		СтраныПроисхождения = НовыйСписокСтран(ФорматУПД);
		ТаблицаТоваров.Колонки.Добавить("СтраныПроисхождения");
		ТаблицаТоваров.Колонки.Добавить("КодПоОКПД2", Новый ОписаниеТипов("Строка",, Новый КвалификаторыСтроки(12)));
	КонецЕсли;
	
	СведенияОДекларации = НовыеСведенияОДекларации(ФорматУПД);

	СведенияОДекларации = Новый ТаблицаЗначений;
	СведенияОДекларации.Колонки.Добавить("КодСтраны", Новый ОписаниеТипов("Строка",, Новый КвалификаторыСтроки(3)));
	СведенияОДекларации.Колонки.Добавить("НомерДекларации", Новый ОписаниеТипов("Строка",, Новый КвалификаторыСтроки(29)));

	// ЭлектронноеВзаимодействие.ЭлектронноеАктированиеЕИС
	ТаблицаТоваров.Колонки.Добавить("ИдентификаторМестаПоставкиЕИС");
	// Конец ЭлектронноеВзаимодействие.ЭлектронноеАктированиеЕИС

	ВыборкаПоДокументам = СтруктураДанных.РезультатПоТабличнойЧасти.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаПоДокументам.Следующий();
	СтрокаТовары = ВыборкаПоДокументам.Выбрать();
	КоличествоЗаписей = СтрокаТовары.Количество();

	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДанныеШапки, "ПредставлениеСтроки5а")
		И ЗначениеЗаполнено(ДанныеШапки.ПредставлениеСтроки5а) Тогда

		ПредставлениеСтроки5а = СокрЛП(ДанныеШапки.ПредставлениеСтроки5а);
		ПутьТаблицы = "СведенияОСчетеФактуре.ДокументыОбОтгрузке";
		ДокументыПодтвержденияОтгрузки = ЭлектронноеВзаимодействие.ДанныеЭлементаДереваЭлектронногоДокумента(ДеревоДанных,
			ПутьТаблицы);

		Если СтруктураЭД.Функция = "СЧФ" Тогда

			Если СтруктураДанных.Свойство("РезультатПоДокументамОснованиям") Тогда
				ВыгрузкаДокументов = СтруктураДанных.РезультатПоДокументамОснованиям.Выгрузить();
				ВыгрузкаДокументов.НайтиСтроки(Новый Структура("СчетФактура", ДанныеШапки.Ссылка));
				Для Каждого ДокументОснование Из ВыгрузкаДокументов Цикл
					Если Не ЗначениеЗаполнено(ДокументОснование.ПредставлениеСтроки5аДокументаОснования) Тогда
						Продолжить;
					КонецЕсли;
					ДокументПодтвержденияОтгрузки = ЭлектронноеВзаимодействие.ДанныеЭлементаДереваЭлектронногоДокумента(ДеревоДанных,
						ПутьТаблицы + ".НомерСтроки.ДокументОбОтгрузке");
					ДокументПодтвержденияОтгрузки.НаименованиеДокумента = ДокументОснование.НаименованиеДокумента;
					ДокументПодтвержденияОтгрузки.НомерДокумента = ДокументОснование.НомерДокумента;
					ДокументПодтвержденияОтгрузки.ДатаДокумента = ДокументОснование.ДатаДокумента;

					СтрокаДокумента = ДокументыПодтвержденияОтгрузки.Добавить();
					СтрокаДокумента.ДокументОбОтгрузке = ДокументПодтвержденияОтгрузки;
				КонецЦикла;
			Иначе
				РеквизитыДокументаОтгрузки = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДокументОтгрузки, "Номер, Дата");
				НаименованиеДокумента = ?(ДанныеШапки.ТолькоУслуги, НСтр("ru = 'Акт'"), НСтр("ru = 'Товарная накладная'"));
				НомерДокументаОтгрузки = ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(РеквизитыДокументаОтгрузки.Номер);

				ДокументПодтвержденияОтгрузки = ЭлектронноеВзаимодействие.ДанныеЭлементаДереваЭлектронногоДокумента(ДеревоДанных,
					ПутьТаблицы + ".НомерСтроки.ДокументОбОтгрузке");
				ДокументПодтвержденияОтгрузки.НаименованиеДокумента = НаименованиеДокумента;
				ДокументПодтвержденияОтгрузки.НомерДокумента = НомерДокументаОтгрузки;
				ДокументПодтвержденияОтгрузки.ДатаДокумента = РеквизитыДокументаОтгрузки.Дата;

				СтрокаДокумента = ДокументыПодтвержденияОтгрузки.Добавить();
				СтрокаДокумента.ДокументОбОтгрузке = ДокументПодтвержденияОтгрузки;
			КонецЕсли;

		Иначе

			ДокументПодтвержденияОтгрузки = ЭлектронноеВзаимодействие.ДанныеЭлементаДереваЭлектронногоДокумента(ДеревоДанных,
				ПутьТаблицы + ".НомерСтроки.ДокументОбОтгрузке");
			РеквизитыДокументаОтгрузки = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДокументОтгрузки, "Дата");

			ДокументПодтвержденияОтгрузки.НаименованиеДокумента = НСтр("ru = 'Универсальный передаточный документ'");
			ДокументПодтвержденияОтгрузки.НомерДокумента = ДанныеШапки.Номер;
			ДокументПодтвержденияОтгрузки.ДатаДокумента = ДанныеШапки.Дата;
			
			Если РеквизитыДокументаОтгрузки.Дата < Дата('20241001') Тогда
				КоличествоСтрок = СтрокаТовары.Количество();
				Если КоличествоСтрок > 1 Тогда
					КонечныйНомер = "-" + Формат(КоличествоСтрок, "ЧГ=0");
				Иначе
					КонечныйНомер = "";
				КонецЕсли;
				ПредставлениеСтроки5а = СтрШаблон(НСтр("ru = '№ п/п %1 № %2 от %3'"),
					КонечныйНомер,
					ДанныеШапки.Номер,
					Формат(ДанныеШапки.Дата, "ДЛФ=ДД"));
			Иначе
				ПредставлениеСтроки5а = СтрШаблон(НСтр("ru = '%1, № %2 от %3'"),
					ДокументПодтвержденияОтгрузки.НаименованиеДокумента,
					ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(ДанныеШапки.Номер),
					Формат(ДанныеШапки.Дата, "ДЛФ=ДД"));
			КонецЕсли;

			СтрокаДокумента = ДокументыПодтвержденияОтгрузки.Добавить();
			СтрокаДокумента.ДокументОбОтгрузке = ДокументПодтвержденияОтгрузки;

		КонецЕсли;

		ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДанных, "ДокументОбОтгрузке", ПредставлениеСтроки5а);
		ЭлектронноеВзаимодействие.ЗагрузитьТаблицуВДерево(ДеревоДанных,
			ДокументыПодтвержденияОтгрузки,
			ПутьТаблицы);

	КонецЕсли;

	ЕстьТовары = Ложь;
	ЕстьУслуги = Ложь;
	ЕстьРаботы = Ложь;
	ЕстьПрава = ТипЗнч(ДокументОтгрузки) = Тип("ДокументСсылка.РеализацияТоваровУслуг")
		И ДокументОтгрузки.ВариантОформленияПродажи = Перечисления.ВариантыОформленияПродажи.АктНаПередачуПрав;

	ИспользоватьНаборы = Ложь;
	Если ОбщегоНазначенияУТКлиентСервер.ЕстьРеквизитОбъекта(ВыборкаПоДокументам, "ЭтоНабор") Тогда
		ИспользоватьНаборы = Истина;
	КонецЕсли;

	ЗаполнятьСопоставление = Истина;
	Если ТипЗнч(ДокументОтгрузки) = Тип("ДокументСсылка.РеализацияУслугПрочихАктивов")
		Или ВидСчетаФактуры = "Авансовый" Тогда
		ЗаполнятьСопоставление = Ложь;
	КонецЕсли;

	ЗаполнениеКодаТовара = СтруктураЭД.ВариантыЗаполненияПолей.ТоварКод;
	Если ЗначениеЗаполнено(СведенияОПокупателе) Тогда
		ВыводитьКодыТНВЭД = ВыводитьКодыТНВЭД(СведенияОПокупателе.СтранаРегистрации, ДанныеШапки.Дата);
	Иначе
		ВыводитьКодыТНВЭД = Ложь;
	КонецЕсли;

	НомерСтроки = 1;
	СуммаНалога = СуммаНалогаУПД_5_02();

	ШтрихкодыКомбинаций = Неопределено;
	ШтрихкодыНоменклатуры = Неопределено;
	НоменклатураПартнеровСервер.ШтрихкодыПоТоварам(СтрокаТовары, ШтрихкодыКомбинаций, ШтрихкодыНоменклатуры);

	Если ЗаполнятьСопоставление Тогда
		ВыборкаДляСопоставления = НоменклатураПартнеровСервер.ВыборкаДляСопоставленияНоменклатуры(ДокументОтгрузки);
		СоответствиеСтавокНДСКонтрагента = Новый Соответствие;
		ЗаполнитьСоответствиеСтавокНДС(СоответствиеСтавокНДСКонтрагента);
		ТаблицаСопоставления = ВыборкаДляСопоставления.Выгрузить();
	КонецЕсли;

	// Получение данных по прослеживаемости
	ТаблицаДанныхПрослеживаемости = Неопределено;
	СтруктураДанных.Свойство("Прослеживаемость", ТаблицаДанныхПрослеживаемости);

	// Получение данных о прослеживаемых комплектующих
	ПрослеживаемыеКомплектующие = Неопределено;
	СтруктураДанных.Свойство("ПрослеживаемыеКомплектующие", ПрослеживаемыеКомплектующие);

	ВыводитьСерии = Константы.ВыводитьСерииВПечатныхФормах.Получить()
		И СтруктураДанных.РезультатПоТабличнойЧасти.Колонки.Найти("СерияНаименование") <> Неопределено;

	Пока СтрокаТовары.Следующий() Цикл

		Если ИспользоватьНаборы
			И СтрокаТовары.ЭтоНабор
			И СтрокаТовары.ВариантПредставленияНабораВПечатныхФормах <> Перечисления.ВариантыПредставленияНаборовВПечатныхФормах.ТолькоНабор Тогда
			Продолжить;
		КонецЕсли;

		Если Не (ЗначениеЗаполнено(СтрокаТовары.Номенклатура) Или ЗначениеЗаполнено(СтрокаТовары.НоменклатураНаименование)) Тогда
			Продолжить;
		КонецЕсли;

		Если ЗначениеЗаполнено(СтрокаТовары.Номенклатура) Тогда
			Если СтрокаТовары.Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Товар 
				или СтрокаТовары.Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Набор Тогда
				ЕстьТовары = Истина;
			ИначеЕсли СтрокаТовары.Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга Тогда
				ЕстьУслуги = Истина;
			ИначеЕсли СтрокаТовары.Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Работа Тогда
				ЕстьРаботы = Истина;
			КонецЕсли;
		КонецЕсли;
		
		СуммаСНДС = Окр(СтрокаТовары.СуммаСНДС, 2);
		СуммаНДС = Окр(СтрокаТовары.СуммаНДС, 2);
		СуммаБезНДС = Окр(СтрокаТовары.СуммаБезНДС, 2);
		
		НоваяСтрока = ТаблицаТоваров.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТовары);
		НоваяСтрока.НомерСтроки = НомерСтроки;
		НомерСтроки = НомерСтроки + 1;
		НоваяСтрока.НомерСтрокиИсходногоДокумента = НомерСтроки;

		СерияНаименование = Неопределено;
		Если ВыводитьСерии Тогда
			СерияНаименование = СтрокаТовары.СерияНаименование;
		КонецЕсли;

		НоваяСтрока.Наименование = НоменклатураКлиентСервер.ПредставлениеНоменклатурыДляПечати(СтрокаТовары.НоменклатураНаименование,
			СтрокаТовары.ХарактеристикаНаименование,
			СерияНаименование) + ?(СтрокаТовары.ЭтоВозвратнаяТара, НСтр("ru = ' (возвратная тара)'"), "");
		Если ЗначениеЗаполнено(СтрокаТовары.Номенклатура) Тогда
			НоваяСтрока.НаименованиеНавигационнаяСсылка = ПолучитьНавигационнуюСсылку(СтрокаТовары.Номенклатура,
				"Наименование");
			КодОКПД2 = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрокаТовары.Номенклатура, "КодОКПД2");
			Если ФорматУПД = ПоддерживаемыеФорматы.УПД_5_02.ИнформацияПродавца Тогда
				НоваяСтрока.КодПоОКДП2 = СокрЛП(КодОКПД2);
			Иначе
				НоваяСтрока.КодПоОКПД2 = СокрЛП(КодОКПД2);
			КонецЕсли;
		КонецЕсли;

		НоваяСтрока.СуммаНалога = СуммаНалогаУПД_5_02();
		Если НДСИсчисляетсяНалоговымАгентом Тогда

			НоваяСтрока.НалоговаяСтавка = НСтр("ru = 'НДС исчисляется налоговым агентом'");
			НоваяСтрока.СтоимостьСНалогом = 0;
			НоваяСтрока.СуммаНалога.БезНДС = Ложь;

			СуммаНалога.БезНДС = Ложь;
			
			Если ВидСчетаФактуры = "Авансовый" Тогда
				СуммаБезНДС = Окр(СтрокаТовары.СуммаСНДС, 2);
			КонецЕсли;
			
		Иначе

			Если ОблагаетсяНДССМежценовойРазницы Тогда
				НоваяСтрока.НалоговаяСтавка = УчетНДСРФВызовСервера.СтавкаНДСПоЗначениюПеречисления(СтрокаТовары.СтавкаНДС.ПеречислениеСтавкаНДС,
					Перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС);
			Иначе
				НоваяСтрока.НалоговаяСтавка = СтрокаТовары.СтавкаНДС;
			КонецЕсли;
			НоваяСтрока.СтоимостьСНалогом = СуммаСНДС;
			Если НоваяСтрока.НалоговаяСтавка <> Справочники.СтавкиНДС.БезНДС Тогда
				НоваяСтрока.СуммаНалога.Сумма = СуммаНДС;
				НоваяСтрока.СуммаНалога.БезНДС = Ложь;

				СуммаНалога.Сумма = СуммаНалога.Сумма + СтрокаТовары.СуммаНДС;
				СуммаНалога.БезНДС = Ложь;
			КонецЕсли;

		КонецЕсли;

		НоваяСтрока.Цена = Окр(СтрокаТовары.Цена, 2);
		НоваяСтрока.СтоимостьБезНалога = СуммаБезНДС;

		Если НоваяСтрока.СуммаНалога.БезНДС Тогда
			НоваяСтрока.СуммаНалога.Сумма = Неопределено;
		Иначе
			НоваяСтрока.СуммаНалога.БезНДС = Неопределено;
		КонецЕсли;

		НоваяСтрока.СуммаАкциза = Новый Структура("Сумма, БезАкциза", 0, Истина);

		УпаковкаИзДокумента = Неопределено;
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаТовары, "Упаковка")
			И ЗначениеЗаполнено(СтрокаТовары.Упаковка) Тогда
			УпаковкаИзДокумента = СтрокаТовары.Упаковка;
		ИначеЕсли ЗаполнятьСопоставление Тогда
			УпаковкаИзДокумента = ЭлектронноеВзаимодействиеУТВызовСервера.ЕдиницаХраненияНоменклатуры(СтрокаТовары.Номенклатура)
		Иначе
			УпаковкаИзДокумента = Справочники.УпаковкиЕдиницыИзмерения.ПустаяСсылка();
		КонецЕсли;

		Если ЗаполнятьСопоставление Тогда
			// Сопоставление.
			ПараметрыОтбора = Новый Структура;
			ПараметрыОтбора.Вставить("Номенклатура", СтрокаТовары.Номенклатура);
			Если СтрокаТовары.Характеристика <> Неопределено Тогда
				ПараметрыОтбора.Вставить("Характеристика", СтрокаТовары.Характеристика);
			Иначе
				ПараметрыОтбора.Вставить("Характеристика", Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка());
			КонецЕсли;
			ПараметрыОтбора.Вставить("Упаковка", УпаковкаИзДокумента);
			СтрокиИзНоменклатурыКонтрагентов = ТаблицаСопоставления.НайтиСтроки(ПараметрыОтбора);
			Если СтрокиИзНоменклатурыКонтрагентов.Количество() > 0 Тогда
				НайденнаяСтрока = СтрокиИзНоменклатурыКонтрагентов[0];
				НоваяСтрока.Сопоставление = ЗаполнитьСопоставлениеНоменклатуры(НайденнаяСтрока,,,, СоответствиеСтавокНДСКонтрагента);
			Иначе
				НоваяСтрока.Сопоставление = ЗаполнитьСопоставлениеНоменклатуры(СтрокаТовары, ШтрихкодыКомбинаций, ШтрихкодыНоменклатуры, УпаковкаИзДокумента);
			КонецЕсли;

			Если ОблагаетсяНДССМежценовойРазницы
				И ТипЗнч(НоваяСтрока.Сопоставление.СтавкаНДС) = Тип("СправочникСсылка.СтавкиНДС") Тогда
				НоваяСтрока.Сопоставление.СтавкаНДС = УчетНДСРФВызовСервера.СтавкаНДСПоЗначениюПеречисления(НоваяСтрока.Сопоставление.СтавкаНДС.ПеречислениеСтавкаНДС,
					Перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС);
			КонецЕсли;
		КонецЕсли;

		Если ВидСчетаФактуры <> "Авансовый" Тогда
			НоваяСтрока.ЕдиницаИзмеренияКод = СокрЛП(СтрокаТовары.ЕдиницаИзмеренияКод);
			НоваяСтрока.ЕдиницаИзмеренияНаименование = СокрЛП(СтрокаТовары.ЕдиницаИзмеренияНаименование);
			//Анализ вариантов заполнения
			Если ЗаполнятьСопоставление
				И ЗаполнениеКодаТовара = "Штрихкод"
				И НоваяСтрока.Сопоставление.Свойство("ШтрихкодКомбинации") Тогда
				НоваяСтрока.Код = НоваяСтрока.Сопоставление.ШтрихкодКомбинации;
			ИначеЕсли ЗаполнятьСопоставление
				И ЗаполнениеКодаТовара = "Штрихкод"
				И (НоваяСтрока.Сопоставление.Свойство("ШтрихкодыНоменклатуры")
				И НоваяСтрока.Сопоставление.ШтрихкодыНоменклатуры.Количество()) Тогда
				НоваяСтрока.Код = НоваяСтрока.Сопоставление.ШтрихкодыНоменклатуры[0];
			Иначе
				НоваяСтрока.Код = СтрокаТовары.НоменклатураКод;
			КонецЕсли;
			//Конец анализа вариантов заполнения
		КонецЕсли;

		Если ЗначениеЗаполнено(СтрокаТовары.СтранаПроисхождения) Тогда
			РеквизитыСтраны = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СтрокаТовары.СтранаПроисхождения, "Код, Наименование");
			Если ФорматУПД = ПоддерживаемыеФорматы.УПД_5_02.ИнформацияПродавца Тогда
				НоваяСтрока.СтранаПроисхождения = РеквизитыСтраны.Наименование;
			ИначеЕсли ФорматУПД = ПоддерживаемыеФорматы.УПД_5_03.ИнформацияПродавца Тогда
				СтрокаСтраныПроисхождения = СтраныПроисхождения.Добавить();
				СтрокаСтраныПроисхождения.СтранаПроисхождения = РеквизитыСтраны.Наименование;
				НоваяСтрока.СтраныПроисхождения = СтраныПроисхождения.Скопировать();
				СтраныПроисхождения.Очистить();
			КонецЕсли;
		КонецЕсли;

		НоваяСтрока.Признак = ОпределитьПризнакТовара(СтрокаТовары.Номенклатура, ДокументОтгрузки);

		Если ЗначениеЗаполнено(СтрокаТовары.НомерГТД)
			Или ЗначениеЗаполнено(СтрокаТовары.СтранаПроисхождения)
			И (Не ЭтоЭлектронноеАктированиеЕИС Или СтрокаТовары.СтранаПроисхождения <> Справочники.СтраныМира.Россия) Тогда
			НоваяСтрокаДекларации = СведенияОДекларации.Добавить();

			Если СтрокаТовары.ТипНомераГТД = Перечисления.ТипыНомеровГТД.НомерРНПТКомплекта Тогда
				НоваяСтрокаДекларации.НомерДекларации = СокрЛП(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрокаТовары.НомерГТДСсылка, "Код"));
			Иначе
				НоваяСтрокаДекларации.НомерДекларации = СокрЛП(СтрокаТовары.НомерГТД);
			КонецЕсли;

			Если ЗначениеЗаполнено(СтрокаТовары.СтранаПроисхождения) Тогда
				НоваяСтрокаДекларации.КодСтраны = РеквизитыСтраны.Код;
			КонецЕсли;

			НоваяСтрока.СведенияОДекларации = СведенияОДекларации.Скопировать();
			СведенияОДекларации.Очистить();
		КонецЕсли;

		Если Не ЭтоКомиссия
			И Не ВидСчетаФактуры = "Авансовый"
			И ТипЗнч(ДокументОтгрузки) <> Тип("ДокументСсылка.АктВыполненныхРабот")
			И ТипЗнч(ДокументОтгрузки) <> Тип("ДокументСсылка.ВозвратТоваровПоставщику")
			И ТипЗнч(ДокументОтгрузки) <> Тип("ДокументСсылка.ВыкупТоваровХранителем")
			И ТипЗнч(ДокументОтгрузки) <> Тип("ДокументСсылка.КорректировкаРеализации")
			И ТипЗнч(ДокументОтгрузки) <> Тип("ДокументСсылка.РеализацияУслугПрочихАктивов")
			И ТипЗнч(ДокументОтгрузки) <> Тип("ДокументСсылка.ВозвратТоваровМеждуОрганизациями")
			И ЗначениеЗаполнено(СтрокаТовары.КодТНВЭД)
			И ВыводитьКодыТНВЭД Тогда

			НоваяСтрока.КодВидаТовара = СтрокаТовары.КодТНВЭД.Код;

		ИначеЕсли ВидСчетаФактуры = "Авансовый"
			И ЗначениеЗаполнено(СтрокаТовары.Номенклатура.КодТНВЭД) И ВыводитьКодыТНВЭД Тогда

			НоваяСтрока.КодВидаТовара = СтрокаТовары.Номенклатура.КодТНВЭД.Код;

		КонецЕсли;

		// Заполнение прослеживаемости
		Если ЗначениеЗаполнено(СтрокаТовары.КоличествоПоРНПТ) Тогда
			ЗаполнитьСведенияОПрослеживаемостиУПД(НоваяСтрока, СтрокаТовары, ПрослеживаемыеКомплектующие, ФорматУПД);
		ИначеЕсли ЗначениеЗаполнено(ТаблицаДанныхПрослеживаемости) Тогда
			ЗаполнитьПрослеживаемостьДляРеализацииАктивов(НоваяСтрока,
				СтрокаТовары,
				ТаблицаДанныхПрослеживаемости,
				ВыводитьКодыТНВЭД,
				ФорматУПД);
		КонецЕсли;
		// Конец заполнения прослеживаемости

		ЭлектронноеВзаимодействиеИСМП.ЗаполнитьСведенияОМаркировке_5_02(НоваяСтрока, СтрокаТовары, ТаблицаКодовМаркировки);

		// ЭлектронноеВзаимодействие.ЭлектронноеАктированиеЕИС
		Если ЭтоЭлектронноеАктированиеЕИС Тогда
			НоваяСтрока.ИдентификаторМестаПоставкиЕИС = ИдентификаторМестаПоставкиЕИС;
			ЭлектронноеАктированиеЕИСУТ.ЗаполнитьДанныеПоСтрокеТоваровУПД_2019(НоваяСтрока, СтрокаТовары, СтруктураДанных, ДанныеПриложенияЕИС);
		КонецЕсли;
		// Конец ЭлектронноеВзаимодействие.ЭлектронноеАктированиеЕИС
		
	КонецЦикла;

	ЭлектронноеВзаимодействиеИСМП.ПроверитьСведенияОМаркировке_5_02(ТаблицаКодовМаркировки, Отказ);
	ЭлектронноеВзаимодействиеИСМП.ЗаполнениеПоказателейМаркировкиВДереве_5_02(ДеревоДанных, ТаблицаКодовМаркировки);
	
	ТекстОшибки = НСтр("ru = 'Не удалось заполнить итоговые стоимостные показатели. Возможные причины:
	|	- не заполнена табличная часть ""Товары""
	|	- не заполнены колонки ""Сумма"", ""НДС"", ""Количество""'");
	ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДанных,
		"ТаблицаСчетаФактуры.ВсегоКОплате.СтоимостьБезНалога",
		ТаблицаТоваров.Итог("СтоимостьБезНалога"),
		ТекстОшибки);
	ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДанных,
		"ТаблицаСчетаФактуры.ВсегоКОплате.СтоимостьСНалогом",
		ТаблицаТоваров.Итог("СтоимостьСНалогом"),
		ТекстОшибки);
	ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДанных,
		"ТаблицаСчетаФактуры.ВсегоКОплате.Количество",
		ТаблицаТоваров.Итог("Количество"),
		ТекстОшибки);

	Если СуммаНалога.БезНДС = Истина Тогда
		СуммаНалога.Сумма = Неопределено;
	Иначе
		СуммаНалога.БезНДС = Неопределено;
	КонецЕсли;

	ЭлектронноеВзаимодействие.ЗагрузитьСтруктуруВГруппуДерева(ДеревоДанных,
		СуммаНалога,
		"ТаблицаСчетаФактуры.ВсегоКОплате.СуммаНалога");
	ЭлектронноеВзаимодействие.ДобавитьВРеквизитОбработкуОшибки(ДеревоДанных,
		"ТаблицаСчетаФактуры.ВсегоКОплате.СуммаНалога",
		ТекстОшибки);

	// Обработка ошибки с открытием формы по навигационной ссылке.
	ЭлектронноеВзаимодействие.ДобавитьВТаблицуОбработкуОшибкиЧерезНавигационнуюСсылку(ТаблицаТоваров,
		"Наименование",
		"НаименованиеНавигационнаяСсылка");
	ЭлектронноеВзаимодействие.ДобавитьВТаблицуОбработкуОшибкиЧерезОткрытиеФормы(ТаблицаТоваров,
		"Наименование",
		"Справочник.Номенклатура.ФормаОбъекта",,
		Новый Структура("Ключ", "Номенклатура"));

	// Обработка ошибки через механизм сообщений пользователю.
	ЭлектронноеВзаимодействие.ДобавитьВТаблицуОбработкуОшибкиЧерезСообщениеПользователю(ТаблицаТоваров,
		"Код",
		"Номенклатура",
		"Объект.Код");
	ЭлектронноеВзаимодействие.ДобавитьВТаблицуОбработкуОшибкиЧерезСообщениеПользователю(ТаблицаТоваров,
		"Наименование",
		"Номенклатура",
		"Объект.НаименованиеПолное");
	ЭлектронноеВзаимодействие.ДобавитьВТаблицуОбработкуОшибкиЧерезСообщениеПользователю(ТаблицаТоваров,
		"Количество",
		ВыборкаПоДокументам.Ссылка,
		"Объект.Товары.Количество",,
		"НомерСтрокиИсходногоДокумента");
	ЭлектронноеВзаимодействие.ДобавитьВТаблицуОбработкуОшибкиЧерезСообщениеПользователю(ТаблицаТоваров,
		"Цена",
		ВыборкаПоДокументам.Ссылка,
		"Объект.Товары.Цена",,
		"НомерСтрокиИсходногоДокумента");
	ЭлектронноеВзаимодействие.ДобавитьВТаблицуОбработкуОшибкиЧерезСообщениеПользователю(ТаблицаТоваров,
		"СтоимостьБезНалога",
		ВыборкаПоДокументам.Ссылка,
		"Объект.Товары.Сумма",,
		"НомерСтрокиИсходногоДокумента");
	ЭлектронноеВзаимодействие.ДобавитьВТаблицуОбработкуОшибкиЧерезСообщениеПользователю(ТаблицаТоваров,
		"ЕдиницаИзмеренияНаименование",
		"ЕдиницаИзмерения",
		"Объект.Наименование");
	ЭлектронноеВзаимодействие.ДобавитьВТаблицуОбработкуОшибкиЧерезСообщениеПользователю(ТаблицаТоваров,
		"ЕдиницаИзмеренияКод",
		"ЕдиницаИзмерения",
		"Объект.Код");
	ЭлектронноеВзаимодействие.ДобавитьВТаблицуОбработкуОшибкиЧерезСообщениеПользователю(ТаблицаТоваров,
		"Признак",
		"Номенклатура",
		"Объект.ВидНоменклатуры");

	// Обработка ошибки через упрощенный механизм
	ТекстОшибки = НСтр("ru = 'для формирования электронного документа необходимо указать налоговую ставку'");
	ЭлектронноеВзаимодействие.ДобавитьВТаблицуОбработкуОшибкиЧерезСообщениеПользователю(ТаблицаТоваров,
		"НалоговаяСтавка",,,
		ТекстОшибки);

	ЭлектронноеВзаимодействие.ЗагрузитьТаблицуВДерево(ДеревоДанных,
		ТаблицаТоваров,
		"ТаблицаСчетаФактуры.СведенияОбОтгруженныхПозициях");

	ТекстОшибки = НСтр("ru = 'Возникла ошибка при заполнении страны происхождения в сведениях по ГТД. Возможные причины:
	|	- не заполнена колонка ""Страна происхождения""
	|	- указанной страны нет в классификаторе стран мира'");
	ЭлектронноеВзаимодействие.ДобавитьВРеквизитОбработкуОшибки(ДеревоДанных,
		"ТаблицаСчетаФактуры.СведенияОбОтгруженныхПозициях.НомерСтроки.СведенияОДекларации.НомерСтроки.КодСтраны",
		ТекстОшибки);

	СоставСодержания = Новый Массив;
	Если ВидСчетаФактуры = "Авансовый" Тогда
		СоставСодержания.Добавить(НСтр("ru = 'Регистрация счет-фактуры на аванс.'"));
	Иначе
		Если ЕстьТовары Тогда
			СоставСодержания.Добавить(НСтр("ru = 'Товары переданы.'"));
		КонецЕсли;
		Если ЕстьУслуги Тогда
			СоставСодержания.Добавить(НСтр("ru = 'Услуги оказаны в полном объеме.'"));
		КонецЕсли;
		Если ЕстьРаботы Тогда
			СоставСодержания.Добавить(НСтр("ru = 'Работы выполнены в полном объеме.'"));
		КонецЕсли;
		Если ЕстьПрава Тогда
			СоставСодержания.Добавить(НСтр("ru = 'Имущественные права переданы.'"));
		КонецЕсли;
		Если СоставСодержания.Количество() = 0 Тогда
			СоставСодержания.Добавить(НСтр("ru = 'Товары переданы.'"));
		КонецЕсли;
	КонецЕсли;
	СодержаниеОперации = СтрСоединить(СоставСодержания, " ");
	ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДанных,
		"СведенияОПередаче.Операция.СодержаниеОперации",
		СодержаниеОперации);

	//Заполним документы основания.
	МассивДокументовОснований = Новый Массив;
	ИсправляемыйДокументЭтоКорректировка = Ложь;
	Если ТипЗнч(ДокументОтгрузки) <> Тип("ДокументСсылка.КорректировкаРеализации")
			И ТипЗнч(ДокументОтгрузки) <> Тип("ДокументСсылка.РеализацияУслугПрочихАктивов")
			И ТипЗнч(ДокументОтгрузки) <> Тип("ДокументСсылка.ОтчетКомиссионера")
			И ТипЗнч(ДокументОтгрузки) <> Тип("ДокументСсылка.ОтчетКомитенту")
			И ТипЗнч(ДокументОтгрузки) <> Тип("ДокументСсылка.ОтгрузкаТоваровСХранения")
			И ТипЗнч(ДокументОтгрузки) <> Тип("ДокументСсылка.ВозвратТоваровПоставщику")
			И ТипЗнч(ДокументОтгрузки) <> Тип("ДокументСсылка.ВыкупТоваровХранителем")
			И ТипЗнч(ДокументОтгрузки) <> Тип("ДокументСсылка.ВозвратТоваровМеждуОрганизациями") 
			И ТипЗнч(ДокументОтгрузки) <> Тип("ДокументСсылка.ПередачаТоваровМеждуОрганизациями") 
			И Не ВидСчетаФактуры = "Авансовый" Тогда
			
		ЗаказКлиента = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументОтгрузки, "ЗаказКлиента");
		Если ЗначениеЗаполнено(ЗаказКлиента) Тогда
			МассивДокументовОснований.Добавить(ЗаказКлиента);
		КонецЕсли;
	ИначеЕсли ТипЗнч(ДокументОтгрузки) = Тип("ДокументСсылка.КорректировкаРеализации") Тогда
		
		ДокументОснование = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументОтгрузки, "ДокументОснование");
		МассивДокументовОснований.Добавить(ДокументОснование);		
		
		ВидКорректировки = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументОтгрузки, "ВидКорректировки");
		Если ВидКорректировки =  Перечисления.ХозяйственныеОперации.ИсправлениеОшибок Тогда
			ИсправляемыйДокумент = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументОтгрузки, "ИсправляемыйДокумент");
			Если ЗначениеЗаполнено(ИсправляемыйДокумент) И ИсправляемыйДокумент <> ДокументОснование Тогда
				ИсправляемыйДокументЭтоКорректировка = Истина;
				МассивДокументовОснований.Добавить(ИсправляемыйДокумент);
			КонецЕсли;
		КонецЕсли;
	ИначеЕсли	ТипЗнч(ДокументОтгрузки) = Тип("ДокументСсылка.ПередачаТоваровХранителю")
				ИЛИ ТипЗнч(ДокументОтгрузки) = Тип("ДокументСсылка.ОтгрузкаТоваровСХранения") Тогда
	
		ДокументОснование =	ДанныеШапки.ДокументОснование;
		Если ДанныеШапки.Исправление И ЗначениеЗаполнено(ДанныеШапки.ИсправляемыйДокумент) Тогда
			ДокументОснование =	ДанныеШапки.ИсправляемыйДокумент;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ДокументОснование) Тогда
			МассивДокументовОснований.Добавить(ДокументОснование);
		КонецЕсли;
	КонецЕсли;
	
	Если МассивДокументовОснований.Количество() > 0 Тогда
		ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДанных, "ДокументыОснованияДокументаОтгрузки", МассивДокументовОснований);
	КонецЕсли;	
		
	Если ДанныеШапки.Исправление Тогда
		ВидОперацииЭД = Перечисления.ВидыОперацийЭД.Исправление;
	Иначе
		ВидОперацииЭД = Перечисления.ВидыОперацийЭД.ПродажаКомиссия;
	КонецЕсли;
	
	ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДанных, "СведенияОПередаче.Операция.ВидОперации", Строка(ВидОперацииЭД));
	ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДанных, "СведенияОПередаче.Операция.ДатаОтгрузки", ДанныеШапки.Дата);

	Путь = "СведенияОПередаче.Операция.ОснованиеОтгрузкиПередачи.";
	Если ВидСчетаФактуры = "Авансовый" Тогда

		ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДанных,
			Путь + "БезДокументаОснования",
			Истина);

	Иначе

		ДокументОснование = Неопределено;
		ДопДанныеДокументаОтгрузки = ЭлектронноеВзаимодействие.ДанныеЭлементаДереваЭлектронногоДокумента(ДеревоДанных,
			"СведенияОПередаче.ИнформационноеПолеФХЖ.ТекстоваяИнформация");
		ТаблицаДокументовОснований = ЭлектронноеВзаимодействие.ДанныеЭлементаДереваЭлектронногоДокумента(ДеревоДанных,
			Путь + "ДокументыОснования");

		Если ЗначениеЗаполнено(ДанныеШапки.ДоверенностьНомер) И ЗначениеЗаполнено(ДанныеШапки.ДоверенностьДата)
			И (ЗначениеЗаполнено(ДанныеШапки.ДоверенностьВыдана) Или ЗначениеЗаполнено(ДанныеШапки.ДоверенностьЛицо)) Тогда

			ДокументОснование = ЭлектронноеВзаимодействие.ДанныеЭлементаДереваЭлектронногоДокумента(ДеревоДанных,
				Путь + "ДокументыОснования.НомерСтроки.ДокументОснование");
			ДокументОснование.НаименованиеДокумента = НСтр("ru = 'по доверенности'");
			ДокументОснование.НомерДокумента = ДанныеШапки.ДоверенностьНомер;
			ДокументОснование.ДатаДокумента = ДанныеШапки.ДоверенностьДата;
			ДокументОснование.ДополнительныеСведения = СтрШаблон(НСтр("ru = 'выданной %1 %2'"),
				ДанныеШапки.ДоверенностьВыдана,
				ДанныеШапки.ДоверенностьЛицо);

			СтрокаДокументаОснования = ТаблицаДокументовОснований.Добавить();
			СтрокаДокументаОснования.ДокументОснование = ДокументОснование;

			ЭлектронноеВзаимодействие.ДобавитьВТаблицуОбработкуОшибкиЧерезСообщениеПользователю(СтрокаДокументаОснования,
				"ДатаДокумента",,,
				НСтр("ru = 'Необходимо указать дату доверенности.'"));
					
		КонецЕсли;	
		
		Если ЗначениеЗаполнено(ДанныеШапки.Основание) И ЗначениеЗаполнено(ДанныеШапки.ОснованиеДата) Тогда
			ПредставлениеОснования = Строка(ДанныеШапки.Основание);
			Если СтрНайти(ПредставлениеОснования, "№") Тогда
				СтрокаНаименование = Лев(ПредставлениеОснования, СтрНайти(ПредставлениеОснования, "№") - 2);
				Если ПустаяСтрока(СтрокаНаименование) Тогда
					СтрокаНаименование = НСтр("ru = 'Договор'");
				КонецЕсли;
			Иначе
				СтрокаНаименование = ПредставлениеОснования;
			КонецЕсли;
			ДокументОснование = ЭлектронноеВзаимодействие.ДанныеЭлементаДереваЭлектронногоДокумента(ДеревоДанных,
				Путь + "ДокументыОснования.НомерСтроки.ДокументОснование");
			ДокументОснование.НаименованиеДокумента = СтрокаНаименование;
			ДокументОснование.НомерДокумента = ДанныеШапки.ОснованиеНомер;
			ДокументОснование.ДатаДокумента = ДанныеШапки.ОснованиеДата;

			СтрокаДокументаОснования = ТаблицаДокументовОснований.Добавить();
			СтрокаДокументаОснования.ДокументОснование = ДокументОснование;

			// Дополним таблицу оснований параметрами обработки ошибок.
			ЭлектронноеВзаимодействие.ДобавитьВТаблицуОбработкуОшибкиЧерезСообщениеПользователю(СтрокаДокументаОснования,
				"ДокументОснование.НаименованиеДокумента",, "Объект.Наименование");
			ЭлектронноеВзаимодействие.ДобавитьВТаблицуОбработкуОшибкиЧерезСообщениеПользователю(СтрокаДокументаОснования,
				"ДокументОснование.НомерДокумента",, "Объект.НомерДоговора");
			ЭлектронноеВзаимодействие.ДобавитьВТаблицуОбработкуОшибкиЧерезСообщениеПользователю(СтрокаДокументаОснования,
				"ДокументОснование.ДатаДокумента",, "Объект.ДатаДоговора");
			
		КонецЕсли;
		
		Если ТипЗнч(ДокументОтгрузки) = Тип("ДокументСсылка.ВозвратТоваровПоставщику") Тогда

			ДокументПоступления = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументОтгрузки, "ДокументПоступления");
			Если ЗначениеЗаполнено(ДокументПоступления) Тогда
				РеквизитыДокументаПоступления = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДокументПоступления,
					"НомерВходящегоДокумента, ДатаВходящегоДокумента");
				Если ЗначениеЗаполнено(РеквизитыДокументаПоступления.ДатаВходящегоДокумента)
					И ЗначениеЗаполнено(РеквизитыДокументаПоступления.НомерВходящегоДокумента) Тогда
					ДокументОснование = ЭлектронноеВзаимодействие.ДанныеЭлементаДереваЭлектронногоДокумента(ДеревоДанных,
						Путь + "ДокументыОснования.НомерСтроки.ДокументОснование");
					ДокументОснование.НаименованиеДокумента = НаименованиеОснованияВходящийЭлектронныйДокумент();
					ДокументОснование.НомерДокумента = РеквизитыДокументаПоступления.НомерВходящегоДокумента;
					ДокументОснование.ДатаДокумента = РеквизитыДокументаПоступления.ДатаВходящегоДокумента;

					СтрокаДокументаОснования = ТаблицаДокументовОснований.Добавить();
					СтрокаДокументаОснования.ДокументОснование = ДокументОснование;

					ЭлектронноеВзаимодействие.ДобавитьВТаблицуОбработкуОшибкиЧерезСообщениеПользователю(СтрокаДокументаОснования,
						"ДокументОснование.ДатаДокумента",, "Объект.ДатаДоговора");
				КонецЕсли;
			КонецЕсли;

		ИначеЕсли ТипЗнч(ДокументОтгрузки) = Тип("ДокументСсылка.ОтчетКомитенту") Тогда

			ДоговорДокументаОтгрузки = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументОтгрузки, "Договор");
			Если ЗначениеЗаполнено(ДоговорДокументаОтгрузки) Тогда
				РеквизитыДоговора = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДоговорДокументаОтгрузки, "Номер, Дата");
				Если ЗначениеЗаполнено(РеквизитыДоговора.Дата) И ЗначениеЗаполнено(РеквизитыДоговора.Номер) Тогда

					ДопДанные = ДопДанныеДокументаОтгрузки.Добавить();
					ДопДанные.Идентификатор = "НомерДоговора";
					ДопДанные.Значение = РеквизитыДоговора.Номер;

					ДопДанные = ДопДанныеДокументаОтгрузки.Добавить();
					ДопДанные.Идентификатор = "ДатаДоговора";
					ДопДанные.Значение = Формат(РеквизитыДоговора.Дата, "ДФ=dd.MM.yyyy");

				КонецЕсли;
			КонецЕсли;

		ИначеЕсли ТипЗнч(ДокументОтгрузки) = Тип("ДокументСсылка.ПередачаТоваровМеждуОрганизациями")
			Или ТипЗнч(ДокументОтгрузки) = Тип("ДокументСсылка.ВозвратТоваровМеждуОрганизациями") Тогда

			ДопДанные = ДопДанныеДокументаОтгрузки.Добавить();
			ДопДанные.Идентификатор = "ИдентификаторПередачи";
			ДопДанные.Значение = Строка(ДокументОтгрузки.УникальныйИдентификатор());
			
		ИначеЕсли	(ТипЗнч(ДокументОтгрузки) = Тип("ДокументСсылка.ПередачаТоваровХранителю")
					ИЛИ ТипЗнч(ДокументОтгрузки) = Тип("ДокументСсылка.ОтгрузкаТоваровСХранения")) Тогда
			
			Основание =	ДанныеШапки.ДокументОснование;
			Если ДанныеШапки.Исправление И ЗначениеЗаполнено(ДанныеШапки.ИсправляемыйДокумент) Тогда
				Основание =	ДанныеШапки.ИсправляемыйДокумент;
			КонецЕсли;
		
			Если ЗначениеЗаполнено(Основание) Тогда
				ДокументыОснования = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Основание);
				ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДанных, "ДокументыОснованияСчетаФактуры", Основание);
			КонецЕсли;
			
			// Строка 8 - Основание передачи (сдачи) / получения (приемки)
			Если НЕ ЗначениеЗаполнено(ТаблицаДокументовОснований) Тогда 
				Основание =	ДанныеШапки.ДокументОснование;
				Если	НЕ ЗначениеЗаполнено(Основание) 
						И ДанныеШапки.Исправление
						И ЗначениеЗаполнено(ДанныеШапки.ИсправляемыйДокумент) Тогда
					Основание =	ДанныеШапки.ИсправляемыйДокумент;
				КонецЕсли;
			
				Если ЗначениеЗаполнено(Основание) Тогда			
					ДокументОснование = ЭлектронноеВзаимодействие.ДанныеЭлементаДереваЭлектронногоДокумента(ДеревоДанных,
												Путь + "ДокументыОснования.НомерСтроки.ДокументОснование");
					
					ЗначенияРеквизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Основание, "Номер, Дата");
					ДокументОснование.НаименованиеДокумента = Основание.Метаданные().Синоним;
					ДокументОснование.ДатаДокумента = ЗначенияРеквизитов.Дата;
					ДокументОснование.НомерДокумента = НомерСчетаФактурыНаПечать(ЗначенияРеквизитов.Номер, ДанныеШапки.ИндексПодразделения);
					
					СтрокаДокументаОснования = ТаблицаДокументовОснований.Добавить();
					СтрокаДокументаОснования.ДокументОснование = ДокументОснование;
					
				Иначе
											
					ДанныеЗаказов = СтруктураДанных.РезультатПоЗаказам.Выбрать();
					Пока ДанныеЗаказов.Следующий() Цикл
						Если	ЗначениеЗаполнено(ДанныеЗаказов.ТипДокумента)
								И ЗначениеЗаполнено(ДанныеЗаказов.Дата)
								И ЗначениеЗаполнено(ДанныеЗаказов.Номер) Тогда
							
							ДокументОснование = ЭлектронноеВзаимодействие.ДанныеЭлементаДереваЭлектронногоДокумента(ДеревоДанных,
														Путь + "ДокументыОснования.НомерСтроки.ДокументОснование");
					
							ДокументОснование.НаименованиеДокумента = Строка(ДанныеЗаказов.ТипДокумента);
							ДокументОснование.ДатаДокумента = ДанныеЗаказов.Дата;
							ДокументОснование.НомерДокумента = НомерСчетаФактурыНаПечать(ДанныеЗаказов.Номер, ДанныеШапки.ИндексПодразделения);
							
							СтрокаДокументаОснования = ТаблицаДокументовОснований.Добавить();
							СтрокаДокументаОснования.ДокументОснование = ДокументОснование;
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
			КонецЕсли;
				
		ИначеЕсли ИсправляемыйДокументЭтоКорректировка Тогда

			ДопДанные = ДопДанныеДокументаОтгрузки.Добавить();
			ДопДанные.Идентификатор = "ИсправляемыйДокументЭтоКорректировка";
			ДопДанные.Значение = Истина;

		КонецЕсли;

		Если ДокументОснование = Неопределено Тогда
			ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДанных,
				Путь + "БезДокументаОснования",
				Истина);
		Иначе
			ЭлектронноеВзаимодействие.ЗагрузитьТаблицуВДерево(ДеревоДанных,
				ТаблицаДокументовОснований,
				Путь + "ДокументыОснования");
		КонецЕсли;

		Если ДопДанныеДокументаОтгрузки.Количество() > 0 Тогда
			ЭлектронноеВзаимодействие.ЗагрузитьТаблицуВДерево(ДеревоДанных,
				ДопДанныеДокументаОтгрузки,
				"СведенияОПередаче.ИнформационноеПолеФХЖ.ТекстоваяИнформация");
		КонецЕсли;

		Если ЗначениеЗаполнено(ДанныеШапки.Кладовщик) Тогда
			ФИО = ФизическиеЛицаКлиентСервер.ЧастиИмени(ДанныеШапки.Кладовщик);
			Если ЗначениеЗаполнено(ДанныеШапки.ДолжностьКладовщика) Тогда
				// Кладовщик работает в организации
				Путь = "СведенияОПередаче.Операция.ЛицоОтветственноеЗаПередачу.РаботникПродавца.";

				ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДанных,
					Путь + "Должность",
					Строка(ДанныеШапки.ДолжностьКладовщика));
				ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДанных,
					Путь + "ФИО.Фамилия",
					ФИО.Фамилия);
				ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДанных,
					Путь + "ФИО.Имя",
					ФИО.Имя);
				ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДанных,
					Путь + "ФИО.Отчество",
					ФИО.Отчество);
			Иначе
				// Кладовщик не работает в организации
				ИННФЛ = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеШапки.Кладовщик, "ИНН");
				Если ЗначениеЗаполнено(ИННФЛ) Тогда
					Путь = "СведенияОПередаче.Операция.ЛицоОтветственноеЗаПередачу.ИноеЛицо.ФизическоеЛицо.";
					ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДанных,
						Путь + "ИНН",
						ИННФЛ);
					ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДанных,
						Путь + "ФИО.Фамилия",
						ФИО.Фамилия);
					ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДанных,
						Путь + "ФИО.Имя",
						ФИО.Имя);
					ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДанных,
						Путь + "ФИО.Отчество",
						ФИО.Отчество);
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;

	// Строки 9, 12 УПД
	Если ТипЗнч(ДокументОтгрузки) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
		ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(
