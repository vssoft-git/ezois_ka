&НаКлиенте
Процедура vs_ДоизготовлениеОтказПриИзменении(Элемент) 
	ТД = Элементы.vs_Доизготовление.ТекущиеДанные ;
	Если не ЗначениеЗаполнено(ТД.Серия) Тогда
	   	Если ТД.Отказ <> 0 и ТД.Отказ > ТД.ТребуетсяДоизготовить - ТД.Количество тогда
	        ТД.Отказ  =  ТД.ТребуетсяДоизготовить - ТД.Количество ;
			ПоказатьПредупреждение(,"Значение количества в столбце  ""Отказ""  не может  превышать  расчетного значения  
			|(разница количества  в  столбцах ""Требуется доизготовить""  и ""Доизготовить""), 
			|уменьшите количество в столбце ""Отказ"" до необходимого расчетного значения!");
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура vs_СтатусПриИзмененииНаСервере()
	Элементы.ГруппаОсновное.ТолькоПросмотр = объект.vs_Статус = Перечисления.СтатусыСборокТоваров.СобраноРазобрано;	
	Элементы.vs_Доизготовление.ТолькоПросмотр = объект.vs_Статус = Перечисления.СтатусыСборокТоваров.СобраноРазобрано;	
	Если Элементы.vs_Доизготовление.ТолькоПросмотр Тогда
		Объект.Товары.Очистить();
		Объект.Серии.Очистить();
		Объект.ВидыЗапасов.Очистить();
		ТЗ = Объект.vs_Доизготовление.Выгрузить();
		ТЗ.Свернуть("Номенклатура,Характеристика,Серия,СтатьяРасходов,АналитикаРасходов,Назначение","Количество");
		Отбор = Новый Структура("Количество",0);
		ИскСтр = ТЗ.НайтиСтроки(Отбор);
		Для Каждого Стр Из ИскСтр Цикл
			ТЗ.Удалить(Стр);
		КонецЦикла;
		Объект.Товары.Загрузить(ТЗ);
		Для Каждого Стр из Объект.Товары Цикл
			Стр.КоличествоУпаковок = Стр.Количество;
			Если ЗначениеЗаполнено(Стр.Серия) Тогда
				Стр.СтатусУказанияСерий  			= 4;
				Стр.СтатусУказанияСерийОтправитель 	= 4; 					// fix Designer 14.02.2023 16:45:13
				НовСтр                      		= Объект.Серии.Добавить();
				ЗаполнитьЗначенияСвойств(НовСтр,Стр);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

