&НаСервере
Процедура ЗаполнитьТч()
    
    Объект.Товары.Очистить();   
    
    Запрос = Новый Запрос;
    Запрос.Текст = 
    "ВЫБРАТЬ
    |	vs_Доизготовление.ДоизготовитьОстаток КАК ТребуетсяДоизготовить,
    |	vs_Доизготовление.АктИзготовления.Номенклатура КАК АналитикаРасходов,
    |	vs_Доизготовление.ДоизготовитьОстаток КАК Количество,
    |	vs_Доизготовление.Номенклатура КАК Номенклатура,
    |	vs_СтатьяДоизготовления.Значение КАК СтатьяРасходов
    |ИЗ
    |	РегистрНакопления.vs_Доизготовление.Остатки(, АктИзготовления = &Акт) КАК vs_Доизготовление,
    |	Константа.vs_СтатьяДоизготовления КАК vs_СтатьяДоизготовления Где vs_Доизготовление.ДоизготовитьОстаток > 0";
    
    Запрос.УстановитьПараметр("Акт", Объект.vs_АктИзготовления);
    Запрос.УстановитьПараметр("Склад", 	Объект.Склад);    // begin fix Designer 10.04.2023 15:56:11
	Запрос.УстановитьПараметр("Дата", Новый Граница(?(ЗначениеЗаполнено(Объект.Дата), Объект.Дата, КонецДня(ТекущаяДатаСеанса())), ВидГраницы.Включая));
	
	Объект.Дата = Запрос.Параметры.Дата.Значение;
	
	Запрос.Текст = "
    |ВЫБРАТЬ
    |	vs_Доизготовление.АктИзготовления.Номенклатура 	КАК АналитикаРасходов,
    |	vs_СтатьяДоизготовления.Значение 					КАК СтатьяРасходов,
    |	vs_Доизготовление.Номенклатура 					КАК Номенклатура,
    |	ТоварыНаСкладахОстатки.Характеристика 				КАК Характеристика,
    |	ТоварыНаСкладахОстатки.Серия 						КАК Серия,
	|	ТоварыНаСкладахОстатки.Назначение 					КАК Назначение,
	|	vs_Доизготовление.ДоизготовитьОстаток 			КАК ТребуетсяДоизготовить,
    |	ВЫБОР
    |		КОГДА ЕСТЬNULL(vs_Доизготовление.ДоизготовитьОстаток,0) < ЕСТЬNULL(ТоварыНаСкладахОстатки.ВНаличииОстаток,0)
    |			ТОГДА ЕСТЬNULL(vs_Доизготовление.ДоизготовитьОстаток,0)
    |		ИНАЧЕ ЕСТЬNULL(ТоварыНаСкладахОстатки.ВНаличииОстаток,0)
    |	КОНЕЦ 												КАК Количество,
	|	0 													КАК Отказ,
	|	СпрВидыНоменклатуры.ИспользоватьСерии 				КАК ИспользуютсяСерии
    |ИЗ
    |	РегистрНакопления.vs_Доизготовление.Остатки(&Дата, АктИзготовления = &Акт) КАК vs_Доизготовление
    |		ЛЕВОЕ СОЕДИНЕНИЕ Константа.vs_СтатьяДоизготовления КАК vs_СтатьяДоизготовления
    |		ПО (ИСТИНА)
    |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыНаСкладах.Остатки(&Дата, Склад = &Склад) КАК ТоварыНаСкладахОстатки
    |		ПО (vs_Доизготовление.Номенклатура = ТоварыНаСкладахОстатки.Номенклатура)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СпрНоменклатура
	|				ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВидыНоменклатуры КАК СпрВидыНоменклатуры
	|				ПО (СпрНоменклатура.ВидНоменклатуры = СпрВидыНоменклатуры.Ссылка)
	|			ПО (vs_Доизготовление.Номенклатура = СпрНоменклатура.Ссылка)
    |ГДЕ
    |	vs_Доизготовление.ДоизготовитьОстаток > 0
	|	И ЕСТЬNULL(ТоварыНаСкладахОстатки.ВНаличииОстаток,0) >= 0
    |
    |УПОРЯДОЧИТЬ ПО
    |	Номенклатура,
    |	Характеристика,
	|   Серия,
	|   ТребуетсяДоизготовить,
    |	Количество ";	// УБЫВ  
	
	//|	vs_Доизготовление.ДоизготовитьОстаток -
	//|	ЕСТЬNULL(ВЫБОР
	//|		КОГДА vs_Доизготовление.ДоизготовитьОстаток < ТоварыНаСкладахОстатки.ВНаличииОстаток
	//|			ТОГДА vs_Доизготовление.ДоизготовитьОстаток
	//|		ИНАЧЕ ТоварыНаСкладахОстатки.ВНаличииОстаток
	//|	КОНЕЦ,0) КАК Отказ
	
	ТЗ = Запрос.Выполнить().Выгрузить();
	сч = ТЗ.Количество();
	ИспользованныйОтбор = Новый ТаблицаЗначений();
	ИспользованныйОтбор.Колонки.Добавить("Номенклатура");
	ИспользованныйОтбор.Колонки.Добавить("Характеристика");
	Пока сч>0 Цикл
		сч = сч - 1;
		Если Не ТЗ[сч].ИспользуютсяСерии Тогда Продолжить; КонецЕсли;
		С = Новый Структура();
		С.Вставить("Номенклатура", ТЗ[сч].Номенклатура);
		С.Вставить("Характеристика", ТЗ[сч].Характеристика);
		Если ИспользованныйОтбор.НайтиСтроки(С).Количество() Тогда
			Продолжить;
		КонецЕсли;
		ИскКол = ТЗ[сч].ТребуетсяДоизготовить;
		ИскСтр = ТЗ.НайтиСтроки(С);
		Если ИскСтр.Количество() = 1 Тогда 
			Если ИскКол = 1 Тогда 
				Продолжить; 
			КонецЕсли;
			Для поз=2 По ИскКол Цикл
				НСтр = ТЗ.Добавить();
				ЗаполнитьЗначенияСвойств(НСтр,ИскСтр[0]);
				НСтр.ТребуетсяДоизготовить=1;	
			КонецЦикла;
			Продолжить; 
		КонецЕсли;
		 
		Для каждого Стр Из ИскСтр Цикл
			Если ИскКол = 0 Тогда
				ТЗ.Удалить(Стр);
				Продолжить;
			КонецЕсли;
			ИскКол = ИскКол - Стр.Количество;
			Если ИскКол <= 0 Тогда
				Стр.Количество = Стр.Количество + ИскКол;
				Стр.ТребуетсяДоизготовить = Стр.Количество;
				ИскКол = 0;
			Иначе
				Стр.ТребуетсяДоизготовить = Стр.Количество;	
			КонецЕсли;
			Если Стр.Количество = 0 Тогда
				ТЗ.Удалить(Стр);
			КонецЕсли;
		КонецЦикла;
		Если ИскКол > 0 Тогда
			Для поз=1 По ИскКол Цикл
				НСтр = ТЗ.Добавить();
				ЗаполнитьЗначенияСвойств(НСтр,ИскСтр[0]);
				НСтр.ТребуетсяДоизготовить=1;	
			КонецЦикла;	
		КонецЕсли;	
		сч = Мин(Сч,ТЗ.Количество());
		СТЗ=ИспользованныйОтбор.Добавить();
		ЗаполнитьЗначенияСвойств(СТЗ,С);
	КонецЦикла;
	С = Новый Структура();
	С.Вставить("ТребуетсяДоизготовить", 0);
	ИскСтр = ТЗ.НайтиСтроки(С);
	Для каждого Стр Из ИскСтр Цикл
		ТЗ.Удалить(Стр);
	КонецЦикла;
    Объект.vs_Доизготовление.Загрузить(ТЗ);
	Объект.ИТБК_Доизготовление.Загрузить(ТЗ);
   	// end fix Designer 10.04.2023 15:56:22 
    
КонецПроцедуры

