&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	ТекущийОбъект.ИТБК_ЭтоДоизготовление	 = Объект.vs_ЭтоДоизготовление;
	ТекущийОбъект.ИТБК_АктИзготовления	 	 = Объект.vs_АктИзготовления;
	ТекущийОбъект.ИТБК_Статус				 = Объект.vs_Статус;
	ТекущийОбъект.ИТБК_Доизготовление.Загрузить(Объект.vs_Доизготовление.Выгрузить());
	
	Ошибки = Неопределено;
	для Каждого стр из ТекущийОбъект.vs_Доизготовление Цикл
		Если стр.Количество + стр.Отказ > стр.ТребуетсяДоизготовить 
			и стр.ТребуетсяДоизготовить > 0 Тогда
			ОбщегоНазначенияКлиентСервер.ДобавитьОшибкуПользователю(Ошибки, "Объект.vs_Доизготовление[%1].ТребуетсяДоизготовить", СтрШаблон("(Количество + Отказ) строка %1 > Требуется доизготовить",стр.НомерСтроки),,(стр.НомерСтроки+1));
		КонецЕсли;
		//Если (Стр.Отказ < Стр.Количество 
		//		или Стр.Отказ - Стр.Количество < Стр.ТребуетсяДоизготовить)
		//		и Справочники.ВидыНоменклатуры.НастройкиИспользованияСерий(Стр.Номенклатура.ВидНоменклатуры).ИспользоватьСерии и не значениеЗаполнено(Стр.Серия) тогда
		//	ОбщегоНазначенияКлиентСервер.ДобавитьОшибкуПользователю(Ошибки, "Объект.vs_Доизготовление[%1].Серия", СтрШаблон("Не заполнена серия по номенклатуре %1", стр.Номенклатура),,(стр.НомерСтроки+1));
		//КонецЕсли;
	КонецЦикла;
	Если Не Ошибки = Неопределено Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьОшибкиПользователю(Ошибки, Отказ);
		Возврат;
	КонецЕсли;
КонецПроцедуры

