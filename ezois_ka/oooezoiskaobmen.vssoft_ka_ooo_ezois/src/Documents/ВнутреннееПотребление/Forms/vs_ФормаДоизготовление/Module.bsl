&НаКлиенте
Процедура vs_ДоизготовлениеПередНачаломИзменения(Элемент, Отказ)
	Если Элементы.vs_Доизготовление.ТолькоПросмотр = Ложь Тогда
		ТД = Элемент.ТекущиеДанные;
		ТЭ = Элемент.ТекущийЭлемент;
		Если Не ТД = Неопределено Тогда
			Если Не ТД.ИспользуютсяСерии 
				и ТЭ.Имя = "vs_ДоизготовлениеСерия" Тогда
				Отказ = Истина;
			ИначеЕсли ТД.ИспользуютсяСерии 
				и ТЭ.Имя = "vs_ДоизготовлениеСерия"
				и Не ЗначениеЗаполнено(ТД.Серия) Тогда
			   	Отказ = Ложь;
			ИначеЕсли ЗначениеЗаполнено(ТД.Серия) 
				и ТЭ.Имя = "vs_ДоизготовлениеКоличество" Тогда
				ТД.Количество = Мин(Элемент.ТекущиеДанные.Количество,1); 
			ИначеЕсли ЗначениеЗаполнено(ТД.Серия) 
				и ТЭ.Имя = "vs_ДоизготовлениеОтказ" Тогда
				ТД.Отказ = Мин(ТД.Отказ,1);
			КонецЕсли;
			Если Не ЗначениеЗаполнено(ТД.ТребуетсяДоизготовить) 
				и ТЭ.Имя = "vs_ДоизготовлениеОтказ" Тогда
				ТД.Отказ = 0;
			КонецЕсли; 
		КонецЕсли; 
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура vs_ДоизготовлениеПередОкончаниемРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования, Отказ)
	Если Элементы.vs_Доизготовление.ТолькоПросмотр = Ложь Тогда
		Если ЗначениеЗаполнено(Элемент.ТекущиеДанные.Серия) 
			и Элемент.ТекущийЭлемент.Имя = "vs_ДоизготовлениеДоизготовление" 
			и (Элемент.ТекущиеДанные.Количество > 1 
			или Элемент.ТекущиеДанные.Количество + Элемент.ТекущиеДанные.Отказ > 1) Тогда
			ПоказатьПредупреждение(,НСтр("ru = 'Нельзя для экземплярного товара указывать значение в сумме колонок ""Количество"" и ""Отказ"" больше 1.'"),30);
			Отказ = Истина;
		ИначеЕсли ЗначениеЗаполнено(Элемент.ТекущиеДанные.Серия) 
			и Элемент.ТекущийЭлемент.Имя = "vs_ДоизготовлениеОтказ" 
			и (Элемент.ТекущиеДанные.Отказ > 1 
			или Элемент.ТекущиеДанные.Количество + Элемент.ТекущиеДанные.Отказ > 1) Тогда
			ПоказатьПредупреждение(,НСтр("ru = 'Нельзя для экземплярного товара указывать значение в сумме колонок ""Количество"" и ""Отказ"" больше 1.'"),30);
			Отказ = Истина;
		КонецЕсли; 
	КонецЕсли;
КонецПроцедуры

