&НаКлиенте
Процедура vs_ДоизготовлениеВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	Если Элементы.vs_Доизготовление.ТолькоПросмотр = Ложь Тогда
		Если Элемент.Имя = "vs_Доизготовление"
			и Элемент.ТекущийЭлемент.Имя = "vs_ДоизготовлениеОтказ"
			и Элемент.ТекущиеДанные.ТребуетсяДоизготовить = 0 Тогда
			Элемент.ТекущийЭлемент.ТолькоПросмотр = Истина;
			Элемент.ТекущиеДанные.Отказ = 0;
		ИначеЕсли Элемент.Имя = "vs_Доизготовление"
			и Элемент.ТекущийЭлемент.Имя = "vs_ДоизготовлениеТребуетсяДоизготовить" Тогда
			Элемент.ТекущийЭлемент.ТолькоПросмотр = Истина;
		Иначе
			Элемент.ТекущийЭлемент.ТолькоПросмотр = Ложь;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура vs_ДоизготовлениеКоличествоПриИзменении(Элемент)
	ТС = Элементы.vs_Доизготовление.ТекущиеДанные;
	Если ТС = Неопределено Тогда Возврат КонецЕсли;
	Если ЗначениеЗаполнено(ТС.Серия) и ТС.Количество > 1 Тогда
		ПоказатьПредупреждение(,НСтр("ru = 'Нельзя для экземплярного товара указывать значение ""Доизготовить"" больше 1.'"),30);
		ТС.Количество = 1;	
	КонецЕсли;
КонецПроцедуры

&Насервере
Функция  ИспользуютсяСерии(Номенклатура)
	
	возврат Номенклатура.ВидНоменклатуры.ИспользоватьСерии;
	
КонецФункции

&НаКлиенте
Процедура vs_ДоизготовлениеПриАктивизацииЯчейки(Элемент)
	Если Элемент.ТолькоПросмотр Тогда Возврат; КонецЕсли;
	ТД = Элемент.ТекущиеДанные;
	ТЭ = Элемент.ТекущийЭлемент;
	Если ТД = Неопределено Тогда Возврат КонецЕсли;

	Элементы.vs_ДоизготовлениеСерия.ТолькоПросмотр = Не (ТД.ИспользуютсяСерии);
	//Если ТД.ИспользуютсяСерии Тогда
	//    ОткрытьФорму("Обработка.vs_Автоизготовление.Форма.выборСерии",новый Структура("Ном",ТД.Номенклатура),Элемент);
	//КонецЕсли;
	Если Элемент.Имя = "vs_Доизготовление"
		и Элемент.ТекущийЭлемент.Имя = "vs_ДоизготовлениеСерия"
		и Не Элемент.ТекущиеДанные.ИспользуютсяСерии Тогда
		Возврат;
	ИначеЕсли Элемент.Имя = "vs_Доизготовление"
		и Элемент.ТекущийЭлемент.Имя = "vs_ДоизготовлениеОтказ"
		и Элемент.ТекущиеДанные.ТребуетсяДоизготовить = 0 Тогда
		Элемент.ТекущийЭлемент.ТолькоПросмотр = Истина;
	ИначеЕсли Элемент.Имя = "vs_Доизготовление"
		и Элемент.ТекущийЭлемент.Имя = "vs_ДоизготовлениеТребуетсяДоизготовить" Тогда
		Элемент.ТекущийЭлемент.ТолькоПросмотр = Истина;
	Иначе
		Элемент.ТекущийЭлемент.ТолькоПросмотр = Ложь;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура vs_ДоизготовлениеПриАктивизацииСтроки(Элемент)
	ТД =  Элементы.vs_Доизготовление.ТекущиеДанные ;
	Если ТД = Неопределено тогда Возврат КонецЕсли;
	Элементы.vs_ДоизготовлениеСерия.ТолькоПросмотр = не (ТД.ИспользуютсяСерии);
КонецПроцедуры

&НаКлиенте
Процедура vs_ДоизготовлениеНоменклатураПриИзменении(Элемент)
	ТС = Элементы.vs_Доизготовление.ТекущаяСтрока;
	Если ТС = Неопределено тогда Возврат КонецЕсли;;
	vs_ДоизготовлениеНоменклатураПриИзмененииНаСервере(ТС);
КонецПроцедуры

&НаСервере
Процедура vs_ДоизготовлениеНоменклатураПриИзмененииНаСервере(ИД)
	ТС = объект.vs_Доизготовление.НайтиПоИдентификатору(ИД);
	//Если не ЗначениеЗаполнено(ТС.СтатьяРасходов) тогда
	//	ТС.СтатьяРасходов = Константы.vs_СтатьяДоизготовления.Получить();
	//	ТС.АналитикаРасходов =  ?(объект.vs_АктИзготовления <> Неопределено, объект.vs_АктИзготовления.Номенклатура,Неопределено);
	//КонецЕсли;
	ТС.ИспользуютсяСерии = ИспользуютсяСерии(ТС.Номенклатура) ;
	ТС.Серия = Справочники.СерииНоменклатуры.ПустаяСсылка();
	Если Не ТС.ИспользуютсяСерии
		и не ЗначениеЗаполнено(ТС.СтатьяРасходов)Тогда
		ТС.СтатьяРасходов = Константы.vs_СтатьяДоизготовления.Получить();
		ТС.АналитикаРасходов =  ?(объект.vs_АктИзготовления <> Неопределено, объект.vs_АктИзготовления.Номенклатура,Неопределено); 
		Элементы.vs_Доизготовление.ТекущийЭлемент = Элементы.vs_ДоизготовлениеКоличество;
	ИначеЕсли Не ТС.ИспользуютсяСерии Тогда
		Элементы.vs_Доизготовление.ТекущийЭлемент = Элементы.vs_ДоизготовлениеКоличество;
	ИначеЕсли ТС.ИспользуютсяСерии Тогда
		Элементы.vs_Доизготовление.ТекущийЭлемент = Элементы.vs_ДоизготовлениеСерия;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура vs_ДоизготовлениеСерияПриИзменении(Элемент)
	ТС = Элементы.vs_Доизготовление.ТекущаяСтрока;
	Если ТС = Неопределено тогда Возврат КонецЕсли;;
	vs_ДоизготовлениеСерияПриИзмененииНаСервере(ТС);
КонецПроцедуры

&НаСервере
Процедура vs_ДоизготовлениеСерияПриИзмененииНаСервере(ИД)
	ТС = объект.vs_Доизготовление.НайтиПоИдентификатору(ИД);
	Если Не ЗначениеЗаполнено(ТС.СтатьяРасходов)Тогда
		ТС.СтатьяРасходов = Константы.vs_СтатьяДоизготовления.Получить();
		ТС.АналитикаРасходов =  ?(объект.vs_АктИзготовления <> Неопределено, объект.vs_АктИзготовления.Номенклатура,Неопределено);
		Элементы.vs_Доизготовление.ТекущийЭлемент = Элементы.vs_ДоизготовлениеКоличество;
	КонецЕсли;
КонецПроцедуры

