	ПараметрыВыбора.АналитикаРасходов = "АналитикаРасходов";
	
	//ПараметрыВыбора.ВыборСтатьиАктивовПассивов = Истина;
	//ПараметрыВыбора.АналитикаАктивовПассивов = "АналитикаАктивовПассивов";
	
	ПараметрыВыбора.ЭлементыФормы.Статья.Добавить("vs_ДоизготовлениеСтатьяРасходов");
	ПараметрыВыбора.ЭлементыФормы.АналитикаРасходов.Добавить("vs_ДоизготовлениеАналитикаРасходов");
	//ПараметрыВыбора.ЭлементыФормы.АналитикаАктивовПассивов.Добавить("ТоварыАналитикаАктивовПассивов");
	
	////////////ВнутреннееПотреблениеЛокализация.ПараметрыВыбораСтатейИАналитик(  ????????????????????????????????????????????
	////////////	ПараметрыВыбора,
	////////////	ХозяйственнаяОперация);
	
	Возврат ПараметрыВыбора;
	
КонецФункции

#КонецОбласти
#КонецЕсли

#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область СлужебныеПроцедурыИФункции

#Область Проведение

&ИзменениеИКонтроль("ЗаполнитьПараметрыИнициализации")
Процедура vs_ЗаполнитьПараметрыИнициализации(Запрос, ДокументСсылка)

	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Таблица.Дата                           КАК Период,
	|	Таблица.Номер                          КАК Номер,
	|	Таблица.Организация                    КАК Организация,
	|	Таблица.Склад                          КАК Склад,
	|	Таблица.Ссылка                         КАК Ссылка,
	|	Таблица.Подразделение                  КАК Подразделение,
	|	ЕСТЬNULL(Таблица.Подразделение.ВариантОбособленногоУчетаТоваров, ЗНАЧЕНИЕ(Перечисление.ВариантыОбособленногоУчетаТоваров.ПустаяСсылка)) КАК ВариантОбособленногоУчетаТоваров,
	|	Таблица.Дата                           КАК ДатаРаспоряжения,
	|	Таблица.ХозяйственнаяОперация          КАК ХозяйственнаяОперация,
	|	Таблица.ЗаказНаВнутреннееПотребление   КАК ЗаказНаВнутреннееПотребление,
	|	Таблица.ПотреблениеПоЗаказам           КАК ПоЗаказуНаВнутреннееПотребление,
	|	Таблица.ПотреблениеДляДеятельности     КАК ПотреблениеДляДеятельности,
	|	Таблица.НаправлениеДеятельности        КАК НаправлениеДеятельности,
	|	Таблица.Ответственный                  КАК Менеджер,
	|	Таблица.Сделка                         КАК Сделка,
	|	ЕСТЬNULL(Таблица.Сделка.ОбособленныйУчетТоваровПоСделке, ЛОЖЬ) КАК ОбособленныйУчетТоваровПоСделке,
	|	ВЫБОР
	|		КОГДА Таблица.Склад.ИспользоватьОрдернуюСхемуПриОтгрузке
	|				И Таблица.Дата >= Таблица.Склад.ДатаНачалаОрдернойСхемыПриОтгрузке
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ                                  КАК ОрдернаяСхемаПриОтгрузке,
	|	Таблица.Ответственный                  КАК Ответственный,
	|	Таблица.Комментарий                    КАК Комментарий,
	|	Таблица.Исправление                    КАК Исправление,
	|	Таблица.СторнируемыйДокумент           КАК СторнируемыйДокумент,
	|	Таблица.ИсправляемыйДокумент           КАК ИсправляемыйДокумент,
	|	Таблица.ПометкаУдаления                КАК ПометкаУдаления,
	|	Таблица.Проведен                       КАК Проведен,
	|	Таблица.Статус                         КАК Статус,
#Вставка
	// Здесь можно описать новое поведение.
	|	Таблица.vs_СтатьяРасходов              КАК vs_СтатьяРасходов,
	|	Таблица.vs_АктИзготовления             КАК vs_АктИзготовления,
	|	Таблица.vs_ЭтоДоизготовление           КАК vs_ЭтоДоизготовление,
	|	Таблица.vs_Статус                      КАК vs_Статус,
	|	Таблица.ИТБК_АктИзготовления           КАК ИТБК_АктИзготовления,
	|	Таблица.ИТБК_ЭтоДоизготовление         КАК ИТБК_ЭтоДоизготовление,
	|	Таблица.ИТБК_Статус                    КАК ИТБК_Статус,
#КонецВставки
	|	НастройкиХозяйственныхОпераций.Ссылка  КАК НастройкаХозяйственнойОперации
	|ИЗ
	|	Документ.ВнутреннееПотребление КАК Таблица
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.НастройкиХозяйственныхОпераций КАК НастройкиХозяйственныхОпераций
	|		ПО Таблица.ХозяйственнаяОперация = НастройкиХозяйственныхОпераций.ХозяйственнаяОперация
	|ГДЕ
	|	Таблица.Ссылка = &Ссылка";

	Реквизиты = Запрос.Выполнить().Выбрать();
	Реквизиты.Следующий();
#Вставка
	// Здесь можно описать новое поведение.
	Запрос.УстановитьПараметр("vs_СтатьяРасходов",                Реквизиты.vs_СтатьяРасходов);
	Запрос.УстановитьПараметр("vs_АктИзготовления",               Реквизиты.vs_АктИзготовления);
	Запрос.УстановитьПараметр("vs_ЭтоДоизготовление",             Реквизиты.vs_ЭтоДоизготовление);
	Запрос.УстановитьПараметр("vs_Статус",                        Реквизиты.vs_Статус);
	Запрос.УстановитьПараметр("ИТБК_АктИзготовления",             Реквизиты.ИТБК_АктИзготовления);
	Запрос.УстановитьПараметр("ИТБК_ЭтоДоизготовление",           Реквизиты.ИТБК_ЭтоДоизготовление);
	Запрос.УстановитьПараметр("ИТБК_Статус",     				  Реквизиты.ИТБК_Статус);
	Запрос.УстановитьПараметр("ДатаКон",                          Новый Граница(Новый МоментВремени(Реквизиты.Период, Реквизиты.Ссылка), ВидГраницы.Исключая));
#КонецВставки

	Запрос.УстановитьПараметр("Склад",                            Реквизиты.Склад);
	Запрос.УстановитьПараметр("Период",                           Реквизиты.Период);
	Запрос.УстановитьПараметр("ДатаРаспоряжения",                 Реквизиты.ДатаРаспоряжения);
	Запрос.УстановитьПараметр("Организация",                      Реквизиты.Организация);
	Запрос.УстановитьПараметр("ХозяйственнаяОперация",            Реквизиты.ХозяйственнаяОперация);
	Запрос.УстановитьПараметр("ОрдернаяСхемаПриОтгрузке",         Реквизиты.ОрдернаяСхемаПриОтгрузке);
	Запрос.УстановитьПараметр("ЗаказНаВнутреннееПотребление",     Реквизиты.ЗаказНаВнутреннееПотребление);
	Запрос.УстановитьПараметр("ПоЗаказуНаВнутреннееПотребление",  Реквизиты.ПоЗаказуНаВнутреннееПотребление);
	Запрос.УстановитьПараметр("Сделка",                           Реквизиты.Сделка);
	Запрос.УстановитьПараметр("ОбособленныйУчетТоваровПоСделке",  Реквизиты.ОбособленныйУчетТоваровПоСделке);
	Запрос.УстановитьПараметр("ВариантОбособленногоУчетаТоваров", Реквизиты.ВариантОбособленногоУчетаТоваров);
	Запрос.УстановитьПараметр("Подразделение",                    Реквизиты.Подразделение);
	Запрос.УстановитьПараметр("ПотреблениеДляДеятельности",       Реквизиты.ПотреблениеДляДеятельности);
	Запрос.УстановитьПараметр("НаправлениеДеятельности",          Реквизиты.НаправлениеДеятельности);
	Запрос.УстановитьПараметр("Менеджер",                         Реквизиты.Менеджер);
	Запрос.УстановитьПараметр("Валюта",                           Константы.ВалютаУправленческогоУчета.Получить());
	Запрос.УстановитьПараметр("ФормироватьВидыЗапасовПоГруппамФинансовогоУчета", ПолучитьФункциональнуюОпцию("ФормироватьВидыЗапасовПоГруппамФинансовогоУчета"));
	Запрос.УстановитьПараметр("ПустойКлючСвязи",                  Новый УникальныйИдентификатор("00000000-0000-0000-0000-000000000000"));
	Запрос.УстановитьПараметр("ПустаяСерия",                      Справочники.СерииНоменклатуры.ПустаяСсылка());
	Запрос.УстановитьПараметр("ПустоеНазначение",                 Справочники.Назначения.ПустаяСсылка());

	Запрос.УстановитьПараметр("СкладскаяОперация", Перечисления.СкладскиеОперации.ОтгрузкаНаВнутренниеНужды);

	Запрос.УстановитьПараметр("Номер",                            Реквизиты.Номер);
	Запрос.УстановитьПараметр("Ответственный",                    Реквизиты.Ответственный);
	Запрос.УстановитьПараметр("Комментарий",                      Реквизиты.Комментарий);
	Запрос.УстановитьПараметр("ПометкаУдаления",                  Реквизиты.ПометкаУдаления);
	Запрос.УстановитьПараметр("Проведен",                         Реквизиты.Проведен);

	Запрос.УстановитьПараметр("Исправление",                      Реквизиты.Исправление);
	Запрос.УстановитьПараметр("СторнируемыйДокумент",             Реквизиты.СторнируемыйДокумент);
	Запрос.УстановитьПараметр("ИсправляемыйДокумент",             Реквизиты.ИсправляемыйДокумент);

	Запрос.УстановитьПараметр("НастройкаХозяйственнойОперации",   Реквизиты.НастройкаХозяйственнойОперации);
	Запрос.УстановитьПараметр("Статус",                           Реквизиты.Статус);

	ЗначенияПараметровПроведения = ЗначенияПараметровПроведения(Реквизиты);
	Для каждого КлючИЗначение Из ЗначенияПараметровПроведения Цикл
		Запрос.УстановитьПараметр(КлючИЗначение.Ключ, КлючИЗначение.Значение);
	КонецЦикла; 

	УчетПрослеживаемыхТоваровЛокализация.УстановитьПараметрыИспользованияУчетаПрослеживаемыхТоваров(Запрос);

	РасчетСебестоимостиПрикладныеАлгоритмы.ЗаполнитьПараметрыИнициализации(Запрос, Реквизиты);

КонецПроцедуры

Функция ТекстЗапросаТаблицаДоизготовление(Запрос, ТекстыЗапроса, Регистры)
	
	ИмяРегистра = "vs_Доизготовление";
	
	Если НЕ ПроведениеДокументов.ТребуетсяТаблицаДляДвижений(ИмяРегистра, Регистры) Тогда
		Возврат "";
	КонецЕсли;
	
	ТекстЗапроса = "ВЫБРАТЬ
	               |	&Ссылка КАК Регистратор,
	               |	&Период КАК Период,
	               |	ТаблицаТовары.Ссылка.vs_АктИзготовления КАК АктИзготовления,
	               |	ТаблицаТовары.Номенклатура КАК Номенклатура,
	               |	ТаблицаТовары.Характеристика КАК Характеристика,
	               |	СУММА(ТаблицаТовары.ТребуетсяДоизготовить) КАК ТребуетсяДоизготовить,
	               |	СУММА(ТаблицаТовары.Количество) КАК Количество,
	               |	СУММА(ТаблицаТовары.Отказ) КАК Отказ
	               |ПОМЕСТИТЬ ВтДокумента
	               |ИЗ
	               |	Документ.ВнутреннееПотребление.vs_Доизготовление КАК ТаблицаТовары
	               |ГДЕ
	               |	ТаблицаТовары.Ссылка = &Ссылка
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ТаблицаТовары.Ссылка.vs_АктИзготовления,
	               |	ТаблицаТовары.Номенклатура,
	               |	ТаблицаТовары.Характеристика,
	               |	ТаблицаТовары.Ссылка.Дата
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ДДокумента.Регистратор КАК Регистратор,
	               |	ДДокумента.Период КАК Период,
	               |	ДДокумента.АктИзготовления КАК АктИзготовления,
	               |	ДДокумента.Номенклатура КАК Номенклатура,
	               |	ДДокумента.Характеристика КАК Характеристика,
	               |	СУММА(ВЫБОР
	               |			КОГДА ЕСТЬNULL(vs_Доизготовление.ДоизготовитьОстаток, 0) > 0
	               |				ТОГДА ЕСТЬNULL(vs_Доизготовление.ДоизготовитьОстаток, 0)
	               |			ИНАЧЕ 0
	               |		КОНЕЦ) КАК ДоизготовитьОстаток,
	               |	СУММА(ДДокумента.ТребуетсяДоизготовить) КАК ТребуетсяДоизготовить,
	               |	СУММА(ДДокумента.Количество) КАК Количество,
	               |	СУММА(ДДокумента.Отказ) КАК Отказ,
	               |	ВЫБОР
	               |		КОГДА НЕ СУММА(ВЫБОР
	               |						КОГДА ЕСТЬNULL(vs_Доизготовление.ДоизготовитьОстаток, 0) > 0
	               |							ТОГДА ЕСТЬNULL(vs_Доизготовление.ДоизготовитьОстаток, 0)
	               |						ИНАЧЕ 0
	               |					КОНЕЦ) > 0
	               |			ТОГДА СУММА(0)
	               |		ИНАЧЕ ВЫБОР
	               |				КОГДА НЕ СУММА(ДДокумента.Количество) > ВЫБОР
	               |							КОГДА СУММА(ЕСТЬNULL(vs_Доизготовление.ДоизготовитьОстаток, 0)) > 0
	               |								ТОГДА СУММА(ЕСТЬNULL(vs_Доизготовление.ДоизготовитьОстаток, 0))
	               |							ИНАЧЕ 0
	               |						КОНЕЦ - СУММА(ДДокумента.Отказ)
	               |					ТОГДА СУММА(ДДокумента.Количество)
	               |				ИНАЧЕ ВЫБОР
	               |						КОГДА СУММА(ЕСТЬNULL(vs_Доизготовление.ДоизготовитьОстаток, 0)) > 0
	               |							ТОГДА СУММА(ЕСТЬNULL(vs_Доизготовление.ДоизготовитьОстаток, 0))
	               |						ИНАЧЕ 0
	               |					КОНЕЦ - СУММА(ДДокумента.Отказ)
	               |			КОНЕЦ
	               |	КОНЕЦ КАК РасчетноеДоизготовить,
	               |	ВЫБОР
	               |		КОГДА СУММА(ДДокумента.Количество) + СУММА(ДДокумента.Отказ) > ВЫБОР
	               |					КОГДА СУММА(ЕСТЬNULL(vs_Доизготовление.ДоизготовитьОстаток, 0)) > 0
	               |						ТОГДА СУММА(ЕСТЬNULL(vs_Доизготовление.ДоизготовитьОстаток, 0))
	               |					ИНАЧЕ 0
	               |				КОНЕЦ
	               |			ТОГДА СУММА(ДДокумента.Количество) + СУММА(ДДокумента.Отказ) - ВЫБОР
	               |					КОГДА СУММА(ЕСТЬNULL(vs_Доизготовление.ДоизготовитьОстаток, 0)) > 0
	               |						ТОГДА СУММА(ЕСТЬNULL(vs_Доизготовление.ДоизготовитьОстаток, 0))
	               |					ИНАЧЕ 0
	               |				КОНЕЦ
	               |		ИНАЧЕ СУММА(0)
	               |	КОНЕЦ КАК РасчетноеДоизготовить1,
	               |	СУММА(ДДокумента.Отказ) КАК РасчетноеОтказ
	               |ПОМЕСТИТЬ ВтДокумента_vs_Доизготовление
	               |ИЗ
	               |	ВтДокумента КАК ДДокумента
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.vs_Доизготовление.Остатки(
	               |				&ДатаКон,
	               |				(АктИзготовления, Номенклатура) В
	               |					(ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |						Т.АктИзготовления,
	               |						Т.Номенклатура
	               |					ИЗ
	               |						ВтДокумента КАК Т)) КАК vs_Доизготовление
	               |		ПО ДДокумента.АктИзготовления = vs_Доизготовление.АктИзготовления
	               |			И ДДокумента.Номенклатура = vs_Доизготовление.Номенклатура
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ДДокумента.Регистратор,
	               |	ДДокумента.Период,
	               |	ДДокумента.АктИзготовления,
	               |	ДДокумента.Номенклатура,
	               |	ДДокумента.Характеристика
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |УНИЧТОЖИТЬ ВтДокумента
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
	               |	ВтДД.Регистратор КАК Регистратор,
	               |	ВтДД.Период КАК Период,
	               |	ВтДД.АктИзготовления КАК АктИзготовления,
	               |	ВтДД.Номенклатура КАК Номенклатура,
	               |	ВтДД.Характеристика КАК Характеристика,
	               |	СУММА(ВтДД.РасчетноеДоизготовить) КАК Доизготовить
	               |ИЗ
	               |	ВтДокумента_vs_Доизготовление КАК ВтДД
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ВтДД.Регистратор,
	               |	ВтДД.Период,
	               |	ВтДД.АктИзготовления,
	               |	ВтДД.Номенклатура,
	               |	ВтДД.Характеристика
	               |
	               |ИМЕЮЩИЕ
	               |	СУММА(ВтДД.РасчетноеДоизготовить) > 0
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход),
	               |	ВтДД.Регистратор,
	               |	ВтДД.Период,
	               |	ВтДД.АктИзготовления,
	               |	ВтДД.Номенклатура,
	               |	ВтДД.Характеристика,
	               |	-СУММА(ВтДД.РасчетноеОтказ)
	               |ИЗ
	               |	ВтДокумента_vs_Доизготовление КАК ВтДД
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ВтДД.Регистратор,
	               |	ВтДД.Период,
	               |	ВтДД.АктИзготовления,
	               |	ВтДД.Номенклатура,
	               |	ВтДД.Характеристика
	               |
	               |ИМЕЮЩИЕ
	               |	СУММА(ВтДД.РасчетноеОтказ) > 0
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход),
	               |	ВтДД.Регистратор,
	               |	ВтДД.Период,
	               |	ВтДД.АктИзготовления,
	               |	ВтДД.Номенклатура,
	               |	ВтДД.Характеристика,
	               |	СУММА(ВтДД.РасчетноеДоизготовить1)
	               |ИЗ
	               |	ВтДокумента_vs_Доизготовление КАК ВтДД
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ВтДД.Регистратор,
	               |	ВтДД.Период,
	               |	ВтДД.АктИзготовления,
	               |	ВтДД.Номенклатура,
	               |	ВтДД.Характеристика
	               |
	               |ИМЕЮЩИЕ
	               |	СУММА(ВтДД.РасчетноеДоизготовить1) > 0
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход),
	               |	ВтДД.Регистратор,
	               |	ВтДД.Период,
	               |	ВтДД.АктИзготовления,
	               |	ВтДД.Номенклатура,
	               |	ВтДД.Характеристика,
	               |	СУММА(ВтДД.РасчетноеДоизготовить1)
	               |ИЗ
	               |	ВтДокумента_vs_Доизготовление КАК ВтДД
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ВтДД.Регистратор,
	               |	ВтДД.Период,
	               |	ВтДД.АктИзготовления,
	               |	ВтДД.Номенклатура,
	               |	ВтДД.Характеристика
	               |
	               |ИМЕЮЩИЕ
	               |	СУММА(ВтДД.РасчетноеДоизготовить1) > 0";
		
