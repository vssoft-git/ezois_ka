
&После("ОбработкаПроведения")
Процедура vs_ОбработкаПроведения(Отказ, РежимПроведения)
	Если Отказ Тогда Возврат; КонецЕсли;
	ТекстЗапроса = "
	|ВЫБРАТЬ
	|	ДополнительныеРеквизитыИСведения.Ссылка КАК Свойство
	|ПОМЕСТИТЬ СписокСвойств
	|ИЗ
	|	ПланВидовХарактеристик.ДополнительныеРеквизитыИСведения КАК ДополнительныеРеквизитыИСведения
	|ГДЕ
	|	ДополнительныеРеквизитыИСведения.Имя В (""Счет1_887a31d73add46e787665d14f31f1db7"", ""Счет2_a068f909f23745ce84ed4d97faadaec5"")
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ИсходныеДанные.Заказ КАК Заказ,
	|	ИсходныеДанные.НомерПоДаннымПоставщика КАК НомерПоДаннымПоставщика,
	|	ИсходныеДанные.ДатаПоДаннымПоставщика КАК ДатаПоДаннымПоставщика,
	|	ВЫРАЗИТЬ(ИсходныеДанные.Комментарий КАК СТРОКА(1024)) КАК Комментарий,
	|	ИсходныеДанные.НомерСтроки КАК НомерСтроки,
	|	ЗаказДР.НомерСтроки КАК ДРНомерСтроки,
	|	ЗаказДР.Свойство КАК ДРСвойство,
	|	ВЫРАЗИТЬ(ЗаказДР.Значение КАК СТРОКА(1024)) КАК ДРКомментарий,
	|	ЗаказДР.ТекстоваяСтрока КАК ДРТекстоваяСтрока
	|ПОМЕСТИТЬ НеСовпадающиеСвойства
	|ИЗ
	|	(ВЫБРАТЬ
	|		ВЫРАЗИТЬ(ОР.Объект КАК Документ.ЗаказПоставщику) КАК Заказ,
	|		ВЫРАЗИТЬ(СБДСРП.Комментарий КАК СТРОКА(1024)) КАК Комментарий,
	|		СБДСРП.НомерСтроки КАК НомерСтроки,
	|		ЗаказПоставщику.НомерПоДаннымПоставщика КАК НомерПоДаннымПоставщика,
	|		ЗаказПоставщику.ДатаПоДаннымПоставщика КАК ДатаПоДаннымПоставщика
	|	ИЗ
	|		Документ.СписаниеБезналичныхДенежныхСредств.РасшифровкаПлатежа КАК СБДСРП
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ОбъектыРасчетов КАК ОР
	|			ПО СБДСРП.ОбъектРасчетов = ОР.Ссылка
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказПоставщику КАК ЗаказПоставщику
	|			ПО ВЫРАЗИТЬ(ОР.Объект КАК Документ.ЗаказПоставщику) = ЗаказПоставщику.Ссылка
	|	ГДЕ
	|		ОР.Объект ССЫЛКА Документ.ЗаказПоставщику
	|		И СБДСРП.Ссылка = &СписаниеБДС
	|		И НЕ (ВЫРАЗИТЬ(СБДСРП.Комментарий КАК СТРОКА(1024))) = """") КАК ИсходныеДанные
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказПоставщику.ДополнительныеРеквизиты КАК ЗаказДР
	|		ПО ИсходныеДанные.Заказ = ЗаказДР.Ссылка
	|			И ((ВЫРАЗИТЬ(ИсходныеДанные.Комментарий КАК СТРОКА(1024))) = (ВЫРАЗИТЬ(ЗаказДР.Значение КАК СТРОКА(1024))))
	|			И (ЗаказДР.Свойство В
	|				(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|					Т.Свойство
	|				ИЗ
	|					СписокСвойств КАК Т))
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НеСовпадающиеСвойства.Заказ КАК Заказ,
	|	НеСовпадающиеСвойства.НомерПоДаннымПоставщика КАК НомерПоДаннымПоставщика,
	|	НеСовпадающиеСвойства.ДатаПоДаннымПоставщика КАК ДатаПоДаннымПоставщика,
	|	НеСовпадающиеСвойства.Комментарий КАК Комментарий,
	|	НеСовпадающиеСвойства.НомерСтроки КАК НомерСтроки,
	|	НеСовпадающиеСвойства.ДРНомерСтроки КАК ДРНомерСтроки,
	|	НеСовпадающиеСвойства.ДРСвойство КАК ДРСвойство,
	|	НеСовпадающиеСвойства.ДРКомментарий КАК ДРКомментарий,
	|	НеСовпадающиеСвойства.ДРТекстоваяСтрока КАК ДРТекстоваяСтрока
	|ПОМЕСТИТЬ СовпадающиеСвойства
	|ИЗ
	|	НеСовпадающиеСвойства КАК НеСовпадающиеСвойства
	|ГДЕ
	|	НеСовпадающиеСвойства.Комментарий = НеСовпадающиеСвойства.ДРКомментарий
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	НеСовпадающиеСвойства.Заказ КАК Заказ,
	|	ЗаказДР.Свойство КАК Свойство
	|ПОМЕСТИТЬ ИспользованныеСвойства
	|ИЗ
	|	НеСовпадающиеСвойства КАК НеСовпадающиеСвойства
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказПоставщику.ДополнительныеРеквизиты КАК ЗаказДР
	|		ПО (НеСовпадающиеСвойства.Заказ = ЗаказДР.Ссылка)
	|ГДЕ
	|	ЗаказДР.Свойство В
	|			(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|				Т.Свойство
	|			ИЗ
	|				СписокСвойств КАК Т)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НеСовпадающиеСвойства.Заказ КАК Заказ,
	|	СписокСвойств.Свойство КАК Свойство
	|ПОМЕСТИТЬ НеИспользованныеСвойства
	|ИЗ
	|	НеСовпадающиеСвойства КАК НеСовпадающиеСвойства
	|		ЛЕВОЕ СОЕДИНЕНИЕ СписокСвойств КАК СписокСвойств
	|		ПО (ИСТИНА)
	|ГДЕ
	|	НЕ СписокСвойств.Свойство В
	|				(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|					Т.Свойство
	|				ИЗ
	|					ИспользованныеСвойства КАК Т)
	|";
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("СписаниеБДС", Ссылка);
	Результат 				= Запрос.ВыполнитьПакетСПромежуточнымиДанными();
	СписокСвойств 			= Результат[0].Выгрузить();
	НеСовпадающиеСвойства 	= Результат[1].Выгрузить();
	НеСовпадающиеСвойства.Сортировать("Заказ,НомерСтроки");
	СовпадающиеСвойства 	= Результат[2].Выгрузить();   
	ИспользованныеСвойства 	= Результат[3].Выгрузить();
	НеИспользованныеСвойства= Результат[4].Выгрузить();
	ТекущийЗаказ = Неопределено;
	ЗаказОбъект	 = Неопределено;	
	Для Каждого СтрТЗ из НеСовпадающиеСвойства Цикл
		Если Не ТекущийЗаказ = СтрТЗ.Заказ Тогда
			Если Не ТекущийЗаказ = Неопределено Тогда
				ЗаказОбъект.ОбменДанными.Загрузка = Истина;
				ЗаказОбъект.Записать(РежимЗаписиДокумента.Запись);	
			КонецЕсли;
			//СписокСвойств 	= СписокСвойств.ВыгрузитьКолонку("Свойство");
			ТекущийЗаказ 	= СтрТЗ.Заказ;
			ЗаказОбъект 	= ТекущийЗаказ.ПолучитьОбъект();
		КонецЕсли;
		Если ЗначениеЗаполнено(СтрТЗ.ДРСвойство) Тогда
			СтруктОтбора = Новый Структура();
			СтруктОтбора.Вставить("Заказ",ТекущийЗаказ); 
			СтруктОтбора.Вставить("Свойство",СтрТЗ.ДРСвойство);
			МассСтрок = НеИспользованныеСвойства.НайтиСтроки(СтруктОтбора);
			Для Каждого МСтрока Из МассСтрок Цикл
				НеИспользованныеСвойства.Удалить(МСтрока);	
			КонецЦикла;
			Продолжить; 
		КонецЕсли;
		СтруктОтбора = Новый Структура();
		СтруктОтбора.Вставить("Заказ",ТекущийЗаказ); 
		МассСтрок = НеИспользованныеСвойства.НайтиСтроки(СтруктОтбора);
		Если Не МассСтрок.Количество() Тогда
			ТекстСообщения =
				СтрШаблон(НСтр("ru = 'В %1 использованы все возможные счета, документ не может быть изменен.'"), ТекущийЗаказ);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю();
			Продолжить;
		КонецЕсли;
			
		СтрокаТЧДР 					= ЗаказОбъект.ДополнительныеРеквизиты.Добавить();
		СтрокаТЧДР.Свойство 		= МассСтрок[0].Свойство;
		СтрокаТЧДР.Значение 		= СтрТЗ.Комментарий;
		СтрокаТЧДР.ТекстоваяСтрока 	= Новый УникальныйИдентификатор();
		
		СтруктОтбора = Новый Структура();
		СтруктОтбора.Вставить("Заказ",		ТекущийЗаказ); 
		СтруктОтбора.Вставить("Свойство",	СтрокаТЧДР.Свойство);
		МассСтрок = НеИспользованныеСвойства.НайтиСтроки(СтруктОтбора);
		Для каждого МСтрока Из МассСтрок Цикл
			НеИспользованныеСвойства.Удалить(МСтрока);	
		КонецЦикла;
	КонецЦикла;
	Если Не ЗаказОбъект = Неопределено
		и ЗаказОбъект.Модифицированность() Тогда
		ЗаказОбъект.ОбменДанными.Загрузка = Истина;
		ЗаказОбъект.Записать(РежимЗаписиДокумента.Запись);	
	КонецЕсли;	
КонецПроцедуры
